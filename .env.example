DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME
JWT_SECRET=replace-with-long-random-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-password
NODE_ENV=production
# 全新空資料庫：請勿設定或設為 0，讓首次請求跑完整 initDb 建表與管理員。
# 表已存在後再設 SKIP_DB_DDL_ON_BOOT=1 可加快 Netlify 冷啟動。
# SKIP_DB_DDL_ON_BOOT=1
# 選填：Postgres 連線池上限（正式環境預設 2）
# PG_POOL_MAX=2
ADMIN_LOGIN_PATH=/admin-portal-change-this-to-random-path
LIFF_ID=your-liff-id
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
LINE_OFFICIAL_ADD_FRIEND_URL=https://line.me/R/ti/p/@your-line-official
# 選填：LIFF「兌換方式」區塊文案，可用 \\n 換行；留空則使用預設三步驟說明
# LIFF_REDEMPTION_NOTE=第一行\\n第二行
# 選填：LIFF 內「官方活動／完整辦法」連結（預設為 OpenRice 春日活動短網址）
# LIFF_CAMPAIGN_PAGE_URL=https://tinyurl.com/mv3f9wfv
LIFF_INVITE_BONUS_MAX=2
