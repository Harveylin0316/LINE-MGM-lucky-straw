DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME
JWT_SECRET=replace-with-long-random-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-password
NODE_ENV=production
# 全新空資料庫：請勿設定或設為 0，讓首次請求跑完整 initDb 建表與管理員。
# 表已存在後再設 SKIP_DB_DDL_ON_BOOT=1 可加快 Netlify 冷啟動。
# SKIP_DB_DDL_ON_BOOT=1
# 選填：Postgres 連線池上限（正式環境預設 2）
# PG_POOL_MAX=2
ADMIN_LOGIN_PATH=/admin-portal-change-this-to-random-path
# 選填：管理員登入防暴力破解（預設 15 分鐘內同 IP 失敗 8 次即暫停；POST 另有限流 10 次／15 分鐘）
# ADMIN_LOGIN_THROTTLE_WINDOW_MIN=15
# ADMIN_LOGIN_MAX_ATTEMPTS=8
# ADMIN_LOGIN_POST_RATE_MAX=10
LIFF_ID=your-liff-id
# LIFF Endpoint URL 若為 https://你的網域/liff（常見），勿設下列變數。永久連結會用 /lottery、/邀請碼，避免變成 /liff/liff/...
# 若 Endpoint 設為網站根目錄 https://你的網域（不含 /liff），請設為 1，永久連結才會帶 /liff/ 前綴。
# LIFF_ENDPOINT_IS_SITE_ROOT=1
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
# 必須為完整 https 網址（例如 https://line.me/R/ti/p/@xxx）。勿填相對路徑如 liff/xxx，否則在邀請頁會變成 /liff/liff/xxx 而錯誤。
LINE_OFFICIAL_ADD_FRIEND_URL=https://line.me/R/ti/p/@your-line-official
# 選填：LIFF「兌換方式」區塊文案，可用 \\n 換行；留空則使用預設三步驟說明
# LIFF_REDEMPTION_NOTE=第一行\\n第二行
# 選填：LIFF 內「官方活動／完整辦法」連結（預設為 OpenRice 春日活動短網址）
# LIFF_CAMPAIGN_PAGE_URL=https://tinyurl.com/mv3f9wfv
# 好友加碼：程式內每人最多僅發 1 次加碼刮次；需累計 LIFF_INVITE_FRIENDS_PER_DRAW 位好友完成任務才發放。設 0 可關閉加碼。
LIFF_INVITE_BONUS_MAX=1
# 每幾位好友完成加好友任務，邀請人獲 1 次加碼刮次（預設 2）
# LIFF_INVITE_FRIENDS_PER_DRAW=2
# 選填：正式站公開網址（僅 https），供 LINE push 附餐籃圖（/images/picnic-basket-00x.png）。
# Netlify 已會提供 URL，多數情況不必設；自架或其它平台可擇一設定（勿結尾斜線）。
# LINE_PUSH_PUBLIC_BASE_URL=https://你的網域
# PUBLIC_SITE_URL=https://你的網域
