<%-
  include('layout', {
    user: user,
    isAdmin: isAdmin,
    bodyClass: bodyClass,
    body: `
    <section class="card msg-hero">
      <div class="msg-hero-inner">
        <div>
          <h1>訊息庫</h1>
          <p class="muted" style="margin-top:6px;">這裡存好的訊息會自動出現在『群發訊息』的模板區，也能在『自動化流程』裡指定發送。點卡片上的『用這則去群發』可直接拿去發。</p>
        </div>
        <a href="/admin/broadcast?msglib=1" class="msg-primary-btn" id="btn-new-msg">＋ 新增訊息</a>
      </div>
      <div style="margin-top:12px;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;">
        <div id="msg-count" class="muted" style="font-size:13px;"></div>
        <div style="display:flex;gap:8px;">
          <button type="button" class="msg-toggle-all" id="btn-collapse-all">全部收合</button>
          <button type="button" class="msg-toggle-all" id="btn-expand-all">全部展開</button>
        </div>
      </div>
    </section>

    <div id="msg-list"><p class="muted" style="padding:20px;">載入中…</p></div>

    <style>
      .msg-hero-inner{display:flex;align-items:flex-start;justify-content:space-between;gap:16px;flex-wrap:wrap;}
      .msg-primary-btn{padding:9px 16px;background:#FCC726;color:#1f2937;font-weight:700;border:0;border-radius:8px;cursor:pointer;font-size:14px;text-decoration:none;display:inline-block;}
      .msg-gallery{column-count:3;column-gap:18px;}
      @media(max-width:1100px){.msg-gallery{column-count:2;}}
      @media(max-width:680px){.msg-gallery{column-count:1;}}
      .msg-toggle-all{padding:7px 12px;background:#fff;border:1px solid #ECECEE;border-radius:7px;font-size:12.5px;cursor:pointer;color:#374151;font-weight:600;}
      .msg-toggle-all:hover{border-color:#1f2937;}
      .msg-card{break-inside:avoid;margin-bottom:18px;border:1px solid #ECECEE;border-radius:16px;overflow:hidden;background:#fff;display:inline-block;width:100%;}
      .msg-card:hover{box-shadow:0 6px 20px rgba(0,0,0,.08);border-color:#e5e7eb;}
      .msg-cardhead{display:flex;align-items:center;gap:8px;padding:12px 14px;border-bottom:1px solid #F3F4F6;}
      .msg-cardhead .nm{font-size:14.5px;font-weight:700;color:#1f2937;flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
      .msg-toggle{flex:0 0 auto;border:1px solid #ECECEE;background:#fff;border-radius:6px;font-size:12px;color:#6B6B70;cursor:pointer;padding:4px 9px;font-weight:600;}
      .msg-toggle:hover{border-color:#1f2937;color:#1f2937;}
      .msg-badge{font-size:10px;font-weight:700;letter-spacing:.04em;color:#6B6B70;background:#F3F4F6;border-radius:5px;padding:2px 6px;flex:0 0 auto;}
      .msg-stage{background:#E9EDF2;padding:18px 16px;display:flex;justify-content:center;}
      .msg-info{padding:14px 16px 16px;}
      .msg-info .desc{font-size:12.5px;color:#6b7280;line-height:1.6;}
      .msg-actions{margin-top:12px;}
      /* 收合狀態：只留 標題列 + 動作 */
      .msg-card.collapsed .msg-stage{display:none;}
      .msg-card.collapsed .msg-info .desc{display:none;}
      .msg-card.collapsed .msg-actions{margin-top:0;}
      .msg-actions{display:flex;gap:8px;margin-top:12px;}
      .msg-actions a,.msg-actions button{flex:1;padding:8px;border:1px solid #ECECEE;background:#fff;border-radius:8px;cursor:pointer;font-size:13px;color:#374151;text-align:center;text-decoration:none;font-weight:600;}
      .msg-actions button.del{color:#b91c1c;flex:0 0 auto;padding:8px 12px;}
      .msg-actions a:hover,.msg-actions button:hover{border-color:#1f2937;}
      .msg-actions a.msg-go-broadcast{background:#FCC726;border-color:#FCC726;color:#1F2937;font-weight:700;}
      .msg-actions a.msg-go-broadcast:hover{border-color:#1f2937;}

      /* ---- LINE bubble mock（唯讀） ---- */
      .lm{width:100%;max-width:300px;background:#fff;border-radius:18px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,.12);font-family:-apple-system,BlinkMacSystemFont,'PingFang TC','Noto Sans TC',sans-serif;}
      .lm *{box-sizing:border-box;}
      .lm-sec{}
      .lm-hero img{display:block;width:100%;}
      .lm-hero-ph{width:100%;aspect-ratio:20/13;background:#F3F4F6 repeating-linear-gradient(45deg,#F3F4F6,#F3F4F6 10px,#ECECEE 10px,#ECECEE 20px);display:flex;align-items:center;justify-content:center;color:#9ca3af;font-size:12px;}
      .lm-txt{font-size:14px;color:#1F2937;line-height:1.5;word-break:break-word;}
      .lm-sep{border:0;border-top:1px solid #ECECEE;margin:0;}
      .lm-carousel{display:flex;gap:10px;overflow-x:auto;padding-bottom:6px;}
      .lm-carousel .lm{flex:0 0 240px;max-width:240px;}
      .lm-cara-tag{font-size:11px;color:#6b7280;margin-bottom:8px;text-align:center;}
    </style>

    <script>
      (function(){
        var $=function(id){return document.getElementById(id);};
        function esc(s){return String(s==null?'':s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
        var SZ={xxs:'10px',xs:'12px',sm:'13px',md:'15px',lg:'17px',xl:'20px',xxl:'24px','3xl':'30px'};
        var SP={none:'0px',xs:'4px',sm:'8px',md:'12px',lg:'16px',xl:'20px',xxl:'24px'};
        function sz(v){return SZ[v]||'14px';}
        function sp(v){return SP[v]!=null?SP[v]:'0px';}

        // 把一個 Flex component 變成 DOM（唯讀）
        function renderComp(c){
          if(!c||typeof c!=='object')return null;
          if(c.type==='text'){
            var t=document.createElement('div');t.className='lm-txt';
            t.textContent=String(c.text==null?'':c.text);
            if(c.color)t.style.color=c.color;
            if(c.size)t.style.fontSize=sz(c.size);
            if(c.weight==='bold')t.style.fontWeight='700';
            if(c.align==='center')t.style.textAlign='center';
            else if(c.align==='end')t.style.textAlign='right';
            if(c.margin)t.style.marginTop=sp(c.margin);
            if(c.lineSpacing)t.style.lineHeight='1.6';
            if(c.flex!=null)t.style.flex=String(c.flex);
            if(c.wrap===false){t.style.whiteSpace='nowrap';t.style.overflow='hidden';t.style.textOverflow='ellipsis';}
            return t;
          }
          if(c.type==='separator'){
            var hr=document.createElement('hr');hr.className='lm-sep';
            if(c.color)hr.style.borderTopColor=c.color;
            if(c.margin)hr.style.marginTop=sp(c.margin);
            return hr;
          }
          if(c.type==='filler'){var f=document.createElement('div');f.style.flex=String(c.flex!=null?c.flex:1);return f;}
          if(c.type==='image'){
            if(c.url&&!/REPLACE_[A-Z0-9_]+/i.test(c.url)){var im=document.createElement('img');im.src=c.url;im.style.width='100%';im.style.display='block';return im;}
            var ph=document.createElement('div');ph.className='lm-hero-ph';ph.textContent='圖片（編輯時替換）';return ph;
          }
          if(c.type==='box')return renderBox(c);
          return null;
        }

        function renderBox(box){
          var el=document.createElement('div');
          var horiz=(box.layout==='horizontal'||box.layout==='baseline');
          el.style.display='flex';
          el.style.flexDirection=horiz?'row':'column';
          if(box.layout==='baseline')el.style.alignItems='baseline';
          if(box.alignItems)el.style.alignItems=box.alignItems==='center'?'center':box.alignItems;
          if(box.justifyContent)el.style.justifyContent=box.justifyContent;
          if(box.spacing)el.style.gap=sp(box.spacing);
          if(box.backgroundColor)el.style.background=box.backgroundColor;
          if(box.cornerRadius)el.style.borderRadius=/px$/.test(String(box.cornerRadius))?box.cornerRadius:'8px';
          if(box.borderWidth&&box.borderColor)el.style.border=box.borderWidth+' solid '+box.borderColor;
          if(box.margin)el.style.marginTop=sp(box.margin);
          if(box.flex!=null)el.style.flex=String(box.flex);
          if(box.width)el.style.width=box.width;
          if(box.height)el.style.height=box.height;
          if(box.paddingAll!=null)el.style.padding=sp(box.paddingAll);
          if(box.paddingTop!=null)el.style.paddingTop=sp(box.paddingTop);
          if(box.paddingBottom!=null)el.style.paddingBottom=sp(box.paddingBottom);
          if(box.paddingStart!=null)el.style.paddingLeft=sp(box.paddingStart);
          if(box.paddingEnd!=null)el.style.paddingRight=sp(box.paddingEnd);
          if(box.action)el.style.cursor='pointer';
          (box.contents||[]).forEach(function(c){var ch=renderComp(c);if(ch)el.appendChild(ch);});
          return el;
        }

        function renderBubble(bubble){
          var b=document.createElement('div');b.className='lm';
          if(bubble.header){var h=renderBox(bubble.header);h.className=(h.className||'')+' lm-sec';b.appendChild(h);}
          if(bubble.hero){var hero=document.createElement('div');hero.className='lm-hero';var c=renderComp(bubble.hero);if(c)hero.appendChild(c);b.appendChild(hero);}
          if(bubble.body){b.appendChild(renderBox(bubble.body));}
          if(bubble.footer){b.appendChild(renderBox(bubble.footer));}
          return b;
        }

        // template 模式 → 仿一張 bubble
        function renderTemplateMock(tpl){
          var b=document.createElement('div');b.className='lm';
          if(tpl.heroMediaId){var ph=document.createElement('div');ph.className='lm-hero-ph';ph.textContent='圖片（編輯時替換）';b.appendChild(ph);}
          var body=document.createElement('div');body.style.padding='16px';body.style.display='flex';body.style.flexDirection='column';body.style.gap='8px';
          if(tpl.title){var t=document.createElement('div');t.className='lm-txt';t.style.fontSize='19px';t.style.fontWeight='700';t.textContent=tpl.title;body.appendChild(t);}
          if(tpl.subtitle){var s=document.createElement('div');s.className='lm-txt';s.style.fontSize='14px';s.style.color='#4B5563';s.style.whiteSpace='pre-wrap';s.textContent=tpl.subtitle;body.appendChild(s);}
          if(tpl.couponCode){var cc=document.createElement('div');cc.className='lm-txt';cc.style.cssText='text-align:center;font-weight:700;border:1px solid #FCC726;background:#FFFBEB;border-radius:10px;padding:10px;margin-top:4px;';cc.textContent=tpl.couponCode;body.appendChild(cc);}
          if(tpl.ctaLabel){var btn=document.createElement('div');btn.className='lm-txt';btn.style.cssText='text-align:center;font-weight:700;color:#1f2937;background:#FCC726;border-radius:12px;padding:12px;margin-top:6px;';btn.textContent=tpl.ctaLabel;body.appendChild(btn);}
          if(tpl.disclaimer){var d=document.createElement('div');d.className='lm-txt';d.style.cssText='font-size:11px;color:#9ca3af;margin-top:2px;';d.textContent=tpl.disclaimer;body.appendChild(d);}
          b.appendChild(body);
          return b;
        }

        function renderPreview(stage,cfg){
          stage.innerHTML='';
          try{
            if(cfg&&cfg.mode==='template'&&cfg.template){stage.appendChild(renderTemplateMock(cfg.template));return;}
            var flex=cfg&&cfg.flex;
            var contents=flex&&flex.contents;
            if(!contents){stage.textContent='（無法預覽）';return;}
            if(contents.type==='carousel'&&Array.isArray(contents.contents)){
              var wrap=document.createElement('div');wrap.style.width='100%';
              var tag=document.createElement('div');tag.className='lm-cara-tag';tag.textContent='多頁卡片 · 共 '+contents.contents.length+' 張（左右滑動）';wrap.appendChild(tag);
              var row=document.createElement('div');row.className='lm-carousel';
              contents.contents.forEach(function(bb){row.appendChild(renderBubble(bb));});
              wrap.appendChild(row);stage.appendChild(wrap);return;
            }
            stage.appendChild(renderBubble(contents));
          }catch(e){stage.textContent='（預覽失敗）';}
        }

        function setCard(div,collapsed){
          div.classList.toggle('collapsed',collapsed);
          if(div._tog)div._tog.textContent=collapsed?'展開':'收合';
        }
        function card(m){
          var div=document.createElement('div');div.className='msg-card';
          // 標題列（一直顯示）：名稱 + 通道 + 收合鈕
          var head=document.createElement('div');head.className='msg-cardhead';
          var nm=document.createElement('div');nm.className='nm';nm.textContent=m.name||'';
          var badge=document.createElement('span');badge.className='msg-badge';badge.textContent=(m.channel||'line').toUpperCase();
          var tog=document.createElement('button');tog.type='button';tog.className='msg-toggle';tog.textContent='收合';
          tog.addEventListener('click',function(){setCard(div,!div.classList.contains('collapsed'));});
          head.appendChild(nm);head.appendChild(badge);head.appendChild(tog);
          div.appendChild(head);
          div._tog=tog;
          // 預覽（可收合）
          var stage=document.createElement('div');stage.className='msg-stage';
          renderPreview(stage,m.message_config);
          div.appendChild(stage);
          // 說明 + 動作
          var info=document.createElement('div');info.className='msg-info';
          if(m.description){var de=document.createElement('div');de.className='desc';de.textContent=m.description;info.appendChild(de);}
          var acts=document.createElement('div');acts.className='msg-actions';
          acts.innerHTML='<a class="msg-go-broadcast" href="/admin/broadcast?tpl='+m.id+'">用這則去群發</a>'+
            '<a href="/admin/broadcast?msglib=1&mid='+m.id+'">編輯</a>'+
            '<a href="/admin/broadcast?msglib=1&mid='+m.id+'&dup=1">複製</a>'+
            '<button class="del" data-del="'+m.id+'">刪除</button>';
          info.appendChild(acts);
          div.appendChild(info);
          return div;
        }

        function loadList(){
          fetch('/admin/messages/api/list').then(function(r){return r.json();}).then(function(d){
            var box=$('msg-list');
            if(!d.ok){box.innerHTML='<p class="muted" style="padding:20px;">載入失敗：'+esc(d.error||'')+'</p>';return;}
            if(!d.messages.length){box.innerHTML='<p class="muted" style="padding:20px;">還沒有訊息。點右上「新增訊息」用編輯器建立第一則。</p>';return;}
            $('msg-count').textContent='共 '+d.messages.length+' 則訊息';
            box.className='msg-gallery';box.innerHTML='';
            d.messages.forEach(function(m){box.appendChild(card(m));});
            box.querySelectorAll('[data-del]').forEach(function(b){b.addEventListener('click',function(){delMsg(b.getAttribute('data-del'));});});
            // 套用記住的收合偏好（預設展開）
            if(getPref())setAll(true);
          }).catch(function(e){var box=$('msg-list');if(box)box.innerHTML='<p class="muted" style="padding:20px;">載入失敗，請重新整理</p>';});
        }
        function setAll(collapsed){
          document.querySelectorAll('#msg-list .msg-card').forEach(function(div){setCard(div,collapsed);});
        }
        function getPref(){try{return localStorage.getItem('msglib_collapsed')==='1';}catch(e){return false;}}
        function setPref(v){try{localStorage.setItem('msglib_collapsed',v?'1':'0');}catch(e){}}
        $('btn-collapse-all').addEventListener('click',function(){setAll(true);setPref(true);});
        $('btn-expand-all').addEventListener('click',function(){setAll(false);setPref(false);});
        function delMsg(id){
          if(!window.confirm('確定刪除這則訊息？若被流程引用會擋下不刪。'))return;
          fetch('/admin/messages/api/'+id,{method:'DELETE'}).then(function(r){return r.json();}).then(function(d){
            if(d.ok)loadList();
            else if(d.error==='message_in_use')window.alert('這則訊息正被自動化流程使用中，請先在流程移除引用再刪除。');
            else window.alert('刪除失敗：'+(d.error||''));
          }).catch(function(e){window.alert('刪除失敗：'+e.message);});
        }
        loadList();
      })();
    </script>
    `
  })
%>
