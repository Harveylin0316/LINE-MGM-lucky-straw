<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#FFFBEB" />
  <title><%= title %></title>
  <script src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>
  <style>
    :root {
      --bg:         #FAFAFA;
      --surface:    #FFFFFF;
      --or-yellow:  #FCC726;
      --or-yellow-d: #E8B400;
      --or-red:     #E11D27;
      --or-soft:    #FFFBEB;
      --ink:        #0F0F10;
      --ink-brand:  #1F2937;
      --ink-2:      #6B6B70;
      --ink-3:      #A0A0A6;
      --border:     #ECECEE;
      --border-2:   #E0E0E4;
    }
    * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
    html, body { margin: 0; padding: 0; }
    body {
      background:
        radial-gradient(circle at 88% -4%, rgba(252, 199, 38, 0.22), transparent 42%),
        radial-gradient(circle at -10% 24%, rgba(252, 199, 38, 0.10), transparent 38%),
        linear-gradient(180deg, var(--or-soft) 0%, var(--bg) 420px);
      color: var(--ink); min-height: 100vh;
      font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Inter", "PingFang TC", sans-serif;
      letter-spacing: -0.011em; -webkit-font-smoothing: antialiased;
    }
    .page { max-width: 480px; margin: 0 auto; padding: 16px 16px 56px; }

    /* 進場動畫（fade + up，逐區交錯） */
    @keyframes rise-in {
      from { opacity: 0; transform: translateY(14px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .brand-bar, .hero, .stats, .invite-card, .stage-card, .section, .foot {
      animation: rise-in 0.38s cubic-bezier(0.22, 0.8, 0.36, 1) both;
    }
    .hero       { animation-delay: 0.04s; }
    .stats      { animation-delay: 0.09s; }
    .invite-card { animation-delay: 0.14s; }
    .stage-card { animation-delay: 0.19s; }
    .section    { animation-delay: 0.26s; }
    .foot       { animation-delay: 0.32s; }

    /* Brand bar */
    .brand-bar { display: flex; align-items: center; justify-content: space-between; padding: 6px 0 16px; }
    .brand-bar .logo { display: inline-flex; align-items: center; gap: 7px; font-size: 13px; font-weight: 700; }
    .brand-bar .logo .dot { width: 18px; height: 18px; border-radius: 6px; background: var(--or-yellow); position: relative; flex-shrink: 0; }
    .brand-bar .logo .dot::after { content: ''; position: absolute; inset: 4px; border-radius: 50%; background: var(--ink); }
    .brand-bar .chip { display: inline-flex; align-items: center; gap: 5px; font-size: 11px; font-weight: 500; color: var(--ink-2); background: var(--surface); border: 1px solid var(--border); padding: 5px 10px; border-radius: 999px; }
    .brand-bar .chip::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: #22C55E; box-shadow: 0 0 0 2px rgba(34, 197, 94, 0.15); }

    /* Hero */
    .hero { background: var(--surface); border: 1px solid var(--border); border-radius: 20px; padding: 22px 22px 24px; position: relative; overflow: hidden; box-shadow: 0 1px 2px rgba(15, 15, 16, 0.04), 0 10px 28px -16px rgba(15, 15, 16, 0.12); }
    .hero::before { content: ''; position: absolute; top: -40px; right: -40px; width: 180px; height: 180px; background: radial-gradient(circle, rgba(252, 199, 38, 0.22), transparent 70%); pointer-events: none; }
    .hero-tag { display: inline-flex; align-items: center; gap: 6px; font-size: 11px; font-weight: 600; letter-spacing: 0.06em; color: var(--or-red); text-transform: uppercase; margin-bottom: 14px; }
    .hero-tag::before { content: ''; width: 6px; height: 6px; background: var(--or-red); border-radius: 50%; }
    .hero h1 { margin: 0 0 8px; font-size: 26px; font-weight: 700; letter-spacing: -0.028em; line-height: 1.2; }
    .hero p { margin: 0; font-size: 14px; line-height: 1.55; color: var(--ink-2); }
    .hero-cover { width: calc(100% + 44px); margin: 18px -22px -24px; aspect-ratio: 16 / 9; object-fit: cover; display: block; border-top: 1px solid var(--border); }

    /* Stats */
    .stats { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; margin-top: 12px; }
    .stat { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; padding: 12px; box-shadow: 0 1px 2px rgba(15, 15, 16, 0.03); }
    .stat .v { font-size: 20px; font-weight: 700; letter-spacing: -0.02em; line-height: 1; font-variant-numeric: tabular-nums; transform-origin: left center; }
    .stat .v .unit { font-size: 11px; font-weight: 500; color: var(--ink-2); margin-left: 2px; }
    .stat .k { font-size: 11px; color: var(--ink-2); margin-top: 5px; font-weight: 500; }
    @keyframes stat-pop {
      0%   { transform: scale(1.3); color: var(--or-yellow-d); }
      100% { transform: scale(1); }
    }
    .stat .v.pop { animation: stat-pop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1); }

    /* Invite（MGM 主視覺：黃底卡片） */
    .invite-card {
      margin-top: 8px;
      background: linear-gradient(135deg, #FFE07A 0%, var(--or-yellow) 55%, #F2B900 100%);
      border-radius: 18px; padding: 15px 16px;
      display: flex; align-items: center; gap: 12px;
      position: relative; overflow: hidden; color: var(--ink-brand);
      box-shadow: 0 12px 26px -14px rgba(232, 180, 0, 0.7), 0 1px 2px rgba(15, 15, 16, 0.04);
    }
    .invite-card::before { content: ''; position: absolute; top: -50px; left: -30px; width: 160px; height: 160px; background: radial-gradient(circle, rgba(255, 255, 255, 0.55), transparent 65%); pointer-events: none; }
    .invite-card::after { content: ''; position: absolute; right: -34px; bottom: -56px; width: 130px; height: 130px; border-radius: 50%; border: 14px solid rgba(255, 255, 255, 0.22); pointer-events: none; }
    .invite-bonus {
      flex-shrink: 0; width: 52px; height: 52px; border-radius: 50%;
      background: var(--ink-brand); color: var(--or-yellow);
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      z-index: 1; box-shadow: 0 6px 12px -4px rgba(31, 41, 55, 0.45);
    }
    .invite-bonus .plus { font-size: 18px; font-weight: 800; line-height: 1; letter-spacing: -0.02em; }
    .invite-bonus .bl { font-size: 10px; font-weight: 600; opacity: 0.85; margin-top: 2px; }
    .invite-left { flex: 1; min-width: 0; z-index: 1; }
    .invite-title { font-size: 15px; font-weight: 800; line-height: 1.3; letter-spacing: -0.01em; }
    .invite-sub { font-size: 11px; color: rgba(31, 41, 55, 0.72); margin-top: 3px; font-weight: 500; }
    .invite-btn { flex-shrink: 0; background: var(--ink-brand); color: #fff; border: none; border-radius: 999px; padding: 9px 16px; font-family: inherit; font-weight: 700; font-size: 13px; cursor: pointer; z-index: 1; transition: background 0.15s ease, transform 0.15s cubic-bezier(0.34, 1.56, 0.64, 1); display: inline-flex; align-items: center; box-shadow: 0 6px 14px -6px rgba(31, 41, 55, 0.55); }
    .invite-btn:hover { background: #111827; }
    .invite-btn:active { transform: scale(0.96); }
    .invite-card.maxed { opacity: 0.6; box-shadow: none; }
    .invite-card.maxed .invite-btn { background: var(--ink-3); cursor: default; pointer-events: none; box-shadow: none; }

    /* ========== Fortune stage ========== */
    .stage-card { margin-top: 12px; background: var(--surface); border: 1px solid var(--border); border-radius: 20px; padding: 24px 20px 22px; position: relative; overflow: hidden; box-shadow: 0 1px 2px rgba(15, 15, 16, 0.04), 0 14px 32px -18px rgba(15, 15, 16, 0.14); }
    .stage-card::before { content: ''; position: absolute; bottom: -80px; left: -60px; width: 240px; height: 240px; background: radial-gradient(circle, rgba(225, 29, 39, 0.05), transparent 70%); pointer-events: none; }
    .stage-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; }
    .stage-head .label { font-size: 11px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink-3); }
    .stage-head .count { font-size: 11px; color: var(--ink-2); font-weight: 500; }

    .fortune-stage {
      position: relative;
      height: 360px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    /* 籤筒後方的呼吸光暈 */
    .fortune-halo {
      position: absolute; left: 50%; top: 50%;
      width: 230px; height: 230px;
      transform: translate(-50%, -50%);
      border-radius: 50%;
      background: radial-gradient(circle, rgba(252, 199, 38, 0.22), rgba(252, 199, 38, 0.07) 55%, transparent 72%);
      pointer-events: none;
      animation: halo-breathe 3s ease-in-out infinite;
    }
    @keyframes halo-breathe {
      0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.75; }
      50%      { transform: translate(-50%, -50%) scale(1.09); opacity: 1; }
    }

    /* 籤筒 */
    .fortune-jar {
      position: relative;
      width: 84px;
      height: 130px;
      transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
                  opacity 0.35s ease;
      cursor: pointer;
      z-index: 2;
      transform-origin: 50% 88%;
    }
    .fortune-jar svg { position: relative; z-index: 1; display: block; }
    /* 搖籤：-6deg ~ 6deg 衰減搖 1.2s */
    .fortune-jar.shake { animation: jar-shake 1.2s cubic-bezier(0.36, 0.07, 0.19, 0.97) both; }
    @keyframes jar-shake {
      0%   { transform: rotate(0); }
      10%  { transform: rotate(-6deg); }
      20%  { transform: rotate(6deg); }
      31%  { transform: rotate(-5deg); }
      42%  { transform: rotate(4.5deg); }
      54%  { transform: rotate(-3.5deg); }
      66%  { transform: rotate(2.8deg); }
      78%  { transform: rotate(-1.8deg); }
      90%  { transform: rotate(1deg); }
      100% { transform: rotate(0); }
    }
    .fortune-jar.tilt { transform: rotate(-30deg) translateY(-10px); }
    .fortune-jar.hidden { opacity: 0; pointer-events: none; }

    /* 出籤：籤條從筒口彈出（藏在筒身後，往上彈） */
    .fortune-stick {
      position: absolute; left: 50%; top: 18px;
      width: 14px; height: 120px; margin-left: -7px;
      background: linear-gradient(180deg, #FFF4CE, var(--or-soft));
      border: 1px solid #EAD9A0;
      border-radius: 7px 7px 3px 3px;
      z-index: 0;
      opacity: 0;
      transform: translateY(34px);
      pointer-events: none;
    }
    .fortune-stick::before {
      content: ''; position: absolute; top: 8px; left: 2px; right: 2px; height: 18px;
      background: var(--or-red); border-radius: 4px;
    }
    .fortune-stick.out { animation: stick-out 0.55s cubic-bezier(0.34, 1.7, 0.5, 1) forwards; }
    @keyframes stick-out {
      0%   { opacity: 0; transform: translateY(34px); }
      30%  { opacity: 1; }
      100% { opacity: 1; transform: translateY(-66px); }
    }

    /* 籤紙散在頂部準備飛出 */
    .fortune-paper-stack {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 280px;
      height: 280px;
      pointer-events: none;
      perspective: 1200px;
    }

    /* 抽出的籤詩紙（由上往下展開揭曉） */
    .fortune-result {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 230px;
      height: 326px;
      background: linear-gradient(180deg, #FFFDF4, var(--or-soft));
      border-radius: 12px;
      border: 1px solid #F0E2B6;
      box-shadow:
        0 24px 60px -12px rgba(15, 15, 16, 0.25),
        0 8px 20px -6px rgba(15, 15, 16, 0.15);
      opacity: 0;
      clip-path: inset(0 0 100% 0);
      padding: 30px 18px 26px;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      z-index: 10;
      pointer-events: none;
    }
    /* 籤詩紙上下虛線裝飾 */
    .fortune-result::before,
    .fortune-result::after {
      content: ''; position: absolute; left: 16px; right: 16px; height: 0;
      border-top: 2px dashed rgba(31, 41, 55, 0.18);
    }
    .fortune-result::before { top: 13px; }
    .fortune-result::after { bottom: 13px; }
    .fortune-result.show {
      pointer-events: auto;
      opacity: 1;
      clip-path: inset(0 0 0 0);
      transition: clip-path 0.6s cubic-bezier(0.22, 0.8, 0.36, 1), opacity 0.3s ease;
    }
    .fortune-result.grand { border-color: var(--or-red); }
    /* 銘謝惠顧：溫和呼吸動效（不放紙花） */
    @keyframes soothe {
      0%, 100% { transform: translate(-50%, -50%) scale(1); }
      50%      { transform: translate(-50%, -50%) scale(1.015); }
    }
    .fortune-result.soothe { animation: soothe 2.4s ease-in-out 2; }

    /* 內容交錯揭曉：先運勢字樣，再獎品 */
    .fortune-result .r-item { opacity: 0; transform: translateY(8px); }
    .fortune-result.show .r-item {
      opacity: 1; transform: translateY(0);
      transition: opacity 0.4s ease, transform 0.45s cubic-bezier(0.22, 0.8, 0.36, 1);
    }
    .fortune-result.show .fortune-rank       { transition-delay: 0.15s; }
    .fortune-result.show .fortune-glyph-wrap { transition-delay: 0.5s; }
    .fortune-result.show .fortune-name       { transition-delay: 0.62s; }
    .fortune-result.show .fortune-desc       { transition-delay: 0.74s; }
    .fortune-result.show .fortune-seal       { transition-delay: 0.86s; opacity: 0.92; }

    .fortune-rank {
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.22em;
      color: var(--or-red);
      padding: 4px 12px;
      background: rgba(225, 29, 39, 0.08);
      border-radius: 999px;
      margin-bottom: 18px;
    }
    .fortune-result.grand .fortune-rank { color: #fff; background: var(--or-red); }

    .fortune-glyph-wrap {
      width: 76px; height: 76px;
      border-radius: 50%;
      background: linear-gradient(135deg, #FFF7DA, var(--or-yellow));
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 14px;
      font-size: 32px;
      font-weight: 700;
      box-shadow: inset 0 -3px 0 rgba(15, 15, 16, 0.08);
    }
    .fortune-result.grand .fortune-glyph-wrap {
      background: linear-gradient(135deg, var(--or-red), #B61118);
      color: #fff;
    }

    .fortune-name {
      font-size: 22px;
      font-weight: 700;
      letter-spacing: -0.025em;
      color: var(--ink);
      margin-bottom: 6px;
      line-height: 1.2;
    }
    .fortune-desc {
      font-size: 13px;
      color: var(--ink-2);
      line-height: 1.55;
      max-height: 76px;
      overflow-y: auto;
    }
    /* 紅印章（籤詩紙落款） */
    .fortune-seal {
      position: absolute; right: 18px; bottom: 22px;
      width: 26px; height: 26px; border-radius: 6px;
      background: var(--or-red); color: #fff;
      font-size: 13px; font-weight: 700;
      display: flex; align-items: center; justify-content: center;
      transform: rotate(-6deg);
    }

    /* 優惠序號區塊 */
    .coupon-block {
      margin-top: 14px;
      background: var(--or-soft);
      border: 1px solid var(--or-yellow);
      border-radius: 14px;
      padding: 14px 14px 16px;
      text-align: center;
    }
    .coupon-label {
      font-size: 10.5px; font-weight: 600; letter-spacing: 0.1em;
      color: var(--ink-2); text-transform: uppercase; margin-bottom: 7px;
    }
    .coupon-code {
      font-size: 23px; font-weight: 800; letter-spacing: 0.04em;
      color: var(--ink); line-height: 1.2; word-break: break-all;
      font-variant-numeric: tabular-nums;
      -webkit-user-select: all; user-select: all;
    }
    .coupon-hint { font-size: 12px; color: var(--ink-2); line-height: 1.5; margin-top: 9px; }
    .coupon-oos {
      margin-top: 14px; background: var(--bg); border: 1px solid var(--border);
      border-radius: 12px; padding: 13px 14px; text-align: center;
      font-size: 12.5px; color: var(--ink-2); line-height: 1.5;
    }
    .wallet-link {
      display: block; text-align: center; margin: 14px auto 0;
      font-size: 13px; font-weight: 600; color: var(--ink-2);
      text-decoration: none;
    }
    .wallet-link:active { opacity: 0.6; }

    /* 抽籤按鈕 */
    .draw-btn-wrap {
      margin-top: 18px;
      display: flex;
      justify-content: center;
    }
    .draw-btn {
      background: var(--or-yellow);
      color: var(--ink);
      border: none;
      padding: 14px 36px;
      border-radius: 999px;
      font-family: inherit;
      font-weight: 700;
      font-size: 16px;
      letter-spacing: 0.04em;
      cursor: pointer;
      box-shadow: 0 6px 16px -4px rgba(252, 199, 38, 0.5);
      transition: background 0.15s ease, transform 0.18s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    /* 可以玩時的呼吸光暈 */
    @keyframes btn-breathe {
      0%, 100% { box-shadow: 0 6px 16px -4px rgba(252, 199, 38, 0.5), 0 0 0 0 rgba(252, 199, 38, 0.4); }
      50%      { box-shadow: 0 8px 22px -4px rgba(252, 199, 38, 0.65), 0 0 0 10px rgba(252, 199, 38, 0); }
    }
    .draw-btn:not(:disabled) { animation: btn-breathe 2.2s ease-in-out infinite; }
    .draw-btn:hover:not(:disabled) { background: var(--or-yellow-d); }
    .draw-btn:active:not(:disabled) { transform: scale(0.97); }
    .draw-btn:disabled { background: #F0F0F2; color: var(--ink-3); cursor: default; box-shadow: none; animation: none; }

    /* Status */
    .status-row { display: flex; align-items: center; justify-content: center; gap: 8px; margin-top: 16px; font-size: 13px; color: var(--ink-2); min-height: 22px; }
    .status-row .name { color: var(--ink); font-weight: 600; }

    /* Prize section（候選籤詩列表）*/
    .section { margin-top: 24px; }
    .section-head { display: flex; align-items: baseline; justify-content: space-between; padding: 0 4px; margin-bottom: 10px; }
    .section-head h2 { margin: 0; font-size: 17px; font-weight: 700; letter-spacing: -0.015em; }
    .section-head .meta { font-size: 11px; color: var(--ink-2); font-weight: 500; }
    .prize-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
    .prize-card { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; padding: 14px; position: relative; box-shadow: 0 1px 2px rgba(15, 15, 16, 0.03); }
    .prize-card.grand { grid-column: span 2; border-color: var(--or-red); background: linear-gradient(180deg, rgba(225, 29, 39, 0.04), transparent); }
    .prize-card .top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }
    .prize-card .icon { width: 32px; height: 32px; border-radius: 10px; background: linear-gradient(135deg, #FFF7DA, var(--or-yellow)); display: flex; align-items: center; justify-content: center; color: var(--ink); font-weight: 700; font-size: 14px; flex-shrink: 0; }
    .prize-card.grand .icon { background: var(--or-red); color: #fff; }
    .prize-card .badge { font-size: 10px; font-weight: 700; letter-spacing: 0.06em; padding: 3px 8px; border-radius: 999px; background: var(--or-red); color: #fff; }
    .prize-card .name { font-size: 14px; font-weight: 600; line-height: 1.35; }
    .prize-card .desc { margin-top: 3px; font-size: 12px; color: var(--ink-2); line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

    /* Footer */
    .foot { margin-top: 28px; padding: 14px 16px; background: var(--surface); border: 1px solid var(--border); border-radius: 16px; display: flex; align-items: center; justify-content: space-between; font-size: 12px; color: var(--ink-2); }
    .foot .l { display: flex; align-items: center; gap: 8px; }
    .foot .i { width: 20px; height: 20px; border-radius: 6px; background: var(--bg); border: 1px solid var(--border); display: inline-flex; align-items: center; justify-content: center; font-size: 11px; color: var(--ink-2); }
    .foot .r { font-weight: 600; color: var(--ink); }

    /* 減少動態偏好：關閉大型動畫 */
    @media (prefers-reduced-motion: reduce) {
      .brand-bar, .hero, .stats, .invite-card, .stage-card, .section, .foot { animation: none; }
      .fortune-halo { animation: none; }
      .draw-btn:not(:disabled) { animation: none; }
      .stat .v.pop { animation: none; }
      .fortune-jar.shake { animation: none; }
      .fortune-result.soothe { animation: none; }
      .fortune-stick.out { animation: none; opacity: 1; transform: translateY(-66px); }
      .fortune-result.show { transition: opacity 0.2s ease; }
      .fortune-result { clip-path: none; }
      .fortune-result .r-item { opacity: 1; transform: none; }
      .fortune-result.show .r-item { transition: none; }
    }
  </style>
</head>
<body>
  <div class="page">

    <header class="brand-bar">
      <div class="logo"><span class="dot"></span>OpenRice</div>
      <div class="chip">活動進行中</div>
    </header>

    <section class="hero">
      <div class="hero-tag">每日抽籤</div>
      <h1><%= activity.name %></h1>
      <% if (activity.description) { %><p><%= activity.description %></p><% } %>
      <% if (activity.cover_image_url) { %>
        <img class="hero-cover" src="<%= activity.cover_image_url %>" alt="" />
      <% } %>
    </section>

    <section class="stats">
      <div class="stat">
        <div class="v" id="stat-remaining">—</div>
        <div class="k">剩餘次數</div>
      </div>
      <div class="stat">
        <div class="v" id="stat-referrals">—</div>
        <div class="k">已邀請</div>
      </div>
      <div class="stat">
        <div class="v"><%= prizes && prizes.length || 0 %><span class="unit">種</span></div>
        <div class="k">籤詩</div>
      </div>
    </section>

    <section class="invite-card" id="invite-card">
      <% if (activity.referral_bonus_per && activity.referral_bonus_per > 0) { %>
        <div class="invite-bonus"><span class="plus">+<%= activity.referral_bonus_per %></span><span class="bl">次</span></div>
        <div class="invite-left">
          <div class="invite-title">邀 1 位好友，多抽 <%= activity.referral_bonus_per %> 次</div>
          <div class="invite-sub" id="invite-sub">最多再加 <%= activity.referral_bonus_max %> 次</div>
        </div>
      <% } else { %>
        <div class="invite-left">
          <div class="invite-title">分享給朋友一起求籤</div>
          <div class="invite-sub" id="invite-sub">把這個活動傳出去</div>
        </div>
      <% } %>
      <button type="button" class="invite-btn" id="invite-btn">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:5px;vertical-align:-2px;"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>分享
      </button>
    </section>

    <section class="stage-card">
      <div class="stage-head">
        <span class="label">每日求籤</span>
        <span class="count">點按鈕，誠心搖一搖</span>
      </div>
      <div class="fortune-stage" id="stage">
        <div class="fortune-halo"></div>

        <!-- 籤筒 SVG -->
        <div class="fortune-jar" id="jar">
          <!-- 出籤籤條（藏在筒身後，從筒口彈出） -->
          <div class="fortune-stick" id="stick"></div>
          <svg viewBox="0 0 84 130" width="84" height="130" fill="none">
            <!-- jar body -->
            <path d="M14 30 Q14 24 20 24 L64 24 Q70 24 70 30 L66 122 Q66 128 60 128 L24 128 Q18 128 18 122 Z"
                  fill="#0F0F10" stroke="#0F0F10" stroke-width="2"/>
            <!-- jar top band -->
            <rect x="10" y="20" width="64" height="10" rx="2" fill="#FCC726"/>
            <rect x="10" y="20" width="64" height="3" fill="#E8B400"/>
            <!-- 籤柱（露出） -->
            <rect x="32" y="8" width="3" height="14" rx="1" fill="#FAFAFA"/>
            <rect x="40" y="4" width="3" height="18" rx="1" fill="#FAFAFA"/>
            <rect x="48" y="10" width="3" height="12" rx="1" fill="#FAFAFA"/>
            <rect x="36" y="6" width="3" height="16" rx="1" fill="#E11D27"/>
          </svg>
        </div>

        <!-- 抽出的籤詩紙（reveal）-->
        <div class="fortune-result" id="result" hidden>
          <div class="fortune-rank r-item" id="result-rank">—</div>
          <div class="fortune-glyph-wrap r-item"><span id="result-glyph">籤</span></div>
          <div class="fortune-name r-item" id="result-name">—</div>
          <div class="fortune-desc r-item" id="result-desc"></div>
          <div class="coupon-block r-item" id="coupon-block" hidden>
            <div class="coupon-label">優惠序號</div>
            <div class="coupon-code" id="coupon-code">—</div>
            <div class="coupon-hint">請到店出示此畫面或序號給店員核銷</div>
          </div>
          <div class="coupon-oos r-item" id="coupon-oos" hidden>此獎品序號暫時發完，請洽客服</div>
          <div class="fortune-seal r-item">籤</div>
        </div>
      </div>

      <div class="draw-btn-wrap">
        <button type="button" class="draw-btn" id="draw-btn">抽 一 支</button>
      </div>

      <a class="wallet-link" id="wallet-link" href="#" hidden>我的優惠券</a>

      <div class="status-row" id="status-row"><span id="status">準備中</span></div>
    </section>

    <% if (prizes && prizes.length > 0) { %>
    <section class="section">
      <div class="section-head">
        <h2>本次籤詩</h2>
        <span class="meta"><%= prizes.length %> 種</span>
      </div>
      <div class="prize-grid">
        <% prizes.forEach(function (p, i) { %>
          <div class="prize-card <%= p.is_grand_prize ? 'grand' : '' %>">
            <div class="top">
              <div class="icon"><%= String(i + 1).padStart(2, '0') %></div>
              <% if (p.is_grand_prize) { %><span class="badge">上上籤</span><% } %>
            </div>
            <div class="name"><%= p.name %></div>
            <% if (p.description) { %><div class="desc"><%= p.description %></div><% } %>
          </div>
        <% }); %>
      </div>
    </section>
    <% } %>

    <div class="foot">
      <div class="l"><span class="i">i</span><span>遊戲規則</span></div>
      <span class="r">公平隨機</span>
    </div>
  </div>

  <script>
    (function () {
      var slug = <%- JSON.stringify(activity.slug) %>;
      var liffId = <%- JSON.stringify(liffId || '') %>;
      var prizes = <%- JSON.stringify(prizes || []) %>;
      var activityMeta = <%- JSON.stringify({
        name: activity.name,
        referral_bonus_per: activity.referral_bonus_per,
        referral_bonus_max: activity.referral_bonus_max
      }) %>;

      var jarEl = document.getElementById('jar');
      var stickEl = document.getElementById('stick');
      var resultEl = document.getElementById('result');
      var drawBtn = document.getElementById('draw-btn');
      var statusEl = document.getElementById('status');
      var statusRow = document.getElementById('status-row');

      var drawing = false;
      var profile = null;
      var idToken = null;
      var liffReady = false;

      var reducedMotion = false;
      try {
        reducedMotion = !!(window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches);
      } catch (e) {}

      function wait(ms) { return new Promise(function (r) { setTimeout(r, ms); }); }

      // 觸覺回饋（guard）
      function buzz(pattern) {
        try { if (navigator.vibrate) navigator.vibrate(pattern); } catch (e) {}
      }

      // 輕量 canvas 紙花：黃/墨/白 小方塊+圓點，~80 顆，約 1.8 秒，自動清理
      function fireConfetti(opts) {
        if (reducedMotion) return;
        opts = opts || {};
        var canvas = document.createElement('canvas');
        canvas.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:9999;';
        document.body.appendChild(canvas);
        var dpr = Math.min(window.devicePixelRatio || 1, 2);
        var W = window.innerWidth, H = window.innerHeight;
        canvas.width = W * dpr; canvas.height = H * dpr;
        var ctx = canvas.getContext('2d');
        ctx.scale(dpr, dpr);
        var colors = opts.grand
          ? ['#FCC726', '#1F2937', '#FFFFFF', '#E11D27']
          : ['#FCC726', '#1F2937', '#FFFFFF'];
        var parts = [];
        for (var i = 0; i < 80; i++) {
          parts.push({
            x: W / 2 + (Math.random() - 0.5) * W * 0.5,
            y: H * 0.36 + (Math.random() - 0.5) * 50,
            vx: (Math.random() - 0.5) * 7,
            vy: -(4 + Math.random() * 7),
            s: 4 + Math.random() * 5,
            c: colors[i % colors.length],
            round: Math.random() < 0.35,
            rot: Math.random() * Math.PI,
            vr: (Math.random() - 0.5) * 0.3
          });
        }
        var t0 = null, DUR = 1800;
        function frame(ts) {
          if (t0 === null) t0 = ts;
          var k = ts - t0;
          ctx.clearRect(0, 0, W, H);
          ctx.globalAlpha = k > DUR - 400 ? Math.max(0, (DUR - k) / 400) : 1;
          for (var i = 0; i < parts.length; i++) {
            var p = parts[i];
            p.vy += 0.28; p.x += p.vx; p.y += p.vy; p.rot += p.vr; p.vx *= 0.99;
            ctx.save();
            ctx.translate(p.x, p.y);
            ctx.rotate(p.rot);
            ctx.fillStyle = p.c;
            if (p.round) { ctx.beginPath(); ctx.arc(0, 0, p.s / 2, 0, 6.2832); ctx.fill(); }
            else { ctx.fillRect(-p.s / 2, -p.s / 2, p.s, p.s * 0.6); }
            ctx.restore();
          }
          if (k < DUR) { requestAnimationFrame(frame); }
          else if (canvas.parentNode) { canvas.parentNode.removeChild(canvas); }
        }
        requestAnimationFrame(frame);
      }

      // 「銘謝惠顧」類判斷（純演出用，不影響後端邏輯）
      function isConsolation(prize) {
        if (!prize) return true;
        if (prize.prize_type === 'none') return true;
        return /銘謝|謝謝惠顧|再接再厲|未中|下次再來/.test(String(prize.name || ''));
      }

      // 數字變化 pop 動畫
      function popStat(el) {
        if (!el) return;
        el.classList.remove('pop');
        void el.offsetWidth;
        el.classList.add('pop');
      }

      async function initLiff() {
        var qs = new URLSearchParams(location.search);
        var devUid = qs.get('uid');
        if (devUid) { profile = { userId: devUid, displayName: qs.get('name') || 'DEV' }; return; }
        if (qs.get('preview') === '1') {
          profile = { userId: 'PREVIEW', displayName: '預覽' };
          drawBtn.disabled = true; drawBtn.textContent = '預覽';
          return;
        }
        if (!liffId) throw new Error('LIFF ID 未設定');
        try { await liff.init({ liffId: liffId }); }
        catch (e) { throw new Error('LIFF 初始化失敗'); }
        if (!liff.isInClient()) throw new Error('請在 LINE App 內打開');
        if (!liff.isLoggedIn()) { liff.login(); return new Promise(function () {}); }
        profile = await liff.getProfile();
        try { idToken = liff.getIDToken(); } catch (e) {}
      }

      async function maybeRegisterReferral() {
        try {
          var qs = new URLSearchParams(location.search);
          var inviter = qs.get('ref');
          if (!inviter || !profile || !profile.userId || inviter === profile.userId) return;
          await fetch('/api/games/fortune/' + encodeURIComponent(slug) + '/referral', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ line_user_id: profile.userId, inviter_line_user_id: inviter, id_token: idToken })
          });
          var url = new URL(location.href);
          url.searchParams.delete('ref');
          history.replaceState({}, '', url.pathname + url.search);
        } catch (e) { console.warn('referral failed:', e); }
      }

      async function refreshQuota() {
        try {
          if (!profile || !profile.userId) return;
          var resp = await fetch('/api/games/fortune/' + encodeURIComponent(slug) +
            '/meta?line_user_id=' + encodeURIComponent(profile.userId) + '&id_token=' + encodeURIComponent(idToken || '')).then(function (r) { return r.json(); });
          if (!resp.ok || !resp.quota) return;
          renderQuota(resp.quota);
        } catch (e) { console.warn('quota fetch failed:', e); }
      }

      function renderQuota(q) {
        var remEl = document.getElementById('stat-remaining');
        var refEl = document.getElementById('stat-referrals');
        var prevRem = remEl.textContent;
        var prevRef = refEl.textContent;
        remEl.innerHTML = q.remaining + '<span class="unit">/ ' + q.total + '</span>';
        refEl.innerHTML = q.referrals + '<span class="unit">人</span>';
        if (prevRem !== remEl.textContent && prevRem !== '—') popStat(remEl);
        if (prevRef !== refEl.textContent && prevRef !== '—') popStat(refEl);
        if (q.remaining <= 0) {
          drawBtn.disabled = true;
          var canMore = q.referral_bonus_per > 0 && q.referral_bonus < q.referral_bonus_max;
          statusEl.textContent = canMore ? '次數用完，邀請朋友 +' + q.referral_bonus_per + ' 次' : '次數已用完';
        } else {
          drawBtn.disabled = false;
        }
        var inviteCard = document.getElementById('invite-card');
        var inviteSub = document.getElementById('invite-sub');
        // 只在有邀請機制時更新文案；否則保留 server render 的「把這個活動傳出去」
        if (inviteCard && q.referral_bonus_per > 0) {
          var bonusLeft = q.referral_bonus_max - q.referral_bonus;
          if (bonusLeft <= 0) {
            inviteCard.classList.add('maxed');
            if (inviteSub) inviteSub.textContent = '邀請次數已用滿';
          } else {
            inviteCard.classList.remove('maxed');
            if (inviteSub) inviteSub.textContent = '還可再邀請 ' + Math.ceil(bonusLeft / q.referral_bonus_per) + ' 位拿 +' + bonusLeft + ' 次';
          }
        }
      }

      async function drawFortune() {
        if (drawing) return;
        if (!liffReady || !profile) { statusEl.textContent = '請稍候'; return; }
        drawing = true;
        drawBtn.disabled = true;
        statusEl.textContent = '誠心搖籤中⋯';

        // 重置 reveal 狀態：先隱藏籤紙、籤筒顯示
        resultEl.classList.remove('show', 'grand', 'soothe');
        resultEl.hidden = true;
        var cb = document.getElementById('coupon-block'); if (cb) cb.hidden = true;
        var co = document.getElementById('coupon-oos'); if (co) co.hidden = true;
        jarEl.classList.remove('hidden', 'tilt');
        stickEl.classList.remove('out');

        // 搖籤儀式：衰減搖 1.2s + 短震
        jarEl.classList.add('shake');
        buzz([18, 70, 18, 70, 18, 70, 14]);

        try {
          var resp = await fetch('/api/games/fortune/' + encodeURIComponent(slug) + '/play', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ line_user_id: profile.userId, line_display_name: profile.displayName || null, id_token: idToken })
          }).then(function (r) { return r.json(); });

          if (!resp.ok) {
            statusEl.textContent = resp.detail || resp.error || '抽籤失敗';
            jarEl.classList.remove('shake');
            drawing = false;
            drawBtn.disabled = false;
            return;
          }

          // 等搖完（停頓，醞釀期待感）
          await wait(reducedMotion ? 150 : 1250);
          jarEl.classList.remove('shake');

          // 出籤：籤條從筒口彈出
          stickEl.classList.add('out');
          buzz(25);
          await wait(reducedMotion ? 120 : 620);

          // 籤筒傾斜倒出
          jarEl.classList.add('tilt');
          await wait(reducedMotion ? 80 : 320);

          // 籤筒淡出 + 籤詩紙展開揭曉
          jarEl.classList.add('hidden');
          showResult(resp.prize, resp);

          // 改按鈕為「再抽一支」
          drawBtn.textContent = '再 抽 一 支';
          statusEl.textContent = '';
          setTimeout(refreshQuota, 800);
        } catch (e) {
          statusEl.textContent = '錯誤：' + e.message;
        } finally {
          drawing = false;
          drawBtn.disabled = false;
        }
      }

      // 優惠序號顯示：coupon_code 可能在 prize 物件上或 /play 回應頂層
      function renderCoupon(prize, resp) {
        var block = document.getElementById('coupon-block');
        var oos = document.getElementById('coupon-oos');
        var walletLinkEl = document.getElementById('wallet-link');
        if (!block || !oos) return;
        var code = (prize && prize.coupon_code) || (resp && resp.coupon_code) || '';
        var outOfStock = !!(resp && resp.coupon_out_of_stock) || !!(prize && prize.coupon_out_of_stock);
        if (code) {
          document.getElementById('coupon-code').textContent = code;
          block.hidden = false;
          oos.hidden = true;
          if (walletLinkEl) walletLinkEl.hidden = false;
        } else if (outOfStock) {
          block.hidden = true;
          oos.hidden = false;
        } else {
          block.hidden = true;
          oos.hidden = true;
        }
      }

      function showResult(prize, resp) {
        renderCoupon(prize, resp);
        var rank = '';
        if (prize.is_grand_prize) rank = '上 上 籤';
        else if (prize.prize_value && prize.prize_value.fortune) rank = prize.prize_value.fortune;
        else rank = '籤 詩';
        document.getElementById('result-rank').textContent = rank;
        document.getElementById('result-name').textContent = prize.name || '—';
        var descParts = [];
        if (prize.description) descParts.push(prize.description);
        if (prize.prize_value) {
          if (prize.prize_value.amount) descParts.push('NT$ ' + prize.prize_value.amount);
          if (prize.prize_value.code) descParts.push('優惠碼 ' + prize.prize_value.code);
          if (prize.prize_value.label) descParts.push(prize.prize_value.label);
        }
        document.getElementById('result-desc').textContent = descParts.join(' · ');
        document.getElementById('result-glyph').textContent = prize.is_grand_prize ? '吉' : '籤';

        if (prize.is_grand_prize) resultEl.classList.add('grand');
        else resultEl.classList.remove('grand');

        resultEl.hidden = false;
        var consolation = isConsolation(prize);

        // 用 requestAnimationFrame 觸發 transition（先展開籤詩、運勢字樣，再揭曉獎品）
        requestAnimationFrame(function () { resultEl.classList.add('show'); });
        buzz(35);

        // 揭曉完成後的慶祝節奏
        setTimeout(function () {
          if (consolation) {
            resultEl.classList.add('soothe');
          } else {
            fireConfetti({ grand: !!prize.is_grand_prize });
            buzz([30, 50, 90]);
          }
        }, reducedMotion ? 200 : 750);
      }

      // 「我的優惠券」連結，導向錢包頁（LIFF 永久連結 /wallet）
      var walletLink = document.getElementById('wallet-link');
      if (walletLink) {
        walletLink.href = liffId ? ('https://liff.line.me/' + liffId + '/wallet') : '/games/wallet';
      }

      var inviteBtn = document.getElementById('invite-btn');
      if (inviteBtn) inviteBtn.addEventListener('click', shareWithFriend);

      async function shareWithFriend() {
        if (!profile || !profile.userId) { alert('身分驗證中'); return; }
        var inviteUrl = 'https://liff.line.me/' + liffId + '/fortune/' + encodeURIComponent(slug) + '?ref=' + encodeURIComponent(profile.userId);
        var msg = '快來抽「' + activityMeta.name + '」籤詩！我已經抽過了，你也來試試';
        try {
          if (liff.isApiAvailable && liff.isApiAvailable('shareTargetPicker')) {
            var res = await liff.shareTargetPicker([{ type: 'text', text: msg + '\n' + inviteUrl }]);
            if (res) { flashStatus('已分享！'); return; }
          }
        } catch (e) { console.warn('shareTargetPicker failed:', e); }
        try {
          await navigator.clipboard.writeText(inviteUrl);
          flashStatus('連結已複製');
        } catch (e) { prompt('複製此連結：', inviteUrl); }
      }
      function flashStatus(msg) {
        statusEl.textContent = msg;
        setTimeout(function () {
          refreshQuota();
          if (profile) statusEl.innerHTML = '哈囉，<span class="name">' + (profile.displayName || '') + '</span>';
        }, 2400);
      }

      drawBtn.addEventListener('click', drawFortune);
      jarEl.addEventListener('click', drawFortune);

      if (prizes.length < 1) {
        statusEl.textContent = '籤詩未設定';
        drawBtn.disabled = true;
      } else {
        statusEl.textContent = '驗證身分中⋯';
        drawBtn.disabled = true;
      }

      (async function () {
        if (prizes.length < 1) return;
        try {
          await initLiff();
          liffReady = true;
          await maybeRegisterReferral();
          await refreshQuota();
          if (statusEl.textContent === '驗證身分中⋯' || statusEl.textContent === '') {
            statusEl.innerHTML = '哈囉，<span class="name">' + (profile.displayName || '') + '</span>';
          }
        } catch (e) {
          statusEl.textContent = e.message || '初始化失敗';
        }
      })();
    })();
  </script>
</body>
</html>
