<%-
  include('layout', {
    user: user,
    isAdmin: isAdmin,
    bodyClass: bodyClass,
    body: `
    <section class="card act-hero">
      <div class="act-hero-inner">
        <div>
          <h1>活動管理</h1>
          <p class="muted" style="margin-top:6px;">
            設定 LINE 用戶可玩的互動活動。支援輪盤、抽籤、刮刮樂、老虎機 4 種玩法。
          </p>
        </div>
        <a href="/admin/activities/new" class="act-primary-btn">＋ 新增活動</a>
      </div>
    </section>

    <section class="card">
      <h2>活動清單</h2>
      <div class="table-wrap">
        <table class="act-list-table">
          <thead>
            <tr>
              <th>活動</th>
              <th>類型</th>
              <th>狀態</th>
              <th>期間</th>
              <th style="text-align:right;">獎品</th>
              <th style="text-align:right;">玩家</th>
              <th style="text-align:right;">總抽次</th>
              <th>連結</th>
              <th></th>
            </tr>
          </thead>
          <tbody id="act-tbody">
            <tr><td colspan="9" class="muted" style="text-align:center;padding:18px 0;">載入中…</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <script>
    (function () {
      var $ = function (id) { return document.getElementById(id); };
      var $$ = function (sel, ctx) { return Array.from((ctx || document).querySelectorAll(sel)); };

      function escapeHtml(s) {
        return String(s == null ? '' : s)
          .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;').replace(/'/g, '&#039;');
      }
      function fmtDate(ts) {
        if (!ts) return '—';
        var d = new Date(ts);
        if (isNaN(d.getTime())) return '—';
        var pad = function (n) { return String(n).padStart(2, '0'); };
        return d.getFullYear() + '-' + pad(d.getMonth() + 1) + '-' + pad(d.getDate());
      }
      function statusBadge(s) {
        var map = {
          draft:  ['草稿',  'badge-draft'],
          active: ['進行中', 'badge-active'],
          paused: ['暫停',  'badge-paused'],
          ended:  ['已結束', 'badge-ended']
        };
        var v = map[s] || [s, 'badge-draft'];
        return '<span class="act-badge ' + v[1] + '">' + v[0] + '</span>';
      }
      function gameLabel(t) {
        return ({ wheel: '輪盤抽獎', fortune: '每日抽籤', scratch: '刮刮樂', slot: '老虎機' })[t] || t;
      }

      function load() {
        fetch('/admin/activities/api')
          .then(function (r) { return r.json(); })
          .then(function (resp) {
            var tbody = $('act-tbody');
            if (!resp.ok) {
              tbody.innerHTML = '<tr><td colspan="9" class="muted" style="text-align:center;padding:18px 0;">載入失敗</td></tr>';
              return;
            }
            var list = resp.activities || [];
            if (list.length === 0) {
              tbody.innerHTML = '<tr><td colspan="9" class="muted" style="text-align:center;padding:24px 0;">尚無活動。點右上「＋ 新增活動」建立第一個。</td></tr>';
              return;
            }
            tbody.innerHTML = list.map(function (a) {
              // 給用戶用的 LIFF 短網址（讓 LINE login redirect 後能保留 path）
              var gt = a.game_type || 'wheel';
              var shareUrl = a.effective_liff_id
                ? 'https://liff.line.me/' + a.effective_liff_id + '/' + gt + '/' + encodeURIComponent(a.slug)
                : (location.origin + '/games/' + gt + '/' + encodeURIComponent(a.slug));
              return '<tr>' +
                '<td>' +
                  '<div class="act-name">' + escapeHtml(a.name) + '</div>' +
                  '<div class="act-slug">/' + escapeHtml(a.slug) + '</div>' +
                '</td>' +
                '<td>' + gameLabel(a.game_type) + '</td>' +
                '<td>' + statusBadge(a.status) + '</td>' +
                '<td>' + fmtDate(a.start_at) + ' → ' + fmtDate(a.end_at) + '</td>' +
                '<td style="text-align:right;">' + a.prize_count + '</td>' +
                '<td style="text-align:right;">' + a.player_count + '</td>' +
                '<td style="text-align:right;">' + a.play_count + '</td>' +
                '<td><button type="button" class="act-link-btn" data-url="' + escapeHtml(shareUrl) + '" title="LIFF 短網址：給用戶分享用">複製連結</button></td>' +
                '<td>' +
                  '<a href="/admin/activities/' + a.id + '/players" class="act-edit-btn">玩家</a>' +
                  '<a href="/admin/activities/' + a.id + '" class="act-edit-btn">編輯</a>' +
                  '<button type="button" class="act-del-btn" data-id="' + a.id + '" data-name="' + escapeHtml(a.name) + '">刪除</button>' +
                '</td>' +
              '</tr>';
            }).join('');
            // copy link
            $$('.act-link-btn', tbody).forEach(function (btn) {
              btn.addEventListener('click', function () {
                var url = btn.getAttribute('data-url');
                navigator.clipboard.writeText(url).then(function () {
                  var orig = btn.textContent;
                  btn.textContent = '已複製';
                  setTimeout(function () { btn.textContent = orig; }, 1200);
                }).catch(function () { alert(url); });
              });
            });
            // delete
            $$('.act-del-btn', tbody).forEach(function (btn) {
              btn.addEventListener('click', function () {
                var id = btn.getAttribute('data-id');
                var name = btn.getAttribute('data-name');
                if (!confirm('確定刪除活動「' + name + '」？所有獎品池與遊玩紀錄都會一併刪除（不可恢復）。')) return;
                fetch('/admin/activities/api/' + id, { method: 'DELETE' })
                  .then(function (r) { return r.json(); })
                  .then(function (d) {
                    if (!d.ok) { alert('刪除失敗：' + (d.detail || d.error)); return; }
                    load();
                  });
              });
            });
          })
          .catch(function () {
            $('act-tbody').innerHTML = '<tr><td colspan="9" class="muted" style="text-align:center;padding:18px 0;">載入失敗</td></tr>';
          });
      }
      load();
    })();
    </script>

    <style>
      .act-hero { background: linear-gradient(135deg, #fffbeb 0%, #fff 100%); border: 1px solid #fde68a; }
      .act-hero-inner { display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap; }
      .act-primary-btn {
        padding: 10px 18px;
        background: #FCC726;
        color: #1f2937;
        font-weight: 600;
        border-radius: 8px;
        text-decoration: none;
        border: none;
        cursor: pointer;
        font-size: 14px;
      }
      .act-primary-btn:hover { background: #f5b800; }

      .table-wrap { overflow-x: auto; }
      .act-list-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
      }
      .act-list-table th, .act-list-table td {
        padding: 10px 12px;
        border-bottom: 1px solid #f3f4f6;
        vertical-align: middle;
      }
      .act-list-table th {
        background: #fafafa;
        text-align: left;
        font-size: 12px;
        color: #6b7280;
        font-weight: 600;
      }
      .act-name { font-weight: 600; color: #1f2937; }
      .act-slug { font-size: 11px; color: #9ca3af; font-family: ui-monospace, Menlo, monospace; }

      .act-badge {
        display: inline-block;
        padding: 2px 8px;
        font-size: 11px;
        font-weight: 600;
        border-radius: 9999px;
      }
      .badge-draft   { background: #f3f4f6; color: #6b7280; }
      .badge-active  { background: #d1fae5; color: #065f46; }
      .badge-paused  { background: #fef3c7; color: #92400e; }
      .badge-ended   { background: #e5e7eb; color: #4b5563; }

      .act-link-btn, .act-edit-btn, .act-del-btn {
        font-size: 12px;
        padding: 4px 10px;
        border-radius: 6px;
        border: 1px solid #e5e7eb;
        background: #fff;
        color: #374151;
        cursor: pointer;
        text-decoration: none;
        margin-right: 4px;
      }
      .act-edit-btn:hover { background: #fffbeb; border-color: #FCC726; }
      .act-del-btn { color: #dc2626; }
      .act-del-btn:hover { background: #fee2e2; border-color: #fca5a5; }
    </style>
    `
  })
%>
