<%-
  include('layout', {
    user: null,
    bodyClass: 'admin-shell',
    body: `
    <section class="card">
      <h1>${title || '管理員登入'}</h1>
      ${error ? `<p class="error">${error}</p>` : ''}
      <form method="post" action="${loginAction || '/admin/login'}" class="form">
        <input type="hidden" name="nextPath" value="${nextPath || '/admin/prizes'}" />
        <label>
          帳號
          <input type="text" name="username" required />
        </label>
        <label>
          密碼
          <input type="password" name="password" required />
        </label>
        <button type="submit" class="btn primary">登入</button>
      </form>
      <p class="muted">${hint || '此入口僅提供管理員登入。'}</p>
    </section>
  `
  })
%>

