<%-
  include('layout_liff', {
    body: `
    <section class="liff-card">
      <h1>春日邀請任務綁定完成</h1>
      <p class="muted">目前使用者：<strong>${user || '-'}</strong></p>
      <p class="muted">${statusText || '已完成春日邀請綁定。'}</p>
      <p class="muted">本邀請任務<strong>僅限尚未加入</strong> OpenRice LINE@ 的好友：請點下方按鈕完成加好友。邀請人需累計每 <strong>${typeof inviteFriendsPerDraw !== 'undefined' && Number.isFinite(Number(inviteFriendsPerDraw)) ? Math.max(1, Number(inviteFriendsPerDraw)) : 2}</strong> 位好友完成任務，可獲得 <strong>1</strong> 次刮刮樂加碼。若您<strong>早已加入</strong>官方帳號，恕無法透過本任務計入加碼。</p>
      ${
        lineOfficialAddFriendUrl
          ? `<div class="actions">
              <a class="btn primary" href="${lineOfficialAddFriendUrl}" target="_blank" rel="noopener noreferrer">前往 OpenRice LINE@</a>
              <a class="btn" href="/liff/lottery">稍後再說</a>
            </div>`
          : `<p class="error">尚未設定 OpenRice LINE@ 連結，請稍後再試。</p>
             <div class="actions">
               <a class="btn" href="/liff/lottery">返回刮刮樂頁</a>
             </div>`
      }
    </section>
  `
  })
%>
