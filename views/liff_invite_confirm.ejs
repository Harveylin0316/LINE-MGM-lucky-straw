<%-
  include('layout_liff', {
    body: `
    <section class="liff-card">
      <h1>邀請任務綁定完成</h1>
      <p class="muted">目前使用者：<strong>${user || '-'}</strong></p>
      <p class="muted">${statusText || '已完成邀請綁定。'}</p>
      ${
        lineOfficialAddFriendUrl
          ? `<div class="actions">
              <a class="btn primary" href="${lineOfficialAddFriendUrl}" target="_blank" rel="noopener noreferrer">前往加入 OpenRice LINE@</a>
              <a class="btn" href="/liff/lottery">稍後再說</a>
            </div>`
          : `<p class="error">尚未設定 OpenRice LINE@ 連結，請稍後再試。</p>
             <div class="actions">
               <a class="btn" href="/liff/lottery">返回抽獎頁</a>
             </div>`
      }
    </section>
  `
  })
%>
