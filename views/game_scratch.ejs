<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#FAFAFA" />
  <title><%= title %></title>
  <script src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>
  <style>
    :root {
      --bg: #FAFAFA; --surface: #FFFFFF;
      --or-yellow: #FCC726; --or-yellow-d: #E8B400; --or-red: #E11D27;
      --ink: #0F0F10; --ink-2: #6B6B70; --ink-3: #A0A0A6;
      --border: #ECECEE;
    }
    * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
    html, body { margin: 0; padding: 0; }
    body { background: var(--bg); color: var(--ink); min-height: 100vh; font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Inter", "PingFang TC", sans-serif; letter-spacing: -0.011em; -webkit-font-smoothing: antialiased; }
    .page { max-width: 480px; margin: 0 auto; padding: 16px 16px 56px; }

    .brand-bar { display: flex; align-items: center; justify-content: space-between; padding: 6px 0 16px; }
    .brand-bar .logo { display: inline-flex; align-items: center; gap: 7px; font-size: 13px; font-weight: 700; }
    .brand-bar .logo .dot { width: 18px; height: 18px; border-radius: 6px; background: var(--or-yellow); position: relative; }
    .brand-bar .logo .dot::after { content: ''; position: absolute; inset: 4px; border-radius: 50%; background: var(--ink); }
    .brand-bar .chip { display: inline-flex; align-items: center; gap: 5px; font-size: 11px; color: var(--ink-2); background: var(--surface); border: 1px solid var(--border); padding: 5px 10px; border-radius: 999px; font-weight: 500; }
    .brand-bar .chip::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: #22C55E; box-shadow: 0 0 0 2px rgba(34, 197, 94, 0.15); }

    .hero { background: var(--surface); border: 1px solid var(--border); border-radius: 20px; padding: 22px 22px 24px; position: relative; overflow: hidden; }
    .hero::before { content: ''; position: absolute; top: -40px; right: -40px; width: 180px; height: 180px; background: radial-gradient(circle, rgba(252, 199, 38, 0.18), transparent 70%); pointer-events: none; }
    .hero-tag { display: inline-flex; align-items: center; gap: 6px; font-size: 11px; font-weight: 600; letter-spacing: 0.06em; color: var(--or-red); text-transform: uppercase; margin-bottom: 14px; }
    .hero-tag::before { content: ''; width: 6px; height: 6px; background: var(--or-red); border-radius: 50%; }
    .hero h1 { margin: 0 0 8px; font-size: 26px; font-weight: 700; letter-spacing: -0.028em; line-height: 1.2; }
    .hero p { margin: 0; font-size: 14px; line-height: 1.55; color: var(--ink-2); }
    .hero-cover { width: calc(100% + 44px); margin: 18px -22px -24px; aspect-ratio: 16 / 9; object-fit: cover; display: block; border-top: 1px solid var(--border); }

    .stats { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; margin-top: 12px; }
    .stat { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; padding: 12px; }
    .stat .v { font-size: 20px; font-weight: 700; letter-spacing: -0.02em; line-height: 1; font-variant-numeric: tabular-nums; }
    .stat .v .unit { font-size: 11px; color: var(--ink-2); margin-left: 2px; font-weight: 500; }
    .stat .k { font-size: 11px; color: var(--ink-2); margin-top: 5px; font-weight: 500; }

    .invite-card { margin-top: 8px; background: var(--ink); border-radius: 16px; padding: 14px 16px; display: flex; align-items: center; justify-content: space-between; gap: 12px; position: relative; overflow: hidden; color: #fff; }
    .invite-card::before { content: ''; position: absolute; top: -40px; right: -30px; width: 140px; height: 140px; background: radial-gradient(circle, rgba(252, 199, 38, 0.32), transparent 70%); }
    .invite-left { flex: 1; z-index: 1; }
    .invite-title { font-size: 14px; font-weight: 700; }
    .invite-sub { font-size: 11px; color: rgba(255, 255, 255, 0.62); margin-top: 3px; }
    .invite-btn { flex-shrink: 0; background: var(--or-yellow); color: var(--ink); border: none; border-radius: 999px; padding: 8px 16px; font-family: inherit; font-weight: 700; font-size: 13px; cursor: pointer; z-index: 1; transition: background 0.15s ease, transform 0.15s cubic-bezier(0.34, 1.56, 0.64, 1); display: inline-flex; align-items: center; }
    .invite-btn:hover { background: var(--or-yellow-d); }
    .invite-btn:active { transform: scale(0.96); }
    .invite-card.maxed { opacity: 0.6; }
    .invite-card.maxed .invite-btn { background: var(--ink-3); cursor: default; pointer-events: none; }

    /* ========== Scratch stage ========== */
    .stage-card { margin-top: 12px; background: var(--surface); border: 1px solid var(--border); border-radius: 24px; padding: 24px 20px 22px; position: relative; overflow: hidden; }
    .stage-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; }
    .stage-head .label { font-size: 11px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink-3); }
    .stage-head .count { font-size: 11px; color: var(--ink-2); font-weight: 500; }

    .scratch-stage {
      position: relative;
      width: 100%;
      max-width: 320px;
      margin: 0 auto;
      aspect-ratio: 4 / 3;
    }
    .scratch-card {
      position: relative;
      width: 100%;
      height: 100%;
      border-radius: 18px;
      overflow: hidden;
      box-shadow:
        0 12px 32px -8px rgba(15, 15, 16, 0.18),
        0 4px 12px -2px rgba(15, 15, 16, 0.08),
        0 0 0 1px var(--border);
      background: var(--surface);
    }
    .scratch-prize {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 20px;
      text-align: center;
      background: linear-gradient(135deg, #FFFDF0, #FFF7DA);
    }
    .scratch-prize.grand { background: linear-gradient(135deg, var(--or-red), #B61118); color: #fff; }
    .scratch-rank {
      font-size: 11px; font-weight: 700; letter-spacing: 0.18em;
      color: var(--or-red); padding: 3px 10px;
      background: rgba(225, 29, 39, 0.1);
      border-radius: 999px;
      margin-bottom: 10px;
    }
    .scratch-prize.grand .scratch-rank { color: #fff; background: rgba(255,255,255,0.18); }
    .scratch-glyph {
      width: 56px; height: 56px;
      border-radius: 50%;
      background: var(--or-yellow);
      display: flex; align-items: center; justify-content: center;
      font-size: 26px; font-weight: 700;
      margin-bottom: 10px;
    }
    .scratch-prize.grand .scratch-glyph { background: rgba(255,255,255,0.2); color: #fff; }
    .scratch-name { font-size: 22px; font-weight: 700; letter-spacing: -0.025em; line-height: 1.2; margin-bottom: 4px; }
    .scratch-desc { font-size: 12px; opacity: 0.8; line-height: 1.5; max-width: 80%; }

    /* canvas 蓋層（要刮的部分） */
    #scratch-canvas {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      cursor: crosshair;
      touch-action: none;
    }
    /* 載入遮罩 — 蓋住整張卡，paintCover 完才移除 */
    .scratch-loading {
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, #D5D9E0, #9CA3AD 50%, #7B8290);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 10px;
      z-index: 4;
      color: rgba(255,255,255,0.85);
      font-weight: 600;
      font-size: 13px;
      letter-spacing: 0.2em;
    }
    .scratch-loading .spinner {
      width: 22px; height: 22px;
      border: 2.5px solid rgba(255,255,255,0.3);
      border-top-color: rgba(255,255,255,0.85);
      border-radius: 50%;
      animation: scratch-spin 0.8s linear infinite;
    }
    @keyframes scratch-spin { to { transform: rotate(360deg); } }
    .scratch-card.ready .scratch-loading { display: none; }
    /* 沒次數時遮罩變成「已用完」提示 */
    .scratch-card.exhausted .scratch-loading {
      background: linear-gradient(135deg, #FAFAFA, #ECECEE);
      color: #6B6B70;
    }
    .scratch-card.exhausted .scratch-loading .spinner { display: none; }

    /* 領取按鈕 */
    .draw-btn-wrap { margin-top: 18px; display: flex; justify-content: center; gap: 10px; }
    .primary-btn {
      background: var(--or-yellow); color: var(--ink); border: none;
      padding: 14px 32px; border-radius: 999px; font-family: inherit;
      font-weight: 700; font-size: 16px; cursor: pointer;
      box-shadow: 0 6px 16px -4px rgba(252, 199, 38, 0.5);
      transition: background 0.15s, transform 0.18s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .primary-btn:hover:not(:disabled) { background: var(--or-yellow-d); }
    .primary-btn:active:not(:disabled) { transform: scale(0.96); }
    .primary-btn:disabled { background: #F0F0F2; color: var(--ink-3); cursor: default; box-shadow: none; }
    .secondary-btn { background: transparent; color: var(--ink-2); border: 1px solid var(--border); padding: 14px 22px; border-radius: 999px; font-family: inherit; font-weight: 600; font-size: 14px; cursor: pointer; }
    .secondary-btn:active { transform: scale(0.96); }

    .status-row { display: flex; align-items: center; justify-content: center; gap: 8px; margin-top: 16px; font-size: 13px; color: var(--ink-2); min-height: 22px; }
    .status-row .name { color: var(--ink); font-weight: 600; }

    .section { margin-top: 24px; }
    .section-head { display: flex; align-items: baseline; justify-content: space-between; padding: 0 4px; margin-bottom: 10px; }
    .section-head h2 { margin: 0; font-size: 17px; font-weight: 700; letter-spacing: -0.015em; }
    .section-head .meta { font-size: 11px; color: var(--ink-2); font-weight: 500; }
    .prize-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
    .prize-card { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; padding: 14px; }
    .prize-card.grand { grid-column: span 2; border-color: var(--or-red); background: linear-gradient(180deg, rgba(225, 29, 39, 0.04), transparent); }
    .prize-card .top { display: flex; justify-content: space-between; margin-bottom: 8px; }
    .prize-card .icon { width: 32px; height: 32px; border-radius: 10px; background: linear-gradient(135deg, #FFF7DA, var(--or-yellow)); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 14px; }
    .prize-card.grand .icon { background: var(--or-red); color: #fff; }
    .prize-card .badge { font-size: 10px; font-weight: 700; padding: 3px 8px; border-radius: 999px; background: var(--or-red); color: #fff; }
    .prize-card .name { font-size: 14px; font-weight: 600; line-height: 1.35; }
    .prize-card .desc { margin-top: 3px; font-size: 12px; color: var(--ink-2); line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

    .foot { margin-top: 28px; padding: 14px 16px; background: var(--surface); border: 1px solid var(--border); border-radius: 14px; display: flex; align-items: center; justify-content: space-between; font-size: 12px; color: var(--ink-2); }
    .foot .l { display: flex; align-items: center; gap: 8px; }
    .foot .i { width: 20px; height: 20px; border-radius: 6px; background: var(--bg); border: 1px solid var(--border); display: inline-flex; align-items: center; justify-content: center; font-size: 11px; }
    .foot .r { font-weight: 600; color: var(--ink); }
  </style>
</head>
<body>
  <div class="page">

    <header class="brand-bar">
      <div class="logo"><span class="dot"></span>OpenRice</div>
      <div class="chip">活動進行中</div>
    </header>

    <section class="hero">
      <div class="hero-tag">刮刮樂</div>
      <h1><%= activity.name %></h1>
      <% if (activity.description) { %><p><%= activity.description %></p><% } %>
      <% if (activity.cover_image_url) { %>
        <img class="hero-cover" src="<%= activity.cover_image_url %>" alt="" />
      <% } %>
    </section>

    <section class="stats">
      <div class="stat"><div class="v" id="stat-remaining">—</div><div class="k">剩餘次數</div></div>
      <div class="stat"><div class="v" id="stat-referrals">—</div><div class="k">已邀請</div></div>
      <div class="stat"><div class="v"><%= prizes && prizes.length || 0 %><span class="unit">種</span></div><div class="k">獎品</div></div>
    </section>

    <% if (activity.referral_bonus_per && activity.referral_bonus_per > 0) { %>
    <section class="invite-card" id="invite-card">
      <div class="invite-left">
        <div class="invite-title">邀請朋友 +<%= activity.referral_bonus_per %> 次</div>
        <div class="invite-sub" id="invite-sub">最多再加 <%= activity.referral_bonus_max %> 次</div>
      </div>
      <button type="button" class="invite-btn" id="invite-btn">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:5px;vertical-align:-2px;"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>分享
      </button>
    </section>
    <% } %>

    <section class="stage-card">
      <div class="stage-head">
        <span class="label">刮獎</span>
        <span class="count" id="stage-hint">準備中⋯</span>
      </div>
      <div class="scratch-stage">
        <div class="scratch-card" id="card">
          <div class="scratch-prize" id="prize">
            <div class="scratch-rank" id="prize-rank">獎 品</div>
            <div class="scratch-glyph" id="prize-glyph">★</div>
            <div class="scratch-name" id="prize-name">—</div>
            <div class="scratch-desc" id="prize-desc"></div>
          </div>
          <canvas id="scratch-canvas"></canvas>
          <!-- 載入遮罩：LIFF init + paintCover 完成才移除（避免底層獎品先閃現） -->
          <div class="scratch-loading" id="card-loading">
            <div class="spinner"></div>
            <div id="card-loading-text">準 備 中</div>
          </div>
        </div>
      </div>

      <div class="draw-btn-wrap">
        <!-- 預設 hidden — 等 LIFF init + quota check 完，confirm 有次數才顯示 -->
        <button type="button" class="primary-btn" id="reveal-btn" hidden>直 接 揭 曉</button>
        <button type="button" class="secondary-btn" id="new-card-btn" hidden>再 來 一 張</button>
      </div>

      <div class="status-row" id="status-row"><span id="status">準備中</span></div>
    </section>

    <% if (prizes && prizes.length > 0) { %>
    <section class="section">
      <div class="section-head"><h2>本次獎項</h2><span class="meta"><%= prizes.length %> 種</span></div>
      <div class="prize-grid">
        <% prizes.forEach(function (p, i) { %>
          <div class="prize-card <%= p.is_grand_prize ? 'grand' : '' %>">
            <div class="top">
              <div class="icon"><%= String(i + 1).padStart(2, '0') %></div>
              <% if (p.is_grand_prize) { %><span class="badge">頭獎</span><% } %>
            </div>
            <div class="name"><%= p.name %></div>
            <% if (p.description) { %><div class="desc"><%= p.description %></div><% } %>
          </div>
        <% }); %>
      </div>
    </section>
    <% } %>

    <div class="foot">
      <div class="l"><span class="i">i</span><span>遊戲規則</span></div>
      <span class="r">公平隨機</span>
    </div>
  </div>

  <script>
    (function () {
      var slug = <%- JSON.stringify(activity.slug) %>;
      var liffId = <%- JSON.stringify(liffId || '') %>;
      var prizes = <%- JSON.stringify(prizes || []) %>;
      var activityMeta = <%- JSON.stringify({
        name: activity.name,
        referral_bonus_per: activity.referral_bonus_per,
        referral_bonus_max: activity.referral_bonus_max
      }) %>;

      var card = document.getElementById('card');
      var canvas = document.getElementById('scratch-canvas');
      var ctx = canvas.getContext('2d');
      var prizeEl = document.getElementById('prize');
      var revealBtn = document.getElementById('reveal-btn');
      var newCardBtn = document.getElementById('new-card-btn');
      var statusEl = document.getElementById('status');
      var stageHint = document.getElementById('stage-hint');

      var profile = null;
      var liffReady = false;
      var canPlay = false;
      var inProgress = false;
      var currentPrize = null;
      var revealed = false;

      function paintCover() {
        var rect = card.getBoundingClientRect();
        var dpr = window.devicePixelRatio || 1;
        var w = Math.floor(rect.width);
        var h = Math.floor(rect.height);
        // physical canvas size = CSS size * dpr → 高解析度
        canvas.width = Math.floor(w * dpr);
        canvas.height = Math.floor(h * dpr);
        canvas.style.width = w + 'px';
        canvas.style.height = h + 'px';
        // 只 setTransform 一次，scale(dpr, dpr) 之後所有座標都用「邏輯像素」(w, h)
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        ctx.globalCompositeOperation = 'source-over';
        // 灰色金屬箔感漸層（用邏輯尺寸 w/h，配合 ctx 的 scale）
        var g = ctx.createLinearGradient(0, 0, w, h);
        g.addColorStop(0, '#D5D9E0');
        g.addColorStop(0.5, '#9CA3AD');
        g.addColorStop(1, '#7B8290');
        ctx.fillStyle = g;
        ctx.fillRect(0, 0, w, h);
        // 細白點 pattern
        for (var i = 0; i < 140; i++) {
          ctx.fillStyle = 'rgba(255,255,255,' + (Math.random() * 0.18 + 0.04) + ')';
          ctx.beginPath();
          ctx.arc(Math.random() * w, Math.random() * h, Math.random() * 1.5 + 0.4, 0, Math.PI * 2);
          ctx.fill();
        }
        // 中央文字提示
        ctx.fillStyle = 'rgba(255,255,255,0.4)';
        ctx.font = 'bold 14px -apple-system, "PingFang TC", sans-serif';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText('刮開查看獎品', w / 2, h / 2);
        // 切換 composite mode 為 destination-out（用來「擦除」）
        ctx.globalCompositeOperation = 'destination-out';
      }

      function setupScratch() {
        var isDrawing = false;
        var lastX = 0, lastY = 0;
        var revealThreshold = 0.35;  // 刮開 35% 自動 reveal（更有成就感）

        // 回邏輯像素座標（ctx 已 scale dpr，邏輯座標跟 CSS 像素一致）
        function getPos(e) {
          var rect = canvas.getBoundingClientRect();
          var x, y;
          if (e.touches) { x = e.touches[0].clientX; y = e.touches[0].clientY; }
          else { x = e.clientX; y = e.clientY; }
          return { x: x - rect.left, y: y - rect.top };
        }
        function startDraw(e) {
          if (!canPlay || revealed) return;
          e.preventDefault();
          isDrawing = true;
          var p = getPos(e);
          lastX = p.x; lastY = p.y;
          // 第一觸點：畫一個小圓圈讓刮跡更明顯
          ctx.lineWidth = 36;
          ctx.lineCap = 'round';
          ctx.beginPath();
          ctx.arc(p.x, p.y, 18, 0, Math.PI * 2);
          ctx.fill();
          card.classList.add('scratched');
        }
        function moveDraw(e) {
          if (!isDrawing || !canPlay || revealed) return;
          e.preventDefault();
          var p = getPos(e);
          ctx.lineWidth = 36;
          ctx.lineCap = 'round';
          ctx.lineJoin = 'round';
          ctx.beginPath();
          ctx.moveTo(lastX, lastY);
          ctx.lineTo(p.x, p.y);
          ctx.stroke();
          lastX = p.x; lastY = p.y;
          card.classList.add('scratched');
          checkProgress();
        }
        function endDraw() { isDrawing = false; checkProgress(); }

        // 估算刮開比例（每 250ms 抽樣一次避免效能 hit）
        var lastCheck = 0;
        function checkProgress() {
          var now = Date.now();
          if (now - lastCheck < 250) return;
          lastCheck = now;
          try {
            // 注意：getImageData 回的是物理像素，不受 ctx scale 影響
            var data = ctx.getImageData(0, 0, canvas.width, canvas.height).data;
            var transparent = 0;
            var sampleStep = 24;  // 抽樣間隔
            var sampled = 0;
            for (var i = 3; i < data.length; i += 4 * sampleStep) {
              if (data[i] === 0) transparent++;
              sampled++;
            }
            var pct = transparent / sampled;
            if (pct >= revealThreshold) doReveal();
          } catch (e) { /* CORS / size 0 等 ignore */ }
        }

        canvas.addEventListener('mousedown', startDraw);
        canvas.addEventListener('mousemove', moveDraw);
        canvas.addEventListener('mouseup', endDraw);
        canvas.addEventListener('mouseleave', endDraw);
        canvas.addEventListener('touchstart', startDraw, { passive: false });
        canvas.addEventListener('touchmove', moveDraw, { passive: false });
        canvas.addEventListener('touchend', endDraw);
        canvas.addEventListener('touchcancel', endDraw);
      }

      function doReveal() {
        if (revealed) return;
        revealed = true;
        // 整個 canvas 漸隱
        canvas.style.transition = 'opacity 0.4s ease';
        canvas.style.opacity = '0';
        stageHint.textContent = '完成！';
        statusEl.textContent = '恭喜抽中 ' + (currentPrize && currentPrize.name || '');
        newCardBtn.hidden = false;
        revealBtn.hidden = true;
        setTimeout(refreshQuota, 500);
      }

      async function initLiff() {
        var qs = new URLSearchParams(location.search);
        var devUid = qs.get('uid');
        if (devUid) { profile = { userId: devUid, displayName: qs.get('name') || 'DEV' }; return; }
        if (qs.get('preview') === '1') {
          profile = { userId: 'PREVIEW', displayName: '預覽' };
          return;
        }
        if (!liffId) throw new Error('LIFF ID 未設定');
        try { await liff.init({ liffId: liffId }); }
        catch (e) { throw new Error('LIFF 初始化失敗'); }
        if (!liff.isInClient()) throw new Error('請在 LINE App 內打開');
        if (!liff.isLoggedIn()) { liff.login(); return new Promise(function () {}); }
        profile = await liff.getProfile();
      }

      async function maybeRegisterReferral() {
        try {
          var qs = new URLSearchParams(location.search);
          var inviter = qs.get('ref');
          if (!inviter || !profile || !profile.userId || inviter === profile.userId) return;
          await fetch('/api/games/scratch/' + encodeURIComponent(slug) + '/referral', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ line_user_id: profile.userId, inviter_line_user_id: inviter })
          });
          var url = new URL(location.href);
          url.searchParams.delete('ref');
          history.replaceState({}, '', url.pathname + url.search);
        } catch (e) { console.warn('referral failed:', e); }
      }

      async function refreshQuota() {
        try {
          if (!profile || !profile.userId) return;
          var resp = await fetch('/api/games/scratch/' + encodeURIComponent(slug) +
            '/meta?line_user_id=' + encodeURIComponent(profile.userId)).then(function (r) { return r.json(); });
          if (!resp.ok || !resp.quota) return;
          renderQuota(resp.quota);
        } catch (e) { console.warn('quota fetch failed:', e); }
      }

      function renderQuota(q) {
        document.getElementById('stat-remaining').innerHTML = q.remaining + '<span class="unit">/ ' + q.total + '</span>';
        document.getElementById('stat-referrals').innerHTML = q.referrals + '<span class="unit">人</span>';

        var inviteCard = document.getElementById('invite-card');
        var inviteSub = document.getElementById('invite-sub');
        if (inviteCard) {
          var bonusLeft = q.referral_bonus_max - q.referral_bonus;
          if (bonusLeft <= 0) {
            inviteCard.classList.add('maxed');
            if (inviteSub) inviteSub.textContent = '邀請次數已用滿';
          } else {
            inviteCard.classList.remove('maxed');
            if (inviteSub) inviteSub.textContent = '還可再邀請 ' + Math.ceil(bonusLeft / q.referral_bonus_per) + ' 位拿 +' + bonusLeft + ' 次';
          }
        }

        // 次數用完：遮罩切換成「已用完」+ 隱藏按鈕 + 禁止刮
        if (q.remaining <= 0) {
          var canMore = q.referral_bonus_per > 0 && q.referral_bonus < q.referral_bonus_max;
          stageHint.textContent = '次數已用完';
          statusEl.textContent = canMore
            ? '次數用完，邀請朋友 +' + q.referral_bonus_per + ' 次'
            : '次數已用完';
          canPlay = false;
          revealBtn.hidden = true;
          newCardBtn.hidden = true;
          // 卡片遮罩切換成「已用完」狀態（灰底）+ 移除 ready（避免之前的卡顯示出來）
          card.classList.remove('ready', 'scratched');
          card.classList.add('exhausted');
          var loadingText = document.getElementById('card-loading-text');
          if (loadingText) loadingText.textContent = '次 數 已 用 完';
        } else if (!revealed && !inProgress && canPlay) {
          // 還有剩 且 不在 reveal/inProgress 狀態 → 顯示揭曉鈕
          revealBtn.hidden = false;
        }
      }

      async function startNewCard() {
        if (inProgress) return;
        if (!liffReady || !profile) { statusEl.textContent = '請稍候'; return; }
        inProgress = true;
        revealed = false;
        canPlay = true;
        newCardBtn.hidden = true;
        revealBtn.hidden = false;
        statusEl.textContent = '刮一下試試';
        stageHint.textContent = '進行中';

        try {
          // 後端決定獎品（同時驗 quota）
          var resp = await fetch('/api/games/scratch/' + encodeURIComponent(slug) + '/play', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ line_user_id: profile.userId, line_display_name: profile.displayName || null })
          }).then(function (r) { return r.json(); });

          if (!resp.ok) {
            // quota 用完或其他錯誤 → 不顯示 reveal/new 按鈕
            statusEl.textContent = resp.detail || resp.error || '抽獎失敗';
            stageHint.textContent = resp.error === 'quota_exhausted' ? '次數已用完' : '無法抽獎';
            revealBtn.hidden = true;
            newCardBtn.hidden = true;
            inProgress = false;
            canPlay = false;
            // 若是 quota error，refresh stat 顯示剩餘 0
            if (resp.quota) renderQuota(resp.quota);
            return;
          }
          currentPrize = resp.prize;
          renderPrize(currentPrize);
          // 重設 canvas（蓋上灰膜）
          card.classList.remove('scratched', 'exhausted');
          canvas.style.transition = 'none';
          canvas.style.opacity = '1';
          paintCover();
          // 灰膜已畫好 → 移除載入遮罩
          card.classList.add('ready');
        } catch (e) {
          statusEl.textContent = '錯誤';
          revealBtn.hidden = true;
          newCardBtn.hidden = true;
          canPlay = false;
        } finally {
          inProgress = false;
        }
      }

      function renderPrize(prize) {
        var rank = prize.is_grand_prize ? '頭 獎' : '獎 品';
        document.getElementById('prize-rank').textContent = rank;
        document.getElementById('prize-name').textContent = prize.name || '—';
        document.getElementById('prize-glyph').textContent = prize.is_grand_prize ? '★' : '◆';
        var descParts = [];
        if (prize.description) descParts.push(prize.description);
        if (prize.prize_value) {
          if (prize.prize_value.amount) descParts.push('NT$ ' + prize.prize_value.amount);
          if (prize.prize_value.code) descParts.push('優惠碼 ' + prize.prize_value.code);
          if (prize.prize_value.label) descParts.push(prize.prize_value.label);
        }
        document.getElementById('prize-desc').textContent = descParts.join(' · ');
        if (prize.is_grand_prize) prizeEl.classList.add('grand');
        else prizeEl.classList.remove('grand');
      }

      var inviteBtn = document.getElementById('invite-btn');
      if (inviteBtn) inviteBtn.addEventListener('click', shareWithFriend);
      async function shareWithFriend() {
        if (!profile || !profile.userId) { alert('身分驗證中'); return; }
        var inviteUrl = 'https://liff.line.me/' + liffId + '/scratch/' + encodeURIComponent(slug) + '?ref=' + encodeURIComponent(profile.userId);
        var msg = '快來刮「' + activityMeta.name + '」！我刮過了，你也來試試';
        try {
          if (liff.isApiAvailable && liff.isApiAvailable('shareTargetPicker')) {
            var res = await liff.shareTargetPicker([{ type: 'text', text: msg + '\n' + inviteUrl }]);
            if (res) { flashStatus('已分享！'); return; }
          }
        } catch (e) {}
        try { await navigator.clipboard.writeText(inviteUrl); flashStatus('連結已複製'); }
        catch (e) { prompt('複製此連結：', inviteUrl); }
      }
      function flashStatus(msg) {
        statusEl.textContent = msg;
        setTimeout(function () {
          refreshQuota();
          if (profile) statusEl.innerHTML = '哈囉，<span class="name">' + (profile.displayName || '') + '</span>';
        }, 2400);
      }

      revealBtn.addEventListener('click', doReveal);
      newCardBtn.addEventListener('click', startNewCard);

      window.addEventListener('load', function () {
        setupScratch();
      });
      window.addEventListener('resize', function () {
        if (!revealed && canPlay) paintCover();
      });

      if (prizes.length < 1) {
        statusEl.textContent = '獎品未設定';
        stageHint.textContent = '—';
      } else {
        statusEl.textContent = '驗證身分中⋯';
      }

      (async function () {
        if (prizes.length < 1) return;
        try {
          await initLiff();
          liffReady = true;
          await maybeRegisterReferral();
          // 拉 quota；如果還有次數才自動發第一張
          var metaResp;
          try {
            metaResp = await fetch('/api/games/scratch/' + encodeURIComponent(slug) +
              '/meta?line_user_id=' + encodeURIComponent(profile.userId)).then(function (r) { return r.json(); });
          } catch (_e) {}
          if (metaResp && metaResp.ok && metaResp.quota) {
            renderQuota(metaResp.quota);
            if (metaResp.quota.remaining <= 0) {
              // 用完了：不發新卡、隱藏揭曉鈕（renderQuota 已處理）
              return;
            }
          }
          statusEl.innerHTML = '哈囉，<span class="name">' + (profile.displayName || '') + '</span>';
          stageHint.textContent = '進行中';
          // 還有剩 → 自動開始第一張
          startNewCard();
        } catch (e) {
          statusEl.textContent = e.message || '初始化失敗';
          stageHint.textContent = '—';
          revealBtn.hidden = true;
          newCardBtn.hidden = true;
        }
      })();
    })();
  </script>
</body>
</html>
