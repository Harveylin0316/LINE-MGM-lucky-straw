<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#FFFBEB" />
  <title><%= title %></title>
  <script src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>
  <style>
    :root {
      --bg: #FAFAFA; --surface: #FFFFFF;
      --or-yellow: #FCC726; --or-yellow-d: #E8B400; --or-red: #E11D27;
      --ink: #0F0F10; --ink-2: #6B6B70; --ink-3: #A0A0A6;
      --border: #ECECEE;
    }
    * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
    html, body { margin: 0; padding: 0; }
    body {
      background: var(--bg);
      background-image:
        radial-gradient(900px 420px at 85% -120px, rgba(252, 199, 38, 0.18), transparent 65%),
        radial-gradient(700px 380px at -10% 10%, rgba(252, 199, 38, 0.10), transparent 60%),
        linear-gradient(180deg, #FFFBEB 0%, #FAFAFA 420px);
      color: var(--ink); min-height: 100vh; font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Inter", "PingFang TC", sans-serif; letter-spacing: -0.011em; -webkit-font-smoothing: antialiased;
    }
    .page { max-width: 480px; margin: 0 auto; padding: 16px 16px 56px; }

    .brand-bar { display: flex; align-items: center; justify-content: space-between; padding: 6px 0 16px; }
    .brand-bar .logo { display: inline-flex; align-items: center; gap: 7px; font-size: 13px; font-weight: 700; }
    .brand-bar .logo .dot { width: 18px; height: 18px; border-radius: 6px; background: var(--or-yellow); position: relative; }
    .brand-bar .logo .dot::after { content: ''; position: absolute; inset: 4px; border-radius: 50%; background: var(--ink); }
    .brand-bar .chip { display: inline-flex; align-items: center; gap: 5px; font-size: 11px; color: var(--ink-2); background: var(--surface); border: 1px solid var(--border); padding: 5px 10px; border-radius: 999px; font-weight: 500; }
    .brand-bar .chip::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: #22C55E; box-shadow: 0 0 0 2px rgba(34, 197, 94, 0.15); }

    .hero { background: var(--surface); border: 1px solid var(--border); border-radius: 20px; padding: 22px 22px 24px; position: relative; overflow: hidden; }
    .hero::before { content: ''; position: absolute; top: -40px; right: -40px; width: 180px; height: 180px; background: radial-gradient(circle, rgba(252, 199, 38, 0.18), transparent 70%); pointer-events: none; }
    .hero-tag { display: inline-flex; align-items: center; gap: 6px; font-size: 11px; font-weight: 600; letter-spacing: 0.06em; color: var(--or-red); text-transform: uppercase; margin-bottom: 14px; }
    .hero-tag::before { content: ''; width: 6px; height: 6px; background: var(--or-red); border-radius: 50%; }
    .hero h1 { margin: 0 0 8px; font-size: 26px; font-weight: 700; letter-spacing: -0.028em; line-height: 1.2; }
    .hero p { margin: 0; font-size: 14px; line-height: 1.55; color: var(--ink-2); }
    .hero-cover { width: calc(100% + 44px); margin: 18px -22px -24px; aspect-ratio: 16 / 9; object-fit: cover; display: block; border-top: 1px solid var(--border); }

    .stats { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; margin-top: 12px; }
    .stat { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; padding: 12px; }
    .stat .v { font-size: 20px; font-weight: 700; letter-spacing: -0.02em; line-height: 1; font-variant-numeric: tabular-nums; transform-origin: left center; }
    .stat .v .unit { font-size: 11px; color: var(--ink-2); margin-left: 2px; font-weight: 500; }
    .stat .k { font-size: 11px; color: var(--ink-2); margin-top: 5px; font-weight: 500; }
    @keyframes stat-pop { 0% { transform: scale(1.3); color: var(--or-yellow-d); } 100% { transform: scale(1); } }
    .stat .v.pop { animation: stat-pop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1); }

    .invite-card { margin-top: 8px; background: linear-gradient(135deg, #FFDC66, var(--or-yellow) 42%, #F3B70E); border-radius: 18px; padding: 16px 18px; display: flex; align-items: center; justify-content: space-between; gap: 12px; position: relative; overflow: hidden; color: var(--ink); box-shadow: 0 12px 26px -12px rgba(232, 180, 0, 0.6); }
    .invite-card::before { content: ''; position: absolute; top: -46px; right: -34px; width: 150px; height: 150px; border-radius: 50%; background: rgba(255, 255, 255, 0.3); pointer-events: none; }
    .invite-card::after { content: ''; position: absolute; bottom: -34px; left: -22px; width: 92px; height: 92px; border-radius: 50%; border: 10px solid rgba(31, 41, 55, 0.08); pointer-events: none; }
    .invite-left { flex: 1; z-index: 1; }
    .invite-kicker { display: inline-block; font-size: 10px; font-weight: 800; letter-spacing: 0.12em; color: var(--ink); background: rgba(255, 255, 255, 0.55); border-radius: 999px; padding: 3px 9px; margin-bottom: 6px; }
    .invite-title { font-size: 15px; font-weight: 800; letter-spacing: -0.01em; }
    .invite-title strong { color: var(--or-red); font-size: 17px; }
    .invite-sub { font-size: 11px; color: rgba(31, 41, 55, 0.68); margin-top: 3px; font-weight: 500; }
    .invite-btn { flex-shrink: 0; background: var(--ink); color: #fff; border: none; border-radius: 999px; padding: 10px 18px; font-family: inherit; font-weight: 700; font-size: 13px; cursor: pointer; z-index: 1; box-shadow: 0 6px 14px -6px rgba(15, 15, 16, 0.5); transition: background 0.15s ease, transform 0.15s cubic-bezier(0.34, 1.56, 0.64, 1); display: inline-flex; align-items: center; }
    .invite-btn:hover { background: #000; }
    .invite-btn:active { transform: scale(0.96); }
    .invite-card.maxed { opacity: 0.6 !important; filter: grayscale(0.5); box-shadow: none; }
    .invite-card.maxed .invite-btn { background: var(--ink-3); cursor: default; pointer-events: none; box-shadow: none; }

    /* ========== Scratch stage ========== */
    .stage-card { margin-top: 12px; background: var(--surface); border: 1px solid var(--border); border-radius: 20px; padding: 24px 20px 22px; position: relative; overflow: hidden; box-shadow: 0 8px 24px -16px rgba(15, 15, 16, 0.14); }
    .stage-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; }
    .stage-head .label { font-size: 11px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink-3); }
    .stage-head .count { font-size: 11px; color: var(--ink-2); font-weight: 500; }

    .scratch-stage {
      position: relative;
      width: 100%;
      max-width: 320px;
      margin: 0 auto;
      aspect-ratio: 4 / 3;
    }
    .scratch-card {
      position: relative;
      width: 100%;
      height: 100%;
      border-radius: 18px;
      overflow: hidden;
      box-shadow:
        0 12px 32px -8px rgba(15, 15, 16, 0.18),
        0 4px 12px -2px rgba(15, 15, 16, 0.08),
        0 0 0 1px var(--border);
      background: var(--surface);
    }
    /* 可玩狀態：金黃微光描邊呼吸 */
    @keyframes card-breathe {
      0%, 100% { box-shadow: 0 12px 32px -8px rgba(15, 15, 16, 0.18), 0 4px 12px -2px rgba(15, 15, 16, 0.08), 0 0 0 2px rgba(252, 199, 38, 0.45); }
      50% { box-shadow: 0 12px 32px -8px rgba(15, 15, 16, 0.18), 0 4px 12px -2px rgba(15, 15, 16, 0.08), 0 0 0 3px rgba(252, 199, 38, 0.9), 0 0 26px 2px rgba(252, 199, 38, 0.4); }
    }
    .scratch-card.ready:not(.revealed):not(.exhausted) { animation: card-breathe 2.4s ease-in-out infinite; }
    .scratch-prize {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 20px;
      text-align: center;
      background: linear-gradient(135deg, #FFFDF0, #FFF7DA);
    }
    .scratch-prize.grand { background: linear-gradient(135deg, var(--or-red), #B61118); color: #fff; }
    .scratch-rank {
      font-size: 11px; font-weight: 700; letter-spacing: 0.18em;
      color: var(--or-red); padding: 3px 10px;
      background: rgba(225, 29, 39, 0.1);
      border-radius: 999px;
      margin-bottom: 10px;
    }
    .scratch-prize.grand .scratch-rank { color: #fff; background: rgba(255,255,255,0.18); }
    .scratch-glyph {
      width: 56px; height: 56px;
      border-radius: 50%;
      background: var(--or-yellow);
      display: flex; align-items: center; justify-content: center;
      font-size: 26px; font-weight: 700;
      margin-bottom: 10px;
    }
    .scratch-prize.grand .scratch-glyph { background: rgba(255,255,255,0.2); color: #fff; }
    .scratch-name { font-size: 22px; font-weight: 700; letter-spacing: -0.025em; line-height: 1.2; margin-bottom: 4px; }
    .scratch-desc { font-size: 12px; opacity: 0.8; line-height: 1.5; max-width: 80%; }
    /* 卡內優惠序號（刮開後隨獎品一起露出，沿用獎品區文字色） */
    .scratch-prize .coupon-block { margin-top: 8px; text-align: center; }
    .scratch-prize .coupon-label { font-size: 9.5px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; opacity: 0.7; margin-bottom: 3px; }
    .scratch-prize .coupon-code { font-size: 18px; font-weight: 800; letter-spacing: 0.04em; line-height: 1.2; word-break: break-all; font-variant-numeric: tabular-nums; -webkit-user-select: all; user-select: all; }
    /* 卡外：核銷提示 + 我的優惠券連結 */
    .coupon-redeem { margin-top: 14px; text-align: center; }
    .coupon-redeem .coupon-hint { font-size: 12.5px; color: var(--ink-2); line-height: 1.5; }
    .coupon-redeem .wallet-link { display: inline-block; margin-top: 10px; font-size: 13px; font-weight: 600; color: var(--ink-2); text-decoration: none; }
    .coupon-redeem .wallet-link:active { opacity: 0.6; }
    .coupon-oos { margin-top: 14px; background: var(--bg); border: 1px solid var(--border); border-radius: 12px; padding: 13px 14px; text-align: center; font-size: 12.5px; color: var(--ink-2); line-height: 1.5; }
    /* 揭曉節奏：獎品區 scale pop；銘謝惠顧再加溫和浮動 */
    @keyframes prize-pop { 0% { transform: scale(0.82); } 55% { transform: scale(1.07); } 100% { transform: scale(1); } }
    .scratch-prize.pop { animation: prize-pop 0.55s cubic-bezier(0.34, 1.56, 0.64, 1); }
    @keyframes prize-soft { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-5px); } }
    .scratch-prize.pop.soft { animation: prize-pop 0.55s cubic-bezier(0.34, 1.56, 0.64, 1), prize-soft 1.7s ease-in-out 0.6s 2; }

    /* canvas 蓋層（要刮的部分） */
    #scratch-canvas {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      cursor: crosshair;
      touch-action: none;
    }
    /* 灰膜光澤：獨立 DOM 層疊在 canvas 上（pointer-events:none，不影響刮除） */
    .scratch-shine {
      position: absolute;
      inset: 0;
      pointer-events: none;
      z-index: 2;
      opacity: 0;
      transition: opacity 0.4s ease;
      border-radius: 18px;
      background: linear-gradient(115deg, transparent 38%, rgba(255, 255, 255, 0.24) 48%, rgba(255, 255, 255, 0.06) 52%, transparent 62%);
      background-size: 300% 300%;
      animation: shine-sweep 3.4s ease-in-out infinite;
    }
    @keyframes shine-sweep { 0% { background-position: 120% 120%; } 60%, 100% { background-position: -60% -60%; } }
    .scratch-card.ready .scratch-shine { opacity: 1; }
    .scratch-card.revealed .scratch-shine, .scratch-card.exhausted .scratch-shine { opacity: 0; }
    /* 刮動碎屑 + 揭曉碎片（額外 DOM 層，不碰 canvas） */
    .scratch-dust { position: absolute; inset: 0; pointer-events: none; z-index: 6; }
    .scratch-dust .dust { position: absolute; width: 5px; height: 5px; border-radius: 50%; background: #9CA3AD; animation: dust-fall 0.75s ease-in forwards; }
    @keyframes dust-fall { 0% { opacity: 0.95; } 100% { transform: translate(var(--dx, 0px), var(--dy, 44px)) scale(0.35); opacity: 0; } }
    .scratch-dust .frag { position: absolute; width: 11px; height: 11px; border-radius: 2px; background: linear-gradient(135deg, #C3C9D2, #8A919E); animation: frag-fly 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
    @keyframes frag-fly { 0% { opacity: 1; } 100% { transform: translate(var(--dx, 0px), var(--dy, -40px)) rotate(var(--rot, 90deg)) scale(0.5); opacity: 0; } }
    /* 載入遮罩 — 蓋住整張卡，paintCover 完才移除 */
    .scratch-loading {
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, #D5D9E0, #9CA3AD 50%, #7B8290);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 10px;
      z-index: 4;
      color: rgba(255,255,255,0.85);
      font-weight: 600;
      font-size: 13px;
      letter-spacing: 0.2em;
    }
    .scratch-loading .spinner {
      width: 22px; height: 22px;
      border: 2.5px solid rgba(255,255,255,0.3);
      border-top-color: rgba(255,255,255,0.85);
      border-radius: 50%;
      animation: scratch-spin 0.8s linear infinite;
    }
    @keyframes scratch-spin { to { transform: rotate(360deg); } }
    .scratch-card.ready .scratch-loading { display: none; }
    /* 沒次數時遮罩變成「已用完」提示 */
    .scratch-card.exhausted .scratch-loading {
      background: linear-gradient(135deg, #FAFAFA, #ECECEE);
      color: #6B6B70;
    }
    .scratch-card.exhausted .scratch-loading .spinner { display: none; }

    /* 領取按鈕 */
    .draw-btn-wrap { margin-top: 18px; display: flex; justify-content: center; gap: 10px; }
    .primary-btn {
      background: var(--or-yellow); color: var(--ink); border: none;
      padding: 14px 32px; border-radius: 999px; font-family: inherit;
      font-weight: 700; font-size: 16px; cursor: pointer;
      box-shadow: 0 6px 16px -4px rgba(252, 199, 38, 0.5);
      transition: background 0.15s, transform 0.18s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .primary-btn:hover:not(:disabled) { background: var(--or-yellow-d); }
    .primary-btn:active:not(:disabled) { transform: scale(0.97); }
    .primary-btn:disabled { background: #F0F0F2; color: var(--ink-3); cursor: default; box-shadow: none; animation: none; }
    /* 可以玩時：黃色呼吸光暈 */
    @keyframes btn-breathe {
      0%, 100% { box-shadow: 0 6px 16px -4px rgba(252, 199, 38, 0.5), 0 0 0 0 rgba(252, 199, 38, 0.4); }
      50% { box-shadow: 0 8px 22px -4px rgba(252, 199, 38, 0.7), 0 0 0 9px rgba(252, 199, 38, 0); }
    }
    .primary-btn:not(:disabled) { animation: btn-breathe 2.2s ease-in-out infinite; }
    .secondary-btn { background: transparent; color: var(--ink-2); border: 1px solid var(--border); padding: 14px 22px; border-radius: 999px; font-family: inherit; font-weight: 600; font-size: 14px; cursor: pointer; transition: transform 0.15s cubic-bezier(0.34, 1.56, 0.64, 1), border-color 0.15s ease; }
    .secondary-btn:hover { border-color: var(--ink-3); }
    .secondary-btn:active { transform: scale(0.97); }

    .status-row { display: flex; align-items: center; justify-content: center; gap: 8px; margin-top: 16px; font-size: 13px; color: var(--ink-2); min-height: 22px; }
    .status-row .name { color: var(--ink); font-weight: 600; }

    .section { margin-top: 24px; }
    .section-head { display: flex; align-items: baseline; justify-content: space-between; padding: 0 4px; margin-bottom: 10px; }
    .section-head h2 { margin: 0; font-size: 17px; font-weight: 700; letter-spacing: -0.015em; }
    .section-head .meta { font-size: 11px; color: var(--ink-2); font-weight: 500; }
    .prize-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
    .prize-card { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; padding: 14px; box-shadow: 0 4px 14px -10px rgba(15, 15, 16, 0.12); }
    .prize-card.grand { grid-column: span 2; border-color: var(--or-red); background: linear-gradient(180deg, rgba(225, 29, 39, 0.04), transparent); }
    .prize-card .top { display: flex; justify-content: space-between; margin-bottom: 8px; }
    .prize-card .icon { width: 32px; height: 32px; border-radius: 10px; background: linear-gradient(135deg, #FFF7DA, var(--or-yellow)); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 14px; }
    .prize-card.grand .icon { background: var(--or-red); color: #fff; }
    .prize-card .badge { font-size: 10px; font-weight: 700; padding: 3px 8px; border-radius: 999px; background: var(--or-red); color: #fff; }
    .prize-card .name { font-size: 14px; font-weight: 600; line-height: 1.35; }
    .prize-card .desc { margin-top: 3px; font-size: 12px; color: var(--ink-2); line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

    .foot { margin-top: 28px; padding: 14px 16px; background: var(--surface); border: 1px solid var(--border); border-radius: 16px; display: flex; align-items: center; justify-content: space-between; font-size: 12px; color: var(--ink-2); }
    .foot .l { display: flex; align-items: center; gap: 8px; }
    .foot .i { width: 20px; height: 20px; border-radius: 6px; background: var(--bg); border: 1px solid var(--border); display: inline-flex; align-items: center; justify-content: center; font-size: 11px; }
    .foot .r { font-weight: 600; color: var(--ink); }

    /* ========== 進場動畫 ========== */
    @keyframes rise-in { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
    .enter { animation: rise-in 0.4s cubic-bezier(0.22, 1, 0.36, 1) both; }
    .enter.d1 { animation-delay: 0.06s; }
    .enter.d2 { animation-delay: 0.12s; }
    .enter.d3 { animation-delay: 0.18s; }
    .enter.d4 { animation-delay: 0.26s; }
    .enter.d5 { animation-delay: 0.34s; }

    /* ========== 動效減量（無障礙） ========== */
    @media (prefers-reduced-motion: reduce) {
      .enter, .enter.d1, .enter.d2, .enter.d3, .enter.d4, .enter.d5 { animation: none; }
      .primary-btn:not(:disabled) { animation: none; }
      .scratch-card.ready:not(.revealed):not(.exhausted) { animation: none; }
      .scratch-shine { animation: none; opacity: 0 !important; }
      .scratch-prize.pop, .scratch-prize.pop.soft { animation: none; }
      .stat .v.pop { animation: none; }
      .scratch-dust .dust, .scratch-dust .frag { animation: none; display: none; }
    }
  </style>
</head>
<body>
  <div class="page">

    <header class="brand-bar">
      <div class="logo"><span class="dot"></span>OpenRice</div>
      <div class="chip">活動進行中</div>
    </header>

    <section class="hero enter">
      <div class="hero-tag">刮刮樂</div>
      <h1><%= activity.name %></h1>
      <% if (activity.description) { %><p><%= activity.description %></p><% } %>
      <% if (activity.cover_image_url) { %>
        <img class="hero-cover" src="<%= activity.cover_image_url %>" alt="" />
      <% } %>
    </section>

    <section class="stats enter d1">
      <div class="stat"><div class="v" id="stat-remaining">—</div><div class="k">剩餘次數</div></div>
      <div class="stat"><div class="v" id="stat-referrals">—</div><div class="k">已邀請</div></div>
      <div class="stat"><div class="v"><%= prizes && prizes.length || 0 %><span class="unit">種</span></div><div class="k">獎品</div></div>
    </section>

    <section class="invite-card enter d2" id="invite-card">
      <div class="invite-left">
        <% if (activity.referral_bonus_per && activity.referral_bonus_per > 0) { %>
          <div class="invite-kicker">好友助攻</div>
          <div class="invite-title">邀 1 位好友，多刮 <strong>+<%= activity.referral_bonus_per %> 次</strong></div>
          <div class="invite-sub" id="invite-sub">最多再加 <%= activity.referral_bonus_max %> 次</div>
        <% } else { %>
          <div class="invite-kicker">分享同樂</div>
          <div class="invite-title">分享給朋友一起玩</div>
          <div class="invite-sub" id="invite-sub">把這個活動傳出去</div>
        <% } %>
      </div>
      <button type="button" class="invite-btn" id="invite-btn">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:5px;vertical-align:-2px;"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>分享
      </button>
    </section>

    <section class="stage-card enter d3">
      <div class="stage-head">
        <span class="label">刮獎</span>
        <span class="count" id="stage-hint">準備中⋯</span>
      </div>
      <div class="scratch-stage">
        <div class="scratch-card" id="card">
          <div class="scratch-prize" id="prize">
            <div class="scratch-rank" id="prize-rank">獎 品</div>
            <div class="scratch-glyph" id="prize-glyph">★</div>
            <div class="scratch-name" id="prize-name">—</div>
            <div class="scratch-desc" id="prize-desc"></div>
            <div class="coupon-block" id="coupon-block" hidden>
              <div class="coupon-label">優惠序號</div>
              <div class="coupon-code" id="coupon-code">—</div>
            </div>
          </div>
          <canvas id="scratch-canvas"></canvas>
          <!-- 灰膜光澤層：純裝飾、pointer-events:none，不影響 canvas 刮除 -->
          <div class="scratch-shine"></div>
          <!-- 載入遮罩：LIFF init + paintCover 完成才移除（避免底層獎品先閃現） -->
          <div class="scratch-loading" id="card-loading">
            <div class="spinner"></div>
            <div id="card-loading-text">準 備 中</div>
          </div>
        </div>
        <!-- 碎屑/碎片層：獨立 DOM、pointer-events:none -->
        <div class="scratch-dust" id="dust-layer"></div>
      </div>

      <div class="draw-btn-wrap">
        <!-- 預設 hidden — 等 LIFF init + quota check 完，confirm 有次數才顯示 -->
        <button type="button" class="primary-btn" id="reveal-btn" hidden>直 接 揭 曉</button>
        <button type="button" class="secondary-btn" id="new-card-btn" hidden>再 來 一 張</button>
      </div>

      <div class="coupon-redeem" id="coupon-redeem" hidden>
        <div class="coupon-hint">請到店出示此畫面或序號給店員核銷</div>
        <a class="wallet-link" id="wallet-link" href="#">我的優惠券</a>
      </div>
      <div class="coupon-oos" id="coupon-oos" hidden>此獎品序號暫時發完，請洽客服</div>

      <div class="status-row" id="status-row"><span id="status">準備中</span></div>
    </section>

    <% if (prizes && prizes.length > 0) { %>
    <section class="section enter d4">
      <div class="section-head"><h2>本次獎項</h2><span class="meta"><%= prizes.length %> 種</span></div>
      <div class="prize-grid">
        <% prizes.forEach(function (p, i) { %>
          <div class="prize-card <%= p.is_grand_prize ? 'grand' : '' %>">
            <div class="top">
              <div class="icon"><%= String(i + 1).padStart(2, '0') %></div>
              <% if (p.is_grand_prize) { %><span class="badge">頭獎</span><% } %>
            </div>
            <div class="name"><%= p.name %></div>
            <% if (p.description) { %><div class="desc"><%= p.description %></div><% } %>
          </div>
        <% }); %>
      </div>
    </section>
    <% } %>

    <div class="foot enter d5">
      <div class="l"><span class="i">i</span><span>遊戲規則</span></div>
      <span class="r">公平隨機</span>
    </div>
  </div>

  <script>
    (function () {
      var slug = <%- JSON.stringify(activity.slug) %>;
      var liffId = <%- JSON.stringify(liffId || '') %>;
      var prizes = <%- JSON.stringify(prizes || []) %>;
      var activityMeta = <%- JSON.stringify({
        name: activity.name,
        referral_bonus_per: activity.referral_bonus_per,
        referral_bonus_max: activity.referral_bonus_max
      }) %>;

      var card = document.getElementById('card');
      var canvas = document.getElementById('scratch-canvas');
      var ctx = canvas.getContext('2d');
      var prizeEl = document.getElementById('prize');
      var revealBtn = document.getElementById('reveal-btn');
      var newCardBtn = document.getElementById('new-card-btn');
      var statusEl = document.getElementById('status');
      var stageHint = document.getElementById('stage-hint');

      var profile = null;
      var idToken = null;
      var liffReady = false;
      var canPlay = false;
      var inProgress = false;
      var currentPrize = null;
      var revealed = false;

      /* ===== 體驗層（純演出，不碰遊戲邏輯） ===== */
      var reducedMotion = false;
      try { reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches; } catch (e) {}
      var dustLayer = document.getElementById('dust-layer');
      var dustCount = 0;
      var lastDustAt = 0;
      var lastRemainingShown = null;
      var lastReferralsShown = null;

      function buzz(pattern) {
        try { if (navigator.vibrate) navigator.vibrate(pattern); } catch (e) {}
      }

      // 數字變化 pop（剩餘次數 / 已邀請）
      function popStat(el) {
        if (!el || reducedMotion) return;
        el.classList.remove('pop');
        void el.offsetWidth;
        el.classList.add('pop');
      }

      // 刮動碎屑：節流 ~40ms，每次最多 2 顆，同時上限 30 顆
      function spawnDust(x, y) {
        if (reducedMotion || !dustLayer) return;
        var now = Date.now();
        if (now - lastDustAt < 40) return;
        lastDustAt = now;
        var n = Math.min(2, 30 - dustCount);
        for (var i = 0; i < n; i++) {
          var d = document.createElement('div');
          d.className = 'dust';
          var s = Math.random() * 3 + 3;
          d.style.width = s + 'px';
          d.style.height = s + 'px';
          d.style.left = (x + (Math.random() - 0.5) * 18) + 'px';
          d.style.top = (y + (Math.random() - 0.5) * 12) + 'px';
          d.style.setProperty('--dx', ((Math.random() - 0.5) * 36) + 'px');
          d.style.setProperty('--dy', (Math.random() * 30 + 34) + 'px');
          dustCount++;
          d.addEventListener('animationend', function () { this.remove(); dustCount--; });
          dustLayer.appendChild(d);
        }
      }

      // 揭曉瞬間：灰色碎片往外飛散
      function spawnFragments() {
        if (reducedMotion || !dustLayer) return;
        var w = dustLayer.offsetWidth || 280;
        var h = dustLayer.offsetHeight || 210;
        for (var i = 0; i < 10; i++) {
          var f = document.createElement('div');
          f.className = 'frag';
          f.style.left = (w * 0.5 + (Math.random() - 0.5) * w * 0.55) + 'px';
          f.style.top = (h * 0.5 + (Math.random() - 0.5) * h * 0.55) + 'px';
          f.style.setProperty('--dx', ((Math.random() - 0.5) * 170) + 'px');
          f.style.setProperty('--dy', ((Math.random() - 0.5) * 130 - 40) + 'px');
          f.style.setProperty('--rot', (Math.random() * 260 - 130) + 'deg');
          f.addEventListener('animationend', function () { this.remove(); });
          dustLayer.appendChild(f);
        }
      }

      // 「銘謝惠顧」類判斷（純文案判斷，僅決定演出，不影響獎品本身）
      function isLosePrize(p) {
        var t = ((p && p.name) || '') + ' ' + ((p && p.description) || '');
        return /銘謝|惠顧|未中獎|沒中|再接再厲|下次再來/.test(t);
      }

      // 輕量 canvas 紙花：黃/墨/白 約 80 顆，~1.8 秒自動清理
      function fireConfetti() {
        if (reducedMotion) return;
        var cv = document.createElement('canvas');
        cv.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:9999;';
        document.body.appendChild(cv);
        var dpr = window.devicePixelRatio || 1;
        var vw = window.innerWidth, vh = window.innerHeight;
        cv.width = vw * dpr;
        cv.height = vh * dpr;
        var cc = cv.getContext('2d');
        cc.scale(dpr, dpr);
        var colors = ['#FCC726', '#1F2937', '#FFFFFF', '#FCC726', '#1F2937', '#FCC726'];
        var parts = [];
        for (var i = 0; i < 80; i++) {
          parts.push({
            x: vw / 2 + (Math.random() - 0.5) * 140,
            y: vh * 0.42,
            vx: (Math.random() - 0.5) * 10,
            vy: -(Math.random() * 9 + 5),
            size: Math.random() * 5 + 4,
            color: colors[i % colors.length],
            circle: Math.random() < 0.4,
            rot: Math.random() * Math.PI * 2,
            vr: (Math.random() - 0.5) * 0.3
          });
        }
        var start = null;
        var DURATION = 1800;
        function frame(ts) {
          if (start === null) start = ts;
          var t = ts - start;
          cc.clearRect(0, 0, vw, vh);
          var fade = t > DURATION - 450 ? Math.max(0, (DURATION - t) / 450) : 1;
          for (var j = 0; j < parts.length; j++) {
            var p = parts[j];
            p.vy += 0.26;
            p.x += p.vx;
            p.y += p.vy;
            p.vx *= 0.99;
            p.rot += p.vr;
            cc.save();
            cc.globalAlpha = fade;
            cc.translate(p.x, p.y);
            cc.rotate(p.rot);
            cc.fillStyle = p.color;
            if (p.circle) { cc.beginPath(); cc.arc(0, 0, p.size / 2, 0, Math.PI * 2); cc.fill(); }
            else { cc.fillRect(-p.size / 2, -p.size / 2, p.size, p.size * 0.62); }
            cc.restore();
          }
          if (t < DURATION) requestAnimationFrame(frame);
          else if (cv.parentNode) cv.parentNode.removeChild(cv);
        }
        requestAnimationFrame(frame);
      }
      /* ===== 體驗層結束 ===== */

      function paintCover() {
        var rect = card.getBoundingClientRect();
        var dpr = window.devicePixelRatio || 1;
        var w = rect.width;   // 用真實尺寸，不要 floor（floor 在小數尺寸螢幕會留下露餡的縫）
        var h = rect.height;
        // 物理像素用 ceil 確保「至少」蓋滿；顯示尺寸交給 CSS（inset:0;width/height:100%）精準貼齊卡片
        canvas.width = Math.ceil(w * dpr);
        canvas.height = Math.ceil(h * dpr);
        canvas.style.width = '100%';
        canvas.style.height = '100%';
        // 只 setTransform 一次，scale(dpr, dpr) 之後所有座標都用「邏輯像素」(w, h)
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        ctx.globalCompositeOperation = 'source-over';
        // 灰色金屬箔感漸層（用邏輯尺寸 w/h，配合 ctx 的 scale）
        var g = ctx.createLinearGradient(0, 0, w, h);
        g.addColorStop(0, '#D5D9E0');
        g.addColorStop(0.5, '#9CA3AD');
        g.addColorStop(1, '#7B8290');
        ctx.fillStyle = g;
        ctx.fillRect(-2, -2, w + 4, h + 4);   // 超刷邊界 2px，保證完全蓋住、不露出底下獎品
        // 細白點 pattern
        for (var i = 0; i < 140; i++) {
          ctx.fillStyle = 'rgba(255,255,255,' + (Math.random() * 0.18 + 0.04) + ')';
          ctx.beginPath();
          ctx.arc(Math.random() * w, Math.random() * h, Math.random() * 1.5 + 0.4, 0, Math.PI * 2);
          ctx.fill();
        }
        // 中央文字提示
        ctx.fillStyle = 'rgba(255,255,255,0.4)';
        ctx.font = 'bold 14px -apple-system, "PingFang TC", sans-serif';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText('刮開查看獎品', w / 2, h / 2);
        // 切換 composite mode 為 destination-out（用來「擦除」）
        ctx.globalCompositeOperation = 'destination-out';
      }

      function setupScratch() {
        var isDrawing = false;
        var lastX = 0, lastY = 0;
        var revealThreshold = 0.35;  // 刮開 35% 自動 reveal（更有成就感）

        // 回邏輯像素座標（ctx 已 scale dpr，邏輯座標跟 CSS 像素一致）
        function getPos(e) {
          var rect = canvas.getBoundingClientRect();
          var x, y;
          if (e.touches) { x = e.touches[0].clientX; y = e.touches[0].clientY; }
          else { x = e.clientX; y = e.clientY; }
          return { x: x - rect.left, y: y - rect.top };
        }
        function startDraw(e) {
          if (!canPlay || revealed) return;
          e.preventDefault();
          isDrawing = true;
          var p = getPos(e);
          lastX = p.x; lastY = p.y;
          buzz(10);              // 開始刮：輕震
          spawnDust(p.x, p.y);   // 碎屑回饋
          // 第一觸點：畫一個小圓圈讓刮跡更明顯
          ctx.lineWidth = 36;
          ctx.lineCap = 'round';
          ctx.beginPath();
          ctx.arc(p.x, p.y, 18, 0, Math.PI * 2);
          ctx.fill();
          card.classList.add('scratched');
        }
        function moveDraw(e) {
          if (!isDrawing || !canPlay || revealed) return;
          e.preventDefault();
          var p = getPos(e);
          ctx.lineWidth = 36;
          ctx.lineCap = 'round';
          ctx.lineJoin = 'round';
          ctx.beginPath();
          ctx.moveTo(lastX, lastY);
          ctx.lineTo(p.x, p.y);
          ctx.stroke();
          lastX = p.x; lastY = p.y;
          spawnDust(p.x, p.y);   // 沿手指產生碎屑（內部已節流）
          card.classList.add('scratched');
          checkProgress();
        }
        function endDraw() { isDrawing = false; checkProgress(); }

        // 估算刮開比例（每 250ms 抽樣一次避免效能 hit）
        var lastCheck = 0;
        function checkProgress() {
          var now = Date.now();
          if (now - lastCheck < 250) return;
          lastCheck = now;
          try {
            // 注意：getImageData 回的是物理像素，不受 ctx scale 影響
            var data = ctx.getImageData(0, 0, canvas.width, canvas.height).data;
            var transparent = 0;
            var sampleStep = 24;  // 抽樣間隔
            var sampled = 0;
            for (var i = 3; i < data.length; i += 4 * sampleStep) {
              if (data[i] === 0) transparent++;
              sampled++;
            }
            var pct = transparent / sampled;
            if (pct >= revealThreshold) doReveal();
          } catch (e) { /* CORS / size 0 等 ignore */ }
        }

        canvas.addEventListener('mousedown', startDraw);
        canvas.addEventListener('mousemove', moveDraw);
        canvas.addEventListener('mouseup', endDraw);
        canvas.addEventListener('mouseleave', endDraw);
        canvas.addEventListener('touchstart', startDraw, { passive: false });
        canvas.addEventListener('touchmove', moveDraw, { passive: false });
        canvas.addEventListener('touchend', endDraw);
        canvas.addEventListener('touchcancel', endDraw);
      }

      function doReveal() {
        if (revealed) return;
        revealed = true;
        card.classList.add('revealed');
        buzz(15);
        // 碎片飛散 + 整個 canvas 漸隱
        spawnFragments();
        canvas.style.transition = 'opacity 0.45s ease';
        canvas.style.opacity = '0';
        stageHint.textContent = '完成！';
        newCardBtn.hidden = false;
        revealBtn.hidden = true;
        // 揭曉節奏：停頓 → 獎品 pop → 慶祝
        var win = currentPrize && !isLosePrize(currentPrize);
        setTimeout(function () {
          prizeEl.classList.add('pop');
          if (win) {
            statusEl.textContent = '恭喜抽中 ' + (currentPrize && currentPrize.name || '');
            buzz([30, 40, 80]);
            fireConfetti();
          } else {
            prizeEl.classList.add('soft');
            statusEl.textContent = '銘謝惠顧，下次再來';
          }
        }, 420);
        setTimeout(refreshQuota, 500);
      }

      async function initLiff() {
        var qs = new URLSearchParams(location.search);
        var devUid = qs.get('uid');
        if (devUid) { profile = { userId: devUid, displayName: qs.get('name') || 'DEV' }; return; }
        if (qs.get('preview') === '1') {
          profile = { userId: 'PREVIEW', displayName: '預覽' };
          return;
        }
        if (!liffId) throw new Error('LIFF ID 未設定');
        try { await liff.init({ liffId: liffId }); }
        catch (e) { throw new Error('LIFF 初始化失敗'); }
        if (!liff.isInClient()) throw new Error('請在 LINE App 內打開');
        if (!liff.isLoggedIn()) { liff.login(); return new Promise(function () {}); }
        profile = await liff.getProfile();
        try { idToken = liff.getIDToken(); } catch (e) {}
      }

      async function maybeRegisterReferral() {
        try {
          var qs = new URLSearchParams(location.search);
          var inviter = qs.get('ref');
          if (!inviter || !profile || !profile.userId || inviter === profile.userId) return;
          await fetch('/api/games/scratch/' + encodeURIComponent(slug) + '/referral', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ line_user_id: profile.userId, inviter_line_user_id: inviter, id_token: idToken })
          });
          var url = new URL(location.href);
          url.searchParams.delete('ref');
          history.replaceState({}, '', url.pathname + url.search);
        } catch (e) { console.warn('referral failed:', e); }
      }

      async function refreshQuota() {
        try {
          if (!profile || !profile.userId) return;
          var resp = await fetch('/api/games/scratch/' + encodeURIComponent(slug) +
            '/meta?line_user_id=' + encodeURIComponent(profile.userId) + '&id_token=' + encodeURIComponent(idToken || '')).then(function (r) { return r.json(); });
          if (!resp.ok || !resp.quota) return;
          renderQuota(resp.quota);
        } catch (e) { console.warn('quota fetch failed:', e); }
      }

      function renderQuota(q) {
        var remEl = document.getElementById('stat-remaining');
        var refStatEl = document.getElementById('stat-referrals');
        if (lastRemainingShown !== null && lastRemainingShown !== q.remaining) popStat(remEl);
        if (lastReferralsShown !== null && lastReferralsShown !== q.referrals) popStat(refStatEl);
        lastRemainingShown = q.remaining;
        lastReferralsShown = q.referrals;
        remEl.innerHTML = q.remaining + '<span class="unit">/ ' + q.total + '</span>';
        refStatEl.innerHTML = q.referrals + '<span class="unit">人</span>';

        var inviteCard = document.getElementById('invite-card');
        var inviteSub = document.getElementById('invite-sub');
        // 只在有邀請機制時更新文案；否則保留 server render 的「把這個活動傳出去」
        if (inviteCard && q.referral_bonus_per > 0) {
          var bonusLeft = q.referral_bonus_max - q.referral_bonus;
          if (bonusLeft <= 0) {
            inviteCard.classList.add('maxed');
            if (inviteSub) inviteSub.textContent = '邀請次數已用滿';
          } else {
            inviteCard.classList.remove('maxed');
            if (inviteSub) inviteSub.textContent = '還可再邀請 ' + Math.ceil(bonusLeft / q.referral_bonus_per) + ' 位拿 +' + bonusLeft + ' 次';
          }
        }

        // 次數用完：遮罩切換成「已用完」+ 隱藏按鈕 + 禁止刮
        if (q.remaining <= 0) {
          var canMore = q.referral_bonus_per > 0 && q.referral_bonus < q.referral_bonus_max;
          stageHint.textContent = '次數已用完';
          statusEl.textContent = canMore
            ? '次數用完，邀請朋友 +' + q.referral_bonus_per + ' 次'
            : '次數已用完';
          canPlay = false;
          revealBtn.hidden = true;
          newCardBtn.hidden = true;
          // 卡片遮罩切換成「已用完」狀態（灰底）+ 移除 ready（避免之前的卡顯示出來）
          card.classList.remove('ready', 'scratched');
          card.classList.add('exhausted');
          var loadingText = document.getElementById('card-loading-text');
          if (loadingText) loadingText.textContent = '次 數 已 用 完';
        } else if (!revealed && !inProgress && canPlay) {
          // 還有剩 且 不在 reveal/inProgress 狀態 → 顯示揭曉鈕
          revealBtn.hidden = false;
        }
      }

      async function startNewCard() {
        if (inProgress) return;
        if (!liffReady || !profile) { statusEl.textContent = '請稍候'; return; }
        inProgress = true;
        revealed = false;
        canPlay = true;
        newCardBtn.hidden = true;
        revealBtn.hidden = false;
        statusEl.textContent = '刮一下試試';
        // 重置上一張的優惠序號顯示（避免新卡尚未刮開就露出舊序號／提示）
        var cb = document.getElementById('coupon-block'); if (cb) cb.hidden = true;
        var cr = document.getElementById('coupon-redeem'); if (cr) cr.hidden = true;
        var co = document.getElementById('coupon-oos'); if (co) co.hidden = true;
        stageHint.textContent = '進行中';

        try {
          // 後端決定獎品（同時驗 quota）
          var resp = await fetch('/api/games/scratch/' + encodeURIComponent(slug) + '/play', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ line_user_id: profile.userId, line_display_name: profile.displayName || null, id_token: idToken })
          }).then(function (r) { return r.json(); });

          if (!resp.ok) {
            // quota 用完或其他錯誤 → 不顯示 reveal/new 按鈕
            statusEl.textContent = resp.detail || resp.error || '抽獎失敗';
            stageHint.textContent = resp.error === 'quota_exhausted' ? '次數已用完' : '無法抽獎';
            revealBtn.hidden = true;
            newCardBtn.hidden = true;
            inProgress = false;
            canPlay = false;
            // 若是 quota error，refresh stat 顯示剩餘 0
            if (resp.quota) renderQuota(resp.quota);
            return;
          }
          currentPrize = resp.prize;
          renderPrize(currentPrize, resp);
          // 重設 canvas（蓋上灰膜）+ 清掉上一輪的演出狀態
          card.classList.remove('scratched', 'exhausted', 'revealed');
          prizeEl.classList.remove('pop', 'soft');
          canvas.style.transition = 'none';
          canvas.style.opacity = '1';
          paintCover();
          // 灰膜已畫好 → 移除載入遮罩
          card.classList.add('ready');
        } catch (e) {
          statusEl.textContent = '錯誤';
          revealBtn.hidden = true;
          newCardBtn.hidden = true;
          canPlay = false;
        } finally {
          inProgress = false;
        }
      }

      function renderPrize(prize, resp) {
        var rank = prize.is_grand_prize ? '頭 獎' : '獎 品';
        document.getElementById('prize-rank').textContent = rank;
        document.getElementById('prize-name').textContent = prize.name || '—';
        document.getElementById('prize-glyph').textContent = prize.is_grand_prize ? '★' : '◆';
        var descParts = [];
        if (prize.description) descParts.push(prize.description);
        if (prize.prize_value) {
          if (prize.prize_value.amount) descParts.push('NT$ ' + prize.prize_value.amount);
          if (prize.prize_value.code) descParts.push('優惠碼 ' + prize.prize_value.code);
          if (prize.prize_value.label) descParts.push(prize.prize_value.label);
        }
        document.getElementById('prize-desc').textContent = descParts.join(' · ');
        if (prize.is_grand_prize) prizeEl.classList.add('grand');
        else prizeEl.classList.remove('grand');
        renderCoupon(prize, resp);
      }

      // 優惠序號顯示：coupon_code 可能在 prize 物件上或 /play 回應頂層
      // 卡內序號隨刮開露出；卡外核銷提示 + 我的優惠券連結
      function renderCoupon(prize, resp) {
        var block = document.getElementById('coupon-block');
        var redeem = document.getElementById('coupon-redeem');
        var oos = document.getElementById('coupon-oos');
        if (!block || !redeem || !oos) return;
        var code = (prize && prize.coupon_code) || (resp && resp.coupon_code) || '';
        var outOfStock = !!(resp && resp.coupon_out_of_stock) || !!(prize && prize.coupon_out_of_stock);
        if (code) {
          document.getElementById('coupon-code').textContent = code;
          block.hidden = false;
          redeem.hidden = false;
          oos.hidden = true;
        } else if (outOfStock) {
          block.hidden = true;
          redeem.hidden = true;
          oos.hidden = false;
        } else {
          block.hidden = true;
          redeem.hidden = true;
          oos.hidden = true;
        }
      }

      // 「我的優惠券」連結，導向錢包頁（LIFF 永久連結 /wallet）
      var walletLink = document.getElementById('wallet-link');
      if (walletLink) {
        walletLink.href = liffId ? ('https://liff.line.me/' + liffId + '/wallet') : '/games/wallet';
      }

      var inviteBtn = document.getElementById('invite-btn');
      if (inviteBtn) inviteBtn.addEventListener('click', shareWithFriend);
      async function shareWithFriend() {
        if (!profile || !profile.userId) { alert('身分驗證中'); return; }
        var inviteUrl = 'https://liff.line.me/' + liffId + '/scratch/' + encodeURIComponent(slug) + '?ref=' + encodeURIComponent(profile.userId);
        var msg = '快來刮「' + activityMeta.name + '」！我刮過了，你也來試試';
        try {
          if (liff.isApiAvailable && liff.isApiAvailable('shareTargetPicker')) {
            var res = await liff.shareTargetPicker([{ type: 'text', text: msg + '\n' + inviteUrl }]);
            if (res) { flashStatus('已分享！'); return; }
          }
        } catch (e) {}
        try { await navigator.clipboard.writeText(inviteUrl); flashStatus('連結已複製'); }
        catch (e) { prompt('複製此連結：', inviteUrl); }
      }
      function flashStatus(msg) {
        statusEl.textContent = msg;
        setTimeout(function () {
          refreshQuota();
          if (profile) statusEl.innerHTML = '哈囉，<span class="name">' + (profile.displayName || '') + '</span>';
        }, 2400);
      }

      revealBtn.addEventListener('click', doReveal);
      newCardBtn.addEventListener('click', startNewCard);

      window.addEventListener('load', function () {
        setupScratch();
      });
      window.addEventListener('resize', function () {
        if (!revealed && canPlay) paintCover();
      });

      if (prizes.length < 1) {
        statusEl.textContent = '獎品未設定';
        stageHint.textContent = '—';
      } else {
        statusEl.textContent = '驗證身分中⋯';
      }

      (async function () {
        if (prizes.length < 1) return;
        try {
          await initLiff();
          liffReady = true;
          await maybeRegisterReferral();
          statusEl.innerHTML = '哈囉，<span class="name">' + (profile.displayName || '') + '</span>';
          stageHint.textContent = '進行中';
          // meta（更新配額顯示）與 第一張卡「並行」，不再 meta 等完才發卡（縮短「準備中」）。
          // 配額是否用完由 /play 自行把關，startNewCard 會妥善處理 quota_exhausted。
          fetch('/api/games/scratch/' + encodeURIComponent(slug) +
            '/meta?line_user_id=' + encodeURIComponent(profile.userId) + '&id_token=' + encodeURIComponent(idToken || ''))
            .then(function (r) { return r.json(); })
            .then(function (m) { if (m && m.ok && m.quota) renderQuota(m.quota); })
            .catch(function () {});
          startNewCard();
        } catch (e) {
          statusEl.textContent = e.message || '初始化失敗';
          stageHint.textContent = '—';
          revealBtn.hidden = true;
          newCardBtn.hidden = true;
        }
      })();
    })();
  </script>
</body>
</html>
