<%-
  include('layout', {
    user: user,
    isAdmin: isAdmin,
    body: `
    <section class="openrice-lottery">
      <header class="or-hero">
        <div class="or-balloon left">
          <span></span><span></span><span></span>
        </div>
        <div class="or-balloon right">
          <span></span><span></span><span></span>
        </div>

        <h1 class="or-title">
          <span class="rose">春日饗里</span>
          <span class="blue">揪友野餐趣</span>
        </h1>
        <div class="or-date">3/10 ~ 3/31</div>

        <div class="or-center-graphic">
          <div class="wood-sign left-one">搜集籃中美味</div>
          <div class="wood-sign left-two">準時赴約野餐日</div>
          <div class="wood-sign right-one">LINE 好友
            <br/>一起抽獎中</div>
          <div class="or-basket"></div>
        </div>
      </header>

      <section class="or-wood-area">
        <div class="or-cta-plaque">
          分享好友領刮刮樂，最高 20,000「亞洲萬里通」里數等你拿
        </div>

        <div class="or-status">
          <p>剩餘抽獎次數：<strong id="draws-left">${typeof drawsLeft !== 'undefined' ? drawsLeft : 0}</strong></p>
          <p>邀請加碼次數：<strong>${typeof extraDraws !== 'undefined' ? extraDraws : 0}</strong></p>
          ${
            result
              ? `<div id="draw-result" class="draw-result ${result.includes('恭喜中獎') ? 'win' : 'normal'}">
                  ${result.includes('恭喜中獎') ? '<div class="draw-result-title">🎉 恭喜中獎！</div>' : ''}
                  <div class="draw-result-text">${result}</div>
                </div>`
              : '<p id="draw-result-placeholder" class="muted">按下下方按鈕開始刮刮樂。</p>'
          }
        </div>

        <section class="or-prize-grid">
          <article class="or-prize-card">
            <span class="or-badge">頭獎</span>
            <div class="or-prize-side am">
              <span class="icon">✈</span>
            </div>
            <div class="or-prize-content">
              <h3>20,000 里</h3>
              <p>「亞洲萬里通」里數</p>
            </div>
          </article>
          <article class="or-prize-card">
            <span class="or-badge">貳獎</span>
            <div class="or-prize-side rd">
              <span class="icon">$</span>
            </div>
            <div class="or-prize-content">
              <h3>Rice Dollars $100</h3>
              <p>餐飲回饋獎勵</p>
            </div>
          </article>
          <article class="or-prize-card">
            <span class="or-badge">參獎</span>
            <div class="or-prize-side rd">
              <span class="icon">$</span>
            </div>
            <div class="or-prize-content">
              <h3>Rice Dollars $30</h3>
              <p>餐飲回饋獎勵</p>
            </div>
          </article>
          <article class="or-prize-card">
            <span class="or-badge">早鳥獎</span>
            <div class="or-prize-side am">
              <span class="icon">✈</span>
            </div>
            <div class="or-prize-content">
              <h3>10,000 里</h3>
              <p>「亞洲萬里通」里數</p>
            </div>
          </article>
        </section>

        <div class="or-available">
          <h2>獎勵大賞</h2>
          ${
            Array.isArray(availablePrizes) && availablePrizes.length > 0
              ? `<div class="available-prizes">
                  ${availablePrizes
                    .map(p => `<span class="prize-pill">${p.name}</span>`)
                    .join('')}
                </div>`
              : '<p class="muted">目前尚無可抽獎品，請稍後再試。</p>'
          }
        </div>

        <div class="or-invite">
          <h2>分享好友再加碼</h2>
          <p>每成功邀請 1 位好友註冊，你可多 1 次抽獎機會。</p>
          ${
            typeof refLink !== 'undefined'
              ? `<code class="invite-link">${refLink}</code>`
              : ''
          }
        </div>

        ${
          (typeof drawsLeft !== 'undefined' ? drawsLeft : 0) > 0
            ? `
        <form method="post" action="/lottery/draw" class="draw-form" id="draw-form">
          <button type="submit" class="draw-button" id="draw-button">立即抽獎</button>
        </form>
        `
            : `<p class="muted center-text" id="no-draw-msg">您目前抽獎次數已用完，邀請好友可再獲得次數。</p>`
        }
      </section>
    </section>
    <script>
      (function () {
        const form = document.getElementById('draw-form');
        const button = document.getElementById('draw-button');
        const drawsLeftEl = document.getElementById('draws-left');
        const placeholder = document.getElementById('draw-result-placeholder');
        if (!form || !button || !drawsLeftEl) return;

        form.addEventListener('submit', async function (e) {
          e.preventDefault();
          const originalText = button.textContent;
          button.disabled = true;
          button.textContent = '抽獎中...';
          button.classList.add('loading');

          try {
            const res = await fetch('/lottery/draw', {
              method: 'POST',
              headers: {
                'Accept': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
              }
            });
            if (!res.ok) throw new Error('request_failed');
            const data = await res.json();

            drawsLeftEl.textContent = String(data.drawsLeft || 0);
            if (placeholder) placeholder.remove();

            let resultBox = document.getElementById('draw-result');
            if (!resultBox) {
              resultBox = document.createElement('div');
              resultBox.id = 'draw-result';
              const statusWrap = document.querySelector('.or-status');
              statusWrap && statusWrap.appendChild(resultBox);
            }

            const isWin = String(data.result || '').includes('恭喜中獎');
            resultBox.className = 'draw-result ' + (isWin ? 'win' : 'normal');
            resultBox.innerHTML =
              (isWin ? '<div class="draw-result-title">🎉 恭喜中獎！</div>' : '') +
              '<div class="draw-result-text">' + (data.result || '') + '</div>';

            if ((data.drawsLeft || 0) <= 0) {
              form.remove();
              const msg = document.createElement('p');
              msg.className = 'muted center-text';
              msg.id = 'no-draw-msg';
              msg.textContent = '您目前抽獎次數已用完，邀請好友可再獲得次數。';
              const wood = document.querySelector('.or-wood-area');
              wood && wood.appendChild(msg);
            }
          } catch (_err) {
            button.textContent = '系統忙碌，請重試';
          } finally {
            button.classList.remove('loading');
            button.disabled = false;
            if (button.textContent === '系統忙碌，請重試') {
              setTimeout(() => {
                if (button) button.textContent = originalText;
              }, 1200);
            } else {
              button.textContent = originalText;
            }
          }
        });
      })();
    </script>
  `
  })
%>

