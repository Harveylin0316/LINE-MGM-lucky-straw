<%-
  include('layout', {
    user: user,
    isAdmin: isAdmin,
    bodyClass: bodyClass,
    body: `
    <section class="card">
      <div class="players-head">
        <a href="/admin/activities/${activity.id}" class="ae-back">← 回活動編輯</a>
        <h1>玩家數據 — ${activity.name}</h1>
        <div class="muted" style="font-size:12px;">
          活動 #${activity.id} · ${({wheel:'輪盤',fortune:'抽籤',scratch:'刮刮樂',slot:'老虎機'})[activity.game_type] || activity.game_type}
          · 基礎 ${activity.base_plays_per_user} 次 / 邀請 +${activity.referral_bonus_per} × ${activity.referral_bonus_max} 上限
        </div>
      </div>
    </section>

    <section class="card">
      <div class="stats-grid">
        <div class="stat-box"><div class="v" id="ov-plays">—</div><div class="k">總抽次</div></div>
        <div class="stat-box"><div class="v" id="ov-players">—</div><div class="k">獨立玩家</div></div>
        <div class="stat-box"><div class="v" id="ov-wins">—</div><div class="k">中獎次數</div></div>
        <div class="stat-box"><div class="v" id="ov-24h">—</div><div class="k">24 小時內</div></div>
        <div class="stat-box"><div class="v" id="ov-7d">—</div><div class="k">7 天內</div></div>
      </div>
    </section>

    <section class="card">
      <div class="players-section-head">
        <h2 style="margin:0;">玩家清單</h2>
        <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
          <input type="text" id="player-search" placeholder="搜尋名稱或 UID..." class="player-search" />
          <button type="button" class="ae-secondary-btn" id="btn-export-list">匯出到名單庫</button>
          <button type="button" class="ae-secondary-btn" id="btn-add-quota">＋ 新增個別配額</button>
        </div>
      </div>
      <p class="muted" style="font-size:12px;margin:6px 0 14px;">
        排序依「最後活動時間」。<strong>個別配額</strong>欄可以為單一用戶覆寫總可玩次數（不受 base + referral 影響）。
      </p>
      <div class="table-wrap">
        <table class="players-table">
          <thead>
            <tr>
              <th>用戶</th>
              <th style="text-align:right;">抽次</th>
              <th style="text-align:right;">中獎</th>
              <th style="text-align:right;">邀請</th>
              <th>最後活動</th>
              <th>個別配額</th>
              <th></th>
            </tr>
          </thead>
          <tbody id="players-tbody">
            <tr><td colspan="7" class="muted" style="text-align:center;padding:18px 0;">載入中…</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Export to recipient list Modal -->
    <div id="export-modal" class="ae-modal" hidden>
      <div class="ae-modal-inner" style="max-width:520px;">
        <div class="ae-modal-head">
          <h3>匯出玩家成名單庫</h3>
          <button type="button" class="ae-modal-close" id="export-modal-close">×</button>
        </div>
        <p class="muted" style="font-size:12px;margin:0 0 12px;">
          會在「名單庫」建立一個新名單，內含符合條件的玩家 LINE userId。建立後可在群發訊息時選用。
        </p>
        <div class="ae-grid">
          <label class="ae-field ae-field-full">
            <span>名單名稱 *</span>
            <input type="text" id="ex-name" placeholder="例：${activity.name} 中獎名單" maxlength="200" />
          </label>
          <label class="ae-field ae-field-full">
            <span>描述（可選）</span>
            <input type="text" id="ex-desc" placeholder="用途備註" maxlength="500" />
          </label>
          <label class="ae-field ae-field-full">
            <span>包含哪些玩家 *</span>
            <select id="ex-filter" style="padding:8px 10px;border:1px solid #ECECEE;border-radius:6px;font-size:13px;font-family:inherit;">
              <option value="all">全部玩過的人</option>
              <option value="winners">中過獎的人（含一般獎 + 頭獎）</option>
              <option value="grand_winners">只取中過頭獎的人</option>
              <option value="losers">玩過但沒中過獎的人</option>
            </select>
            <div id="ex-preview" class="muted" style="font-size:11px;min-height:14px;margin-top:4px;"></div>
          </label>
        </div>
        <div class="ae-actions">
          <button type="button" class="ae-primary-btn" id="ex-save">建立名單</button>
          <button type="button" class="ae-secondary-btn" id="ex-cancel">取消</button>
        </div>
        <div id="ex-status" class="muted" style="font-size:12px;min-height:18px;margin-top:8px;"></div>
      </div>
    </div>

    <!-- Quota Modal -->
    <div id="quota-modal" class="ae-modal" hidden>
      <div class="ae-modal-inner" style="max-width:480px;">
        <div class="ae-modal-head">
          <h3 id="quota-modal-title">設定個別配額</h3>
          <button type="button" class="ae-modal-close" id="quota-modal-close">×</button>
        </div>
        <div class="ae-grid">
          <label class="ae-field ae-field-full">
            <span>LINE userId *（U 開頭的 33 字元）</span>
            <input type="text" id="qm-uid" placeholder="U3eca22d67d352c4db1428decf3ebcf14" />
          </label>
          <label class="ae-field ae-field-full">
            <span>顯示名稱（可選，後台辨識用）</span>
            <input type="text" id="qm-name" placeholder="VIP 客戶 / 內部測試 / ..." />
          </label>
          <label class="ae-field">
            <span>可玩次數上限 *</span>
            <input type="number" id="qm-max" min="0" step="1" value="1" />
          </label>
          <label class="ae-field">
            <span>備註（譬如「VIP」「黑名單」）</span>
            <input type="text" id="qm-note" placeholder="" />
          </label>
        </div>
        <div style="background:#FFFBEB;border:1px solid #FCC726;border-radius:8px;padding:10px 14px;margin-top:14px;font-size:12px;color:#92400e;">
          設定後此用戶<strong>不再受基礎次數 / 邀請加碼影響</strong>，直接以此值為總配額。<br>
          設 0 = 此用戶被禁止玩；設 99 = 給 VIP 無限放送。
        </div>
        <div class="ae-actions">
          <button type="button" class="ae-primary-btn" id="qm-save">儲存</button>
          <button type="button" class="ae-secondary-btn" id="qm-cancel">取消</button>
        </div>
      </div>
    </div>

    <script>
    (function () {
      var activityId = ${activity.id};
      var allPlayers = [];

      var tbody = document.getElementById('players-tbody');
      var searchInput = document.getElementById('player-search');

      function fmt(n) { return n == null ? '—' : Number(n).toLocaleString('zh-Hant-TW'); }
      function fmtTime(ts) {
        if (!ts) return '—';
        var d = new Date(ts);
        if (isNaN(d.getTime())) return '—';
        return d.toLocaleString('sv-SE', { timeZone: 'Asia/Taipei' }).slice(0, 16);
      }
      function esc(s) {
        return String(s == null ? '' : s)
          .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;').replace(/'/g, '&#039;');
      }
      function shortUid(uid) {
        if (!uid) return '';
        return uid.slice(0, 6) + '…' + uid.slice(-4);
      }

      function load() {
        fetch('/admin/activities/api/' + activityId + '/players')
          .then(function (r) { return r.json(); })
          .then(function (resp) {
            if (!resp.ok) {
              tbody.innerHTML = '<tr><td colspan="7" class="muted">載入失敗</td></tr>';
              return;
            }
            allPlayers = resp.players || [];
            // 統計
            var ov = resp.overview || {};
            document.getElementById('ov-plays').textContent = fmt(ov.total_plays);
            document.getElementById('ov-players').textContent = fmt(ov.unique_players);
            document.getElementById('ov-wins').textContent = fmt(ov.total_wins);
            document.getElementById('ov-24h').textContent = fmt(ov.plays_24h);
            document.getElementById('ov-7d').textContent = fmt(ov.plays_7d);
            render(allPlayers);
          })
          .catch(function () {
            tbody.innerHTML = '<tr><td colspan="7" class="muted">載入失敗</td></tr>';
          });
      }

      function render(list) {
        if (!list.length) {
          tbody.innerHTML = '<tr><td colspan="7" class="muted" style="text-align:center;padding:24px 0;">尚無玩家。等用戶開始抽就會出現在這裡。</td></tr>';
          return;
        }
        tbody.innerHTML = list.map(function (p) {
          var name = p.crm_display_name || p.line_display_name || '<span class="muted" style="font-style:italic;">未登入 CRM</span>';
          var uid = p.line_user_id || '';
          var override = p.max_plays_override != null
            ? '<span class="quota-pill">' + p.max_plays_override + ' 次</span>' +
              (p.quota_note ? ' <span class="quota-note">' + esc(p.quota_note) + '</span>' : '')
            : '<span class="muted" style="font-size:11px;">標準</span>';
          var grandPill = p.grand_wins > 0 ? ' <span class="grand-pill">頭獎 ×' + p.grand_wins + '</span>' : '';
          return '<tr data-uid="' + esc(uid) + '">' +
            '<td>' +
              '<div class="player-name">' + name + '</div>' +
              '<button type="button" class="player-uid" data-uid="' + esc(uid) + '">' + esc(shortUid(uid)) + '</button>' +
            '</td>' +
            '<td style="text-align:right;font-weight:600;">' + fmt(p.plays) + '</td>' +
            '<td style="text-align:right;">' + fmt(p.wins) + grandPill + '</td>' +
            '<td style="text-align:right;">' + fmt(p.referrals) + '</td>' +
            '<td style="font-size:12px;color:#6b7280;">' + fmtTime(p.last_played_at) + '</td>' +
            '<td>' + override + '</td>' +
            '<td>' +
              '<button type="button" class="ae-link-btn edit-quota" data-uid="' + esc(uid) + '">配額</button>' +
              (p.max_plays_override != null
                ? '<button type="button" class="ae-link-btn del-quota" data-uid="' + esc(uid) + '" style="color:#dc2626;">移除</button>'
                : '') +
            '</td>' +
          '</tr>';
        }).join('');

        // UID 複製
        tbody.querySelectorAll('.player-uid').forEach(function (btn) {
          btn.addEventListener('click', function () {
            var uid = btn.getAttribute('data-uid');
            if (!uid) return;
            navigator.clipboard.writeText(uid).then(function () {
              var orig = btn.textContent;
              btn.textContent = '已複製';
              setTimeout(function () { btn.textContent = orig; }, 1200);
            }).catch(function () { alert(uid); });
          });
        });

        // 編輯配額
        tbody.querySelectorAll('.edit-quota').forEach(function (btn) {
          btn.addEventListener('click', function () {
            var uid = btn.getAttribute('data-uid');
            var p = allPlayers.find(function (x) { return x.line_user_id === uid; });
            openQuotaModal(p);
          });
        });

        // 移除配額
        tbody.querySelectorAll('.del-quota').forEach(function (btn) {
          btn.addEventListener('click', function () {
            var uid = btn.getAttribute('data-uid');
            if (!confirm('移除此用戶的個別配額？將回歸標準（base + 邀請加碼）算法。')) return;
            fetch('/admin/activities/api/' + activityId + '/players/quota?line_user_id=' + encodeURIComponent(uid), {
              method: 'DELETE'
            })
              .then(function (r) { return r.json(); })
              .then(function (d) {
                if (!d.ok) { alert('移除失敗'); return; }
                load();
              });
          });
        });
      }

      // 搜尋
      searchInput.addEventListener('input', function () {
        var q = searchInput.value.trim().toLowerCase();
        if (!q) { render(allPlayers); return; }
        var filtered = allPlayers.filter(function (p) {
          var name = (p.crm_display_name || p.line_display_name || '').toLowerCase();
          var uid = (p.line_user_id || '').toLowerCase();
          return name.indexOf(q) >= 0 || uid.indexOf(q) >= 0;
        });
        render(filtered);
      });

      // ------- Quota Modal -------
      var modal = document.getElementById('quota-modal');
      var editingUid = null;
      function openQuotaModal(p) {
        editingUid = (p && p.line_user_id) || null;
        document.getElementById('quota-modal-title').textContent = p ? '編輯個別配額' : '新增個別配額';
        document.getElementById('qm-uid').value = p ? p.line_user_id : '';
        document.getElementById('qm-uid').disabled = !!p;
        document.getElementById('qm-name').value = p ? (p.line_display_name || p.crm_display_name || '') : '';
        document.getElementById('qm-max').value = p && p.max_plays_override != null ? p.max_plays_override : 1;
        document.getElementById('qm-note').value = p ? (p.quota_note || '') : '';
        modal.hidden = false;
      }
      function closeQuotaModal() { modal.hidden = true; editingUid = null; }
      document.getElementById('btn-add-quota').addEventListener('click', function () { openQuotaModal(null); });

      // ---- 匯出到名單庫 ----
      var exportModal = document.getElementById('export-modal');
      function updateExportPreview() {
        var filter = document.getElementById('ex-filter').value;
        var count = 0;
        if (filter === 'all') {
          count = allPlayers.filter(function (p) { return p.plays > 0; }).length;
        } else if (filter === 'winners') {
          count = allPlayers.filter(function (p) { return p.wins > 0; }).length;
        } else if (filter === 'grand_winners') {
          count = allPlayers.filter(function (p) { return p.grand_wins > 0; }).length;
        } else if (filter === 'losers') {
          count = allPlayers.filter(function (p) { return p.plays > 0 && p.wins === 0; }).length;
        }
        document.getElementById('ex-preview').textContent = '預估包含 ' + count + ' 人（建立後以後端實算為準）';
      }
      document.getElementById('btn-export-list').addEventListener('click', function () {
        document.getElementById('ex-name').value = '';
        document.getElementById('ex-desc').value = '';
        document.getElementById('ex-filter').value = 'all';
        document.getElementById('ex-status').textContent = '';
        updateExportPreview();
        exportModal.hidden = false;
        setTimeout(function () { document.getElementById('ex-name').focus(); }, 50);
      });
      document.getElementById('export-modal-close').addEventListener('click', function () { exportModal.hidden = true; });
      document.getElementById('ex-cancel').addEventListener('click', function () { exportModal.hidden = true; });
      document.getElementById('ex-filter').addEventListener('change', updateExportPreview);

      document.getElementById('ex-save').addEventListener('click', function () {
        var name = document.getElementById('ex-name').value.trim();
        var desc = document.getElementById('ex-desc').value.trim();
        var filter = document.getElementById('ex-filter').value;
        if (!name) { document.getElementById('ex-status').textContent = '請填名單名稱'; return; }
        document.getElementById('ex-save').disabled = true;
        document.getElementById('ex-status').textContent = '建立中⋯';
        fetch('/admin/activities/api/' + activityId + '/export-players-to-list', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name: name, description: desc, filter: filter })
        })
          .then(function (r) { return r.json(); })
          .then(function (d) {
            document.getElementById('ex-save').disabled = false;
            if (!d.ok) {
              document.getElementById('ex-status').textContent = '失敗：' + (d.detail || d.error || '未知');
              return;
            }
            document.getElementById('ex-status').innerHTML =
              '成功！已建立名單「' + (d.list.name || '').replace(/</g, '&lt;') + '」（' + d.total + ' 人）<br>' +
              '<a href="/admin/recipient-lists/' + d.list.id + '" style="color:#2563eb;">→ 前往名單庫查看</a>';
            setTimeout(function () { exportModal.hidden = true; }, 3500);
          })
          .catch(function (e) {
            document.getElementById('ex-save').disabled = false;
            document.getElementById('ex-status').textContent = '錯誤：' + e.message;
          });
      });
      document.getElementById('quota-modal-close').addEventListener('click', closeQuotaModal);
      document.getElementById('qm-cancel').addEventListener('click', closeQuotaModal);
      document.getElementById('qm-save').addEventListener('click', function () {
        var uid = document.getElementById('qm-uid').value.trim();
        var name = document.getElementById('qm-name').value.trim();
        var max = Number(document.getElementById('qm-max').value);
        var note = document.getElementById('qm-note').value.trim();
        if (!uid) { alert('LINE userId 必填'); return; }
        if (!Number.isFinite(max) || max < 0) { alert('次數必須是 0 或正整數'); return; }
        fetch('/admin/activities/api/' + activityId + '/players/quota', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            line_user_id: uid,
            line_display_name: name || null,
            max_plays_override: max,
            note: note || null
          })
        })
          .then(function (r) { return r.json(); })
          .then(function (d) {
            if (!d.ok) { alert('儲存失敗：' + (d.detail || d.error)); return; }
            closeQuotaModal();
            load();
          });
      });

      load();
    })();
    </script>

    <style>
      .players-head { display: flex; flex-direction: column; gap: 4px; }
      .players-head h1 { margin: 0; font-size: 22px; }
      .ae-back { color: #6b7280; font-size: 13px; text-decoration: none; }
      .ae-back:hover { color: #1f2937; }

      .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
        gap: 10px;
      }
      .stat-box {
        padding: 14px;
        border: 1px solid #ECECEE;
        border-radius: 12px;
        background: #FAFAFA;
      }
      .stat-box .v {
        font-size: 22px;
        font-weight: 700;
        letter-spacing: -0.02em;
        font-variant-numeric: tabular-nums;
      }
      .stat-box .k { font-size: 11px; color: #6B6B70; margin-top: 4px; }

      .players-section-head { display: flex; justify-content: space-between; align-items: center; gap: 12px; flex-wrap: wrap; }

      .player-search {
        padding: 6px 12px;
        border: 1px solid #ECECEE;
        border-radius: 6px;
        font-size: 13px;
        width: 200px;
      }

      .table-wrap { overflow-x: auto; }
      .players-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
      }
      .players-table th, .players-table td {
        padding: 10px 12px;
        border-bottom: 1px solid #F3F4F6;
        vertical-align: middle;
      }
      .players-table th {
        background: #FAFAFA;
        text-align: left;
        font-size: 11px;
        color: #6B6B70;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.04em;
      }
      .player-name {
        font-weight: 600;
        color: #1f2937;
        font-size: 13px;
      }
      .player-uid {
        background: none;
        border: none;
        padding: 2px 0;
        font-family: ui-monospace, Menlo, monospace;
        font-size: 11px;
        color: #9ca3af;
        cursor: pointer;
        margin-top: 2px;
      }
      .player-uid:hover { color: #1f2937; text-decoration: underline; }

      .quota-pill {
        display: inline-block;
        padding: 2px 8px;
        background: #FFF4D1;
        color: #92400e;
        border-radius: 999px;
        font-size: 11px;
        font-weight: 700;
      }
      .quota-note {
        font-size: 11px;
        color: #6B6B70;
      }
      .grand-pill {
        display: inline-block;
        padding: 1px 6px;
        background: #FDECEC;
        color: #DC2127;
        border-radius: 4px;
        font-size: 10px;
        font-weight: 600;
      }
      .ae-link-btn {
        padding: 3px 9px;
        background: #fff;
        border: 1px solid #ECECEE;
        border-radius: 4px;
        font-size: 11px;
        cursor: pointer;
        color: #374151;
        margin-right: 4px;
        font-family: inherit;
      }
      .ae-link-btn:hover { background: #FFFBEB; border-color: #FCC726; }

      /* Modal 沿用 admin_activity_edit 的 modal class */
      .ae-modal {
        position: fixed; inset: 0; background: rgba(0,0,0,0.5);
        display: flex; align-items: center; justify-content: center;
        z-index: 100; padding: 16px;
      }
      .ae-modal[hidden] { display: none !important; }
      .ae-modal-inner {
        background: #fff; border-radius: 12px; max-width: 640px; width: 100%;
        max-height: 90vh; overflow-y: auto; padding: 20px;
      }
      .ae-modal-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
      .ae-modal-head h3 { margin: 0; }
      .ae-modal-close {
        background: none; border: none; font-size: 24px; cursor: pointer;
        color: #6b7280; line-height: 1;
      }
      .ae-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 12px;
      }
      .ae-field { display: flex; flex-direction: column; gap: 4px; font-size: 13px; }
      .ae-field span { color: #6B6B70; font-size: 12px; }
      .ae-field input {
        padding: 8px 10px;
        border: 1px solid #ECECEE;
        border-radius: 6px;
        font-size: 13px;
      }
      .ae-field-full { grid-column: 1 / -1; }
      .ae-actions { margin-top: 14px; display: flex; gap: 8px; }
      .ae-primary-btn {
        padding: 9px 16px;
        background: #FCC726;
        color: #1f2937;
        font-weight: 600;
        border-radius: 6px;
        border: none;
        cursor: pointer;
        font-size: 13px;
      }
      .ae-secondary-btn {
        padding: 8px 12px;
        background: #fff;
        color: #374151;
        border: 1px solid #ECECEE;
        border-radius: 6px;
        cursor: pointer;
        font-size: 12px;
        text-decoration: none;
        font-family: inherit;
      }
    </style>
    `
  })
%>
