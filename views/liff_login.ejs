<%-
  include('layout_liff', {
    body: `
    <section class="liff-card">
      <h1>LINE 春日野餐祭入口</h1>
      <p class="muted">LINE 登入中...</p>
      ${reason === 'line_only' ? '<p class="error">此活動頁僅允許 LINE 登入，已自動登出非 LINE 帳號。</p>' : ''}
      ${
        reason === 'line_client_only'
          ? `<div class="liff-client-only-box">
              <img
                src="/images/liff-line-client-only-mascot.png"
                alt="請透過 LINE App 開啟"
                class="liff-client-only-image"
              />
              <p class="liff-client-only-title">請透過手機或平板的 LINE App 開啟此活動頁</p>
            </div>`
          : ''
      }
      <p id="liff-status" class="muted">LINE 登入中...</p>
      <div id="liff-error" class="error" style="display:none;"></div>
      <p class="muted liff-client-only-note">非 LINE client 無法使用，請透過手機或平板的 LINE App 開啟。</p>
    </section>
    <script src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>
    <script>
      (function () {
        var liffId = ${JSON.stringify(liffId || '')};
        var nextPath = ${JSON.stringify(nextPath || '/liff/lottery')};
        var statusEl = document.getElementById('liff-status');
        var errorEl = document.getElementById('liff-error');

        function setError(message) {
          errorEl.style.display = 'block';
          errorEl.textContent = message;
        }

        async function submitLiffAuth() {
          statusEl.textContent = '驗證 LINE 身分中...';
          const accessToken = liff.getAccessToken();
          if (!accessToken) {
            setError('無法取得 LINE access token，請重新登入。');
            return;
          }

          const response = await fetch('/liff/auth', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ accessToken: accessToken, nextPath: nextPath })
          });
          const payload = await response.json().catch(function () { return null; });
          if (!response.ok || !payload || !payload.ok) {
            setError('LINE 登入驗證失敗，請稍後再試。');
            statusEl.textContent = '驗證失敗';
            return;
          }
          window.location.href = payload.redirect || '/liff/lottery';
        }

        async function startLoginFlow() {
          if (!liffId) {
            statusEl.textContent = '尚未設定活動 ID';
            setError('活動設定尚未完成，請稍後再試或聯絡管理員。');
            return;
          }

          statusEl.textContent = 'LINE 登入中...';
          await liff.init({ liffId: liffId });

          if (!liff.isInClient()) {
            statusEl.textContent = '請改用 LINE App 開啟';
            setError('請透過手機或平板的 LINE App 開啟此活動頁。');
            return;
          }

          if (!liff.isLoggedIn()) {
            statusEl.textContent = 'LINE 登入中...';
            liff.login({ redirectUri: window.location.href });
            return;
          }

          await submitLiffAuth();
        }

        startLoginFlow().catch(function (err) {
          console.error(err);
          setError('活動頁初始化失敗，請稍後再試。');
          statusEl.textContent = '初始化失敗';
        });
      })();
    </script>
  `
  })
%>
