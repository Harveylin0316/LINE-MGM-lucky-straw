<%-
  include('layout_liff', {
    body: `
    <section class="liff-card liff-campaign">
      <div class="liff-event-header">
        <div class="liff-event-overlay"></div>
      </div>
      <p class="muted liff-hello">嗨，<strong>${displayName || user || '朋友'}</strong> 👋</p>
      <p class="liff-brand-line">春日野餐祭開跑！使用 OpenRice app 訂位餐廳，餐餐吃飯折抵現金</p>

      ${
        (() => {
          const canScratch = (typeof drawsLeft !== 'undefined' ? drawsLeft : 0) > 0;
          const hasResult = !!result;
          const isWin = hasResult && String(result).includes('恭喜中獎');

          if (hasResult) {
            return `<section class="scratch-zone">
              <div class="scratch-card scratch-result ${isWin ? 'win' : 'normal'}">
                <div class="scratch-result-card">
                  ${isWin ? '<div class="scratch-result-title">🌸 春日好運中獎！</div>' : '<div class="scratch-result-title">春日結果揭曉</div>'}
                  <div class="scratch-result-text">${result}</div>
                  ${isWin ? '<p class="scratch-result-note">請查看下方「兌換方式」與「我的中獎紀錄」完成兌換。</p>' : ''}
                </div>
              </div>
              ${
                canScratch
                  ? `<div class="actions scratch-result-actions">
                      <a class="btn primary" href="/liff/lottery" id="retry-scratch-btn">再刮一次（剩餘${typeof drawsLeft !== 'undefined' ? drawsLeft : 0}次）</a>
                    </div>
                    <p id="retry-loading-hint" class="muted center-text retry-loading-hint" style="display:none;">讀取中，請勿關閉視窗</p>`
                  : '<p class="muted center-text">目前可刮次數為 0，快邀請 1 位好友完成任務，再獲得 1 次春日刮刮樂機會。</p>'
              }
            </section>`;
          }

          if (!canScratch) {
            return `<section class="scratch-zone">
              <div class="scratch-card scratch-disabled">
                <div class="scratch-underlay">🎁 目前可刮次數為 0</div>
              </div>
              <p class="muted center-text">邀請 1 位好友完成任務可再獲得 1 次春日刮刮樂機會。</p>
            </section>`;
          }

          return `<section class="scratch-zone">
            <p class="muted center-text">滑動刮開卡片，揭曉你的春日好運。</p>
            <div id="scratch-card" class="scratch-card" role="button" tabindex="0" aria-label="刮開卡片開始刮刮樂">
              <div class="scratch-underlay">🍀 刮開看看你的春日好運</div>
              <canvas id="scratch-canvas" class="scratch-canvas"></canvas>
              <div id="scratch-gate" class="scratch-gate">
                <button id="scratch-start-btn" type="button" class="btn primary scratch-start-btn">開始刮（剩餘${typeof drawsLeft !== 'undefined' ? drawsLeft : 0}次）</button>
              </div>
            </div>
            <p id="scratch-hint" class="muted center-text">刮開超過 45% 會自動揭曉春日結果</p>
            <form id="scratch-draw-form" method="post" action="/liff/lottery/draw" class="draw-form"></form>
          </section>`;
        })()
      }

      <div class="liff-metric-grid">
        <div class="liff-metric-item">
          <span class="label">春日可刮次數</span>
          <strong>${typeof drawsLeft !== 'undefined' ? drawsLeft : 0}</strong>
        </div>
        <div class="liff-metric-item">
          <span class="label">好友加碼次數</span>
          <strong>${typeof extraDraws !== 'undefined' ? extraDraws : 0}</strong>
        </div>
        <div class="liff-metric-item">
          <span class="label">剩餘好友加碼名額</span>
          <strong>${Math.max(0, 2 - (typeof rewardedInviteCount !== 'undefined' ? rewardedInviteCount : 0))}</strong>
        </div>
      </div>

      ${
        Array.isArray(recentWins) && recentWins.length
          ? `<section class="liff-win-history" id="liff-win-history">
        <h2 class="liff-title">我的中獎紀錄</h2>
        <ul class="liff-win-list">
          ${recentWins
            .map(
              w =>
                `<li class="liff-win-item"><span class="liff-win-prize">${w.prizeName}</span><time class="liff-win-time">${w.atText}</time></li>`
            )
            .join('')}
        </ul>
      </section>`
          : `<section class="liff-win-history liff-win-history-empty" id="liff-win-history">
        <h2 class="liff-title">我的中獎紀錄</h2>
        <p class="muted">尚無中獎紀錄。刮中獎項後會顯示在這裡，方便你之後對照兌換。</p>
      </section>`
      }

      <section class="liff-redemption-box" id="liff-redemption">
        <h2 class="liff-title">兌換方式</h2>
        <div class="liff-redemption-body">${typeof redemptionNoteHtml !== 'undefined' ? redemptionNoteHtml : ''}</div>
        ${
          lineOfficialAddFriendUrl
            ? `<div class="actions liff-redemption-actions">
            <a class="btn primary" href="${lineOfficialAddFriendUrl}" target="_blank" rel="noopener noreferrer">前往 OpenRice LINE@</a>
          </div>`
            : ''
        }
      </section>

      <h2 class="liff-title">春日野餐祭 刮刮樂獎項</h2>
      <div class="liff-prize-section-static">
        <img
          src="/images/prize-section-board.png"
          alt="春日野餐祭刮刮樂獎項"
          class="liff-prize-section-image"
        />
      </div>

      <div class="liff-invite-box">
      <h2 class="liff-title">揪好友同行春日野餐祭</h2>
      <p class="muted">每位好友完成 OpenRice LINE@ 任務可加碼 1 次，最多 2 次，剩餘可加碼 <strong>${Math.max(0, 2 - (typeof rewardedInviteCount !== 'undefined' ? rewardedInviteCount : 0))}</strong> 次。</p>
      <code class="invite-link invite-link-compact" id="liff-invite-link" title="${inviteLink || ''}">${inviteLink || ''}</code>
      <div class="actions">
        <button type="button" class="btn primary" id="share-invite-btn">分享春日邀請給好友</button>
        <button type="button" class="btn" id="copy-invite-btn">複製邀請連結</button>
        ${
          lineOfficialAddFriendUrl
            ? `<a class="btn" href="${lineOfficialAddFriendUrl}" target="_blank" rel="noopener noreferrer">OpenRice LINE@</a>`
            : ''
        }
      </div>
      </div>
      <p class="liff-campaign-note">活動期間至 4/30。若 5/1 仍有剩餘刮刮樂次數，將無法再使用。</p>
    </section>
    <script src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>
    <script>
      (function () {
        var btn = document.getElementById('share-invite-btn');
        var copyBtn = document.getElementById('copy-invite-btn');
        var linkEl = document.getElementById('liff-invite-link');
        var retryBtn = document.getElementById('retry-scratch-btn');
        var retryLoadingHint = document.getElementById('retry-loading-hint');
        var liffId = ${JSON.stringify(liffId || '')};
        var liffInitPromise = null;
        if (!btn || !linkEl) return;

        async function ensureLiffReady() {
          if (!liffId || typeof liff === 'undefined') return false;
          if (!liffInitPromise) {
            liffInitPromise = liff
              .init({ liffId: liffId })
              .then(function () {
                return true;
              })
              .catch(function () {
                return false;
              });
          }
          return liffInitPromise;
        }

        async function shareViaLiff(inviteLink) {
          var ready = await ensureLiffReady();
          if (!ready) return false;
          if (!liff.isLoggedIn()) return false;
          if (!liff.isInClient()) return false;
          if (!liff.isApiAvailable('shareTargetPicker')) return false;
          const text = 'OpenRice 春日野餐祭開跑！訂餐廳能賺現金，現在還有春日刮刮樂，刮開就知道有沒有中，大獎有 2 萬里程數！一起來試試手氣吧 👇\\n' + inviteLink;
          const result = await liff.shareTargetPicker([{ type: 'text', text: text }]);
          return result !== null;
        }

        function openLineShareFallback(inviteLink) {
          var text = 'OpenRice 春日野餐祭開跑！訂餐廳能賺現金，現在還有春日刮刮樂，刮開就知道有沒有中，大獎有 2 萬里程數！一起來試試手氣吧 👇\\n' + inviteLink;
          window.location.href = 'https://line.me/R/msg/text/?' + encodeURIComponent(text);
        }

        async function copyInviteLink(inviteLink) {
          if (!inviteLink) return false;
          if (navigator.clipboard && typeof navigator.clipboard.writeText === 'function') {
            await navigator.clipboard.writeText(inviteLink);
            return true;
          }
          return false;
        }

        btn.addEventListener('click', async function () {
          try {
            var inviteLink = (linkEl.textContent || '').trim();
            if (!inviteLink) return;
            btn.disabled = true;
            var shared = await shareViaLiff(inviteLink);
            if (!shared) {
              openLineShareFallback(inviteLink);
              return;
            }
            btn.textContent = '已開啟分享';
            setTimeout(function () {
              btn.textContent = '分享春日邀請給好友';
            }, 1200);
          } catch (err) {
            var inviteLink = (linkEl.textContent || '').trim();
            if (!inviteLink) return;
            openLineShareFallback(inviteLink);
          } finally {
            setTimeout(function () {
              btn.disabled = false;
            }, 300);
          }
        });

        if (copyBtn) {
          copyBtn.addEventListener('click', async function () {
            try {
              var inviteLink = (linkEl.textContent || '').trim();
              if (!inviteLink) return;
              var copied = await copyInviteLink(inviteLink);
              if (!copied) {
                window.prompt('請手動複製邀請連結', inviteLink);
                return;
              }
              copyBtn.textContent = '已複製';
              setTimeout(function () {
                copyBtn.textContent = '複製邀請連結';
              }, 1200);
            } catch (_err) {
              var inviteLink = (linkEl.textContent || '').trim();
              if (inviteLink) window.prompt('請手動複製邀請連結', inviteLink);
            }
          });
        }

        if (retryBtn && retryLoadingHint) {
          retryBtn.addEventListener('click', function () {
            retryLoadingHint.style.display = 'block';
            retryBtn.setAttribute('aria-disabled', 'true');
            retryBtn.style.pointerEvents = 'none';
          });
        }

        (function initScratchCard() {
          var card = document.getElementById('scratch-card');
          var canvas = document.getElementById('scratch-canvas');
          var hint = document.getElementById('scratch-hint');
          var form = document.getElementById('scratch-draw-form');
          var gate = document.getElementById('scratch-gate');
          var startBtn = document.getElementById('scratch-start-btn');
          if (!card || !canvas || !form) return;

          var ctx = canvas.getContext('2d');
          if (!ctx) {
            card.addEventListener('click', function () {
              form.submit();
            });
            return;
          }

          var submitted = false;
          var isDrawing = false;
          var started = false;
          var brushRadius = 22;
          var coverImageLoaded = false;
          var coverImageFailed = false;
          var coverImage = new Image();
          coverImage.onload = function () {
            coverImageLoaded = true;
            setupCanvas();
          };
          coverImage.onerror = function () {
            coverImageFailed = true;
          };
          coverImage.src = '/images/scratch-cover-spring-picnic.png';

          function submitDraw() {
            if (submitted) return;
            submitted = true;
            card.classList.add('is-done');
            if (hint) hint.textContent = '揭曉結果中...';
            setTimeout(function () {
              form.submit();
            }, 150);
          }

          function setupCanvas() {
            var rect = card.getBoundingClientRect();
            var ratio = Math.max(1, window.devicePixelRatio || 1);
            canvas.width = Math.floor(rect.width * ratio);
            canvas.height = Math.floor(rect.height * ratio);
            ctx.setTransform(ratio, 0, 0, ratio, 0, 0);

            ctx.globalCompositeOperation = 'source-over';

            if (coverImageLoaded && !coverImageFailed) {
              var imgW = coverImage.naturalWidth || coverImage.width || rect.width;
              var imgH = coverImage.naturalHeight || coverImage.height || rect.height;
              var cardRatio = rect.width / Math.max(1, rect.height);
              var imgRatio = imgW / Math.max(1, imgH);
              var sx = 0;
              var sy = 0;
              var sWidth = imgW;
              var sHeight = imgH;
              if (imgRatio > cardRatio) {
                sWidth = Math.max(1, imgH * cardRatio);
                sx = (imgW - sWidth) / 2;
              } else {
                sHeight = Math.max(1, imgW / cardRatio);
                sy = (imgH - sHeight) / 2;
              }
              ctx.drawImage(coverImage, sx, sy, sWidth, sHeight, 0, 0, rect.width, rect.height);
              return;
            }

            // Fallback cover if image is not ready.
            var gradient = ctx.createLinearGradient(0, 0, rect.width, rect.height);
            gradient.addColorStop(0, '#a3a3a3');
            gradient.addColorStop(0.5, '#d4d4d4');
            gradient.addColorStop(1, '#9ca3af');
            ctx.fillStyle = gradient;
            ctx.fillRect(0, 0, rect.width, rect.height);
          }

          function eraseAt(clientX, clientY) {
            var rect = canvas.getBoundingClientRect();
            var x = clientX - rect.left;
            var y = clientY - rect.top;
            ctx.globalCompositeOperation = 'destination-out';
            ctx.beginPath();
            ctx.arc(x, y, brushRadius, 0, Math.PI * 2);
            ctx.fill();
          }

          function scratchedRatio() {
            var pixels = ctx.getImageData(0, 0, canvas.width, canvas.height).data;
            var transparent = 0;
            var total = pixels.length / 4;
            for (var i = 3; i < pixels.length; i += 4) {
              if (pixels[i] < 20) transparent += 1;
            }
            return total > 0 ? transparent / total : 0;
          }

          function handleScratchMove(x, y) {
            if (!started || !isDrawing || submitted) return;
            eraseAt(x, y);
            if (scratchedRatio() >= 0.45) {
              submitDraw();
            }
          }

          function startScratch() {
            if (started) return;
            started = true;
            if (gate) gate.style.display = 'none';
            if (hint) hint.textContent = '開始刮吧！刮開超過 45% 會自動揭曉春日結果';
          }

          if (startBtn) {
            startBtn.addEventListener('click', startScratch);
          }

          card.addEventListener('pointerdown', function (e) {
            if (submitted) return;
            if (!started) return;
            isDrawing = true;
            card.setPointerCapture(e.pointerId);
            handleScratchMove(e.clientX, e.clientY);
          });

          card.addEventListener('pointermove', function (e) {
            handleScratchMove(e.clientX, e.clientY);
          });

          card.addEventListener('pointerup', function () {
            isDrawing = false;
          });

          card.addEventListener('pointercancel', function () {
            isDrawing = false;
          });

          card.addEventListener('keydown', function (e) {
            if (e.key === 'Enter' || e.key === ' ') {
              e.preventDefault();
              if (!started) {
                startScratch();
                return;
              }
              submitDraw();
            }
          });

          setupCanvas();
          window.addEventListener('resize', setupCanvas);
        })();
      })();
    </script>
  `
  })
%>
