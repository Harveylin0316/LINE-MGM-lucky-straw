<%-
  include('layout_liff', {
    body: `
    <section class="liff-card liff-campaign">
      <div class="liff-event-header">
        <div class="liff-event-overlay"></div>
      </div>
      <p class="muted liff-hello">嗨，<strong>${displayName || user || '朋友'}</strong> 👋</p>
      <p class="liff-brand-line">使用 OpenRice app訂位餐廳，餐餐吃飯折抵現金</p>

      ${
        result
          ? `<div class="draw-result ${result.includes('恭喜中獎') ? 'win' : 'normal'}">
              ${result.includes('恭喜中獎') ? '<div class="draw-result-title">🎉 恭喜中獎！</div>' : ''}
              <div class="draw-result-text">${result}</div>
            </div>`
          : ''
      }

      <div class="liff-metric-grid">
        <div class="liff-metric-item">
          <span class="label">可抽次數</span>
          <strong>${typeof drawsLeft !== 'undefined' ? drawsLeft : 0}</strong>
        </div>
        <div class="liff-metric-item">
          <span class="label">邀請加碼</span>
          <strong>${typeof extraDraws !== 'undefined' ? extraDraws : 0}</strong>
        </div>
        <div class="liff-metric-item">
          <span class="label">剩餘可邀請加碼</span>
          <strong>${Math.max(0, 2 - (typeof rewardedInviteCount !== 'undefined' ? rewardedInviteCount : 0))}</strong>
        </div>
      </div>

      <h2 class="liff-title">OpenRice 活動抽獎</h2>
      ${
        (() => {
          if (!Array.isArray(availablePrizes) || availablePrizes.length === 0) {
            return '<p class="muted">目前尚無可抽獎品。</p>';
          }

          function detectTier(name) {
            if (/頭獎/.test(name)) return '頭獎';
            if (/貳獎|二獎/.test(name)) return '貳獎';
            if (/參獎|三獎/.test(name)) return '參獎';
            if (/早鳥/.test(name)) return '早鳥獎';
            return '活動獎項';
          }

          function detectType(name) {
            if (/里數|亞洲萬里通|里程/.test(name)) return 'miles';
            return 'cash';
          }

          function formatPrize(name) {
            const raw = String(name || '').trim();
            const withoutTier = raw.replace(/^(頭獎|貳獎|二獎|參獎|三獎|早鳥獎?)[:：]\s*/, '');
            const match = withoutTier.match(/^(.*?)(（.*）)$/);
            if (match) {
              return {
                main: match[1].trim(),
                sub: match[2].trim()
              };
            }
            return {
              main: withoutTier,
              sub: ''
            };
          }

          const grandPrize = availablePrizes.find(
            (p) => /頭獎/.test(p.name || '') && /亞洲萬里通|里數|里程/.test(p.name || '')
          );
          const displayPrizes = grandPrize ? availablePrizes.filter((p) => p !== grandPrize) : availablePrizes;

          const grandBlock = grandPrize
            ? `<div class="liff-grand-prize-wrap">
                <img
                  class="liff-grand-prize-image"
                  src="/images/grand-prize-banner.png"
                  alt="分享好友領刮刮樂，最高20,000「亞洲萬里通」里數等你拿"
                />
                <p class="liff-grand-prize-text">${grandPrize.name || ''}</p>
              </div>`
            : '';

          return `${grandBlock}<div class="liff-prize-grid">
            ${displayPrizes
              .map((p) => {
                const tier = detectTier(p.name || '');
                const type = detectType(p.name || '');
                const formatted = formatPrize(p.name || '');
                const accentClass = type === 'miles' ? 'miles' : 'cash';
                const icon = type === 'miles' ? 'A' : 'RD$';
                return `<article class="liff-prize-card ${accentClass}">
                  <span class="liff-prize-badge">${tier}</span>
                  <div class="liff-prize-side">${icon}</div>
                  <div class="liff-prize-content">
                    <p class="liff-prize-main">${formatted.main}</p>
                    ${formatted.sub ? `<p class="liff-prize-sub">${formatted.sub}</p>` : ''}
                  </div>
                </article>`;
              })
              .join('')}
          </div>`;
        })()
      }

      ${
        (typeof drawsLeft !== 'undefined' ? drawsLeft : 0) > 0
          ? `
      <form method="post" action="/liff/lottery/draw" class="draw-form">
        <button type="submit" class="draw-button">立即抽獎（有機會中 2 萬里程數）</button>
      </form>
      `
          : '<p class="muted center-text">目前可抽次數為 0，邀請 1 位好友完成任務可再獲得 1 次抽獎機會。</p>'
      }

      <div class="liff-invite-box">
      <h2 class="liff-title">邀請好友加碼</h2>
      <p class="muted">每位好友完成加入 OpenRice LINE@ 可加碼 1 次，最多 2 次，剩餘可加碼 <strong>${Math.max(0, 2 - (typeof rewardedInviteCount !== 'undefined' ? rewardedInviteCount : 0))}</strong> 次。</p>
      <code class="invite-link invite-link-compact" id="liff-invite-link" title="${inviteLink || ''}">${inviteLink || ''}</code>
      <div class="actions">
        <button type="button" class="btn primary" id="share-invite-btn">分享邀請給好友</button>
        <button type="button" class="btn" id="copy-invite-btn">複製邀請連結</button>
        ${
          lineOfficialAddFriendUrl
            ? `<a class="btn" href="${lineOfficialAddFriendUrl}" target="_blank" rel="noopener noreferrer">加入 OpenRice LINE@</a>`
            : ''
        }
      </div>
      </div>
    </section>
    <script src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>
    <script>
      (function () {
        var btn = document.getElementById('share-invite-btn');
        var copyBtn = document.getElementById('copy-invite-btn');
        var linkEl = document.getElementById('liff-invite-link');
        var liffId = ${JSON.stringify(liffId || '')};
        if (!btn || !linkEl) return;

        async function shareViaLiff(inviteLink) {
          if (!liffId || typeof liff === 'undefined') return false;
          await liff.init({ liffId: liffId });
          if (!liff.isLoggedIn()) return false;
          if (!liff.isApiAvailable('shareTargetPicker')) return false;
          const text = 'OpenRice 訂餐廳能賺現金，現在還有抽獎活動，按下就知道有沒有抽中，大獎有 2 萬里程數！來試試手氣吧 👇\\n' + inviteLink;
          const result = await liff.shareTargetPicker([{ type: 'text', text: text }]);
          return result !== null;
        }

        function openLineShareFallback(inviteLink) {
          var text = 'OpenRice 訂餐廳能賺現金，現在還有抽獎活動，按下就知道有沒有抽中，大獎有 2 萬里程數！來試試手氣吧 👇\\n' + inviteLink;
          window.location.href = 'https://line.me/R/msg/text/?' + encodeURIComponent(text);
        }

        async function copyInviteLink(inviteLink) {
          if (!inviteLink) return false;
          if (navigator.clipboard && typeof navigator.clipboard.writeText === 'function') {
            await navigator.clipboard.writeText(inviteLink);
            return true;
          }
          return false;
        }

        btn.addEventListener('click', async function () {
          try {
            var inviteLink = (linkEl.textContent || '').trim();
            if (!inviteLink) return;
            var shared = await shareViaLiff(inviteLink);
            if (!shared) {
              openLineShareFallback(inviteLink);
              return;
            }
            btn.textContent = '已開啟分享';
            setTimeout(function () {
              btn.textContent = '分享邀請給好友';
            }, 1200);
          } catch (_err) {
            var inviteLink = (linkEl.textContent || '').trim();
            if (inviteLink) openLineShareFallback(inviteLink);
          }
        });

        if (copyBtn) {
          copyBtn.addEventListener('click', async function () {
            try {
              var inviteLink = (linkEl.textContent || '').trim();
              if (!inviteLink) return;
              var copied = await copyInviteLink(inviteLink);
              if (!copied) {
                window.prompt('請手動複製邀請連結', inviteLink);
                return;
              }
              copyBtn.textContent = '已複製';
              setTimeout(function () {
                copyBtn.textContent = '複製邀請連結';
              }, 1200);
            } catch (_err) {
              var inviteLink = (linkEl.textContent || '').trim();
              if (inviteLink) window.prompt('請手動複製邀請連結', inviteLink);
            }
          });
        }
      })();
    </script>
  `
  })
%>
