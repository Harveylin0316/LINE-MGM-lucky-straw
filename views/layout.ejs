<!DOCTYPE html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>OpenRice LINE CRM 後台</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="/style.css" />
    <style>
      .navgrp { position: relative; display: inline-block; }
      .navgrp-btn { cursor: pointer; border: 0; background: none; color: #d1d5db; font-family: inherit; font-size: 14px; font-weight: 500; padding: 6px 2px; display: inline-flex; align-items: center; gap: 5px; }
      .navgrp-btn:hover, .navgrp:hover .navgrp-btn, .navgrp:focus-within .navgrp-btn { color: #ffffff; }
      .navgrp-caret { font-size: 10px; opacity: .65; }
      .navgrp-menu { position: absolute; top: 100%; right: 0; margin-top: 8px; background: #fff; border: 1px solid #ECECEE; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,.14); min-width: 170px; padding: 6px; display: none; z-index: 100; }
      /* 透明橋接：填滿按鈕與選單間的空隙，滑鼠移過去 hover 不會中斷 */
      .navgrp-menu::before { content: ''; position: absolute; top: -12px; left: 0; right: 0; height: 12px; }
      .navgrp:hover .navgrp-menu, .navgrp:focus-within .navgrp-menu { display: block; }
      .navgrp.open .navgrp-menu { display: block; }
      .navgrp-menu a { display: block; padding: 10px 12px; border-radius: 8px; color: #374151; text-decoration: none; font-size: 14px; white-space: nowrap; }
      .navgrp-menu a:hover { background: #F9FAFB; }
      .navgrp-menu a.active { background: #FFFBEB; color: #1f2937; font-weight: 700; }
      .navgrp-btn.has-active { color: #FCC726; }

      /* 手機漢堡按鈕：桌機隱藏，窄螢幕才出現 */
      .nav-toggle { display: none; }
      .nav-toggle-btn { width: 40px; height: 36px; border: 0; background: none; cursor: pointer; padding: 8px; }
      .nav-toggle-btn .bar { display: block; width: 100%; height: 2px; background: #d1d5db; border-radius: 2px; transition: transform .2s, opacity .2s; }
      .nav-toggle-btn .bar + .bar { margin-top: 5px; }
      .nav-toggle-btn[aria-expanded="true"] .bar:nth-child(1) { transform: translateY(7px) rotate(45deg); }
      .nav-toggle-btn[aria-expanded="true"] .bar:nth-child(2) { opacity: 0; }
      .nav-toggle-btn[aria-expanded="true"] .bar:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

      @media (max-width: 640px) {
        .nav-toggle { display: inline-flex; align-items: center; }
        /* 窄螢幕：nav 預設收起，點漢堡才展開（直向堆疊） */
        .topbar-nav { display: none; width: 100%; flex-direction: column; align-items: stretch; gap: 4px; margin-top: 10px; }
        .topbar-nav.nav-open { display: flex; }
        .topbar-inner { flex-wrap: wrap; }
        .navgrp { display: block; }
        .navgrp-btn { width: 100%; justify-content: space-between; padding: 12px 4px; }
        /* 手機展開時下拉選單改為內嵌、不浮動，避免超出畫面 */
        .navgrp.open .navgrp-menu { position: static; margin-top: 0; box-shadow: none; border: 0; padding: 4px 0 4px 12px; min-width: 0; }
        .navgrp-menu::before { display: none; }
      }
    </style>
  </head>
  <body class="<%= typeof bodyClass === 'string' && bodyClass.trim() ? bodyClass.trim() : '' %>">
    <header class="topbar<%= typeof bodyClass === 'string' && String(bodyClass).includes('admin-shell') ? ' topbar--admin' : '' %>">
      <div class="container topbar-inner">
        <div class="brand">
          <% if (typeof isAdmin !== 'undefined' && isAdmin && user) { %>
          <a href="/admin" class="brand-link">OpenRice LINE CRM</a>
          <% } else { %>
          <span class="brand-text">OpenRice LINE CRM</span>
          <% } %>
        </div>
        <% if (user) { %>
        <div class="nav-toggle">
          <button type="button" class="nav-toggle-btn" id="nav-toggle-btn" aria-label="開關選單" aria-expanded="false" aria-controls="topbar-nav">
            <span class="bar"></span><span class="bar"></span><span class="bar"></span>
          </button>
        </div>
        <% } %>
        <nav class="topbar-nav" id="topbar-nav" aria-label="主選單">
          <% if (user) { %>
          <span class="welcome">嗨，<%= user %></span>
          <% if (isAdmin) { %>
          <div class="navgrp">
            <button type="button" class="nav-item navgrp-btn" aria-haspopup="true" aria-expanded="false">訊息 <span class="navgrp-caret">▾</span></button>
            <div class="navgrp-menu">
              <a href="/admin/broadcast">群發訊息</a>
              <a href="/admin/broadcast/history">發送紀錄</a>
              <a href="/admin/reports">成效報表</a>
              <a href="/admin/messages">訊息庫</a>
              <a href="/admin/flows">自動化流程</a>
              <a href="/admin/keyword-replies">關鍵字回覆</a>
            </div>
          </div>
          <div class="navgrp">
            <button type="button" class="nav-item navgrp-btn" aria-haspopup="true" aria-expanded="false">名單與用戶 <span class="navgrp-caret">▾</span></button>
            <div class="navgrp-menu">
              <a href="/admin/recipient-lists">名單庫</a>
              <a href="/admin/users">用戶檔案</a>
              <a href="/admin/restaurants">餐廳目錄</a>
              <a href="/admin/rfm">會員分級分析</a>
            </div>
          </div>
          <div class="navgrp">
            <button type="button" class="nav-item navgrp-btn" aria-haspopup="true" aria-expanded="false">活動 <span class="navgrp-caret">▾</span></button>
            <div class="navgrp-menu">
              <a href="/admin/activities">活動管理</a>
              <a href="/admin/referrals">邀請成效</a>
              <a href="/admin/campaigns/spring">春日饗里活動</a>
              <a href="/admin/liff/random-rice">活動頁面數據</a>
            </div>
          </div>
          <% } %>
          <form action="/logout" method="post" class="inline-form topbar-logout">
            <button type="submit">登出</button>
          </form>
          <% } else { %>
          <a class="topbar-guest-hint" href="<%= typeof loginAction === 'string' && loginAction ? loginAction : '/admin/login' %>">內部員工請由此登入</a>
          <% } %>
        </nav>
      </div>
    </header>
    <main class="container">
      <%- body %>
    </main>
    <script>
      (function () {
        var p = location.pathname;
        document.querySelectorAll('.navgrp').forEach(function (g) {
          var btn = g.querySelector('.navgrp-btn');
          var has = false;
          g.querySelectorAll('.navgrp-menu a').forEach(function (a) {
            var h = a.getAttribute('href');
            if (h && (p === h || p.indexOf(h + '/') === 0)) { a.classList.add('active'); has = true; }
          });
          if (has && btn) btn.classList.add('has-active');
        });

        // 點擊開合（觸控/手機友善）：點按鈕 toggle、一次只開一個；點外面或 Esc 關閉。桌機 hover 仍可用。
        var groups = document.querySelectorAll('.navgrp');
        function closeAll(except) {
          groups.forEach(function (g) {
            if (g === except) return;
            g.classList.remove('open');
            var b = g.querySelector('.navgrp-btn');
            if (b) b.setAttribute('aria-expanded', 'false');
          });
        }
        groups.forEach(function (g) {
          var btn = g.querySelector('.navgrp-btn');
          if (!btn) return;
          btn.addEventListener('click', function (e) {
            e.stopPropagation();
            var willOpen = !g.classList.contains('open');
            closeAll(g);
            g.classList.toggle('open', willOpen);
            btn.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
          });
        });
        document.addEventListener('click', function () { closeAll(null); });
        document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeAll(null); });

        // 手機漢堡：點按鈕開關整個 nav（桌機 CSS 不顯示此按鈕，行為不受影響）
        var navToggle = document.getElementById('nav-toggle-btn');
        var topbarNav = document.getElementById('topbar-nav');
        if (navToggle && topbarNav) {
          navToggle.addEventListener('click', function (e) {
            e.stopPropagation();
            var willOpen = !topbarNav.classList.contains('nav-open');
            topbarNav.classList.toggle('nav-open', willOpen);
            navToggle.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
            if (!willOpen) closeAll(null);
          });
        }
      })();
    </script>
  </body>
</html>

