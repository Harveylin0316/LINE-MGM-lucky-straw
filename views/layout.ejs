<!DOCTYPE html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>OpenRice LINE CRM 後台</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body class="<%= typeof bodyClass === 'string' && bodyClass.trim() ? bodyClass.trim() : '' %>">
    <header class="topbar<%= typeof bodyClass === 'string' && String(bodyClass).includes('admin-shell') ? ' topbar--admin' : '' %>">
      <div class="container topbar-inner">
        <div class="brand">
          <% if (typeof isAdmin !== 'undefined' && isAdmin && user) { %>
          <a href="/admin/broadcast" class="brand-link">OpenRice LINE CRM</a>
          <% } else { %>
          <span class="brand-text">OpenRice LINE CRM</span>
          <% } %>
        </div>
        <nav class="topbar-nav" aria-label="主選單">
          <% if (user) { %>
          <span class="welcome">嗨，<%= user %></span>
          <% if (isAdmin) { %>
          <a href="/admin/broadcast" class="nav-item">群發訊息</a>
          <a href="/admin/messages" class="nav-item">訊息庫</a>
          <a href="/admin/flows" class="nav-item">自動化流程</a>
          <a href="/admin/recipient-lists" class="nav-item">名單庫</a>
          <a href="/admin/users" class="nav-item">用戶檔案</a>
          <a href="/admin/rfm" class="nav-item">RFM 資料層</a>
          <a href="/admin/referrals" class="nav-item">邀請成效</a>
          <a href="/admin/activities" class="nav-item">活動管理</a>
          <a href="/admin/liff/random-rice" class="nav-item">LIFF 數據分析</a>
          <a href="/admin/campaigns/spring" class="nav-item">春日饗里活動</a>
          <% } %>
          <form action="/logout" method="post" class="inline-form topbar-logout">
            <button type="submit">登出</button>
          </form>
          <% } else { %>
          <span class="topbar-guest-hint">管理入口為內部專用</span>
          <% } %>
        </nav>
      </div>
    </header>
    <main class="container">
      <%- body %>
    </main>
  </body>
</html>

