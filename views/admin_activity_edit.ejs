<%-
  include('layout', {
    user: user,
    isAdmin: isAdmin,
    bodyClass: bodyClass,
    body: `
    <section class="card">
      <div class="ae-head">
        <a href="/admin/activities" class="ae-back">← 回列表</a>
        <h1 id="ae-title">${activityId ? '編輯活動' : '新增活動'}</h1>
        <div id="ae-status" class="muted" style="font-size:12px;"></div>
      </div>

      <h2>1. 基本資訊</h2>
      <div class="ae-grid">
        <label class="ae-field">
          <span>活動名稱 *</span>
          <input type="text" id="ae-name" placeholder="例：夏日大轉盤" />
        </label>
        <label class="ae-field">
          <span>slug *（網址用，只接受英數字與 -）</span>
          <input type="text" id="ae-slug" placeholder="summer-wheel" />
        </label>
        <label class="ae-field">
          <span>遊戲類型</span>
          <select id="ae-game-type">
            ${gameTypes.map(t => `<option value="${t}">${({wheel:'輪盤抽獎',fortune:'每日抽籤',scratch:'刮刮樂'})[t] || t}</option>`).join('')}
          </select>
        </label>
        <label class="ae-field">
          <span>狀態</span>
          <select id="ae-status-select">
            ${statuses.map(s => `<option value="${s}">${({draft:'草稿',active:'進行中',paused:'暫停',ended:'已結束'})[s] || s}</option>`).join('')}
          </select>
        </label>
        <label class="ae-field">
          <span>開始時間</span>
          <input type="datetime-local" id="ae-start" />
        </label>
        <label class="ae-field">
          <span>結束時間</span>
          <input type="datetime-local" id="ae-end" />
        </label>
        <label class="ae-field">
          <span>每用戶每天可玩次數（空白 = 無限）</span>
          <input type="number" id="ae-daily-limit" min="0" placeholder="1" />
        </label>
        <label class="ae-field">
          <span>每用戶基礎可玩次數 *</span>
          <input type="number" id="ae-base-plays" min="1" value="1" />
        </label>
        <label class="ae-field">
          <span>每邀請 1 人 +N 次（0 = 關閉邀請）</span>
          <input type="number" id="ae-ref-per" min="0" value="0" />
        </label>
        <label class="ae-field">
          <span>透過邀請最多可加幾次（cap）</span>
          <input type="number" id="ae-ref-max" min="0" value="0" />
        </label>
        <label class="ae-field">
          <span>封面圖 URL（可選）</span>
          <input type="text" id="ae-cover" placeholder="https://..." />
        </label>
        <label class="ae-field ae-field-full">
          <span>活動說明</span>
          <textarea id="ae-desc" rows="3" placeholder="顯示給用戶看的活動介紹"></textarea>
        </label>
        <label class="ae-field ae-field-full">
          <input type="checkbox" id="ae-require-follow" /> 需先加入 LINE OA 好友才能玩
        </label>
        <label class="ae-field ae-field-full">
          <span>自訂 LIFF ID（進階，留空 = 用預設的 GAMES_LIFF_ID）</span>
          <input type="text" id="ae-liff-override" placeholder="例：1234567890-abcDEF12（特殊拉新活動才需要）" />
          <span class="muted" style="font-size:11px;font-weight:400;">99% 活動留空就好。需要 Aggressive 加好友等特殊設定時才填獨立 LIFF ID。</span>
        </label>
      </div>

      <div class="ae-actions">
        <button type="button" class="ae-primary-btn" id="ae-save">${activityId ? '更新' : '儲存並繼續設定獎品'}</button>
        <span class="muted" style="margin-left:12px;font-size:12px;" id="ae-save-status"></span>
      </div>
    </section>

    ${activityId ? `
    <section class="card" id="ae-prizes-section">
      <div class="ae-head" style="margin-bottom:8px;">
        <h2 style="margin:0;">2. 獎品池</h2>
        <button type="button" class="ae-secondary-btn" id="ae-add-prize">＋ 新增獎品</button>
      </div>
      <p class="muted" style="font-size:12px;">輪盤照「位置」排序顯示。「概率權重」是相對值（不需總和=100），系統自動算百分比。「庫存」為空 = 無限。</p>
      <div class="table-wrap">
        <table class="ae-prize-table">
          <thead>
            <tr>
              <th>位置</th>
              <th>獎品名稱</th>
              <th>類型</th>
              <th style="text-align:right;">權重</th>
              <th style="text-align:right;">機率</th>
              <th style="text-align:right;">庫存</th>
              <th>大獎</th>
              <th></th>
            </tr>
          </thead>
          <tbody id="ae-prize-tbody">
            <tr><td colspan="8" class="muted" style="text-align:center;padding:18px 0;">載入中…</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="card">
      <h2>3. 活動連結</h2>

      <div class="ae-link-title">給用戶用（LIFF 分享短網址）</div>
      <p class="muted" style="font-size:12px;margin:4px 0 8px;">
        把這個貼到 LINE OA 圖文選單、推播訊息或 QR Code。用戶在 LINE 內點開會自動 login 進活動頁。
      </p>
      <div class="ae-link-box">
        <code id="ae-liff-share-url">—</code>
        <button type="button" class="ae-secondary-btn" id="ae-copy-liff">複製</button>
      </div>

      <div class="ae-link-title" style="margin-top:16px;">桌機預覽用（直連）</div>
      <p class="muted" style="font-size:12px;margin:4px 0 8px;">
        在電腦瀏覽器看 UI，<strong>不能真抽</strong>（避免汙染資料）。
      </p>
      <div class="ae-link-box">
        <code id="ae-direct-url">—</code>
        <button type="button" class="ae-secondary-btn" id="ae-copy-direct">複製</button>
        <a href="#" target="_blank" rel="noopener" id="ae-preview-link" class="ae-secondary-btn">在新視窗開啟</a>
      </div>
    </section>
    ` : `
    <section class="card" style="background:#f9fafb;text-align:center;padding:32px 16px;">
      <div class="muted">儲存基本資訊後，會進入獎品池編輯</div>
    </section>
    `}

    <!-- 獎品編輯 modal -->
    <div id="prize-modal" class="ae-modal" hidden>
      <div class="ae-modal-inner">
        <div class="ae-modal-head">
          <h3 id="prize-modal-title">新增獎品</h3>
          <button type="button" class="ae-modal-close" id="prize-modal-close">×</button>
        </div>
        <div class="ae-grid">
          <label class="ae-field ae-field-full">
            <span>獎品名稱 *</span>
            <input type="text" id="pm-name" placeholder="例：Rice Dollar $100" />
          </label>
          <label class="ae-field">
            <span>獎品類型</span>
            <select id="pm-type">
              <option value="rice_dollar">Rice Dollar</option>
              <option value="coupon_code">優惠券碼</option>
              <option value="badge">徽章 / 虛擬</option>
              <option value="physical">實體獎品</option>
              <option value="none">銘謝惠顧</option>
            </select>
          </label>
          <label class="ae-field">
            <span>位置（輪盤順序）</span>
            <input type="number" id="pm-position" min="0" value="0" />
          </label>
          <label class="ae-field">
            <span>概率權重</span>
            <input type="number" id="pm-weight" min="0" step="0.01" value="1" />
          </label>
          <label class="ae-field">
            <span>庫存（空白 = 無限）</span>
            <input type="number" id="pm-stock" min="0" placeholder="" />
          </label>
          <label class="ae-field">
            <span>圖片 URL（輪盤格子用，可選）</span>
            <input type="text" id="pm-image" placeholder="https://..." />
          </label>
          <label class="ae-field ae-field-full">
            <span>獎品說明（兌換方式等）</span>
            <textarea id="pm-desc" rows="2"></textarea>
          </label>
          <label class="ae-field ae-field-full" id="pm-value-field">
            <span id="pm-value-label">獎勵金額 / 內容</span>
            <input type="text" id="pm-value" placeholder="100" />
          </label>
          <label class="ae-field ae-field-full">
            <input type="checkbox" id="pm-grand" /> 標記為大獎（UI 動畫加強）
          </label>
        </div>
        <div class="ae-actions">
          <button type="button" class="ae-primary-btn" id="pm-save">儲存獎品</button>
          <button type="button" class="ae-secondary-btn" id="pm-cancel">取消</button>
        </div>
      </div>
    </div>

    <script>
    (function () {
      var $ = function (id) { return document.getElementById(id); };
      var $$ = function (sel, ctx) { return Array.from((ctx || document).querySelectorAll(sel)); };
      var activityId = ${activityId || 'null'};
      var currentActivity = null;
      var currentPrizes = [];
      var editingPrizeId = null;
      var effectiveLiffId = '';

      function escapeHtml(s) {
        return String(s == null ? '' : s)
          .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;').replace(/'/g, '&#039;');
      }
      function toLocalDt(ts) {
        if (!ts) return '';
        var d = new Date(ts);
        if (isNaN(d.getTime())) return '';
        var pad = function (n) { return String(n).padStart(2, '0'); };
        return d.getFullYear() + '-' + pad(d.getMonth() + 1) + '-' + pad(d.getDate()) +
               'T' + pad(d.getHours()) + ':' + pad(d.getMinutes());
      }
      function fromLocalDt(v) {
        if (!v) return null;
        var d = new Date(v);
        return isNaN(d.getTime()) ? null : d.toISOString();
      }

      function collectActivityForm() {
        return {
          slug: $('ae-slug').value.trim(),
          name: $('ae-name').value.trim(),
          description: $('ae-desc').value.trim(),
          game_type: $('ae-game-type').value,
          status: $('ae-status-select').value,
          start_at: fromLocalDt($('ae-start').value),
          end_at: fromLocalDt($('ae-end').value),
          cover_image_url: $('ae-cover').value.trim() || null,
          daily_plays_per_user: $('ae-daily-limit').value ? Number($('ae-daily-limit').value) : null,
          require_follow_oa: $('ae-require-follow').checked,
          liff_id_override: $('ae-liff-override').value.trim() || null,
          base_plays_per_user: Number($('ae-base-plays').value || 1),
          referral_bonus_per: Number($('ae-ref-per').value || 0),
          referral_bonus_max: Number($('ae-ref-max').value || 0),
          rules: {}
        };
      }

      function fillActivityForm(a) {
        $('ae-slug').value = a.slug || '';
        $('ae-name').value = a.name || '';
        $('ae-desc').value = a.description || '';
        $('ae-game-type').value = a.game_type || 'wheel';
        $('ae-status-select').value = a.status || 'draft';
        $('ae-start').value = toLocalDt(a.start_at);
        $('ae-end').value = toLocalDt(a.end_at);
        $('ae-cover').value = a.cover_image_url || '';
        $('ae-daily-limit').value = a.daily_plays_per_user || '';
        $('ae-require-follow').checked = Boolean(a.require_follow_oa);
        $('ae-liff-override').value = a.liff_id_override || '';
        $('ae-base-plays').value = a.base_plays_per_user != null ? a.base_plays_per_user : 1;
        $('ae-ref-per').value = a.referral_bonus_per != null ? a.referral_bonus_per : 0;
        $('ae-ref-max').value = a.referral_bonus_max != null ? a.referral_bonus_max : 0;
      }

      function loadActivity() {
        if (!activityId) return Promise.resolve();
        return fetch('/admin/activities/api/' + activityId)
          .then(function (r) { return r.json(); })
          .then(function (resp) {
            if (!resp.ok) { alert('載入失敗'); return; }
            currentActivity = resp.activity;
            currentPrizes = resp.prizes || [];
            effectiveLiffId = resp.effective_liff_id || '';
            fillActivityForm(resp.activity);
            renderPrizes();
            updateLiffLink();
          });
      }

      function updateLiffLink() {
        if (!currentActivity) return;
        var directUrl = location.origin + '/games/wheel/' + encodeURIComponent(currentActivity.slug);
        // LIFF 短網址：用 effective LIFF ID + 子路徑（LIFF SDK 會 append 到 Endpoint URL）
        var liffShareUrl = effectiveLiffId
          ? 'https://liff.line.me/' + effectiveLiffId + '/wheel/' + encodeURIComponent(currentActivity.slug)
          : '（尚未設定 GAMES_LIFF_ID 環境變數，或活動未設 liff_id_override）';
        var liffEl = $('ae-liff-share-url');
        var directEl = $('ae-direct-url');
        var prev = $('ae-preview-link');
        if (liffEl) liffEl.textContent = liffShareUrl;
        if (directEl) directEl.textContent = directUrl;
        if (prev) prev.href = directUrl + '?preview=1';
      }

      // ---- save activity ----
      $('ae-save').addEventListener('click', function () {
        var data = collectActivityForm();
        var statusEl = $('ae-save-status');
        statusEl.textContent = '儲存中…';
        var url = activityId ? '/admin/activities/api/' + activityId : '/admin/activities/api';
        var method = activityId ? 'PUT' : 'POST';
        fetch(url, {
          method: method,
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        })
          .then(function (r) { return r.json(); })
          .then(function (resp) {
            if (!resp.ok) {
              statusEl.textContent = '失敗：' + (resp.detail || resp.error);
              return;
            }
            statusEl.textContent = '已儲存 ' + new Date().toLocaleTimeString();
            if (!activityId) {
              // 新建後跳到編輯頁
              location.href = '/admin/activities/' + resp.activity.id;
            } else {
              currentActivity = resp.activity;
              updateLiffLink();
            }
          })
          .catch(function (e) { statusEl.textContent = '錯誤：' + e.message; });
      });

      // ---- copy link helpers ----
      function bindCopyBtn(btnId, sourceElId) {
        var btn = $(btnId);
        if (!btn) return;
        btn.addEventListener('click', function () {
          var t = $(sourceElId).textContent;
          if (!t || t.startsWith('（')) return;
          navigator.clipboard.writeText(t).then(function () {
            var orig = btn.textContent;
            btn.textContent = '已複製';
            setTimeout(function () { btn.textContent = orig; }, 1200);
          }).catch(function () { alert(t); });
        });
      }
      bindCopyBtn('ae-copy-liff', 'ae-liff-share-url');
      bindCopyBtn('ae-copy-direct', 'ae-direct-url');

      // ---- prizes ----
      function renderPrizes() {
        var tbody = $('ae-prize-tbody');
        if (!tbody) return;
        if (!currentPrizes.length) {
          tbody.innerHTML = '<tr><td colspan="8" class="muted" style="text-align:center;padding:24px 0;">尚無獎品，點右上「＋ 新增獎品」加第一個</td></tr>';
          return;
        }
        var totalWeight = currentPrizes.reduce(function (sum, p) { return sum + Number(p.probability_weight || 0); }, 0);
        tbody.innerHTML = currentPrizes.map(function (p) {
          var pct = totalWeight > 0 ? (Number(p.probability_weight || 0) / totalWeight * 100).toFixed(2) + '%' : '—';
          var stock = (p.stock_total == null)
            ? '<span class="muted">∞</span>'
            : (p.stock_remaining + ' / ' + p.stock_total);
          var typeLabel = ({rice_dollar:'Rice Dollar',coupon_code:'優惠券',badge:'虛擬',physical:'實體',none:'謝謝惠顧'})[p.prize_type] || p.prize_type;
          return '<tr>' +
            '<td>' + p.position + '</td>' +
            '<td><div style="font-weight:600;">' + escapeHtml(p.name) + '</div>' +
              (p.description ? '<div class="muted" style="font-size:11px;">' + escapeHtml(p.description) + '</div>' : '') +
            '</td>' +
            '<td>' + typeLabel + '</td>' +
            '<td style="text-align:right;">' + p.probability_weight + '</td>' +
            '<td style="text-align:right;font-weight:600;">' + pct + '</td>' +
            '<td style="text-align:right;">' + stock + '</td>' +
            '<td>' + (p.is_grand_prize ? '<span class="ae-grand-badge">大獎</span>' : '—') + '</td>' +
            '<td>' +
              '<button type="button" class="ae-link-btn ae-edit-prize" data-id="' + p.id + '">編輯</button>' +
              '<button type="button" class="ae-link-btn ae-del-prize" data-id="' + p.id + '" data-name="' + escapeHtml(p.name) + '">刪</button>' +
            '</td>' +
          '</tr>';
        }).join('');

        $$('.ae-edit-prize', tbody).forEach(function (btn) {
          btn.addEventListener('click', function () { openPrizeModal(Number(btn.getAttribute('data-id'))); });
        });
        $$('.ae-del-prize', tbody).forEach(function (btn) {
          btn.addEventListener('click', function () {
            var id = btn.getAttribute('data-id');
            var name = btn.getAttribute('data-name');
            if (!confirm('刪除獎品「' + name + '」？')) return;
            fetch('/admin/activities/api/prizes/' + id, { method: 'DELETE' })
              .then(function (r) { return r.json(); })
              .then(function (d) {
                if (!d.ok) { alert('刪除失敗'); return; }
                loadActivity();
              });
          });
        });
      }

      function openPrizeModal(prizeId) {
        editingPrizeId = prizeId || null;
        $('prize-modal-title').textContent = editingPrizeId ? '編輯獎品' : '新增獎品';
        if (editingPrizeId) {
          var p = currentPrizes.find(function (x) { return x.id === editingPrizeId; });
          if (!p) return;
          $('pm-name').value = p.name || '';
          $('pm-type').value = p.prize_type || 'badge';
          $('pm-position').value = p.position || 0;
          $('pm-weight').value = p.probability_weight || 1;
          $('pm-stock').value = p.stock_total == null ? '' : p.stock_total;
          $('pm-image').value = p.image_url || '';
          $('pm-desc').value = p.description || '';
          $('pm-grand').checked = Boolean(p.is_grand_prize);
          var v = p.prize_value || {};
          $('pm-value').value = v.amount || v.code || v.note || '';
        } else {
          $('pm-name').value = '';
          $('pm-type').value = 'badge';
          $('pm-position').value = currentPrizes.length;
          $('pm-weight').value = 1;
          $('pm-stock').value = '';
          $('pm-image').value = '';
          $('pm-desc').value = '';
          $('pm-grand').checked = false;
          $('pm-value').value = '';
        }
        updatePrizeValueLabel();
        $('prize-modal').hidden = false;
      }
      function closePrizeModal() {
        $('prize-modal').hidden = true;
        editingPrizeId = null;
      }
      function updatePrizeValueLabel() {
        var t = $('pm-type').value;
        var labelMap = {
          rice_dollar: 'Rice Dollar 金額',
          coupon_code: '優惠券代碼（例：SUMMER2026）',
          badge: '徽章 / 顯示文字',
          physical: '備註（給後台兌獎用）',
          none: '不需填寫'
        };
        $('pm-value-label').textContent = labelMap[t] || '獎勵內容';
        $('pm-value').disabled = (t === 'none');
        $('pm-value').placeholder = labelMap[t] === '不需填寫' ? '—' : (labelMap[t] || '');
      }

      var addBtn = $('ae-add-prize');
      if (addBtn) addBtn.addEventListener('click', function () { openPrizeModal(null); });
      $('prize-modal-close').addEventListener('click', closePrizeModal);
      $('pm-cancel').addEventListener('click', closePrizeModal);
      $('pm-type').addEventListener('change', updatePrizeValueLabel);

      $('pm-save').addEventListener('click', function () {
        var pt = $('pm-type').value;
        var valStr = $('pm-value').value.trim();
        var prizeValue = {};
        if (pt === 'rice_dollar' && valStr) prizeValue.amount = Number(valStr);
        else if (pt === 'coupon_code' && valStr) prizeValue.code = valStr;
        else if (pt === 'badge' && valStr) prizeValue.label = valStr;
        else if (pt === 'physical' && valStr) prizeValue.note = valStr;

        var data = {
          name: $('pm-name').value.trim(),
          description: $('pm-desc').value.trim(),
          image_url: $('pm-image').value.trim() || null,
          probability_weight: Number($('pm-weight').value || 0),
          stock_total: $('pm-stock').value ? Number($('pm-stock').value) : null,
          prize_type: pt,
          prize_value: prizeValue,
          position: Number($('pm-position').value || 0),
          is_grand_prize: $('pm-grand').checked
        };
        var url = editingPrizeId
          ? '/admin/activities/api/prizes/' + editingPrizeId
          : '/admin/activities/api/' + activityId + '/prizes';
        var method = editingPrizeId ? 'PUT' : 'POST';
        fetch(url, {
          method: method,
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        })
          .then(function (r) { return r.json(); })
          .then(function (d) {
            if (!d.ok) { alert('儲存失敗：' + (d.detail || d.error)); return; }
            closePrizeModal();
            loadActivity();
          });
      });

      // bootstrap
      loadActivity();
    })();
    </script>

    <style>
      .ae-head {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 12px;
        flex-wrap: wrap;
      }
      .ae-head h1, .ae-head h2 { margin: 0; }
      .ae-back {
        text-decoration: none;
        color: #6b7280;
        font-size: 13px;
      }
      .ae-back:hover { color: #1f2937; }

      .ae-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 12px;
      }
      .ae-field { display: flex; flex-direction: column; gap: 4px; font-size: 13px; }
      .ae-field span { color: #6b7280; font-size: 12px; }
      .ae-field input[type="text"],
      .ae-field input[type="number"],
      .ae-field input[type="datetime-local"],
      .ae-field select,
      .ae-field textarea {
        padding: 8px 10px;
        border: 1px solid #e5e7eb;
        border-radius: 6px;
        font-size: 13px;
      }
      .ae-field-full { grid-column: 1 / -1; }

      .ae-actions {
        margin-top: 14px;
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
      }
      .ae-primary-btn {
        padding: 9px 16px;
        background: #FCC726;
        color: #1f2937;
        font-weight: 600;
        border-radius: 6px;
        border: none;
        cursor: pointer;
        font-size: 13px;
      }
      .ae-primary-btn:hover { background: #f5b800; }
      .ae-secondary-btn {
        padding: 8px 12px;
        background: #fff;
        color: #374151;
        border: 1px solid #e5e7eb;
        border-radius: 6px;
        cursor: pointer;
        font-size: 12px;
        text-decoration: none;
      }
      .ae-secondary-btn:hover { background: #f9fafb; border-color: #d1d5db; }

      .ae-prize-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
      }
      .ae-prize-table th, .ae-prize-table td {
        padding: 8px 12px;
        border-bottom: 1px solid #f3f4f6;
        vertical-align: middle;
      }
      .ae-prize-table th {
        background: #fafafa;
        text-align: left;
        font-size: 12px;
        color: #6b7280;
        font-weight: 600;
      }
      .ae-link-btn {
        padding: 3px 8px;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 4px;
        font-size: 11px;
        cursor: pointer;
        color: #374151;
        margin-right: 4px;
      }
      .ae-link-btn:hover { background: #fffbeb; border-color: #FCC726; }
      .ae-del-prize { color: #dc2626; }
      .ae-grand-badge {
        background: #FCC726;
        color: #1f2937;
        padding: 2px 8px;
        border-radius: 4px;
        font-size: 11px;
        font-weight: 600;
      }

      .ae-link-title {
        font-weight: 600;
        font-size: 13px;
        color: #1f2937;
        margin-top: 4px;
      }
      .ae-link-box {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 12px;
        background: #f9fafb;
        border-radius: 6px;
        font-family: ui-monospace, Menlo, monospace;
        font-size: 12px;
        flex-wrap: wrap;
      }
      .ae-link-box code { color: #1f2937; flex: 1; word-break: break-all; min-width: 0; }

      .ae-modal {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 100;
        padding: 16px;
      }
      .ae-modal[hidden] { display: none !important; }
      .ae-modal-inner {
        background: #fff;
        border-radius: 12px;
        max-width: 640px;
        width: 100%;
        max-height: 90vh;
        overflow-y: auto;
        padding: 20px;
      }
      .ae-modal-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
      .ae-modal-head h3 { margin: 0; }
      .ae-modal-close {
        background: none;
        border: none;
        font-size: 24px;
        cursor: pointer;
        color: #6b7280;
        line-height: 1;
      }

      .table-wrap { overflow-x: auto; }
    </style>
    `
  })
