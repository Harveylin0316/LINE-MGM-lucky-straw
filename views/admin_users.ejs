<%-
  include('layout', {
    user: user,
    isAdmin: isAdmin,
    bodyClass: bodyClass,
    body: `
    <section class="card us-hero">
      <div>
        <h1>用戶檔案</h1>
        <p class="muted" style="margin-top:6px;">看單一用戶在系統內的所有行為：加入/封鎖、玩遊戲、邀請、點擊、口味偏好、傳訊息、時間軸。</p>
      </div>
      <input type="search" id="us-search" placeholder="搜尋名字或 LINE 編號…" />
    </section>

    <div class="us-grid">
      <section class="card us-list-card">
        <div id="us-list"><p class="muted">載入中…</p></div>
        <div id="us-more-wrap" style="margin-top:10px;display:none;">
          <button type="button" id="us-more-btn" class="us-more-btn">載入更多</button>
        </div>
      </section>
      <section class="card us-profile-card">
        <div id="us-profile"><p class="muted">← 從左邊點一個用戶看完整檔案</p></div>
      </section>
    </div>

    <style>
      .us-hero{display:flex;align-items:flex-start;justify-content:space-between;gap:16px;flex-wrap:wrap;}
      .us-hero input{padding:8px 12px;border:1px solid #e5e7eb;border-radius:8px;font-size:14px;min-width:220px;}
      .us-grid{display:grid;grid-template-columns:320px 1fr;gap:16px;align-items:start;}
      @media(max-width:820px){.us-grid{grid-template-columns:1fr;}}
      .us-row{display:flex;align-items:center;gap:10px;padding:9px 10px;border-radius:8px;cursor:pointer;border:1px solid transparent;}
      .us-row:hover{background:#f9fafb;border-color:#e5e7eb;}
      .us-row.active{background:#FFFBEB;border-color:#FCC726;}
      .us-row .av{width:34px;height:34px;border-radius:50%;background:#f3f4f6;display:flex;align-items:center;justify-content:center;font-size:13px;color:#6b7280;flex:0 0 auto;overflow:hidden;}
      .us-row .av img{width:100%;height:100%;object-fit:cover;}
      .us-row .nm{font-size:14px;color:#1f2937;}
      .us-row .sub{font-size:11px;color:#9ca3af;}
      .us-blocked{color:#b91c1c;font-size:11px;font-weight:700;}
      .us-more-btn{width:100%;padding:9px 12px;border:1px solid #e5e7eb;border-radius:8px;background:#fff;font-size:13px;color:#374151;cursor:pointer;}
      .us-more-btn:hover:not(:disabled){background:#f9fafb;border-color:#d1d5db;}
      .us-more-btn:disabled{color:#9ca3af;cursor:default;}
      .us-prof-head{display:flex;align-items:center;gap:14px;margin-bottom:16px;}
      .us-prof-head .av{width:56px;height:56px;border-radius:50%;background:#f3f4f6;overflow:hidden;display:flex;align-items:center;justify-content:center;color:#6b7280;}
      .us-prof-head .av img{width:100%;height:100%;object-fit:cover;}
      .us-prof-head h2{margin:0;font-size:20px;}
      .us-prof-head .meta{font-size:12px;color:#6b7280;margin-top:3px;}
      .us-stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(110px,1fr));gap:10px;margin:16px 0;}
      .us-stat{border:1px solid #e5e7eb;border-radius:10px;padding:12px;background:#fafafa;}
      .us-stat .v{font-size:22px;font-weight:700;color:#1f2937;font-variant-numeric:tabular-nums;}
      .us-stat .k{font-size:11px;color:#6b7280;margin-top:3px;}
      .us-sec-title{font-size:13px;font-weight:700;color:#1f2937;margin:18px 0 8px;}
      .us-chip{display:inline-block;background:#f3f4f6;border-radius:20px;padding:4px 11px;font-size:12px;color:#374151;margin:0 6px 6px 0;}
      .us-pref-chip{background:#FFFBEB;border:1px solid #FCC726;color:#1F2937;font-weight:600;}
      .us-lifecycle-chip{background:#FFFBEB;border:1px solid #FCC726;color:#1F2937;font-weight:600;margin:0;}
      .us-chip-tag{color:#9ca3af;font-size:11px;margin-left:4px;}
      .us-tl{border-left:2px solid #e5e7eb;padding-left:14px;margin-top:8px;}
      .us-tl-item{position:relative;padding:6px 0;font-size:13px;}
      .us-tl-item .k{font-weight:600;color:#1f2937;}
      .us-tl-item .l{color:#6b7280;}
      .us-tl-item .t{color:#9ca3af;font-size:11px;}
      .us-actions{border:1px solid #e5e7eb;border-radius:10px;padding:12px;background:#fafafa;margin-bottom:6px;}
      .us-act-row{display:flex;gap:8px;flex-wrap:wrap;align-items:center;}
      .us-act-select{flex:1 1 200px;min-width:160px;padding:8px 10px;border:1px solid #e5e7eb;border-radius:8px;font-size:13px;font-family:inherit;background:#fff;}
      .us-act-btn{padding:8px 16px;background:#FCC726;color:#1F2937;font-weight:600;border:none;border-radius:8px;cursor:pointer;font-size:13px;font-family:inherit;}
      .us-act-btn:hover:not(:disabled){background:#f5b800;}
      .us-act-btn:disabled{opacity:0.6;cursor:not-allowed;}
      .us-act-note{font-size:12px;color:#9ca3af;margin-top:6px;}
      .us-act-status{font-size:12px;color:#6b7280;min-height:16px;margin-top:6px;}
      .us-act-status.ok{color:#1F2937;}
      .us-act-status.err{color:#E11D27;}
    </style>

    <script>
      (function(){
        var $=function(id){return document.getElementById(id);};
        function esc(s){return String(s==null?'':s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
        function fmt(ts){if(!ts)return'';var d=new Date(ts);return isNaN(d.getTime())?'':d.toLocaleString('sv-SE',{timeZone:'Asia/Taipei'}).slice(0,16);}
        function shortUid(u){return u?(u.slice(0,7)+'…'+u.slice(-4)):'';}
        var KIND={follow:'加好友',unfollow:'封鎖了',message:'傳訊息給你',game_play:'玩了遊戲',restaurant_click:'點了餐廳',broadcast_click:'點了推播',liff:'今天吃什麼',invite_rewarded:'邀請成功'};
        // 生命週期階段 chip 文字（門檻與群發、沉睡喚醒口徑一致）
        function lifecycleChip(stage,days){
          var d=(days==null||isNaN(days))?null:Math.max(0,Math.floor(days));
          var label;
          if(stage==='new')label='新客';
          else if(stage==='active')label='活躍客';
          else if(stage==='sleeping')label='沉睡客';
          else if(stage==='lost')label='流失客';
          else return '';
          var detail;
          if(stage==='new')detail=(d!=null?('加入 '+d+' 天'):'剛加入');
          else detail=(d!=null?(d+' 天沒互動'):'近期有互動');
          return '<span class="us-chip us-lifecycle-chip">'+esc(label)+'（'+esc(detail)+'）</span>';
        }
        var curUid=null, timer=null;
        var PAGE=80, loaded=0, total=0, loading=false;

        function rowHtml(u){
          var nm=u.line_display_name||u.username||'（未命名）';
          var av=u.line_display_name?esc(nm.slice(0,1)):'?';
          return '<div class="us-row" data-uid="'+esc(u.line_user_id)+'"><div class="av">'+av+'</div>'+
            '<div><div class="nm">'+esc(nm)+(u.blocked_at?' <span class="us-blocked">已封鎖</span>':'')+'</div>'+
            '<div class="sub">'+esc(shortUid(u.line_user_id))+' · '+(fmt(u.created_at)||'—')+'</div></div></div>';
        }
        function bindRows(scope){
          scope.querySelectorAll('[data-uid]').forEach(function(el){
            if(el.getAttribute('data-bound'))return;
            el.setAttribute('data-bound','1');
            el.addEventListener('click',function(){openProfile(el.getAttribute('data-uid'));});
          });
        }
        function updateCount(){
          var c=$('us-count');if(c)c.textContent='顯示 '+loaded+' / 共 '+total+' 人';
        }
        function updateMore(){
          var wrap=$('us-more-wrap'),btn=$('us-more-btn');if(!wrap||!btn)return;
          if(total===0){wrap.style.display='none';return;}
          wrap.style.display='';
          if(loaded>=total){btn.disabled=true;btn.textContent='已全部載入（共 '+total+' 人）';}
          else{btn.disabled=false;btn.textContent='載入更多';}
        }

        // reset=true：搜尋或首次載入，offset 歸 0、清空列表；reset=false：載入更多，append
        function loadList(reset){
          if(loading)return;
          loading=true;
          var s=$('us-search').value.trim();
          var offset=reset?0:loaded;
          var btn=$('us-more-btn');
          if(!reset&&btn){btn.disabled=true;btn.textContent='載入中…';}
          fetch('/admin/users/api/list?limit='+PAGE+'&offset='+offset+'&search='+encodeURIComponent(s)).then(function(r){return r.json();}).then(function(d){
            loading=false;
            var box=$('us-list');
            if(!d.ok){if(reset)box.innerHTML='<p class="muted">載入失敗</p>';updateMore();return;}
            if(reset){
              loaded=0;
              total=d.total||0;
              if(!d.users.length){box.innerHTML='<p class="muted">沒有符合的用戶</p>';updateCount();updateMore();return;}
              box.innerHTML='<div class="muted" id="us-count" style="font-size:12px;margin-bottom:8px;"></div>'+
                '<div id="us-rows">'+d.users.map(rowHtml).join('')+'</div>';
            }else{
              total=d.total||total;
              var rows=$('us-rows');
              if(rows&&d.users.length){rows.insertAdjacentHTML('beforeend',d.users.map(rowHtml).join(''));}
            }
            loaded+=d.users.length;
            bindRows(box);
            updateCount();
            updateMore();
          }).catch(function(e){
            loading=false;
            var box=$('us-list');
            if(reset){if(box)box.innerHTML='<p class="muted">載入失敗，請重新整理</p>';}
            else{updateMore();}
          });
        }

        function openProfile(uid){
          curUid=uid;
          document.querySelectorAll('.us-row').forEach(function(r){r.classList.toggle('active',r.getAttribute('data-uid')===uid);});
          var box=$('us-profile');box.innerHTML='<p class="muted">載入中…</p>';
          fetch('/admin/users/api/profile/'+uid).then(function(r){return r.json();}).then(function(d){
            if(!d.ok){box.innerHTML='<p class="muted">載入失敗：'+esc(d.error||'')+'</p>';return;}
            var p=d.profile,c=d.counts;
            var nm=p.line_display_name||p.username||'（未命名）';
            var avatar=p.line_picture_url?'<img src="'+esc(p.line_picture_url)+'">':esc(nm.slice(0,1));
            var lcChip=lifecycleChip(p.lifecycle_stage,p.days_since_active);
            var h='<div class="us-prof-head"><div class="av">'+avatar+'</div><div>'+
              '<h2>'+esc(nm)+(p.blocked_at?' <span class="us-blocked">已封鎖</span>':'')+'</h2>'+
              '<div class="meta">'+esc(shortUid(p.line_user_id))+'</div>'+
              '<div class="meta">加入：'+(fmt(p.created_at)||'未知')+(p.blocked_at?(' · 封鎖：'+fmt(p.blocked_at)):'')+'</div>'+
              (lcChip?('<div style="margin-top:6px;">'+lcChip+'</div>'):'')+
              '</div></div>';

            // 快速動作：把這個用戶加進某個名單（不用跳頁）
            var canList = !!(p.line_user_id);
            h+='<div class="us-actions">'+
              '<div class="us-act-row">'+
                '<select id="us-list-select" class="us-act-select"'+(canList?'':' disabled')+'>'+
                  '<option value="">載入名單中…</option>'+
                '</select>'+
                '<button type="button" id="us-add-to-list" class="us-act-btn"'+(canList?'':' disabled')+'>加入名單</button>'+
              '</div>'+
              (canList?'':'<div class="us-act-note">此用戶沒有 LINE 編號，無法加入名單。</div>')+
              '<div id="us-act-status" class="us-act-status"></div>'+
            '</div>';
            h+='<div class="us-stats">'+
              stat(c.game_plays,'玩遊戲次數')+stat(c.prizes_won,'中獎次數')+stat(c.invites_rewarded,'成功邀請')+
              stat(c.broadcast_clicks,'點推播')+stat(c.restaurant_clicks,'點餐廳')+stat(c.inbound_messages,'傳訊息')+
              stat(c.liff_events,'今天吃什麼')+'</div>';
            if(d.rfm){
              var rf=d.rfm;
              h+='<div class="us-sec-title">消費紀錄（來自會員名單，已用 LINE 帳號自動比對）</div>'+
                '<div class="us-stats">'+
                  stat((rf.recency==null?'—':rf.recency),'距上次消費（天）')+
                  stat((rf.frequency==null?'—':rf.frequency),'歷史消費（次）')+
                  '<div class="us-stat"><div class="v">'+(rf.monetary_est==null?'—':Math.round(rf.monetary_est).toLocaleString())+'</div><div class="k">預估價位帶*</div></div>'+
                '</div>'+
                '<p class="muted" style="font-size:11px;margin-top:4px;">*M 為餐廳客單價推算的預估價位帶，非真實消費金額</p>';
            }
            if(d.interest&&d.interest.length){
              var pref=d.preference||{};
              var topCu=(pref.cuisine&&pref.cuisine.length)?pref.cuisine[0]:null;
              var topPb=(pref.price_band&&pref.price_band.length)?pref.price_band[0]:null;
              h+='<div class="us-sec-title">口味偏好</div>';
              if(topCu||topPb){
                h+='<div style="margin-bottom:8px;">'+
                  (topCu?'<span class="us-chip us-pref-chip">'+esc(topCu.k)+' '+topCu.n+' 次</span>':'')+
                  (topPb?'<span class="us-chip us-pref-chip">'+esc(topPb.k)+'</span>':'')+'</div>';
              }else{
                h+='<p class="muted" style="font-size:12px;margin:0 0 8px;">尚未能判斷偏好——到「<a href="/admin/restaurants">餐廳目錄</a>」幫餐廳標上種類與價位後，這裡會自動顯示</p>';
              }
              h+='<div>'+d.interest.map(function(i){
                var tag=(i.cuisine||i.price_band)?((i.cuisine||'—')+' · '+(i.price_band||'—')):'—';
                return '<span class="us-chip">'+esc(i.name)+' ×'+i.clicks+'<span class="us-chip-tag">'+esc(tag)+'</span></span>';
              }).join('')+'</div>';
            }
            if(d.lists&&d.lists.length){
              h+='<div class="us-sec-title">在這些名單裡</div><div>'+d.lists.map(function(l){return '<span class="us-chip">'+esc(l.name)+'</span>';}).join('')+'</div>';
            }
            h+='<div class="us-sec-title">行為時間軸</div>';
            if(!d.timeline||!d.timeline.length){h+='<p class="muted" style="font-size:13px;">尚無紀錄</p>';}
            else{h+='<div class="us-tl">'+d.timeline.map(function(t){
              return '<div class="us-tl-item"><span class="k">'+esc(KIND[t.kind]||t.kind)+'</span> <span class="l">'+esc((t.label||'').slice(0,60))+'</span><div class="t">'+fmt(t.at)+'</div></div>';
            }).join('')+'</div>';}
            box.innerHTML=h;
            if(p.line_user_id){bindProfileActions(p.line_user_id);}
          }).catch(function(e){var box=$('us-profile');if(box)box.innerHTML='<p class="muted">載入失敗：'+((e&&e.message)||e)+'</p>';});
        }
        function stat(v,k){return '<div class="us-stat"><div class="v">'+(v||0)+'</div><div class="k">'+k+'</div></div>';}

        // ---- 快速動作：加入名單 ----
        function bindProfileActions(uid){
          var sel=$('us-list-select');
          var btn=$('us-add-to-list');
          var status=$('us-act-status');
          if(!sel||!btn)return;
          // 載入名單清單（重用群發的名單 API）
          fetch('/admin/broadcast/recipient-lists').then(function(r){return r.json();}).then(function(d){
            if(!d.ok||!d.lists||!d.lists.length){
              sel.innerHTML='<option value="">尚無名單，請先到名單庫建立</option>';
              sel.disabled=true;btn.disabled=true;
              return;
            }
            sel.innerHTML='<option value="">選擇要加入的名單…</option>'+d.lists.map(function(l){
              return '<option value="'+l.id+'">'+esc(l.name)+'（'+(l.total||0)+' 人）</option>';
            }).join('');
          }).catch(function(){
            sel.innerHTML='<option value="">名單載入失敗</option>';
            sel.disabled=true;btn.disabled=true;
          });
          btn.addEventListener('click',function(){
            var listId=sel.value;
            if(!listId){status.textContent='請先選擇名單';status.className='us-act-status err';return;}
            btn.disabled=true;sel.disabled=true;
            status.textContent='加入中…';status.className='us-act-status';
            fetch('/admin/recipient-lists/api/'+listId+'/members',{
              method:'POST',
              headers:{'Content-Type':'application/json'},
              body:JSON.stringify({lineUserIds:[uid]})
            }).then(function(r){return r.json();}).then(function(d){
              btn.disabled=false;sel.disabled=false;
              if(!d.ok){status.textContent='加入失敗：'+(d.detail||d.error||'未知');status.className='us-act-status err';return;}
              var added=Number(d.inserted_uids||0);
              var existed=Number(d.already_existed_uids||0);
              if(added>0){status.textContent='已加入名單';status.className='us-act-status ok';}
              else if(existed>0){status.textContent='這個用戶本來就在名單裡了';status.className='us-act-status';}
              else{status.textContent='沒有變更';status.className='us-act-status';}
            }).catch(function(e){
              btn.disabled=false;sel.disabled=false;
              status.textContent='錯誤：'+((e&&e.message)||e);status.className='us-act-status err';
            });
          });
        }

        $('us-search').addEventListener('input',function(){clearTimeout(timer);timer=setTimeout(function(){loadList(true);},250);});
        var moreBtn=$('us-more-btn');
        if(moreBtn)moreBtn.addEventListener('click',function(){loadList(false);});
        loadList(true);
      })();
    </script>
    `
  })
%>
