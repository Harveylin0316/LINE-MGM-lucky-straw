<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#FFFBEB" />
  <title><%= title %></title>
  <script src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>
  <style>
    :root {
      --bg: #FAFAFA; --surface: #FFFFFF;
      --or-yellow: #FCC726; --or-yellow-d: #E8B400; --or-red: #E11D27;
      --ink: #0F0F10; --ink-2: #6B6B70; --ink-3: #A0A0A6;
      --border: #ECECEE;
    }
    * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
    html, body { margin: 0; padding: 0; }
    body { background: radial-gradient(420px 420px at 88% -80px, rgba(252, 199, 38, 0.20), transparent 70%), linear-gradient(180deg, #FFFBEB 0%, #FAFAFA 420px), var(--bg); color: var(--ink); min-height: 100vh; font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Inter", "PingFang TC", sans-serif; letter-spacing: -0.011em; -webkit-font-smoothing: antialiased; }
    .page { max-width: 480px; margin: 0 auto; padding: 16px 16px 56px; }

    .brand-bar { display: flex; align-items: center; justify-content: space-between; padding: 6px 0 16px; }
    .brand-bar .logo { display: inline-flex; align-items: center; gap: 7px; font-size: 13px; font-weight: 700; }
    .brand-bar .logo .dot { width: 18px; height: 18px; border-radius: 6px; background: var(--or-yellow); position: relative; }
    .brand-bar .logo .dot::after { content: ''; position: absolute; inset: 4px; border-radius: 50%; background: var(--ink); }
    .brand-bar .chip { display: inline-flex; align-items: center; gap: 5px; font-size: 11px; color: var(--ink-2); background: var(--surface); border: 1px solid var(--border); padding: 5px 10px; border-radius: 999px; font-weight: 500; }
    .brand-bar .chip::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: #22C55E; box-shadow: 0 0 0 2px rgba(34, 197, 94, 0.15); }

    .hero { background: var(--surface); border: 1px solid var(--border); border-radius: 20px; padding: 22px 22px 24px; position: relative; overflow: hidden; }
    .hero::before { content: ''; position: absolute; top: -40px; right: -40px; width: 180px; height: 180px; background: radial-gradient(circle, rgba(252, 199, 38, 0.18), transparent 70%); pointer-events: none; }
    .hero-tag { display: inline-flex; align-items: center; gap: 6px; font-size: 11px; font-weight: 600; letter-spacing: 0.06em; color: var(--or-red); text-transform: uppercase; margin-bottom: 14px; }
    .hero-tag::before { content: ''; width: 6px; height: 6px; background: var(--or-red); border-radius: 50%; }
    .hero h1 { margin: 0 0 8px; font-size: 26px; font-weight: 700; letter-spacing: -0.028em; line-height: 1.2; }
    .hero p { margin: 0; font-size: 14px; line-height: 1.55; color: var(--ink-2); }
    .hero-cover { width: calc(100% + 44px); margin: 18px -22px -24px; aspect-ratio: 16 / 9; object-fit: cover; display: block; border-top: 1px solid var(--border); }

    .stats { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; margin-top: 12px; }
    .stat { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; padding: 12px; }
    .stat .v { font-size: 20px; font-weight: 700; letter-spacing: -0.02em; line-height: 1; font-variant-numeric: tabular-nums; }
    .stat .v .unit { font-size: 11px; color: var(--ink-2); margin-left: 2px; font-weight: 500; }
    .stat .k { font-size: 11px; color: var(--ink-2); margin-top: 5px; font-weight: 500; }

    .invite-card { margin-top: 8px; background: linear-gradient(135deg, #FFD75A 0%, var(--or-yellow) 58%, #F2B900 100%); border-radius: 18px; padding: 16px 18px; display: flex; align-items: center; justify-content: space-between; gap: 12px; position: relative; overflow: hidden; color: var(--ink); box-shadow: 0 12px 28px -12px rgba(232, 180, 0, 0.6); }
    .invite-card::before { content: ''; position: absolute; top: -48px; right: -34px; width: 150px; height: 150px; border-radius: 50%; background: rgba(255, 255, 255, 0.3); }
    .invite-card::after { content: ''; position: absolute; bottom: -60px; left: -28px; width: 120px; height: 120px; border-radius: 50%; background: rgba(31, 41, 55, 0.08); }
    .invite-left { flex: 1; z-index: 1; }
    .invite-title { font-size: 15px; font-weight: 800; letter-spacing: -0.01em; }
    .invite-sub { font-size: 12px; color: rgba(31, 41, 55, 0.68); margin-top: 3px; font-weight: 500; }
    .invite-btn { flex-shrink: 0; background: var(--ink); color: var(--or-yellow); border: none; border-radius: 999px; padding: 10px 18px; font-family: inherit; font-weight: 700; font-size: 13px; cursor: pointer; z-index: 1; transition: transform 0.15s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.2s ease; box-shadow: 0 6px 14px -4px rgba(15, 15, 16, 0.45); display: inline-flex; align-items: center; }
    .invite-btn:hover { box-shadow: 0 8px 18px -4px rgba(15, 15, 16, 0.55); }
    .invite-btn:active { transform: scale(0.96); }
    .invite-card.maxed { opacity: 0.6; box-shadow: none; }
    .invite-card.maxed .invite-btn { background: var(--ink-3); color: #fff; cursor: default; pointer-events: none; box-shadow: none; }

    /* ========== Slot stage ========== */
    .stage-card { margin-top: 12px; background: var(--surface); border: 1px solid var(--border); border-radius: 24px; padding: 24px 20px 22px; position: relative; overflow: hidden; }
    .stage-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; }
    .stage-head .label { font-size: 11px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink-3); }
    .stage-head .count { font-size: 11px; color: var(--ink-2); font-weight: 500; }

    /* 三軸機台 */
    .slot-machine {
      background: linear-gradient(180deg, #2B2B33 0%, #17171B 52%, #0E0E10 100%);
      border-radius: 20px;
      padding: 18px 16px 20px;
      box-shadow:
        inset 0 0 0 3px var(--or-yellow),
        inset 0 0 0 5px rgba(0, 0, 0, 0.55),
        inset 0 18px 28px rgba(255, 255, 255, 0.05),
        0 24px 48px -16px rgba(15, 15, 16, 0.5),
        0 10px 18px -10px rgba(232, 180, 0, 0.35);
      position: relative;
      overflow: hidden;
    }
    .slot-machine::before, .slot-machine::after {
      content: '';
      position: absolute;
      top: 8px;
      width: 8px; height: 8px;
      border-radius: 50%;
      background: var(--or-red);
      box-shadow: 0 0 8px var(--or-red);
    }
    .slot-machine::before { left: 16px; }
    .slot-machine::after { right: 16px; }
    .slot-reels {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 8px;
      margin: 0 auto;
    }
    .slot-reel {
      background: #FFFFFF;
      border-radius: 12px;
      height: 110px;
      overflow: hidden;
      position: relative;
      box-shadow: inset 0 0 0 2px rgba(255,255,255,0.4);
    }
    /* 軸條：包含多個 symbol，垂直排列 */
    .slot-strip {
      position: absolute;
      left: 0; right: 0;
      transition: transform 0s linear;
      display: flex;
      flex-direction: column;
      will-change: transform, filter;
    }
    .slot-strip.spinning {
      transition: none;
    }
    /* 滾動中的 motion blur 殘影感 */
    .slot-strip.motion { filter: blur(1.6px); }
    /* 軸窗上下內陰影，加深機械感 */
    .slot-reel::after {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: 12px;
      pointer-events: none;
      background: linear-gradient(180deg, rgba(15, 15, 16, 0.2), transparent 24%, transparent 76%, rgba(15, 15, 16, 0.2));
    }
    .slot-symbol {
      height: 110px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 2px;
      flex-shrink: 0;
      font-weight: 800;
      color: var(--ink);
      padding: 6px;
      text-align: center;
      line-height: 1.1;
      letter-spacing: -0.01em;
    }
    .slot-symbol.grand { color: var(--or-red); }
    .slot-symbol img {
      width: 56px;
      height: 56px;
      object-fit: cover;
      border-radius: 8px;
      flex-shrink: 0;
    }
    .slot-symbol .num {
      font-size: 11px;
      font-weight: 700;
      color: rgba(15,15,16,0.45);
      font-variant-numeric: tabular-nums;
      letter-spacing: 0.05em;
    }
    .slot-symbol.grand .num { color: rgba(225,29,39,0.6); }
    .slot-symbol .label {
      display: block;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      max-width: 100%;
    }
    /* 動態字級依名稱長度（JS 加 data-len） */
    .slot-symbol[data-len="1"] .label { font-size: 38px; }
    .slot-symbol[data-len="2"] .label { font-size: 28px; }
    .slot-symbol[data-len="3"] .label { font-size: 22px; }
    .slot-symbol[data-len="4"] .label { font-size: 17px; }
    .slot-symbol[data-len="5"] .label { font-size: 14px; }
    /* 中央高亮線 */
    .slot-machine::after { display: none; } /* override; we'll use a different highlight method */

    /* 中央 frame 標示中獎線 */
    .slot-frame {
      position: relative;
      margin: 0 auto;
    }
    .slot-frame::before {
      content: '';
      position: absolute;
      left: -6px; right: -6px;
      top: 50%;
      height: 2px;
      background: var(--or-yellow);
      transform: translateY(-50%);
      opacity: 0;
      transition: opacity 0.3s ease;
    }
    .slot-frame.win::before { opacity: 0.8; }

    /* SPIN 按鈕 */
    .slot-spin-row { margin-top: 18px; display: flex; justify-content: center; }
    .slot-spin-btn {
      background: var(--or-yellow); color: var(--ink); border: none;
      padding: 16px 44px; border-radius: 999px;
      font-family: inherit; font-weight: 800; font-size: 17px;
      letter-spacing: 0.06em; cursor: pointer;
      box-shadow: 0 8px 20px -4px rgba(252, 199, 38, 0.55);
      transition: background 0.15s, transform 0.18s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .slot-spin-btn:hover:not(:disabled) { background: var(--or-yellow-d); }
    /* 拉桿感：按下時往下壓 */
    .slot-spin-btn:active:not(:disabled) { transform: scale(0.96) translateY(3px); }
    .slot-spin-btn:disabled { background: #F0F0F2; color: var(--ink-3); cursor: default; box-shadow: none; }
    /* 可以玩時的呼吸光暈 */
    .slot-spin-btn:not(:disabled) { animation: btnBreath 2.4s ease-in-out infinite; }
    @keyframes btnBreath {
      0%, 100% { box-shadow: 0 8px 20px -4px rgba(252, 199, 38, 0.55); }
      50% { box-shadow: 0 8px 26px -2px rgba(252, 199, 38, 0.85), 0 0 0 8px rgba(252, 199, 38, 0.12); }
    }

    .status-row { display: flex; align-items: center; justify-content: center; gap: 8px; margin-top: 16px; font-size: 13px; color: var(--ink-2); min-height: 22px; }
    .status-row .name { color: var(--ink); font-weight: 600; }

    /* Prize section */
    .section { margin-top: 24px; }
    .section-head { display: flex; align-items: baseline; justify-content: space-between; padding: 0 4px; margin-bottom: 10px; }
    .section-head h2 { margin: 0; font-size: 17px; font-weight: 700; letter-spacing: -0.015em; }
    .section-head .meta { font-size: 11px; color: var(--ink-2); font-weight: 500; }
    .prize-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
    .prize-card { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; padding: 14px; }
    .prize-card.grand { grid-column: span 2; border-color: var(--or-red); background: linear-gradient(180deg, rgba(225, 29, 39, 0.04), transparent); }
    .prize-card .top { display: flex; justify-content: space-between; margin-bottom: 8px; }
    .prize-card .icon { width: 32px; height: 32px; border-radius: 10px; background: linear-gradient(135deg, #FFF7DA, var(--or-yellow)); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 14px; }
    .prize-card.grand .icon { background: var(--or-red); color: #fff; }
    .prize-card .badge { font-size: 10px; font-weight: 700; padding: 3px 8px; border-radius: 999px; background: var(--or-red); color: #fff; }
    .prize-card .name { font-size: 14px; font-weight: 600; line-height: 1.35; }
    .prize-card .desc { margin-top: 3px; font-size: 12px; color: var(--ink-2); line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

    .foot { margin-top: 28px; padding: 14px 16px; background: var(--surface); border: 1px solid var(--border); border-radius: 14px; display: flex; align-items: center; justify-content: space-between; font-size: 12px; color: var(--ink-2); }
    .foot .l { display: flex; align-items: center; gap: 8px; }
    .foot .i { width: 20px; height: 20px; border-radius: 6px; background: var(--bg); border: 1px solid var(--border); display: inline-flex; align-items: center; justify-content: center; font-size: 11px; }
    .foot .r { font-weight: 600; color: var(--ink); }

    /* Result modal */
    .modal { position: fixed; inset: 0; z-index: 100; pointer-events: none; opacity: 0; transition: opacity 0.3s ease; background: rgba(15, 15, 16, 0.55); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); display: flex; align-items: flex-end; justify-content: center; }
    .modal.open { opacity: 1; pointer-events: auto; }
    .sheet { width: 100%; max-width: 480px; background: var(--surface); border-radius: 28px 28px 0 0; padding: 14px 24px 32px; padding-bottom: max(32px, env(safe-area-inset-bottom)); transform: translateY(100%); transition: transform 0.5s cubic-bezier(0.32, 0.72, 0, 1); }
    .modal.open .sheet { transform: translateY(0); }
    .handle { width: 36px; height: 5px; border-radius: 999px; background: #E0E0E4; margin: 0 auto 22px; }
    .modal-eyebrow { text-align: center; font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--or-red); margin-bottom: 16px; }
    .modal-img-wrap { width: 88px; height: 88px; margin: 0 auto 16px; border-radius: 22px; background: linear-gradient(135deg, #FFF7DA, var(--or-yellow)); display: flex; align-items: center; justify-content: center; }
    .modal.grand .modal-img-wrap { background: linear-gradient(135deg, var(--or-red), #B61118); }
    .modal-img-wrap .glyph { font-size: 36px; font-weight: 700; color: var(--ink); }
    .modal.grand .modal-img-wrap .glyph { color: #fff; }
    .modal-prize { text-align: center; font-size: 26px; font-weight: 700; letter-spacing: -0.025em; margin-bottom: 8px; line-height: 1.15; }
    .modal-desc { text-align: center; color: var(--ink-2); font-size: 14px; line-height: 1.55; margin-bottom: 24px; }
    .modal-btn { display: block; width: 100%; padding: 15px; background: var(--ink); color: #fff; border: none; border-radius: 14px; font-size: 15px; font-weight: 600; font-family: inherit; cursor: pointer; transition: transform 0.15s cubic-bezier(0.34, 1.56, 0.64, 1); }
    .modal-btn:active { transform: scale(0.98); }

    /* ========== 優惠序號區塊 ========== */
    .coupon-block { background: #FFFBEB; border: 1px solid var(--or-yellow); border-radius: 16px; padding: 16px 18px 18px; margin-bottom: 16px; text-align: center; }
    .coupon-label { font-size: 11px; font-weight: 600; letter-spacing: 0.1em; color: var(--ink-2); text-transform: uppercase; margin-bottom: 8px; }
    .coupon-code { font-size: 26px; font-weight: 800; letter-spacing: 0.04em; color: var(--ink); line-height: 1.2; word-break: break-all; font-variant-numeric: tabular-nums; -webkit-user-select: all; user-select: all; }
    .coupon-hint { font-size: 12.5px; color: var(--ink-2); line-height: 1.5; margin-top: 10px; }
    .coupon-oos { background: var(--bg); border: 1px solid var(--border); border-radius: 14px; padding: 14px 16px; margin-bottom: 16px; text-align: center; font-size: 13px; color: var(--ink-2); line-height: 1.5; }
    .wallet-link { display: block; text-align: center; margin-top: 14px; font-size: 13px; font-weight: 600; color: var(--ink-2); text-decoration: none; }
    .wallet-link:active { opacity: 0.6; }

    /* ========== 體驗升級：動效層 ========== */
    /* 進場：卡片柔和 fade + up，依序錯開 */
    @keyframes enterUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
    .hero, .stats, .invite-card, .stage-card, .section, .foot { animation: enterUp 0.38s cubic-bezier(0.22, 0.9, 0.3, 1) backwards; }
    .stats { animation-delay: 0.05s; }
    .invite-card { animation-delay: 0.1s; }
    .stage-card { animation-delay: 0.15s; }
    .section { animation-delay: 0.2s; }
    .foot { animation-delay: 0.25s; }

    /* 卡片陰影層次 + 圓角統一 */
    .hero, .stage-card { box-shadow: 0 1px 2px rgba(15, 15, 16, 0.03), 0 12px 32px -18px rgba(15, 15, 16, 0.14); }
    .stat, .prize-card, .foot { box-shadow: 0 1px 2px rgba(15, 15, 16, 0.03), 0 8px 20px -14px rgba(15, 15, 16, 0.12); }
    .stat, .prize-card, .foot { border-radius: 16px; }

    /* 剩餘次數變化 pop */
    .stat .v { display: inline-block; }
    .stat .v.pop { animation: statPop 0.45s cubic-bezier(0.34, 1.56, 0.64, 1); }
    @keyframes statPop { 0% { transform: scale(1.3); } 100% { transform: scale(1); } }

    /* 機台跑馬燈 */
    .slot-lamps { display: flex; justify-content: center; gap: 9px; margin-bottom: 14px; position: relative; z-index: 1; }
    .slot-lamps span { width: 6px; height: 6px; border-radius: 50%; background: rgba(255, 255, 255, 0.16); transition: background 0.25s ease, box-shadow 0.25s ease; }
    .slot-machine.running .slot-lamps span { animation: lampBlink 0.5s ease-in-out infinite; }
    .slot-machine.running .slot-lamps span:nth-child(even) { animation-delay: 0.25s; }
    @keyframes lampBlink {
      0%, 100% { background: rgba(255, 255, 255, 0.16); box-shadow: none; }
      50% { background: var(--or-yellow); box-shadow: 0 0 8px rgba(252, 199, 38, 0.9); }
    }
    .slot-machine.celebrate .slot-lamps span { background: var(--or-yellow); box-shadow: 0 0 8px rgba(252, 199, 38, 0.9); }

    /* 機身黃色飾條 */
    .slot-trim { margin-top: 16px; height: 4px; border-radius: 999px; background: linear-gradient(90deg, transparent, var(--or-yellow), transparent); opacity: 0.45; }

    /* 拉桿機身震動 */
    .slot-machine.shake { animation: machineShake 0.2s ease; }
    @keyframes machineShake {
      0%, 100% { transform: none; }
      25% { transform: translate(-2px, 1px) rotate(-0.35deg); }
      50% { transform: translate(2px, -1px) rotate(0.35deg); }
      75% { transform: translate(-1px, 1px); }
    }

    /* near-miss 心跳：第三軸停止前的紅光快閃 */
    .slot-machine.near-miss { animation: nearMissFlash 0.17s linear 3; }
    @keyframes nearMissFlash {
      0%, 100% { box-shadow: inset 0 0 0 3px var(--or-yellow), inset 0 0 0 5px rgba(0, 0, 0, 0.55), 0 24px 48px -16px rgba(15, 15, 16, 0.5); }
      50% { box-shadow: inset 0 0 0 3px var(--or-red), inset 0 0 0 5px rgba(0, 0, 0, 0.55), 0 0 30px rgba(225, 29, 39, 0.55), 0 24px 48px -16px rgba(15, 15, 16, 0.5); }
    }

    /* 軸停止回彈 */
    .slot-reel.settle { animation: reelSettle 0.32s cubic-bezier(0.34, 1.56, 0.64, 1); }
    @keyframes reelSettle { 0% { transform: translateY(0); } 35% { transform: translateY(5px); } 100% { transform: translateY(0); } }

    /* 中獎三格黃光 pulse */
    .slot-reel.win-glow { animation: winPulse 0.55s ease-in-out 3; }
    @keyframes winPulse {
      0%, 100% { box-shadow: inset 0 0 0 2px rgba(255, 255, 255, 0.4); }
      50% { box-shadow: inset 0 0 0 3px var(--or-yellow), 0 0 0 2px var(--or-yellow), 0 0 22px rgba(252, 199, 38, 0.9); }
    }

    /* 揭曉 modal 內容節奏 */
    .modal.open .modal-img-wrap { animation: prizePop 0.55s cubic-bezier(0.34, 1.56, 0.64, 1) 0.12s backwards; }
    @keyframes prizePop { 0% { opacity: 0; transform: scale(0.5); } 100% { opacity: 1; transform: scale(1); } }
    .modal.open .modal-prize { animation: riseIn 0.4s ease 0.22s backwards; }
    .modal.open .modal-desc { animation: riseIn 0.4s ease 0.3s backwards; }
    @keyframes riseIn { 0% { opacity: 0; transform: translateY(10px); } 100% { opacity: 1; transform: translateY(0); } }

    /* 銘謝惠顧類：溫和版 modal */
    .modal.consolation .modal-eyebrow { color: var(--ink-3); }
    .modal.consolation .modal-img-wrap { background: linear-gradient(135deg, #F4F4F6, #E9E9EE); }
    .modal.consolation .modal-img-wrap .glyph { color: var(--ink-2); }

    @media (prefers-reduced-motion: reduce) {
      .hero, .stats, .invite-card, .stage-card, .section, .foot,
      .slot-spin-btn:not(:disabled),
      .slot-machine.shake, .slot-machine.near-miss,
      .slot-machine.running .slot-lamps span,
      .slot-reel.settle, .slot-reel.win-glow,
      .stat .v.pop,
      .modal.open .modal-img-wrap, .modal.open .modal-prize, .modal.open .modal-desc { animation: none !important; }
      .slot-strip { transition-duration: 1ms !important; }
      .slot-strip.motion { filter: none; }
      .sheet { transition-duration: 1ms; }
    }
  </style>
</head>
<body>
  <div class="page">

    <header class="brand-bar">
      <div class="logo"><span class="dot"></span>OpenRice</div>
      <div class="chip">活動進行中</div>
    </header>

    <section class="hero">
      <div class="hero-tag">老虎機</div>
      <h1><%= activity.name %></h1>
      <% if (activity.description) { %><p><%= activity.description %></p><% } %>
      <% if (activity.cover_image_url) { %>
        <img class="hero-cover" src="<%= activity.cover_image_url %>" alt="" />
      <% } %>
    </section>

    <section class="stats">
      <div class="stat"><div class="v" id="stat-remaining">—</div><div class="k">剩餘次數</div></div>
      <div class="stat"><div class="v" id="stat-referrals">—</div><div class="k">已邀請</div></div>
      <div class="stat"><div class="v"><%= prizes && prizes.length || 0 %><span class="unit">種</span></div><div class="k">獎品</div></div>
    </section>

    <section class="invite-card" id="invite-card">
      <div class="invite-left">
        <% if (activity.referral_bonus_per && activity.referral_bonus_per > 0) { %>
          <div class="invite-title">邀 1 位朋友，立得 +<%= activity.referral_bonus_per %> 次</div>
          <div class="invite-sub" id="invite-sub">最多再加 <%= activity.referral_bonus_max %> 次</div>
        <% } else { %>
          <div class="invite-title">分享給朋友一起玩</div>
          <div class="invite-sub" id="invite-sub">把這個活動傳出去</div>
        <% } %>
      </div>
      <button type="button" class="invite-btn" id="invite-btn">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:5px;vertical-align:-2px;"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>分享
      </button>
    </section>

    <section class="stage-card">
      <div class="stage-head"><span class="label">老虎機</span><span class="count">三軸對齊就中獎</span></div>

      <div class="slot-machine" id="slot-machine">
        <div class="slot-lamps" aria-hidden="true"><span></span><span></span><span></span><span></span><span></span><span></span></div>
        <div class="slot-frame" id="slot-frame">
          <div class="slot-reels">
            <div class="slot-reel"><div class="slot-strip" id="reel-0"></div></div>
            <div class="slot-reel"><div class="slot-strip" id="reel-1"></div></div>
            <div class="slot-reel"><div class="slot-strip" id="reel-2"></div></div>
          </div>
        </div>
        <div class="slot-trim" aria-hidden="true"></div>
      </div>

      <div class="slot-spin-row">
        <button type="button" class="slot-spin-btn" id="spin-btn">PULL</button>
      </div>

      <div class="status-row" id="status-row"><span id="status">準備中</span></div>
    </section>

    <% if (prizes && prizes.length > 0) { %>
    <section class="section">
      <div class="section-head"><h2>本次獎項</h2><span class="meta"><%= prizes.length %> 種</span></div>
      <div class="prize-grid">
        <% prizes.forEach(function (p, i) { %>
          <div class="prize-card <%= p.is_grand_prize ? 'grand' : '' %>">
            <div class="top">
              <div class="icon"><%= String(i + 1).padStart(2, '0') %></div>
              <% if (p.is_grand_prize) { %><span class="badge">頭獎</span><% } %>
            </div>
            <div class="name"><%= p.name %></div>
            <% if (p.description) { %><div class="desc"><%= p.description %></div><% } %>
          </div>
        <% }); %>
      </div>
    </section>
    <% } %>

    <div class="foot">
      <div class="l"><span class="i">i</span><span>遊戲規則</span></div>
      <span class="r">公平隨機</span>
    </div>
  </div>

  <div id="modal" class="modal" aria-hidden="true">
    <div class="sheet">
      <div class="handle"></div>
      <div class="modal-eyebrow" id="modal-eyebrow">中 獎</div>
      <div class="modal-img-wrap"><span class="glyph" id="modal-glyph">★</span></div>
      <div class="modal-prize" id="modal-prize">—</div>
      <div class="modal-desc" id="modal-desc"></div>
      <div class="coupon-block" id="coupon-block" hidden>
        <div class="coupon-label">優惠序號</div>
        <div class="coupon-code" id="coupon-code">—</div>
        <div class="coupon-hint">請到店出示此畫面或序號給店員核銷</div>
      </div>
      <div class="coupon-oos" id="coupon-oos" hidden>此獎品序號暫時發完，請洽客服</div>
      <button type="button" class="modal-btn" id="modal-close">完成</button>
      <a class="wallet-link" id="wallet-link" href="#">我的優惠券</a>
    </div>
  </div>

  <script>
    (function () {
      var slug = <%- JSON.stringify(activity.slug) %>;
      var liffId = <%- JSON.stringify(liffId || '') %>;
      var prizes = <%- JSON.stringify(prizes || []) %>;
      var activityMeta = <%- JSON.stringify({
        name: activity.name,
        referral_bonus_per: activity.referral_bonus_per,
        referral_bonus_max: activity.referral_bonus_max
      }) %>;

      var spinBtn = document.getElementById('spin-btn');
      var statusEl = document.getElementById('status');
      var statusRow = document.getElementById('status-row');
      var slotFrame = document.getElementById('slot-frame');
      var modal = document.getElementById('modal');

      var profile = null;
      var idToken = null;
      var liffReady = false;
      var spinning = false;

      var machineEl = document.getElementById('slot-machine');
      var reducedMotion = !!(window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches);
      function buzz(pattern) { if (navigator.vibrate) { try { navigator.vibrate(pattern); } catch (e) {} } }
      function wait(ms) { return new Promise(function (r) { setTimeout(r, ms); }); }

      function escapeHtml(s) {
        return String(s == null ? '' : s)
          .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;').replace(/'/g, '&#039;');
      }
      // 截斷顯示名稱（保留中英文易讀性）
      function symbolLabel(p, i) {
        if (!p) return { text: '?', len: 1 };
        var name = String(p.name || '').trim();
        if (!name) return { text: String(i + 1), len: 1 };
        // 5 字以上 truncate（保前 4 字 + …）
        if (name.length > 5) return { text: name.slice(0, 4) + '…', len: 5 };
        return { text: name, len: name.length };
      }

      // 建立三個軸的 strip — 每軸有 prizes.length * 6 個 symbol 重複（足夠滾動）
      function buildReels() {
        for (var r = 0; r < 3; r++) {
          var strip = document.getElementById('reel-' + r);
          if (!strip) continue;
          strip.innerHTML = '';
          // 6 圈 prizes
          for (var loop = 0; loop < 6; loop++) {
            prizes.forEach(function (p, i) {
              var s = document.createElement('div');
              s.className = 'slot-symbol' + (p.is_grand_prize ? ' grand' : '');
              if (p.image_url) {
                // 有圖：直接放圖（最高優先級，最直觀）
                var img = document.createElement('img');
                img.src = p.image_url;
                img.alt = p.name || '';
                s.appendChild(img);
                // 圖下面附小編號
                var num = document.createElement('div');
                num.className = 'num';
                num.textContent = String(i + 1).padStart(2, '0');
                s.appendChild(num);
              } else {
                // 沒圖：顯示獎品全名 + 編號（編號用來識別「第幾個獎品」對應 prize-list 編號）
                var info = symbolLabel(p, i);
                s.setAttribute('data-len', String(info.len));
                var label = document.createElement('div');
                label.className = 'label';
                label.textContent = info.text;
                s.appendChild(label);
                var num2 = document.createElement('div');
                num2.className = 'num';
                num2.textContent = (p.is_grand_prize ? '★ ' : '') + String(i + 1).padStart(2, '0');
                s.appendChild(num2);
              }
              strip.appendChild(s);
            });
          }
          // 起始位置 reset
          strip.style.transform = 'translateY(0)';
        }
      }

      function reelStripFor(r) { return document.getElementById('reel-' + r); }

      // 把第 r 個軸轉到指定獎品 index，帶 spin 動畫
      // opts: { ease 自訂緩動, keepMotion 滾完保留殘影（預轉用）, tick 停止時輕震 }
      function spinReel(r, targetIndex, duration, opts) {
        opts = opts || {};
        return new Promise(function (resolve) {
          var strip = reelStripFor(r);
          if (!strip) { resolve(); return; }
          var symbolHeight = 110;
          var n = prizes.length;
          // 目標位置：第 5 圈的 targetIndex（5*n + targetIndex）讓動畫感覺多
          var finalIndex = 5 * n + targetIndex;
          var finalY = -finalIndex * symbolHeight;
          // 滾動中加 motion blur 殘影
          if (!reducedMotion) strip.classList.add('motion');
          strip.style.transition = 'transform ' + duration + 'ms ' + (opts.ease || 'cubic-bezier(0.2, 0.7, 0.2, 1)');
          // requestAnimationFrame 確保 transition 生效
          requestAnimationFrame(function () {
            strip.style.transform = 'translateY(' + finalY + 'px)';
          });
          setTimeout(function () {
            if (!opts.keepMotion) {
              // 停止：移除殘影 + 回彈
              strip.classList.remove('motion');
              var reel = strip.parentElement;
              if (reel && !reducedMotion) {
                reel.classList.remove('settle');
                void reel.offsetWidth;
                reel.classList.add('settle');
              }
              if (opts.tick) buzz(10);
            }
            resolve();
          }, duration + 50);
        });
      }

      // ===== 慶祝特效（inline、零依賴、自動清理）=====
      function runParticles(parts, duration) {
        if (reducedMotion || !parts.length) return;
        var canvas = document.createElement('canvas');
        canvas.style.cssText = 'position:fixed;inset:0;width:100%;height:100%;pointer-events:none;z-index:300;';
        document.body.appendChild(canvas);
        var dpr = Math.min(window.devicePixelRatio || 1, 2);
        var W = window.innerWidth, H = window.innerHeight;
        canvas.width = W * dpr;
        canvas.height = H * dpr;
        var ctx = canvas.getContext('2d');
        ctx.scale(dpr, dpr);
        var last = null, elapsed = 0;
        function frame(t) {
          if (last === null) last = t;
          var dt = Math.min((t - last) / 1000, 0.05);
          last = t;
          elapsed += dt * 1000;
          ctx.clearRect(0, 0, W, H);
          var fade = elapsed > duration - 400 ? Math.max(0, (duration - elapsed) / 400) : 1;
          for (var i = 0; i < parts.length; i++) {
            var p = parts[i];
            p.vy += p.g * dt;
            p.x += p.vx * dt;
            p.y += p.vy * dt;
            p.rot += p.vr * dt;
            if (p.y > H + 40) continue;
            ctx.save();
            ctx.globalAlpha = fade;
            ctx.translate(p.x, p.y);
            ctx.rotate(p.rot);
            ctx.fillStyle = p.color;
            if (p.shape === 'dot') {
              ctx.beginPath();
              ctx.arc(0, 0, p.w / 2, 0, Math.PI * 2);
              ctx.fill();
            } else {
              ctx.fillRect(-p.w / 2, -p.w / 2, p.w, p.w * 0.62);
            }
            ctx.restore();
          }
          if (elapsed < duration) requestAnimationFrame(frame);
          else if (canvas.parentNode) canvas.parentNode.removeChild(canvas);
        }
        requestAnimationFrame(frame);
      }
      // 紙花：黃/墨/白 小方塊 + 圓點，約 80 顆，自頂落下
      function launchConfetti() {
        var colors = ['#FCC726', '#1F2937', '#FFFFFF'];
        var W = window.innerWidth;
        var parts = [];
        for (var i = 0; i < 80; i++) {
          parts.push({
            x: Math.random() * W,
            y: -30 - Math.random() * 120,
            w: 5 + Math.random() * 5,
            vx: -50 + Math.random() * 100,
            vy: 120 + Math.random() * 200,
            g: 260,
            rot: Math.random() * Math.PI,
            vr: -5 + Math.random() * 10,
            shape: Math.random() < 0.45 ? 'dot' : 'rect',
            color: colors[i % colors.length]
          });
        }
        runParticles(parts, 1900);
      }
      // 金幣噴出感：黃色圓點從機台往上噴灑落下
      function coinBurst() {
        if (!machineEl) return;
        var rect = machineEl.getBoundingClientRect();
        var cx = rect.left + rect.width / 2;
        var cy = rect.top + rect.height * 0.35;
        var colors = ['#FCC726', '#FFD95C', '#E8B400'];
        var parts = [];
        for (var i = 0; i < 26; i++) {
          var ang = -Math.PI / 2 + (-0.9 + Math.random() * 1.8) * 0.7;
          var speed = 300 + Math.random() * 320;
          parts.push({
            x: cx + (-44 + Math.random() * 88),
            y: cy,
            w: 7 + Math.random() * 6,
            vx: Math.cos(ang) * speed * 0.55,
            vy: Math.sin(ang) * speed,
            g: 780,
            rot: 0,
            vr: 0,
            shape: 'dot',
            color: colors[i % colors.length]
          });
        }
        runParticles(parts, 1700);
      }
      // 「銘謝惠顧」類獎項：不放紙花，改溫和動效
      function isConsolation(p) {
        if (!p) return true;
        if (p.is_grand_prize) return false;
        return /銘謝|惠顧|再接再厲|未中|沒中|下次|殘念|謝謝參/.test(String(p.name || ''));
      }
      function setReelGlow(on) {
        var reels = document.querySelectorAll('.slot-reel');
        for (var i = 0; i < reels.length; i++) {
          reels[i].classList.remove('win-glow');
          if (on) { void reels[i].offsetWidth; reels[i].classList.add('win-glow'); }
        }
      }
      function stopSpinVisuals() {
        if (machineEl) machineEl.classList.remove('running');
        for (var r = 0; r < 3; r++) {
          var s = reelStripFor(r);
          if (s) s.classList.remove('motion');
        }
      }

      async function initLiff() {
        var qs = new URLSearchParams(location.search);
        var devUid = qs.get('uid');
        if (devUid) { profile = { userId: devUid, displayName: qs.get('name') || 'DEV' }; return; }
        if (qs.get('preview') === '1') {
          profile = { userId: 'PREVIEW', displayName: '預覽' };
          spinBtn.disabled = true; spinBtn.textContent = '預覽';
          return;
        }
        if (!liffId) throw new Error('LIFF ID 未設定');
        try { await liff.init({ liffId: liffId }); }
        catch (e) { throw new Error('LIFF 初始化失敗'); }
        if (!liff.isInClient()) throw new Error('請在 LINE App 內打開');
        if (!liff.isLoggedIn()) { liff.login(); return new Promise(function () {}); }
        profile = await liff.getProfile();
        try { idToken = liff.getIDToken(); } catch (e) {}
      }

      async function maybeRegisterReferral() {
        try {
          var qs = new URLSearchParams(location.search);
          var inviter = qs.get('ref');
          if (!inviter || !profile || !profile.userId || inviter === profile.userId) return;
          await fetch('/api/games/slot/' + encodeURIComponent(slug) + '/referral', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ line_user_id: profile.userId, inviter_line_user_id: inviter, id_token: idToken })
          });
          var url = new URL(location.href);
          url.searchParams.delete('ref');
          history.replaceState({}, '', url.pathname + url.search);
        } catch (e) {}
      }

      async function refreshQuota() {
        try {
          if (!profile || !profile.userId) return;
          var resp = await fetch('/api/games/slot/' + encodeURIComponent(slug) +
            '/meta?line_user_id=' + encodeURIComponent(profile.userId) + '&id_token=' + encodeURIComponent(idToken || '')).then(function (r) { return r.json(); });
          if (!resp.ok || !resp.quota) return;
          renderQuota(resp.quota);
        } catch (e) {}
      }

      var lastStat = { remaining: null, referrals: null };
      function popStat(el) {
        if (!el || reducedMotion) return;
        el.classList.remove('pop');
        void el.offsetWidth;
        el.classList.add('pop');
      }
      function renderQuota(q) {
        var remEl = document.getElementById('stat-remaining');
        var refEl = document.getElementById('stat-referrals');
        remEl.innerHTML = q.remaining + '<span class="unit">/ ' + q.total + '</span>';
        refEl.innerHTML = q.referrals + '<span class="unit">人</span>';
        // 數字變化時 pop（讓 +2 次有感）
        if (lastStat.remaining !== null && lastStat.remaining !== q.remaining) popStat(remEl);
        if (lastStat.referrals !== null && lastStat.referrals !== q.referrals) popStat(refEl);
        lastStat.remaining = q.remaining;
        lastStat.referrals = q.referrals;
        if (q.remaining <= 0) {
          spinBtn.disabled = true;
          var canMore = q.referral_bonus_per > 0 && q.referral_bonus < q.referral_bonus_max;
          statusEl.textContent = canMore ? '次數用完，邀請朋友 +' + q.referral_bonus_per + ' 次' : '次數已用完';
        } else {
          spinBtn.disabled = false;
        }
        var inviteCard = document.getElementById('invite-card');
        var inviteSub = document.getElementById('invite-sub');
        // 只在有邀請機制時更新文案；否則保留 server render 的「把這個活動傳出去」
        if (inviteCard && q.referral_bonus_per > 0) {
          var bonusLeft = q.referral_bonus_max - q.referral_bonus;
          if (bonusLeft <= 0) {
            inviteCard.classList.add('maxed');
            if (inviteSub) inviteSub.textContent = '邀請次數已用滿';
          } else {
            inviteCard.classList.remove('maxed');
            if (inviteSub) inviteSub.textContent = '還可再邀請 ' + Math.ceil(bonusLeft / q.referral_bonus_per) + ' 位拿 +' + bonusLeft + ' 次';
          }
        }
      }

      async function spin() {
        if (spinning) return;
        if (!liffReady || !profile) { statusEl.textContent = '請稍候'; return; }
        spinning = true;
        spinBtn.disabled = true;
        statusEl.textContent = '轉動中⋯';
        slotFrame.classList.remove('win');
        setReelGlow(false);
        // 拉桿動效：機身微震 + 跑馬燈 + 觸覺
        if (machineEl) {
          machineEl.classList.remove('celebrate');
          machineEl.classList.add('running');
          if (!reducedMotion) {
            machineEl.classList.remove('shake');
            void machineEl.offsetWidth;
            machineEl.classList.add('shake');
          }
        }
        buzz(15);

        // 立即啟動三軸隨機滾動（先給用戶視覺感；keepMotion 保留殘影遮住稍後的瞬移 reset）
        var preTargets = [
          Math.floor(Math.random() * prizes.length),
          Math.floor(Math.random() * prizes.length),
          Math.floor(Math.random() * prizes.length)
        ];
        spinReel(0, preTargets[0], 600, { keepMotion: true });
        spinReel(1, preTargets[1], 800, { keepMotion: true });
        spinReel(2, preTargets[2], 1000, { keepMotion: true });

        try {
          var resp = await fetch('/api/games/slot/' + encodeURIComponent(slug) + '/play', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ line_user_id: profile.userId, line_display_name: profile.displayName || null, id_token: idToken })
          }).then(function (r) { return r.json(); });

          if (!resp.ok) {
            stopSpinVisuals();
            statusEl.textContent = resp.detail || resp.error || '抽獎失敗';
            spinning = false;
            spinBtn.disabled = false;
            return;
          }

          // 等預先滾完，重置位置
          await new Promise(function (r) { setTimeout(r, 1200); });

          // reset 各軸（瞬移）
          for (var r = 0; r < 3; r++) {
            var strip = reelStripFor(r);
            if (!strip) continue;
            strip.style.transition = 'none';
            strip.style.transform = 'translateY(0)';
          }
          await new Promise(function (r) { setTimeout(r, 50); });

          // 取得真實中獎獎品 index
          var winIdx = prizes.findIndex(function (p) { return p.id === resp.prize.id; });
          if (winIdx < 0) winIdx = 0;

          // 三軸錯開停止（三軸相同 = 中獎）：第 1 軸先停，第 2 軸 +400ms，第 3 軸 +800ms（放慢收尾、拉期待感）
          var stop0 = spinReel(0, winIdx, 2000, { tick: true });
          var stop1 = spinReel(1, winIdx, 2400, { tick: true });
          var stop2 = spinReel(2, winIdx, 2800, { tick: true, ease: 'cubic-bezier(0.12, 0.82, 0.16, 1)' });
          // near-miss 心跳：前兩軸已對齊，第三軸停止前機身紅光快閃（純視覺）
          stop1.then(function () {
            if (machineEl && !reducedMotion) {
              machineEl.classList.add('near-miss');
              setTimeout(function () { machineEl.classList.remove('near-miss'); }, 540);
            }
          });
          await Promise.all([stop0, stop1, stop2]);
          stopSpinVisuals();

          // 揭曉節奏：停頓 → 揭曉 → 慶祝
          await wait(450);
          slotFrame.classList.add('win');
          setReelGlow(true);
          if (isConsolation(resp.prize)) {
            buzz(15);
          } else {
            if (machineEl) machineEl.classList.add('celebrate');
            buzz([30, 50, 30]);
            launchConfetti();
            coinBurst();
          }
          await wait(650);
          showResult(resp.prize, resp);
          setTimeout(refreshQuota, 800);
        } catch (e) {
          stopSpinVisuals();
          statusEl.textContent = '錯誤';
        } finally {
          spinning = false;
          spinBtn.disabled = false;
        }
      }

      // 優惠序號顯示：coupon_code 可能在 prize 物件上或 /play 回應頂層
      function renderCoupon(prize, resp) {
        var block = document.getElementById('coupon-block');
        var oos = document.getElementById('coupon-oos');
        if (!block || !oos) return;
        var code = (prize && prize.coupon_code) || (resp && resp.coupon_code) || '';
        var outOfStock = !!(resp && resp.coupon_out_of_stock) || !!(prize && prize.coupon_out_of_stock);
        if (code) {
          document.getElementById('coupon-code').textContent = code;
          block.hidden = false;
          oos.hidden = true;
        } else if (outOfStock) {
          block.hidden = true;
          oos.hidden = false;
        } else {
          block.hidden = true;
          oos.hidden = true;
        }
      }

      function showResult(prize, resp) {
        statusEl.textContent = '';
        renderCoupon(prize, resp);
        var consolation = isConsolation(prize);
        var eyebrow = document.getElementById('modal-eyebrow');
        if (eyebrow) eyebrow.textContent = consolation ? '再接再厲' : (prize.is_grand_prize ? '頭 獎' : '中 獎');
        if (consolation) modal.classList.add('consolation'); else modal.classList.remove('consolation');
        document.getElementById('modal-prize').textContent = prize.name || '—';
        document.getElementById('modal-glyph').textContent = prize.is_grand_prize ? '★' : '◆';
        var descParts = [];
        if (prize.description) descParts.push(prize.description);
        if (prize.prize_value) {
          if (prize.prize_value.amount) descParts.push('NT$ ' + prize.prize_value.amount);
          if (prize.prize_value.code) descParts.push('優惠碼 ' + prize.prize_value.code);
          if (prize.prize_value.label) descParts.push(prize.prize_value.label);
        }
        document.getElementById('modal-desc').textContent = descParts.join(' · ');
        if (prize.is_grand_prize) modal.classList.add('grand'); else modal.classList.remove('grand');
        requestAnimationFrame(function () { modal.classList.add('open'); });
      }

      // 「我的優惠券」連結，導向錢包頁（LIFF 永久連結 /wallet）
      var walletLink = document.getElementById('wallet-link');
      if (walletLink) {
        walletLink.href = liffId ? ('https://liff.line.me/' + liffId + '/wallet') : '/games/wallet';
      }

      document.getElementById('modal-close').addEventListener('click', function () {
        modal.classList.remove('open');
      });
      modal.addEventListener('click', function (e) { if (e.target === modal) modal.classList.remove('open'); });

      var inviteBtn = document.getElementById('invite-btn');
      if (inviteBtn) inviteBtn.addEventListener('click', shareWithFriend);
      async function shareWithFriend() {
        if (!profile || !profile.userId) return;
        var inviteUrl = 'https://liff.line.me/' + liffId + '/slot/' + encodeURIComponent(slug) + '?ref=' + encodeURIComponent(profile.userId);
        var msg = '快來玩「' + activityMeta.name + '」老虎機！';
        try {
          if (liff.isApiAvailable && liff.isApiAvailable('shareTargetPicker')) {
            var res = await liff.shareTargetPicker([{ type: 'text', text: msg + '\n' + inviteUrl }]);
            if (res) { flashStatus('已分享！'); return; }
          }
        } catch (e) {}
        try { await navigator.clipboard.writeText(inviteUrl); flashStatus('連結已複製'); }
        catch (e) { prompt('複製此連結：', inviteUrl); }
      }
      function flashStatus(msg) {
        statusEl.textContent = msg;
        setTimeout(function () {
          refreshQuota();
          if (profile) statusEl.innerHTML = '哈囉，<span class="name">' + (profile.displayName || '') + '</span>';
        }, 2400);
      }

      spinBtn.addEventListener('click', spin);

      // bootstrap
      if (prizes.length < 1) {
        statusEl.textContent = '獎品未設定';
        spinBtn.disabled = true;
      } else {
        buildReels();
        spinBtn.disabled = true;
        statusEl.textContent = '驗證身分中⋯';
      }

      (async function () {
        if (prizes.length < 1) return;
        try {
          await initLiff();
          liffReady = true;
          await maybeRegisterReferral();
          await refreshQuota();
          statusEl.innerHTML = '哈囉，<span class="name">' + (profile.displayName || '') + '</span>';
        } catch (e) {
          statusEl.textContent = e.message || '初始化失敗';
        }
      })();
    })();
  </script>
</body>
</html>
