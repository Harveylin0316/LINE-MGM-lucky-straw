<%-
  include('layout', {
    user: user,
    isAdmin: isAdmin,
    bodyClass: 'admin-shell',
    body: `
    <section class="card">
      <h1>LINE Webhook 診斷</h1>
      <p class="muted">檢查 follow 事件是否進站，以及邀請加碼處理結果。下方時間為<strong>台灣時間</strong>（Asia/Taipei）。</p>
      <div class="admin-toolbar">
        <a class="btn" href="/admin/prizes">獎品設定</a>
        <a class="btn" href="/admin/prizes/logs">獎品修改紀錄</a>
        <a class="btn" href="/admin/reports">活動成效報表</a>
      </div>

      ${
        Array.isArray(records) && records.length > 0
          ? `<div class="table-responsive"><table class="prize-table">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>事件</th>
                  <th>LINE User ID</th>
                  <th>邀請ID</th>
                  <th>邀請者ID</th>
                  <th>結果</th>
                  <th>說明</th>
                  <th>事件時間（台灣）</th>
                  <th>記錄時間（台灣）</th>
                </tr>
              </thead>
              <tbody>
                ${records
                  .map(
                    r => `<tr>
                      <td>${r.id}</td>
                      <td>${r.event_type}</td>
                      <td>${r.line_user_id || '-'}</td>
                      <td>${r.invite_id || '-'}</td>
                      <td>${r.inviter_user_id || '-'}</td>
                      <td>${r.result}</td>
                      <td style="max-width:360px;white-space:normal;font-size:13px;line-height:1.45;">${r.detailHtml}</td>
                      <td>${r.event_at_taipei}</td>
                      <td>${r.logged_at_taipei}</td>
                    </tr>`
                  )
                  .join('')}
              </tbody>
            </table></div>
            <div class="actions">
              ${hasPrevPage ? `<a class="btn" href="/admin/line/webhooks?page=${page - 1}">上一頁</a>` : ''}
              ${hasNextPage ? `<a class="btn" href="/admin/line/webhooks?page=${page + 1}">下一頁</a>` : ''}
            </div>`
          : '<p class="muted">目前尚無 webhook 紀錄。</p>'
      }
    </section>
  `
  })
%>
