<%-
  include('layout', {
    user: user,
    isAdmin: isAdmin,
    bodyClass: bodyClass,
    body: `
    <section class="card">
      <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;">
        <div>
          <h1 style="margin:0;">批次 #${broadcast.id}</h1>
          <p class="muted" style="margin-top:6px;font-size:13px;">
            建立於 ${new Date(broadcast.created_at).toLocaleString('zh-TW', { timeZone: 'Asia/Taipei' })}
            · 建立者 ${String(broadcast.admin_username || '').replace(/</g,'&lt;')}
            · 狀態 <span class="status-pill status-${broadcast.status}">${broadcast.status}</span>
            ${broadcast.scheduled_at ? `· 排程於 <strong>${new Date(broadcast.scheduled_at).toLocaleString('zh-TW', { timeZone: 'Asia/Taipei' })}</strong>` : ''}
          </p>
        </div>
        <div style="display:flex;gap:8px;flex-wrap:wrap;">
          <button type="button" class="btn btn-export-list" id="btn-export-list">匯出到名單庫</button>
          <a href="/admin/broadcast/history" class="btn">回歷史列表</a>
          <a href="/admin/broadcast" class="btn">回主頁</a>
        </div>
      </div>
    </section>

    <section class="card">
      <h2 style="margin-top:0;">送出統計</h2>
      <div class="stat-grid">
        <div class="stat-cell">
          <div class="stat-label">總數</div>
          <div class="stat-value">${broadcast.recipient_total}</div>
        </div>
        <div class="stat-cell">
          <div class="stat-label">成功</div>
          <div class="stat-value" style="color:#065f46;">${broadcast.recipient_ok}</div>
        </div>
        <div class="stat-cell">
          <div class="stat-label">失敗</div>
          <div class="stat-value" style="color:#991b1b;">${broadcast.recipient_fail}</div>
        </div>
        <div class="stat-cell">
          <div class="stat-label">跳過</div>
          <div class="stat-value" style="color:#6b7280;">${broadcast.recipient_skip}</div>
        </div>
        <div class="stat-cell stat-cell--highlight">
          <div class="stat-label">Hero 被看（開信率 proxy）</div>
          <div class="stat-value">${viewStat.views || 0}</div>
          ${broadcast.recipient_ok > 0 ? `<div class="stat-sub muted">${Math.round((Number(viewStat.views || 0) / broadcast.recipient_ok) * 100)}% 對成功送達者</div>` : ''}
        </div>
        <div class="stat-cell stat-cell--highlight">
          <div class="stat-label">CTA 點擊</div>
          <div class="stat-value">${clickStat.clicks || 0}</div>
          ${broadcast.recipient_ok > 0 ? `<div class="stat-sub muted">${Math.round((Number(clickStat.clicks || 0) / broadcast.recipient_ok) * 100)}% 對成功送達者</div>` : ''}
        </div>
      </div>

      <p class="muted" style="margin-top:10px;font-size:11px;line-height:1.5;">
        備註：LINE 平台對 OA push 沒有原生「已讀」回條。「Hero 被看」是用「Hero 圖被 fetch 的次數」當開信率
        proxy — LINE app cache 可能少報，多人同時打開可能多報，僅供參考。「CTA 點擊」是強訊號（有看到才會點）。
        只有「模板模式」會追蹤；進階 Flex JSON 由你自行用 utm 追蹤。
      </p>

      ${abStat && abStat.length > 0 ? `
        <h2 style="margin-top:24px;">A/B Test 對比</h2>
        <p class="muted" style="font-size:13px;margin-bottom:10px;">收件人隨機切兩半，A/B 各收一版訊息，比較開信率與點擊率找出更好的版本。</p>
        <div class="ab-grid">
          ${abStat.map(v => {
            const sent = v.sent_ok || 0;
            const openRate = sent > 0 ? Math.round((v.views / sent) * 100) : 0;
            const clickRate = sent > 0 ? Math.round((v.clicks / sent) * 100) : 0;
            return `<div class="ab-cell">
              <div class="ab-cell-head">版本 ${String(v.variant || '?').toUpperCase()}</div>
              <div class="ab-cell-row"><span class="ab-cell-label">收件人</span><span class="ab-cell-val">${v.sent_total}</span></div>
              <div class="ab-cell-row"><span class="ab-cell-label">送達成功</span><span class="ab-cell-val">${v.sent_ok}</span></div>
              <div class="ab-cell-row"><span class="ab-cell-label">送達失敗</span><span class="ab-cell-val">${v.sent_fail}</span></div>
              <div class="ab-cell-row ab-cell-row--highlight"><span class="ab-cell-label">Hero 被看</span><span class="ab-cell-val">${v.views} <span class="muted" style="font-size:11px;">(${openRate}%)</span></span></div>
              <div class="ab-cell-row ab-cell-row--highlight"><span class="ab-cell-label">CTA 點擊</span><span class="ab-cell-val">${v.clicks} <span class="muted" style="font-size:11px;">(${clickRate}%)</span></span></div>
            </div>`;
          }).join('')}
        </div>
      ` : ''}

      ${broadcast.recipient_fail > 0 && broadcast.status !== 'running' ? `
        <div class="resend-block">
          <button type="button" class="btn btn-warning" id="btn-resend-failed">把 ${broadcast.recipient_fail} 個失敗的重設為 pending 並重發</button>
          <span id="resend-status" class="muted" style="font-size:13px;"></span>
        </div>
      ` : ''}
    </section>

    <section class="card">
      <h2 style="margin-top:0;">收件人前 30 筆</h2>
      ${recentSample.length === 0
        ? '<p class="muted">無資料</p>'
        : `<div class="table-responsive"><table class="prize-table">
            <thead>
              <tr>
                <th>ID</th>
                <th>顯示名 / 帳號</th>
                <th>line_user_id</th>
                <th>狀態</th>
                <th>送出時間</th>
                <th>錯誤訊息</th>
              </tr>
            </thead>
            <tbody>
              ${recentSample.map(r => {
                const pushed = r.pushed_at
                  ? new Date(r.pushed_at).toLocaleString('sv-SE', { timeZone: 'Asia/Taipei' }).slice(11, 19)
                  : '';
                return `<tr>
                  <td>${r.id}</td>
                  <td>${String(r.line_display_name || r.username || '').replace(/</g,'&lt;')}</td>
                  <td><code style="font-size:11px;">${String(r.line_user_id || '').replace(/</g,'&lt;')}</code></td>
                  <td><span class="status-pill status-${r.status}">${r.status}</span></td>
                  <td class="muted" style="font-size:12px;">${pushed}</td>
                  <td class="muted" style="font-size:12px;">${String(r.error || '').replace(/</g,'&lt;')}</td>
                </tr>`;
              }).join('')}
            </tbody>
          </table></div>`
      }
    </section>

    ${(clickStat.clicks || 0) > 0 ? `
      <section class="card">
        <h2 style="margin-top:0;">最近 10 次點擊</h2>
        <div class="table-responsive"><table class="prize-table">
          <thead>
            <tr>
              <th>時間</th>
              <th>User-Agent</th>
            </tr>
          </thead>
          <tbody>
            ${clickRecent.map(c => {
              const ts = c.clicked_at ? new Date(c.clicked_at).toLocaleString('zh-TW', { timeZone: 'Asia/Taipei' }) : '';
              return `<tr>
                <td>${ts}</td>
                <td class="muted" style="font-size:11px;font-family:monospace;">${String(c.user_agent || '').replace(/</g,'&lt;').slice(0,200)}</td>
              </tr>`;
            }).join('')}
          </tbody>
        </table></div>
      </section>
    ` : ''}

    <style>
      .stat-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
        gap: 10px;
        margin-top: 6px;
      }
      .stat-cell {
        padding: 14px 16px;
        background: #fafafa;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
      }
      .stat-cell--highlight {
        background: #FFFBEB;
        border-color: #FCC726;
      }
      .stat-label { font-size: 12px; color: #6b7280; margin-bottom: 4px; }
      .stat-value { font-size: 24px; font-weight: 700; color: #1f2937; line-height: 1.2; }
      .stat-sub { font-size: 11px; margin-top: 4px; }
      .resend-block {
        display: flex;
        gap: 10px;
        align-items: center;
        margin-top: 16px;
        padding: 12px;
        background: #fef3c7;
        border-radius: 8px;
      }
      .status-pill {
        display: inline-block;
        padding: 2px 8px;
        border-radius: 999px;
        font-size: 12px;
        background: #e5e7eb;
        color: #374151;
      }
      .status-pill.status-running,
      .status-pill.status-sending,
      .status-pill.status-pending { background: #fde68a; color: #92400e; }
      .status-pill.status-done,
      .status-pill.status-sent { background: #d1fae5; color: #065f46; }
      .status-pill.status-cancelled,
      .status-pill.status-failed { background: #fee2e2; color: #991b1b; }
      .status-pill.status-skipped { background: #e5e7eb; color: #6b7280; }
      .status-pill.status-scheduled { background: #dbeafe; color: #1e40af; }
      .ab-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 12px;
      }
      .ab-cell {
        padding: 14px 16px;
        background: #fff;
        border: 1px solid #bfdbfe;
        border-radius: 8px;
      }
      .ab-cell-head {
        font-weight: 700;
        color: #1e40af;
        margin-bottom: 10px;
        font-size: 14px;
      }
      .ab-cell-row {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        padding: 4px 0;
        font-size: 13px;
        color: #4b5563;
      }
      .ab-cell-row--highlight { background: #FFFBEB; padding: 6px 8px; border-radius: 6px; margin: 2px 0; }
      .ab-cell-label { color: #6b7280; }
      .ab-cell-val { font-weight: 600; color: #1f2937; }
    </style>

    <!-- 匯出收件人到名單庫 modal -->
    <div id="bc-export-modal" class="bc-modal" hidden>
      <div class="bc-modal-inner">
        <div class="bc-modal-head">
          <h3 style="margin:0;">匯出收件人到名單庫</h3>
          <button type="button" class="bc-modal-close" id="bc-export-close">×</button>
        </div>
        <p class="muted" style="font-size:12px;margin:0 0 12px;">
          會在「名單庫」建立一個新名單，內含符合條件的 LINE userId。建立後可在群發訊息時選用。
        </p>
        <div class="bc-grid">
          <label class="bc-field">
            <span>名單名稱 *</span>
            <input type="text" id="bcex-name" placeholder="例：5/22 推播點過的人" maxlength="200" />
          </label>
          <label class="bc-field">
            <span>描述（可選）</span>
            <input type="text" id="bcex-desc" placeholder="用途備註" maxlength="500" />
          </label>
          <label class="bc-field">
            <span>包含哪些人 *</span>
            <select id="bcex-filter">
              <option value="all">所有收件人（含失敗、跳過）</option>
              <option value="sent" selected>成功送達的人</option>
              <option value="failed">送達失敗的人</option>
              <option value="viewed">開過信的人（hero 圖被載入）</option>
              <option value="clicked">點過 CTA 按鈕的人</option>
            </select>
          </label>
        </div>
        <p style="background:#FFFBEB;border:1px solid #FCC726;border-radius:8px;padding:10px 14px;margin-top:10px;font-size:12px;color:#92400e;">
          注意：「開過信 / 點過 CTA」只記錄在新版批次（含 per-recipient tracking）後的推播。
          5/22 之前的批次只有 broadcast 維度沒有 line_user_id 對應，可能匯出 0 人。
        </p>
        <div style="display:flex;gap:8px;margin-top:14px;">
          <button type="button" class="btn" style="background:#FCC726;border:none;font-weight:600;" id="bcex-save">建立名單</button>
          <button type="button" class="btn" id="bcex-cancel">取消</button>
        </div>
        <div id="bcex-status" class="muted" style="font-size:12px;min-height:18px;margin-top:8px;"></div>
      </div>
    </div>

    <style>
      .bc-modal { position: fixed; inset: 0; background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; z-index: 100; padding: 16px; }
      .bc-modal[hidden] { display: none !important; }
      .bc-modal-inner { background: #fff; border-radius: 12px; max-width: 520px; width: 100%; max-height: 90vh; overflow-y: auto; padding: 20px; }
      .bc-modal-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px; }
      .bc-modal-close { background: none; border: none; font-size: 24px; cursor: pointer; color: #6b7280; line-height: 1; }
      .bc-grid { display: flex; flex-direction: column; gap: 12px; }
      .bc-field { display: flex; flex-direction: column; gap: 4px; font-size: 13px; }
      .bc-field span { color: #6B6B70; font-size: 12px; }
      .bc-field input, .bc-field select { padding: 8px 10px; border: 1px solid #ECECEE; border-radius: 6px; font-size: 13px; font-family: inherit; }
      .btn-export-list { background: #FCC726; color: #1f2937; font-weight: 600; border: none; cursor: pointer; }
      .btn-export-list:hover { background: #f5b800; }
    </style>

    <script>
      // 匯出收件人到名單庫
      (function () {
        var modal = document.getElementById('bc-export-modal');
        var openBtn = document.getElementById('btn-export-list');
        if (!openBtn) return;
        function open() {
          document.getElementById('bcex-name').value = '';
          document.getElementById('bcex-desc').value = '';
          document.getElementById('bcex-filter').value = 'sent';
          document.getElementById('bcex-status').textContent = '';
          modal.hidden = false;
          setTimeout(function () { document.getElementById('bcex-name').focus(); }, 50);
        }
        function close() { modal.hidden = true; }
        openBtn.addEventListener('click', open);
        document.getElementById('bc-export-close').addEventListener('click', close);
        document.getElementById('bcex-cancel').addEventListener('click', close);
        document.getElementById('bcex-save').addEventListener('click', function () {
          var name = document.getElementById('bcex-name').value.trim();
          var desc = document.getElementById('bcex-desc').value.trim();
          var filter = document.getElementById('bcex-filter').value;
          var statusEl = document.getElementById('bcex-status');
          if (!name) { statusEl.textContent = '請填名單名稱'; return; }
          var saveBtn = document.getElementById('bcex-save');
          saveBtn.disabled = true;
          statusEl.textContent = '建立中⋯';
          fetch('/admin/broadcast/${broadcast.id}/export-recipients-to-list', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name: name, description: desc, filter: filter })
          })
            .then(function (r) { return r.json(); })
            .then(function (d) {
              saveBtn.disabled = false;
              if (!d.ok) {
                statusEl.textContent = '失敗：' + (d.detail || d.error || '未知');
                return;
              }
              statusEl.innerHTML =
                '成功！已建立「' + (d.list.name || '').replace(/</g,'&lt;') + '」（' + d.total + ' 人）<br>' +
                '<a href="/admin/recipient-lists/' + d.list.id + '" style="color:#2563eb;">→ 前往名單庫</a>';
              setTimeout(close, 3500);
            })
            .catch(function (e) {
              saveBtn.disabled = false;
              statusEl.textContent = '錯誤：' + e.message;
            });
        });
      })();
    </script>

    <script>
      (function () {
        var btn = document.getElementById('btn-resend-failed');
        if (!btn) return;
        var statusEl = document.getElementById('resend-status');
        btn.addEventListener('click', function () {
          if (!confirm('將把所有失敗收件人重設為 pending 並重發。確認？')) return;
          btn.disabled = true;
          statusEl.textContent = '處理中…';
          fetch('/admin/broadcast/${broadcast.id}/resend-failed', { method: 'POST' })
            .then(function (r) { return r.json(); })
            .then(function (data) {
              if (data.ok) {
                statusEl.textContent = '已重設 ' + data.resetCount + ' 個。請回主頁從「近期批次」進入這個批次手動點重發，或等下次 chunk loop。';
                setTimeout(function () { location.reload(); }, 1500);
              } else {
                statusEl.textContent = '失敗：' + (data.error || '') + (data.detail ? '｜' + data.detail : '');
                btn.disabled = false;
              }
            })
            .catch(function (e) {
              statusEl.textContent = '網路錯誤：' + e.message;
              btn.disabled = false;
            });
        });
      })();
    </script>
    `
  })
%>
