<%-
  include('layout', {
    user: user,
    isAdmin: isAdmin,
    bodyClass: bodyClass,
    body: `
    <section class="card kr-hero">
      <div class="kr-hero-inner">
        <div>
          <h1>關鍵字回覆</h1>
          <p class="muted" style="margin-top:6px;">
            用戶在聊天室輸入訊息命中關鍵字時，自動回覆指定的訊息庫訊息。由上而下比對，命中第一條就回覆。
          </p>
        </div>
        <button type="button" class="kr-primary-btn" id="btn-new-rule">新增規則</button>
      </div>
    </section>

    <section class="card">
      <h2 style="margin:0 0 10px;">規則清單</h2>
      <div class="table-wrap">
        <table class="kr-table">
          <thead>
            <tr>
              <th>關鍵字</th>
              <th>比對方式</th>
              <th>回覆訊息</th>
              <th style="text-align:center;">啟用</th>
              <th style="text-align:right;">命中次數</th>
              <th></th>
            </tr>
          </thead>
          <tbody id="kr-tbody">
            <tr><td colspan="6" class="muted" style="text-align:center;padding:18px 0;">載入中…</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- 新增 / 編輯規則 modal -->
    <div id="rule-modal" class="kr-modal" hidden>
      <div class="kr-modal-inner">
        <div class="kr-modal-head">
          <h3 style="margin:0;" id="rule-modal-title">新增規則</h3>
          <button type="button" class="kr-modal-close" id="rule-modal-close">×</button>
        </div>
        <div class="kr-grid">
          <label class="kr-field">
            <span>關鍵字（逗號分隔多個，命中任一即回覆）*</span>
            <input type="text" id="kr-keywords" placeholder="優惠, 折扣, coupon" maxlength="500" />
          </label>
          <label class="kr-field">
            <span>比對方式</span>
            <select id="kr-match-type">
              <option value="contains">包含（訊息文字含有任一關鍵字）</option>
              <option value="exact">完全相同（訊息文字等於任一關鍵字）</option>
            </select>
          </label>
          <label class="kr-field">
            <span>回覆訊息（從訊息庫選擇）*</span>
            <select id="kr-template"></select>
            <div class="muted" style="font-size:12px;">沒有想要的訊息？<a href="/admin/messages" target="_blank" rel="noopener" style="color:#374151;text-decoration:underline;">前往訊息庫建立</a></div>
          </label>
          <label class="kr-field">
            <span>優先序（數字小的先比對，預設 100）</span>
            <input type="number" id="kr-priority" min="0" max="9999" value="100" />
          </label>
          <label class="kr-field kr-field-inline">
            <input type="checkbox" id="kr-active" checked />
            <span>啟用此規則</span>
          </label>
        </div>
        <div class="kr-modal-actions">
          <button type="button" class="kr-primary-btn" id="kr-save">儲存規則</button>
          <button type="button" class="kr-secondary-btn" id="kr-cancel">取消</button>
        </div>
        <div id="kr-status" class="muted" style="font-size:12px;min-height:18px;margin-top:8px;"></div>
      </div>
    </div>

    <script>
    (function () {
      var $ = function (id) { return document.getElementById(id); };
      var allRules = [];
      var allTemplates = [];
      var editingId = null;

      function esc(s) {
        return String(s == null ? '' : s)
          .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;').replace(/'/g, '&#039;');
      }

      function matchTypeLabel(t) {
        return t === 'exact' ? '完全相同' : '包含';
      }

      function load() {
        fetch('/admin/keyword-replies/api/list')
          .then(function (r) { return r.json(); })
          .then(function (resp) {
            if (!resp.ok) {
              $('kr-tbody').innerHTML = '<tr><td colspan="6" class="muted" style="text-align:center;padding:18px 0;">載入失敗</td></tr>';
              return;
            }
            allRules = resp.rules || [];
            allTemplates = resp.templates || [];
            fillTemplateOptions();
            render(allRules);
          })
          .catch(function () {
            $('kr-tbody').innerHTML = '<tr><td colspan="6" class="muted" style="text-align:center;padding:18px 0;">載入失敗</td></tr>';
          });
      }

      function fillTemplateOptions() {
        var sel = $('kr-template');
        if (!allTemplates.length) {
          sel.innerHTML = '<option value="">（訊息庫尚無訊息，請先建立）</option>';
          return;
        }
        sel.innerHTML = '<option value="">請選擇回覆訊息</option>' + allTemplates.map(function (t) {
          return '<option value="' + t.id + '">' + esc(t.name) + '</option>';
        }).join('');
      }

      function render(rules) {
        var tbody = $('kr-tbody');
        if (!rules.length) {
          tbody.innerHTML = '<tr><td colspan="6" class="muted" style="text-align:center;padding:24px 0;">' +
            '還沒有規則。點「新增規則」建立第一條，例如：關鍵字「優惠」回覆優惠券訊息。</td></tr>';
          return;
        }
        tbody.innerHTML = rules.map(function (r) {
          var tplName = r.template_name
            ? esc(r.template_name)
            : '<span style="color:#E11D27;">（訊息已刪除，此規則不會回覆）</span>';
          return '<tr data-id="' + r.id + '">' +
            '<td><div class="kr-keywords">' + esc(r.keywords) + '</div>' +
              '<div class="muted" style="font-size:11px;">優先序 ' + (r.priority == null ? 100 : r.priority) + '</div></td>' +
            '<td>' + matchTypeLabel(r.match_type) + '</td>' +
            '<td>' + tplName + '</td>' +
            '<td style="text-align:center;"><input type="checkbox" class="kr-toggle" data-id="' + r.id + '"' + (r.is_active ? ' checked' : '') + ' /></td>' +
            '<td style="text-align:right;font-weight:600;font-variant-numeric:tabular-nums;">' + (r.hit_count || 0) + '</td>' +
            '<td style="white-space:nowrap;">' +
              '<button type="button" class="kr-link-btn kr-edit-btn" data-id="' + r.id + '">編輯</button>' +
              '<button type="button" class="kr-del-btn" data-id="' + r.id + '" data-keywords="' + esc(r.keywords) + '">刪除</button>' +
            '</td>' +
          '</tr>';
        }).join('');

        tbody.querySelectorAll('.kr-toggle').forEach(function (cb) {
          cb.addEventListener('change', function () {
            var id = cb.getAttribute('data-id');
            cb.disabled = true;
            fetch('/admin/keyword-replies/api/' + id + '/update', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ is_active: cb.checked })
            })
              .then(function (r) { return r.json(); })
              .then(function (d) {
                cb.disabled = false;
                if (!d.ok) {
                  alert('更新失敗：' + (d.detail || d.error || '未知'));
                  cb.checked = !cb.checked;
                  return;
                }
                var found = allRules.filter(function (x) { return String(x.id) === String(id); })[0];
                if (found) found.is_active = cb.checked;
              })
              .catch(function (e) {
                cb.disabled = false;
                cb.checked = !cb.checked;
                alert('錯誤：' + e.message);
              });
          });
        });

        tbody.querySelectorAll('.kr-edit-btn').forEach(function (btn) {
          btn.addEventListener('click', function () {
            var id = btn.getAttribute('data-id');
            var rule = allRules.filter(function (x) { return String(x.id) === String(id); })[0];
            if (rule) openModal(rule);
          });
        });

        tbody.querySelectorAll('.kr-del-btn').forEach(function (btn) {
          btn.addEventListener('click', function () {
            var id = btn.getAttribute('data-id');
            var kw = btn.getAttribute('data-keywords') || '';
            var msg = '確定刪除規則「' + kw + '」？\\n\\n刪除後用戶輸入這些關鍵字將不再自動回覆。';
            if (!confirm(msg)) return;
            fetch('/admin/keyword-replies/api/' + id, { method: 'DELETE' })
              .then(function (r) { return r.json(); })
              .then(function (d) {
                if (!d.ok) { alert('刪除失敗：' + (d.detail || d.error || '未知')); return; }
                load();
              })
              .catch(function (e) { alert('錯誤：' + e.message); });
          });
        });
      }

      // ---- modal ----
      var modal = $('rule-modal');
      function openModal(rule) {
        editingId = rule ? rule.id : null;
        $('rule-modal-title').textContent = rule ? '編輯規則' : '新增規則';
        $('kr-keywords').value = rule ? (rule.keywords || '') : '';
        $('kr-match-type').value = rule && rule.match_type === 'exact' ? 'exact' : 'contains';
        $('kr-template').value = rule && rule.message_template_id ? String(rule.message_template_id) : '';
        $('kr-priority').value = rule && rule.priority != null ? rule.priority : 100;
        $('kr-active').checked = rule ? !!rule.is_active : true;
        $('kr-status').textContent = '';
        modal.hidden = false;
        setTimeout(function () { $('kr-keywords').focus(); }, 50);
      }
      function closeModal() { modal.hidden = true; editingId = null; }
      $('btn-new-rule').addEventListener('click', function () { openModal(null); });
      $('rule-modal-close').addEventListener('click', closeModal);
      $('kr-cancel').addEventListener('click', closeModal);

      $('kr-save').addEventListener('click', function () {
        var keywords = $('kr-keywords').value.trim();
        var templateId = $('kr-template').value;
        if (!keywords) { $('kr-status').textContent = '請填寫關鍵字'; return; }
        if (!templateId) { $('kr-status').textContent = '請選擇回覆訊息'; return; }
        var payload = {
          keywords: keywords,
          match_type: $('kr-match-type').value,
          message_template_id: Number(templateId),
          priority: Number($('kr-priority').value),
          is_active: $('kr-active').checked
        };
        var url = editingId
          ? '/admin/keyword-replies/api/' + editingId + '/update'
          : '/admin/keyword-replies/api/create';
        $('kr-status').textContent = '儲存中…';
        $('kr-save').disabled = true;
        fetch(url, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        })
          .then(function (r) { return r.json(); })
          .then(function (d) {
            $('kr-save').disabled = false;
            if (!d.ok) {
              $('kr-status').textContent = '失敗：' + (d.detail || d.error || '未知');
              return;
            }
            closeModal();
            load();
          })
          .catch(function (e) {
            $('kr-save').disabled = false;
            $('kr-status').textContent = '錯誤：' + e.message;
          });
      });

      load();
    })();
    </script>

    <style>
      .kr-hero { background: linear-gradient(135deg, #fffbeb 0%, #fff 100%); border: 1px solid #fde68a; }
      .kr-hero-inner { display: flex; justify-content: space-between; align-items: center; gap: 12px; flex-wrap: wrap; }
      .kr-primary-btn { padding: 10px 18px; background: #FCC726; color: #1f2937; font-weight: 600; border-radius: 8px; border: none; cursor: pointer; font-size: 14px; }
      .kr-primary-btn:hover { background: #f5b800; }
      .kr-primary-btn:disabled { opacity: 0.6; cursor: not-allowed; }
      .kr-secondary-btn { padding: 9px 16px; background: #fff; color: #374151; border: 1px solid #e5e7eb; border-radius: 8px; cursor: pointer; font-size: 13px; }

      .table-wrap { overflow-x: auto; }
      .kr-table { width: 100%; border-collapse: collapse; font-size: 13px; }
      .kr-table th, .kr-table td { padding: 10px 12px; border-bottom: 1px solid #F3F4F6; vertical-align: middle; }
      .kr-table th { background: #FAFAFA; text-align: left; font-size: 11px; color: #6B6B70; font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em; }
      .kr-keywords { font-weight: 600; color: #1f2937; font-size: 14px; }
      .kr-toggle { width: 16px; height: 16px; accent-color: #FCC726; cursor: pointer; }
      .kr-link-btn { display: inline-block; padding: 4px 10px; background: #fff; border: 1px solid #e5e7eb; border-radius: 6px; font-size: 12px; cursor: pointer; color: #374151; margin-right: 4px; font-family: inherit; }
      .kr-link-btn:hover { background: #fffbeb; border-color: #FCC726; }
      .kr-del-btn { padding: 4px 10px; background: #fff; border: 1px solid #fca5a5; border-radius: 6px; font-size: 12px; cursor: pointer; color: #dc2626; font-family: inherit; }
      .kr-del-btn:hover { background: #fee2e2; }

      .kr-modal { position: fixed; inset: 0; background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; z-index: 100; padding: 16px; }
      .kr-modal[hidden] { display: none !important; }
      .kr-modal-inner { background: #fff; border-radius: 12px; max-width: 520px; width: 100%; max-height: 90vh; overflow-y: auto; padding: 20px; }
      .kr-modal-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px; }
      .kr-modal-close { background: none; border: none; font-size: 24px; cursor: pointer; color: #6b7280; line-height: 1; }
      .kr-grid { display: flex; flex-direction: column; gap: 12px; }
      .kr-field { display: flex; flex-direction: column; gap: 4px; font-size: 13px; }
      .kr-field span { color: #6B6B70; font-size: 12px; }
      .kr-field input[type="text"], .kr-field input[type="number"], .kr-field select { padding: 8px 10px; border: 1px solid #ECECEE; border-radius: 6px; font-size: 13px; font-family: inherit; }
      .kr-field-inline { flex-direction: row; align-items: center; gap: 8px; }
      .kr-field-inline input { width: 16px; height: 16px; accent-color: #FCC726; }
      .kr-field-inline span { color: #374151; font-size: 13px; }
      .kr-modal-actions { margin-top: 14px; display: flex; gap: 8px; }
    </style>
    `
  })
%>
