      /* hidden attribute 必須贏過 display:flex（否則 hidden 失效） */
      .text-format-toolbar[hidden] { display: none !important; }
      .text-format-toolbar.dragging { opacity: 0.92; transition: none; }
      .text-format-toolbar .tft-grip {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0 4px;
        cursor: grab;
        color: rgba(255,255,255,0.6);
