        color: #92400e;
        text-decoration: none;
        padding: 8px;
        margin-top: 4px;
      }
      .sched-more:hover { text-decoration: underline; }

      /* ===== 訊息庫模式：藏掉收件人 / 送出 / 排程，只留訊息編輯器 ===== */
      .msglib-mode .run-banner,
      .msglib-mode .sched-banner,
      .msglib-mode .broadcast-page-head,
      .msglib-mode #bc-channel-step,
      .msglib-mode #bc-audience-step,
      .msglib-mode #bc-send-step,
      .msglib-mode .advanced-settings-block,
      .msglib-mode .template-picker,
      .msglib-mode .draft-bar { display: none !important; }
      /* 訊息庫模式：編輯器佔滿、預覽固定旁邊 */
      .msglib-mode .broadcast-grid { grid-template-columns: 1fr 360px; }
      .msglib-bar {
        display: flex; align-items: center; justify-content: space-between; gap: 12px;
        flex-wrap: wrap; padding: 12px 0 16px; margin-bottom: 12px;
        border-bottom: 1px solid #e5e7eb;
      }
      .msglib-bar-left { display: flex; align-items: center; gap: 14px; flex: 1; min-width: 280px; }
      .msglib-bar-right { display: flex; align-items: center; gap: 12px; }
      .msglib-back { font-size: 13px; color: #6b7280; text-decoration: none; white-space: nowrap; }
      .msglib-back:hover { color: #1f2937; text-decoration: underline; }
      #msglib-name { flex: 1; padding: 9px 12px; border: 1px solid #e5e7eb; border-radius: 8px; font-size: 14px; }
    </style>

    <script id="broadcast-init-data" type="application/json">${JSON.stringify({
      hasLineToken: Boolean(hasLineToken),
      maxRecipients: maxRecipients,
      chunkSize: chunkSize,
      fieldLimits: fieldLimits,
      msgLibMode: Boolean(typeof msgLibMode !== 'undefined' && msgLibMode),
      msgLibId: (typeof msgLibId !== 'undefined' && msgLibId) ? String(msgLibId) : null,
      msgLibDup: Boolean(typeof msgLibDup !== 'undefined' && msgLibDup)
    }).replace(/</g, '\\u003c')}</script>

    <script>
    // 排程取消 + 立即推進 + 自動 polling running batches
    document.addEventListener('DOMContentLoaded', function () {
      // ----- 取消 -----
      document.querySelectorAll('.sched-cancel-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var id = btn.getAttribute('data-id');
          if (!id) return;
          if (!confirm('確定取消 #' + id + ' 這個批次？取消後不能還原。')) return;
          btn.disabled = true;
          var orig = btn.textContent;
          btn.textContent = '取消中…';
          fetch('/admin/broadcast/' + id + '/cancel', { method: 'POST' })
            .then(function (r) { return r.json(); })
            .then(function (data) {
              if (!data || !data.ok) {
                alert('取消失敗：' + (data && (data.detail || data.error) || '未知錯誤'));
                btn.disabled = false; btn.textContent = orig;
                return;
              }
              var row = document.querySelector('.sched-row[data-id="' + id + '"]');
              if (row) row.remove();
              // 若 banner 內沒元素了，移除
              ['.sched-banner', '.run-banner'].forEach(function (sel) {
                var banner = document.querySelector(sel);
                if (banner && banner.querySelectorAll('.sched-row').length === 0) banner.remove();
              });
            })
            .catch(function (e) {
              alert('取消失敗：' + e.message);
              btn.disabled = false; btn.textContent = orig;
            });
        });
      });

      // ----- 立即推進（手動觸發 process-chunk） -----
      document.querySelectorAll('.sched-advance-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var id = btn.getAttribute('data-id');
          if (!id) return;
          btn.disabled = true;
          var orig = btn.textContent;
          btn.textContent = '處理中…';
          fetch('/admin/broadcast/' + id + '/process-chunk', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ chunkSize: 50 })
          })
            .then(function (r) { return r.json(); })
            .then(function (data) {
              if (!data || !data.ok) {
                alert('推進失敗：' + (data && (data.detail || data.error) || '未知錯誤'));
                btn.disabled = false; btn.textContent = orig;
                return;
              }
              var msg = '推進完成：成功 ' + (data.ok_count || 0) + ' / 失敗 ' + (data.fail || 0) +
                ' / 跳過 ' + (data.skip || 0) + ' / 剩 ' + (data.remaining || 0) + ' 筆';
              if (data.remaining === 0) {
                msg += '\\n\\n整批完成！';
                location.reload();
                return;
              }
              btn.textContent = orig;
              btn.disabled = false;
              alert(msg + '\\n\\n可繼續按「立即推進」處理下一批。');
              // 軟刷新 banner 顯示新進度
              location.reload();
            })
            .catch(function (e) {
              alert('推進失敗：' + e.message);
              btn.disabled = false; btn.textContent = orig;
            });
        });
      });
    });
    </script>

    <div class="send-confirm-overlay" id="send-confirm-overlay" hidden>
      <div class="send-confirm-modal" role="dialog" aria-modal="true" aria-labelledby="sc-title">
        <h3 id="sc-title" class="sc-title">最後確認：正式發送</h3>
        <p class="sc-warn" id="sc-warn">送出後無法回收。請再次確認以下內容。</p>
        <div class="sc-rows">
          <div class="sc-row"><span class="sc-k">發送管道</span><span class="sc-v" id="sc-channel">—</span></div>
          <div class="sc-row"><span class="sc-k">收件人數</span><span class="sc-v sc-big" id="sc-total">—</span></div>
          <div class="sc-row"><span class="sc-k" id="sc-titlek">通知文字</span><span class="sc-v" id="sc-msgtitle">—</span></div>
          <div class="sc-row" id="sc-schedule-row" hidden><span class="sc-k">排程時間</span><span class="sc-v" id="sc-schedule">—</span></div>
          <div class="sc-row" id="sc-ab-row" hidden><span class="sc-k">A/B 測試</span><span class="sc-v">已啟用（A、B 版各送一半）</span></div>
        </div>
        <label class="sc-check"><input type="checkbox" id="sc-confirm-check" /><span>我已發送測試訊息給自己，並確認內容、圖片、連結都正確</span></label>
        <div class="sc-actions">
          <button type="button" class="sc-btn-cancel" id="sc-btn-cancel">返回檢查</button>
          <button type="button" class="sc-btn-go" id="sc-btn-go" disabled>確定發送</button>
        </div>
      </div>
    </div>
    <style>
      .send-confirm-overlay{position:fixed;inset:0;background:rgba(15,15,16,.5);display:flex;align-items:center;justify-content:center;z-index:1000;padding:20px;}
      /* hidden 屬性會被上面的 display:flex 蓋掉（UA 的 display:none 輸給作者樣式），必須明確補回 */
      .send-confirm-overlay[hidden]{display:none;}
      .sc-row[hidden]{display:none;}
      .send-confirm-modal{background:#fff;border-radius:16px;max-width:440px;width:100%;padding:24px;box-shadow:0 20px 60px rgba(0,0,0,.3);}
      .sc-title{margin:0 0 6px;font-size:18px;color:#1f2937;}
      .sc-warn{margin:0 0 16px;font-size:13px;color:#b91c1c;line-height:1.6;}
      .sc-rows{border:1px solid #ECECEE;border-radius:10px;overflow:hidden;margin-bottom:16px;}
      .sc-row{display:flex;justify-content:space-between;align-items:center;gap:12px;padding:11px 14px;border-bottom:1px solid #F3F4F6;}
      .sc-row:last-child{border-bottom:none;}
      .sc-k{font-size:13px;color:#6B7280;flex-shrink:0;}
      .sc-v{font-size:14px;color:#1f2937;font-weight:600;text-align:right;word-break:break-word;}
      .sc-v.sc-big{font-size:22px;}
      .sc-check{display:flex;align-items:flex-start;gap:8px;font-size:13px;color:#374151;line-height:1.5;cursor:pointer;background:#FFFBEB;border:1px solid #FCC726;border-radius:10px;padding:12px;margin-bottom:18px;}
      .sc-check input{margin-top:2px;flex-shrink:0;}
      .sc-actions{display:flex;gap:10px;justify-content:flex-end;}
      .sc-btn-cancel{padding:11px 18px;border:1px solid #D1D5DB;background:#fff;border-radius:10px;font-size:14px;font-weight:600;color:#374151;cursor:pointer;}
      .sc-btn-go{padding:11px 20px;border:none;background:#DC2626;color:#fff;border-radius:10px;font-size:14px;font-weight:700;cursor:pointer;}
      .sc-btn-go:disabled{opacity:.45;cursor:not-allowed;}
    </style>

    <script src="/admin-broadcast.js" defer></script>
    `
  })
%>
