<%-
  include('layout', {
    user: user,
    isAdmin: isAdmin,
    bodyClass: bodyClass,
    body: `
    <section class="card broadcast-card">
      <div class="broadcast-page-head">
        <h1>群發訊息</h1>
        <p class="page-subtitle">三步驟：① 選收件人 → ② 編訊息（含預覽即時更新 / 點文字直接編輯） → ③ 先測試再正式送</p>
      </div>

      ${
        !hasLineToken
          ? `<p class="error-banner">尚未設定 <code>LINE_CHANNEL_ACCESS_TOKEN</code>，無法實際送出訊息。可先預覽人數與訊息樣式。</p>`
          : ''
      }

      <div class="broadcast-grid">
        <div class="broadcast-form">
          <fieldset class="broadcast-step">
            <legend><span class="step-pill">1</span> 收件人</legend>

            <div class="broadcast-tabs audience-tabs">
              <button type="button" class="tab-btn active" data-audience="conditions">條件篩選</button>
              <button type="button" class="tab-btn" data-audience="saved_list">已儲存名單</button>
              <button type="button" class="tab-btn" data-audience="upload">上傳新名單</button>
            </div>

            <div class="audience-pane" id="audience-pane-conditions">

            <div class="broadcast-field">
              <div class="broadcast-field-label">中過獎品（可多選）</div>
              <div class="prize-checkbox-list">
                ${
                  Array.isArray(prizes) && prizes.length > 0
                    ? prizes
                        .map(
                          p => `<label class="chip-checkbox">
                            <input type="checkbox" name="prize_name" value="${p.name.replace(/"/g, '&quot;')}" />
                            <span>${p.name}</span>
                          </label>`
                        )
                        .join('')
                    : '<span class="muted">目前沒有可選獎品</span>'
                }
              </div>
              <div class="broadcast-inline-field">
                <label>
                  比對方式
                  <select name="prize_mode" id="prize-mode">
                    <option value="any">中過其中至少一項</option>
                    <option value="all">中過全部勾選的獎品</option>
                    <option value="none">沒中過任何勾選的獎品</option>
                  </select>
                </label>
              </div>
            </div>

            <div class="broadcast-field">
              <label class="broadcast-inline-field">
                <span>邀請好友成功數 ≥</span>
                <input type="number" id="invite-min" min="0" max="1000" placeholder="留空 = 不限" style="width:120px;" />
                <span class="muted">（line_invites.status = rewarded）</span>
              </label>
            </div>

            <div class="broadcast-field">
              <label class="broadcast-inline-field">
                <span>活動期間刮獎狀況</span>
                <select id="drew-in-campaign">
                  <option value="">不限</option>
                  <option value="true">有刮過獎</option>
                  <option value="false">從未刮過</option>
                </select>
              </label>
            </div>

            </div><!-- /audience-pane-conditions -->

            <div class="audience-pane" id="audience-pane-saved_list" hidden>
              <div class="broadcast-field">
                <label>
                  選擇已儲存名單
                  <select id="saved-list-select">
                    <option value="">— 載入中 —</option>
                  </select>
                </label>
              </div>
              <div class="broadcast-action-row" style="margin-top:6px;">
                <button type="button" class="btn link-btn" id="btn-delete-saved-list" hidden style="color:#dc2626;">刪除這份名單</button>
              </div>
            </div>

            <div class="audience-pane" id="audience-pane-upload" hidden>
              <div class="broadcast-field">
                <label>
                  名單顯示名
                  <input type="text" id="upload-list-name" maxlength="200" placeholder="例如：2026-05 Rice $100 中獎者" />
                </label>
              </div>
              <div class="broadcast-field">
                <label>
                  說明（選填）
                  <input type="text" id="upload-list-desc" maxlength="500" placeholder="這份名單從哪來、要做什麼用" />
                </label>
              </div>
              <div class="broadcast-field">
                <label>
                  LINE userId 清單（一行一個 U + 32 hex；或貼 CSV，會自動忽略其他欄位／空白）
                  <textarea id="upload-list-uids" rows="8" placeholder="Ua59ae887867bfe0a26c6a41616fa4f66&#10;U72b796db38442742d09386bc8d1ac524&#10;..." spellcheck="false" style="font-family:monospace;font-size:12px;"></textarea>
                </label>
                <div id="upload-list-counter" class="muted" style="font-size:12px;margin-top:4px;">已輸入 0 個 UID</div>
              </div>
              <div class="broadcast-action-row">
                <button type="button" class="btn btn-warning" id="btn-upload-list">儲存名單</button>
                <div id="upload-list-status" class="muted" style="font-size:13px;">尚未儲存</div>
              </div>
            </div>

            <div class="broadcast-action-row" style="margin-top:14px;border-top:1px solid #fde68a;padding-top:12px;">
              <button type="button" class="btn btn-warning" id="btn-preview-audience">預覽收件人</button>
              <div id="audience-status" class="audience-status muted">尚未預覽</div>
            </div>
            <div id="audience-sample" class="audience-sample" hidden></div>
          </fieldset>

          <fieldset class="broadcast-step">
            <legend><span class="step-pill">2</span> 訊息內容</legend>

            <div class="template-picker">
              <div class="template-picker-head">
                <span class="template-picker-title">挑一個模板開始（或從頭編輯下方表單）</span>
                <div class="template-picker-actions">
                  <button type="button" id="btn-save-template" class="link-btn">儲存目前為新模板</button>
                  <button type="button" id="btn-delete-template" class="link-btn" hidden style="color:#dc2626;">刪除目前模板</button>
                </div>
              </div>
              <div id="template-grid" class="template-grid">
                <div class="muted" style="font-size:12px;padding:8px 0;">載入模板中…</div>
              </div>
              <select id="template-select" hidden><option value="">—</option></select>
            </div>

            <div class="draft-bar">
              <span class="draft-bar-hint">草稿自動儲存：這區塊填的內容會記住，下次回來自動帶回</span>
              <span id="draft-status-time" class="muted">尚未儲存</span>
              <button type="button" id="btn-clear-draft" class="link-btn">清除草稿</button>
            </div>

            <div class="ab-variant-label" id="variant-a-label" hidden>
              <strong>版本 A</strong>（50% 收件人）
            </div>

            <div class="broadcast-tab-pane" id="pane-template">
              <div class="broadcast-field">
                <div class="broadcast-field-label">Hero 圖（選填，PNG/JPEG，≤2MB）</div>
                <div class="broadcast-inline-field">
                  <input type="file" id="hero-file" accept="image/png,image/jpeg" />
                  <button type="button" class="btn" id="btn-hero-upload">上傳</button>
                  <span id="hero-status" class="muted">未上傳</span>
                </div>
                <div class="muted" style="font-size:12px;margin-top:4px;">
                  未上傳會自動套 OpenRice 黃色品牌 bar（細條 header），同時用於追蹤開信率。
                </div>
              </div>

              <div class="broadcast-field">
                <label>
                  標題
                  <input type="text" id="tpl-title" maxlength="100" placeholder="例如：OpenRice 春日饗里活動更新" />
                </label>
              </div>
              <div class="broadcast-field">
                <label>
                  副標題（可換行）
                  <textarea id="tpl-subtitle" maxlength="500" rows="3" placeholder="主訊息／活動細節說明"></textarea>
                </label>
              </div>
              <div class="broadcast-field">
                <label>
                  優惠碼（選填，會顯示為置中的「強調框」）
                  <input type="text" id="tpl-coupon-code" maxlength="60" placeholder="例如：spring100" />
                </label>
                <div class="muted field-hint">
                  在 LINE 上用戶點此框會自動複製到剪貼簿，方便他們貼到 OpenRice 兌換頁。
                </div>
              </div>
              <div class="broadcast-field">
                <label>
                  注意事項（選填，顯示為小灰字）
                  <input type="text" id="tpl-disclaimer" maxlength="300" placeholder="例如：每位會員限使用一次，使用期限 30 天" />
                </label>
                <div class="muted field-hint">
                  多個項目用「<code>*</code>」隔開（譬如 <code>*項目A *項目B *項目C</code>），LINE 上會自動拆成
                  <code>•</code> bullet 換行顯示。
                </div>
              </div>
              <div class="broadcast-field">
                <label>
                  CTA 按鈕文字（≤40 字）
                  <input type="text" id="tpl-cta-label" maxlength="40" placeholder="例如：立即查看活動" />
                </label>
              </div>
              <div class="broadcast-field">
                <label>
                  CTA 連結（https:// 開頭）
                  <input type="url" id="tpl-cta-url" placeholder="https://tw.openrice.com/..." />
                </label>
              </div>
              <div class="broadcast-field">
                <label>
                  altText（LINE 通知列／聊天列表顯示，留空自動用標題）
                  <input type="text" id="tpl-alt" maxlength="400" placeholder="留空用標題" />
                </label>
              </div>
            </div>

            <details class="advanced-json-block" id="advanced-json-block">
              <summary>進階模式：直接編輯 Flex JSON（給工程師用 / 內建模板會自動切到這裡）</summary>
              <div class="broadcast-tab-pane" id="pane-flex-json">
              <div id="json-image-helper" class="json-image-helper" hidden>
                <div class="json-image-helper-head">
                  <span>圖片上傳助手（自動偵測 JSON 內 <code>REPLACE_*</code> 圖片位置）</span>
                  <button type="button" id="btn-scan-json-images" class="link-btn">重新掃描</button>
                </div>
                <div id="json-image-list"></div>
              </div>
              <div id="json-url-helper" class="json-url-helper" hidden>
                <div class="json-url-helper-head">
                  <span>URL 填寫助手（自動偵測 JSON 內 <code>REPLACE_*</code> 連結位置）</span>
                </div>
                <div id="json-url-list"></div>
              </div>
              <details class="json-textarea-block">
                <summary>直接編輯 Flex JSON（一般不需要動，填完上方助手即可）</summary>
                <div class="broadcast-field">
                  <label>
                    Flex JSON（root 必含 type:"flex", altText, contents）
                    <textarea id="flex-json" rows="14" placeholder='{ "type": "flex", "altText": "...", "contents": { "type": "bubble", ... } }' spellcheck="false"></textarea>
                  </label>
                </div>
              </details>
              </div>
            </details>

            <details class="advanced-settings-block">
              <summary>進階設定：A/B test 分組發送</summary>
              <div class="ab-test-toggle-bar">
                <label class="ab-toggle-label">
                  <input type="checkbox" id="ab-test-enable" />
                  <span>啟用 A/B test — 收件人隨機分成兩半，各收一版訊息，方便對比成效</span>
                </label>
              </div>
            <!-- A/B variant B 編輯區（啟用 A/B test 才顯示） -->
            <div id="variant-b-pane" hidden>
              <div class="ab-variant-label">
                <strong>版本 B</strong>（50% 收件人）
              </div>
              <div class="broadcast-tab-pane" id="pane-b-template">
                <div class="broadcast-field">
                  <div class="broadcast-field-label">Hero 圖（選填）</div>
                  <div class="broadcast-inline-field">
                    <input type="file" id="b-hero-file" accept="image/png,image/jpeg" />
                    <button type="button" class="btn" id="btn-b-hero-upload">上傳</button>
                    <span id="b-hero-status" class="muted">未上傳</span>
                  </div>
                </div>
                <div class="broadcast-field"><label>標題<input type="text" id="b-tpl-title" maxlength="100" /></label></div>
                <div class="broadcast-field"><label>副標題<textarea id="b-tpl-subtitle" maxlength="500" rows="3"></textarea></label></div>
                <div class="broadcast-field"><label>優惠碼<input type="text" id="b-tpl-coupon-code" maxlength="60" /></label></div>
                <div class="broadcast-field"><label>注意事項<input type="text" id="b-tpl-disclaimer" maxlength="300" /></label></div>
                <div class="broadcast-field"><label>CTA 按鈕文字<input type="text" id="b-tpl-cta-label" maxlength="40" /></label></div>
                <div class="broadcast-field"><label>CTA 連結 (https://)<input type="url" id="b-tpl-cta-url" /></label></div>
                <div class="broadcast-field"><label>altText<input type="text" id="b-tpl-alt" maxlength="400" /></label></div>
              </div>
              <div class="broadcast-tab-pane" id="pane-b-flex-json" hidden>
                <div class="broadcast-field">
                  <label>版本 B 的 Flex JSON
                    <textarea id="b-flex-json" rows="14" spellcheck="false"></textarea>
                  </label>
                </div>
              </div>
            </div>
            </details>

            <div class="broadcast-action-row" id="msg-status-row">
              <div id="msg-status" class="muted" style="font-size:12px;">右側預覽會在你編輯時自動更新</div>
            </div>

          </fieldset>

          <fieldset class="broadcast-step">
            <legend><span class="step-pill">3</span> 送出</legend>
            <p class="muted" style="margin-bottom:10px;">建議先發測試訊息確認沒問題，再正式批次送。</p>

            <div class="broadcast-field test-push-block">
              <div class="broadcast-field-label">先發測試訊息</div>

              <div class="test-recipient-list" id="test-recipient-list">
                <div class="muted" style="font-size:12px;">載入中…</div>
              </div>

              <div class="broadcast-action-row" style="margin-top:10px;">
                <button type="button" class="btn btn-warning" id="btn-test-push-all">發給全部測試人員</button>
                <span id="test-push-status" class="muted" style="font-size:13px;">尚未送出</span>
              </div>

              <details class="add-test-recipient" style="margin-top:12px;">
                <summary>新增 / 用其他 LINE userId 臨時發送</summary>
                <div style="margin-top:10px; display:grid; gap:10px;">
                  <div>
                    <div class="broadcast-field-label" style="font-size:12px;">臨時發給單一收件人（不會加入清單）</div>
                    <div class="broadcast-inline-field">
                      <input type="text" id="test-recipient" placeholder="留空 = 送給自己｜LINE userId｜會員顯示名/帳號" style="flex:1;min-width:280px;" />
                      <button type="button" class="btn" id="btn-test-push">發測試訊息</button>
                    </div>
                  </div>
                  <div>
                    <div class="broadcast-field-label" style="font-size:12px;">加入測試人員清單（之後可一鍵發送）</div>
                    <div class="broadcast-inline-field">
                      <input type="text" id="new-tr-label" placeholder="顯示名 e.g. Harvey" style="width:160px;" />
                      <input type="text" id="new-tr-uid" placeholder="LINE userId (U+32 hex)" style="flex:1;min-width:280px;" />
                      <button type="button" class="btn" id="btn-add-recipient">加入清單</button>
                    </div>
                    <div id="add-recipient-status" class="muted" style="font-size:12px;margin-top:4px;"></div>
                  </div>
                </div>
              </details>
            </div>

            <hr style="border:none;border-top:1px solid #e5e7eb;margin:14px 0;" />

            <div class="broadcast-field-label">正式批次送出</div>

            <div class="broadcast-field send-mode-row">
              <label class="radio-pill">
                <input type="radio" name="send-mode" value="immediate" checked />
                <span>立即送出</span>
              </label>
              <label class="radio-pill">
                <input type="radio" name="send-mode" value="scheduled" />
                <span>排程指定時間</span>
              </label>
            </div>

            <div class="broadcast-field" id="schedule-field" hidden>
              <label>
                送出時間（台灣時間）
                <input type="datetime-local" id="schedule-datetime" />
              </label>
              <div class="muted" style="font-size:12px;margin-top:4px;">
                Cron 每 5 分鐘掃一次到期任務，實際送出時間可能晚 0–5 分鐘。
              </div>
            </div>

            <div class="broadcast-action-row">
              <button type="button" class="btn btn-warning btn-large" id="btn-send">立即送出</button>
              <button type="button" class="btn" id="btn-cancel" hidden>取消這個批次</button>
            </div>
            <div id="send-progress" class="send-progress" hidden>
              <div class="progress-bar"><div class="progress-bar-inner" id="progress-bar-inner"></div></div>
              <div class="progress-meta" id="progress-meta">等待開始…</div>
            </div>
          </fieldset>
        </div>

        <aside class="broadcast-preview-side">
          <div class="preview-head">
            <h2 class="preview-heading">訊息預覽</h2>
            <span class="preview-edit-hint" title="WYSIWYG: 點預覽內任何文字即可編輯">
              <span class="preview-edit-dot"></span>點文字可編輯
            </span>
          </div>
          <p class="muted" style="font-size:12px;margin-top:4px;">編輯時自動更新 · 模擬 LINE 行動裝置卡片視覺</p>
          <div id="msg-preview-wrap" class="line-mock-wrap">
            <div id="msg-preview" class="line-mock empty">尚未有訊息內容。從上方挑一個模板，或直接編輯下方表單。</div>
          </div>
        </aside>

        <!-- floating text format toolbar (跟著 focus 的 text) -->
        <div id="text-format-toolbar" class="text-format-toolbar" hidden>
          <span class="tft-grip" title="按住拖曳移動工具列" aria-label="拖曳把手">⋮⋮</span>
          <button type="button" class="tft-btn" data-action="add-above" title="在上方插入一列文字">＋上方</button>
          <button type="button" class="tft-btn" data-action="add-below" title="在下方插入一列文字">＋下方</button>
          <button type="button" class="tft-btn" data-action="add-box" title="在下方插入一個區塊（box，可有背景色）">＋區塊</button>
          <button type="button" class="tft-btn" data-action="add-image" title="在下方插入一張圖片（從電腦上傳）">＋圖</button>
          <input type="file" id="tft-image-file" accept="image/*" hidden />
          <span class="tft-sep"></span>
          <button type="button" class="tft-btn" data-action="move-up" title="上移一格">↑</button>
          <button type="button" class="tft-btn" data-action="move-down" title="下移一格">↓</button>
          <span class="tft-sep"></span>
          <label class="tft-label" title="字級">
            <span>字</span>
            <select class="tft-size">
              <option value="xs">XS</option>
              <option value="sm">S</option>
              <option value="md" selected>M</option>
              <option value="lg">L</option>
              <option value="xl">XL</option>
              <option value="xxl">XXL</option>
              <option value="3xl">3XL</option>
            </select>
          </label>
          <label class="tft-label" title="文字顏色">
            <span>色</span>
            <input type="color" class="tft-color" value="#1f2937" />
          </label>
          <label class="tft-label" title="此文字所在區塊的背景色">
            <span>框</span>
            <input type="color" class="tft-box-bg" value="#ffffff" />
          </label>
          <button type="button" class="tft-btn tft-bold" data-action="bold" title="粗體切換"><strong>B</strong></button>
          <span class="tft-sep"></span>
          <button type="button" class="tft-btn tft-align" data-action="align-start" title="靠左">⟸</button>
          <button type="button" class="tft-btn tft-align" data-action="align-center" title="置中">⇔</button>
          <button type="button" class="tft-btn tft-align" data-action="align-end" title="靠右">⟹</button>
          <span class="tft-sep"></span>
          <button type="button" class="tft-btn tft-danger" data-action="delete-row" title="刪除這一列">刪這列</button>
          <button type="button" class="tft-btn tft-close" data-action="close" title="關閉編輯工具列">✕</button>
        </div>
      </div>
    </section>

    <section class="card system-tools-card">
      <h2>進階工具</h2>
      <a class="system-tool-link" href="/admin/line/webhooks">
        <div class="stl-body">
          <div class="stl-title">LINE Webhook 事件診斷</div>
          <div class="stl-desc">查 follow / unfollow / message 事件入站紀錄與處理結果。目前主要用於排查邀請加碼是否正確觸發。</div>
        </div>
        <div class="stl-chevron">›</div>
      </a>
      <style>
        .system-tools-card { background: #fafafa; }
        .system-tool-link {
          display: flex;
          align-items: center;
          gap: 14px;
          padding: 14px 18px;
          background: #fff;
          border: 1px solid #e5e7eb;
          border-radius: 8px;
          text-decoration: none;
          color: inherit;
          transition: border-color 0.15s, background 0.15s;
          margin-top: 8px;
        }
        .system-tool-link:hover {
          border-color: #1f2937;
          background: #fafafa;
          text-decoration: none;
        }
        .stl-body { flex: 1; min-width: 0; }
        .stl-title { font-weight: 600; color: #1f2937; font-size: 14px; margin-bottom: 2px; }
        .stl-desc { color: #6b7280; font-size: 12px; line-height: 1.5; }
        .stl-chevron { color: #9ca3af; font-size: 22px; font-weight: 300; }
      </style>
    </section>

    <section class="card">
      <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;">
        <h2 style="margin:0;">近期批次（最新 10 筆）</h2>
