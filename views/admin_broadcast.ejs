<%-
  include('layout', {
    user: user,
    isAdmin: isAdmin,
    bodyClass: bodyClass,
    body: `
    ${
      (() => {
        // 統一台灣時區格式化（sv-SE locale 給 ISO-like + 加 Asia/Taipei 時區）
        const fmtTW = (ts, len = 16) => {
          if (!ts) return '—';
          const d = new Date(ts);
          if (isNaN(d.getTime())) return '—';
          return d.toLocaleString('sv-SE', { timeZone: 'Asia/Taipei' }).slice(0, len);
        };
        const blocks = [];
        if (Array.isArray(running) && running.length > 0) {
          blocks.push(`<section class="card run-banner">
            <div class="sched-head">
              <div>
                <h2 style="margin:0;font-size:18px;">執行中的批次（${running.length}）</h2>
                <p class="muted" style="margin:4px 0 0;font-size:12px;">cron 每 5 分鐘推進一輪；卡住時可手動「立即推進」一波（每次處理最多 50 個）。</p>
              </div>
              <a href="/admin/broadcast/history" class="btn" style="font-size:12px;">完整歷史 ›</a>
            </div>
            <div class="sched-list">
              ${running.slice(0, 5).map(r => {
                const startStr = fmtTW(r.started_at);
                const pending = Number(r.pending_count || 0);
                const total = Number(r.recipient_total || 0);
                const sent = Number(r.recipient_ok || 0);
                const failed = Number(r.recipient_fail || 0);
                const skipped = Number(r.recipient_skip || 0);
                const progress = total > 0 ? Math.round(((sent + failed + skipped) / total) * 100) : 0;
                return `<div class="sched-row run-row" data-id="${r.id}">
                  <div class="sched-info">
                    <div class="sched-id">#${r.id} · 進度 ${sent + failed + skipped} / ${total} <span class="sched-eta run-eta">${progress}%</span></div>
                    <div class="sched-time">啟動 ${startStr} · 剩 ${pending} 待發 · 失敗 ${failed}</div>
                  </div>
                  <div class="sched-actions">
                    <a href="/admin/broadcast/${r.id}" class="sched-detail-link">查看</a>
                    <button type="button" class="sched-advance-btn" data-id="${r.id}">立即推進</button>
                    <button type="button" class="sched-cancel-btn" data-id="${r.id}">取消</button>
                  </div>
                </div>`;
              }).join('')}
            </div>
          </section>`);
        }
        if (Array.isArray(scheduled) && scheduled.length > 0) {
          blocks.push(`<section class="card sched-banner">
            <div class="sched-head">
              <div>
                <h2 style="margin:0;font-size:18px;">排程中的訊息（${scheduled.length}）</h2>
                <p class="muted" style="margin:4px 0 0;font-size:12px;">尚未發出，可隨時取消。時間到後 cron 每 5 分鐘檢查一次自動發送。</p>
              </div>
              <a href="/admin/broadcast/history" class="btn" style="font-size:12px;">完整歷史 ›</a>
            </div>
            <div class="sched-list">
              ${scheduled.slice(0, 5).map(r => {
                const sched = r.scheduled_at ? new Date(r.scheduled_at) : null;
                const schedStr = fmtTW(r.scheduled_at);
                let etaStr = '—';
                if (sched) {
                  const diffMs = sched.getTime() - Date.now();
                  if (diffMs < 0) etaStr = '<span style="color:#dc2626;">已到時間，系統將在 5 分鐘內送出</span>';
                  else if (diffMs < 60000) etaStr = '< 1 分鐘';
                  else if (diffMs < 3600000) etaStr = Math.floor(diffMs / 60000) + ' 分鐘後';
                  else if (diffMs < 86400000) etaStr = Math.floor(diffMs / 3600000) + ' 小時後';
                  else etaStr = Math.floor(diffMs / 86400000) + ' 天後';
                }
                return `<div class="sched-row" data-id="${r.id}">
                  <div class="sched-info">
                    <div class="sched-id">#${r.id} · ${r.recipient_total || 0} 人</div>
                    <div class="sched-time">${schedStr} <span class="sched-eta">${etaStr}</span></div>
                  </div>
                  <div class="sched-actions">
                    <a href="/admin/broadcast/${r.id}" class="sched-detail-link">查看</a>
                    <button type="button" class="sched-cancel-btn" data-id="${r.id}">取消</button>
                  </div>
                </div>`;
              }).join('')}
              ${scheduled.length > 5 ? `<a href="/admin/broadcast/history" class="sched-more">還有 ${scheduled.length - 5} 筆 →</a>` : ''}
            </div>
          </section>`);
        }
        return blocks.join('');
      })()
    }

    <section class="card broadcast-card">
      ${
        (typeof msgLibMode !== 'undefined' && msgLibMode)
          ? `<div class="msglib-bar">
              <div class="msglib-bar-left">
                <a href="/admin/messages" class="msglib-back">← 返回訊息庫</a>
                <input type="text" id="msglib-name" placeholder="訊息名稱（內部辨識用）" maxlength="200" />
              </div>
              <div class="msglib-bar-right">
                <span id="msglib-status" class="muted" style="font-size:13px;"></span>
                <button type="button" class="btn btn-warning" id="msglib-save">儲存到訊息庫</button>
              </div>
            </div>`
          : ''
      }
      <div class="broadcast-page-head">
        <h1>群發訊息</h1>
        <p class="page-subtitle">四步驟 · ① 選通道 · ② 選收件人 · ③ 編訊息（含預覽即時更新 / 點文字直接編輯） · ④ 先測試再正式送</p>
      </div>

      ${
        !hasLineToken
          ? `<p class="error-banner">尚未設定 <code>LINE_CHANNEL_ACCESS_TOKEN</code>，無法實際送出訊息。可先預覽人數與訊息樣式。</p>`
          : ''
      }

      <div class="broadcast-grid">
        <div class="broadcast-form">
          <fieldset class="broadcast-step" id="bc-channel-step">
            <legend><span class="step-pill">1</span> 通道</legend>
            <div class="broadcast-tabs channel-tabs">
              <button type="button" class="tab-btn active" data-channel="line">LINE 推播</button>
              <button type="button" class="tab-btn" data-channel="email">Email 信件</button>
            </div>
            <div class="muted" style="font-size:12px;margin-top:6px;">
              <span class="channel-hint-line">送到使用者的 LINE 聊天視窗。每月免費額度由 LINE OA 方案決定。</span>
              <span class="channel-hint-email" hidden>用 Brevo 送信，免費 9,000 封/月（300/日）。需先設定 <code>BREVO_API_KEY</code> 與已驗證的 sender。Email 通道需從「名單庫」選一份含 email 的名單。</span>
            </div>
          </fieldset>

          <fieldset class="broadcast-step" id="bc-audience-step">
            <legend><span class="step-pill">2</span> 收件人</legend>

            <div class="broadcast-tabs audience-tabs">
              <button type="button" class="tab-btn active" data-audience="conditions">條件篩選</button>
              <button type="button" class="tab-btn" data-audience="saved_list">已儲存名單</button>
              <button type="button" class="tab-btn" data-audience="upload">上傳新名單</button>
            </div>

            <div class="audience-pane" id="audience-pane-conditions">

            <div class="broadcast-field" style="background:#FFFBEB;border:1px solid #FDE68A;border-radius:8px;padding:12px;">
              <label class="broadcast-inline-field" style="font-weight:600;">
                <input type="checkbox" id="all-members" />
                <span>發送給全部會員</span>
              </label>
              <div class="muted" style="font-size:12px;margin-top:4px;">勾選後忽略下方的獎品/邀請/刮獎條件（可搭配「加入時間」一起用）。</div>
              <div class="broadcast-inline-field" style="margin-top:10px;">
                <span>加入時間</span>
                <select id="joined-within" style="width:160px;">
                  <option value="">不限</option>
                  <option value="1">1 天內加入</option>
                  <option value="7">7 天內加入</option>
                  <option value="30">30 天內加入</option>
                  <option value="90">90 天內加入</option>
                </select>
              </div>
            </div>

            <div class="broadcast-field" id="behavior-conditions">
              <div class="broadcast-field-label">活躍程度（生命週期階段，可多選）</div>
              <div class="lifecycle-checkbox-list">
                <label class="chip-checkbox">
                  <input type="checkbox" name="lifecycle_stage" value="new" />
                  <span>新客（14 天內剛加入）</span>
                </label>
                <label class="chip-checkbox">
                  <input type="checkbox" name="lifecycle_stage" value="active" />
                  <span>活躍（30 天內有互動）</span>
                </label>
                <label class="chip-checkbox">
                  <input type="checkbox" name="lifecycle_stage" value="sleeping" />
                  <span>沉睡（30 至 90 天沒互動）</span>
                </label>
                <label class="chip-checkbox">
                  <input type="checkbox" name="lifecycle_stage" value="lost" />
                  <span>流失（超過 90 天沒互動）</span>
                </label>
              </div>
              <div class="muted" style="font-size:12px;margin:0 0 14px;">不勾＝不限。互動包含：加好友、玩遊戲、點推播、點餐廳、傳訊息、用「今天吃什麼」。</div>

              <div class="broadcast-field-label">中過獎品（可多選）</div>
              <div class="prize-checkbox-list">
                ${
                  Array.isArray(prizes) && prizes.length > 0
                    ? prizes
                        .map(
                          p => {
                            const nm = String(p.name == null ? '' : p.name).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
                            return `<label class="chip-checkbox">
                            <input type="checkbox" name="prize_name" value="${nm}" />
                            <span>${nm}</span>
                          </label>`;
                          }
                        )
                        .join('')
                    : '<span class="muted">目前沒有可選獎品</span>'
                }
              </div>
              <div class="broadcast-inline-field">
                <label>
                  比對方式
                  <select name="prize_mode" id="prize-mode">
                    <option value="any">中過其中至少一項</option>
                    <option value="all">中過全部勾選的獎品</option>
                    <option value="none">沒中過任何勾選的獎品</option>
                  </select>
                </label>
              </div>
            </div>

            <div class="broadcast-field">
              <label class="broadcast-inline-field">
                <span>邀請好友成功數 ≥</span>
                <input type="number" id="invite-min" min="0" max="1000" placeholder="留空 = 不限" style="width:120px;" />
                <span class="muted">（line_invites.status = rewarded）</span>
              </label>
            </div>

            <div class="broadcast-field">
              <label class="broadcast-inline-field">
                <span>活動期間刮獎狀況</span>
                <select id="drew-in-campaign">
                  <option value="">不限</option>
                  <option value="true">有刮過獎</option>
                  <option value="false">從未刮過</option>
                </select>
              </label>
            </div>

            </div><!-- /audience-pane-conditions -->

            <div class="audience-pane" id="audience-pane-saved_list" hidden>
              <div class="broadcast-field">
                <label>
                  選擇已儲存名單
                  <select id="saved-list-select">
                    <option value="">— 載入中 —</option>
                  </select>
                </label>
              </div>
              <div class="broadcast-action-row" style="margin-top:6px;">
                <button type="button" class="btn link-btn" id="btn-delete-saved-list" hidden style="color:#dc2626;">刪除這份名單</button>
              </div>
            </div>

            <div class="audience-pane" id="audience-pane-upload" hidden>
              <div class="broadcast-field">
                <label>
                  名單顯示名
                  <input type="text" id="upload-list-name" maxlength="200" placeholder="例如：2026-05 Rice $100 中獎者" />
                </label>
              </div>
              <div class="broadcast-field">
                <label>
                  說明（選填）
                  <input type="text" id="upload-list-desc" maxlength="500" placeholder="這份名單從哪來、要做什麼用" />
                </label>
              </div>
              <div class="broadcast-field">
                <label>
                  LINE userId 清單（一行一個 U + 32 hex；或貼 CSV，會自動忽略其他欄位／空白）
                  <textarea id="upload-list-uids" rows="8" placeholder="Ua59ae887867bfe0a26c6a41616fa4f66&#10;U72b796db38442742d09386bc8d1ac524&#10;..." spellcheck="false" style="font-family:monospace;font-size:12px;"></textarea>
                </label>
                <div id="upload-list-counter" class="muted" style="font-size:12px;margin-top:4px;">已輸入 0 個 UID</div>
              </div>
              <div class="broadcast-action-row">
                <button type="button" class="btn btn-warning" id="btn-upload-list">儲存名單</button>
                <div id="upload-list-status" class="muted" style="font-size:13px;">尚未儲存</div>
              </div>
            </div>

            <div class="broadcast-action-row" style="margin-top:14px;border-top:1px solid #fde68a;padding-top:12px;">
              <button type="button" class="btn btn-warning" id="btn-preview-audience">預覽收件人</button>
              <div id="audience-status" class="audience-status muted">尚未預覽</div>
            </div>
            <div id="audience-sample" class="audience-sample" hidden></div>
          </fieldset>

          <fieldset class="broadcast-step">
            <legend><span class="step-pill">3</span> 訊息內容</legend>

            <!-- Email 專屬：主旨 + 寄件人欄位（channel='email' 時顯示）-->
            <div class="email-only-fields" hidden>
              <div class="broadcast-field">
                <div class="broadcast-field-label">主旨 <span class="muted" style="font-weight:400;">（必填，最多 200 字）</span></div>
                <input type="text" id="email-subject" name="email_subject" maxlength="200" placeholder="例：OpenRice 春日限定優惠 — 滿 $500 折 $100" style="width:100%;padding:10px 12px;border:1px solid #E5E7EB;border-radius:8px;font-size:14px;box-sizing:border-box;">
              </div>
              <div class="broadcast-inline-field" style="gap:12px;">
                <div class="broadcast-field" style="flex:1;">
                  <div class="broadcast-field-label">寄件人名稱 <span class="muted" style="font-weight:400;">（選填）</span></div>
                  <input type="text" id="email-from-name" name="email_from_name" maxlength="100" placeholder="OpenRice 開飯喇（留空用預設）" style="width:100%;padding:10px 12px;border:1px solid #E5E7EB;border-radius:8px;font-size:14px;box-sizing:border-box;">
                </div>
                <div class="broadcast-field" style="flex:1;">
                  <div class="broadcast-field-label">寄件人 Email <span class="muted" style="font-weight:400;">（選填）</span></div>
                  <input type="text" id="email-from-address" name="email_from_address" maxlength="200" placeholder="noreply@openrice.tw（留空用預設）" style="width:100%;padding:10px 12px;border:1px solid #E5E7EB;border-radius:8px;font-size:14px;box-sizing:border-box;">
                </div>
              </div>
              <div class="muted" style="font-size:12px;margin-bottom:12px;">寄件人 email 必須是已在 Brevo 驗證過的，否則會送失敗。</div>
            </div>

            <div class="template-picker">
              <div class="template-picker-head">
                <span class="template-picker-title">挑一個模板開始（或從頭編輯下方表單）</span>
                <div class="template-picker-actions">
                  <button type="button" id="btn-save-template" class="link-btn">儲存目前為新模板</button>
                  <button type="button" id="btn-delete-template" class="link-btn" hidden style="color:#dc2626;">刪除目前模板</button>
                </div>
              </div>
              <div id="template-grid" class="template-grid">
                <div class="muted" style="font-size:12px;padding:8px 0;">載入模板中…</div>
              </div>
              <select id="template-select" hidden><option value="">—</option></select>
            </div>

            <div class="draft-bar">
              <span class="draft-bar-hint">草稿自動儲存：這區塊填的內容會記住，下次回來自動帶回</span>
              <span id="draft-status-time" class="muted">尚未儲存</span>
              <button type="button" id="btn-clear-draft" class="link-btn">清除草稿</button>
            </div>

            <div class="ab-variant-label" id="variant-a-label" hidden>
              <strong>版本 A</strong>（50% 收件人）
            </div>

            <!-- 通知預覽文字（altText）— 兩種 mode 共用，模板載入時也會帶過來，可隨時改 -->
            <div class="broadcast-field channel-line-only" style="background:#FFFBEB;border:1px solid #FDE68A;border-radius:8px;padding:10px 12px;margin-bottom:14px;">
              <label style="display:block;">
                <span style="font-size:12px;font-weight:600;color:#92400E;">📱 LINE 通知預覽文字（altText）</span>
                <input type="text" id="msg-alt-text" maxlength="400" placeholder="留空自動用標題；改這裡馬上同步到要送的訊息" style="margin-top:6px;width:100%;padding:8px 10px;border:1px solid #FDE68A;border-radius:6px;font-size:14px;box-sizing:border-box;" />
                <span class="muted" style="font-size:11px;margin-top:4px;display:block;">這是用戶在 LINE 通知列和聊天列表看到的文字。Flex JSON 模式也會覆蓋 JSON 內的 altText。</span>
              </label>
            </div>

            <div class="broadcast-tab-pane" id="pane-template">
              <div class="broadcast-field">
                <div class="broadcast-field-label">Hero 圖（選填，PNG/JPEG，≤2MB）</div>
                <div class="broadcast-inline-field">
                  <input type="file" id="hero-file" accept="image/png,image/jpeg" />
                  <button type="button" class="btn" id="btn-hero-upload">上傳</button>
                  <span id="hero-status" class="muted">未上傳</span>
                </div>
                <div class="muted" style="font-size:12px;margin-top:4px;">
                  未上傳會自動套 OpenRice 黃色品牌 bar（細條 header），同時用於追蹤開信率。
                </div>
              </div>

              <div class="broadcast-field">
                <label>
                  標題
                  <input type="text" id="tpl-title" maxlength="100" placeholder="例如：OpenRice 春日饗里活動更新" />
                </label>
              </div>
              <div class="broadcast-field">
                <label>
                  副標題（可換行）
                  <textarea id="tpl-subtitle" maxlength="500" rows="3" placeholder="主訊息／活動細節說明"></textarea>
                </label>
              </div>
              <div class="broadcast-field">
                <label>
                  優惠碼（選填，會顯示為置中的「強調框」）
                  <input type="text" id="tpl-coupon-code" maxlength="60" placeholder="例如：spring100" />
                </label>
                <div class="muted field-hint">
                  在 LINE 上用戶點此框會自動複製到剪貼簿，方便他們貼到 OpenRice 兌換頁。
                </div>
              </div>
              <div class="broadcast-field">
                <label>
                  注意事項（選填，顯示為小灰字）
                  <input type="text" id="tpl-disclaimer" maxlength="300" placeholder="例如：每位會員限使用一次，使用期限 30 天" />
                </label>
                <div class="muted field-hint">
                  多個項目用「<code>*</code>」隔開（譬如 <code>*項目A *項目B *項目C</code>），LINE 上會自動拆成
                  <code>•</code> bullet 換行顯示。
                </div>
              </div>
              <div class="broadcast-field">
                <label>
                  CTA 按鈕文字（≤40 字）
                  <input type="text" id="tpl-cta-label" maxlength="40" placeholder="例如：立即查看活動" />
                </label>
              </div>
              <div class="broadcast-field">
                <label>
                  CTA 連結（https:// 開頭）
                  <input type="url" id="tpl-cta-url" placeholder="https://tw.openrice.com/..." />
                </label>
              </div>
              <!-- altText 欄位移到上方 #msg-alt-text（兩種模式共用） -->
              <input type="hidden" id="tpl-alt" />
            </div>

            <details class="advanced-json-block" id="advanced-json-block">
              <summary>這則訊息的內容設定（圖片與連結）</summary>
              <div class="broadcast-tab-pane" id="pane-flex-json">
              <div style="background:#FFFBEB;color:#92400E;font-size:12px;padding:8px 10px;border-radius:8px;margin-bottom:10px;">想改文字？直接點右側預覽裡的文字就能修改。這區只需要用助手換圖片和連結。</div>
              <div id="json-image-helper" class="json-image-helper" hidden>
                <div class="json-image-helper-head">
                  <span>圖片上傳助手（自動偵測 JSON 內 <code>REPLACE_*</code> 圖片位置）</span>
                  <button type="button" id="btn-scan-json-images" class="link-btn">重新掃描</button>
                </div>
                <div id="json-image-list"></div>
              </div>
              <div id="json-url-helper" class="json-url-helper" hidden>
                <div class="json-url-helper-head">
                  <span>URL 填寫助手（自動偵測 JSON 內 <code>REPLACE_*</code> 連結位置）</span>
                </div>
                <div id="json-url-list"></div>
              </div>
              <details class="json-textarea-block">
                <summary>直接編輯 Flex JSON（一般不需要動，填完上方助手即可）</summary>
                <div class="broadcast-field">
                  <label>
                    Flex JSON（root 必含 type:"flex", altText, contents）
                    <textarea id="flex-json" rows="14" placeholder='{ "type": "flex", "altText": "...", "contents": { "type": "bubble", ... } }' spellcheck="false"></textarea>
                  </label>
                </div>
              </details>
              </div>
            </details>

            <details class="advanced-settings-block">
              <summary>進階設定：A/B test 分組發送</summary>
              <div class="ab-test-toggle-bar">
                <label class="ab-toggle-label">
                  <input type="checkbox" id="ab-test-enable" />
