      /* floating text format toolbar */
      .text-format-toolbar {
        position: absolute;
        z-index: 1000;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 4px;
        padding: 5px 8px;
        background: #1f2937;
        color: #fff;
        border-radius: 8px;
