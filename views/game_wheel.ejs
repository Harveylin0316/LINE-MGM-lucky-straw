<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#FFFFFF" />
  <title><%= title %></title>
  <script src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>
  <style>
    :root {
      --or-yellow: #FCC726;
      --or-red:    #E81E25;
      --ink:       #0A0A0A;
      --ink-2:     #595959;
      --ink-3:     #B3B3B3;
      --line:      #0A0A0A;
      --bg:        #FFFFFF;
    }
    * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
    html, body { margin: 0; padding: 0; background: var(--bg); }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "PingFang TC", "Microsoft JhengHei", sans-serif;
      color: var(--ink);
      min-height: 100vh;
      letter-spacing: -0.005em;
    }

    .page {
      max-width: 480px;
      margin: 0 auto;
      padding: 28px 24px 48px;
    }

    /* ----- Header（編輯設計風：左對齊大字 + 細線分隔） ----- */
    .head {
      padding-bottom: 20px;
      border-bottom: 1px solid var(--line);
      margin-bottom: 32px;
    }
    .head .meta {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--ink-2);
      margin-bottom: 14px;
      font-weight: 500;
    }
    .head .meta .no { font-variant-numeric: tabular-nums; }
    .head h1 {
      margin: 0 0 8px;
      font-size: 36px;
      font-weight: 800;
      letter-spacing: -0.04em;
      line-height: 1.05;
    }
    .head p {
      margin: 0;
      font-size: 14px;
      line-height: 1.55;
      color: var(--ink-2);
      max-width: 28em;
    }
    .head .cover {
      width: 100%;
      max-width: 320px;
      aspect-ratio: 16 / 9;
      object-fit: cover;
      display: block;
      margin-top: 16px;
    }

    /* ----- Stage ----- */
    .stage-outer {
      display: flex;
      justify-content: center;
      padding: 12px 0 8px;
    }
    .stage {
      position: relative;
      width: min(82vw, 320px);
      aspect-ratio: 1;
    }
    /* 指針：純黑小三角，最低限度的形狀 */
    .pointer {
      position: absolute;
      top: -8px;
      left: 50%;
      transform: translateX(-50%);
      width: 0;
      height: 0;
      border-left: 9px solid transparent;
      border-right: 9px solid transparent;
      border-top: 18px solid var(--ink);
      z-index: 5;
    }
    .canvas-wrap {
      position: relative;
      width: 100%;
      height: 100%;
      border-radius: 50%;
      overflow: hidden;
    }
    #wheel {
      width: 100%;
      height: 100%;
      display: block;
      transition: transform 5.6s cubic-bezier(0.16, 0.74, 0.24, 1);
    }
    /* 中央按鈕：純黑圓鈕、白字。按下 invert */
    .center {
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      width: 26%;
      height: 26%;
      z-index: 4;
    }
    .spin-btn {
      width: 100%;
      height: 100%;
      border-radius: 50%;
      border: none;
      background: var(--ink);
      color: var(--bg);
      font-family: inherit;
      font-weight: 700;
      font-size: 15px;
      letter-spacing: 0.12em;
      cursor: pointer;
      transition: transform 0.15s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .spin-btn:active:not(:disabled) {
      transform: scale(0.92);
    }
    .spin-btn:disabled {
      cursor: default;
      background: var(--ink-3);
    }

    /* ----- Status line：印刷感 ----- */
    .status {
      margin: 28px 0 0;
      text-align: center;
      font-size: 13px;
      color: var(--ink-2);
      min-height: 18px;
      font-variant-numeric: tabular-nums;
    }
    .status strong { color: var(--ink); font-weight: 600; }

    /* ----- Prize list：純粹清單，黑線分隔 ----- */
    .prize-section {
      margin-top: 48px;
      padding-top: 20px;
      border-top: 1px solid var(--line);
    }
    .prize-section .label {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--ink-2);
      margin-bottom: 16px;
      font-weight: 500;
    }
    .prize-list { list-style: none; margin: 0; padding: 0; }
    .prize-row {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      padding: 14px 0;
      border-bottom: 1px solid #E8E8E8;
      gap: 12px;
    }
    .prize-row:last-child { border-bottom: none; }
    .prize-left { display: flex; align-items: baseline; gap: 12px; flex: 1; min-width: 0; }
    .prize-num {
      font-size: 11px;
      color: var(--ink-3);
      font-variant-numeric: tabular-nums;
      flex-shrink: 0;
      min-width: 18px;
    }
    .prize-name {
      font-size: 15px;
      font-weight: 600;
      color: var(--ink);
      line-height: 1.3;
    }
    .prize-row.grand .prize-name { color: var(--or-red); }
    .prize-tag {
      font-size: 12px;
      color: var(--ink-2);
      margin-top: 2px;
    }
    .prize-mark {
      flex-shrink: 0;
      font-size: 11px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--or-red);
      font-weight: 700;
    }

    /* ----- Footer ----- */
    .foot {
      margin-top: 40px;
      padding-top: 16px;
      border-top: 1px solid #E8E8E8;
      text-align: center;
      font-size: 11px;
      color: var(--ink-3);
      letter-spacing: 0.05em;
    }

    /* ----- Result modal：iOS sheet 但極簡 ----- */
    .modal {
      position: fixed;
      inset: 0;
      z-index: 100;
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.3s ease;
      background: rgba(10, 10, 10, 0.55);
      display: flex;
      align-items: flex-end;
      justify-content: center;
    }
    .modal.open { opacity: 1; pointer-events: auto; }
    .sheet {
      width: 100%;
      max-width: 480px;
      background: var(--bg);
      border-radius: 24px 24px 0 0;
      padding: 20px 28px 32px;
      padding-bottom: max(32px, env(safe-area-inset-bottom));
      transform: translateY(100%);
      transition: transform 0.5s cubic-bezier(0.32, 0.72, 0, 1);
    }
    .modal.open .sheet { transform: translateY(0); }
    .handle {
      width: 36px; height: 4px;
      border-radius: 999px;
      background: #D9D9D9;
      margin: 0 auto 26px;
    }
    .modal-eyebrow {
      text-align: center;
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--ink-2);
      margin-bottom: 12px;
      font-weight: 500;
    }
    .modal-prize {
      text-align: center;
      font-size: 36px;
      font-weight: 800;
      letter-spacing: -0.035em;
      color: var(--ink);
      margin-bottom: 12px;
      line-height: 1.1;
    }
    .modal.grand .modal-prize { color: var(--or-red); }
    .modal-img-wrap {
      width: 80px;
      height: 80px;
      margin: 0 auto 18px;
      border-radius: 50%;
      background: var(--or-yellow);
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    .modal.grand .modal-img-wrap { background: var(--or-red); }
    .modal-img-wrap img { width: 100%; height: 100%; object-fit: cover; }
    .modal-img-wrap .glyph {
      font-size: 32px;
      color: var(--ink);
      font-weight: 700;
    }
    .modal.grand .modal-img-wrap .glyph { color: #FFFFFF; }
    .modal-desc {
      text-align: center;
      color: var(--ink-2);
      font-size: 14px;
      line-height: 1.6;
      margin-bottom: 28px;
    }
    .modal-btn {
      display: block;
      width: 100%;
      padding: 16px;
      background: var(--ink);
      color: var(--bg);
      border: none;
      border-radius: 0;
      font-size: 15px;
      font-weight: 700;
      font-family: inherit;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      cursor: pointer;
      transition: transform 0.15s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .modal-btn:active { transform: scale(0.98); }
  </style>
</head>
<body>
  <div class="page">

    <header class="head">
      <div class="meta">
        <span>OpenRice · 抽獎</span>
        <span class="no" id="head-no">№ <%= activity.id %></span>
      </div>
      <h1><%= activity.name %></h1>
      <% if (activity.description) { %>
        <p><%= activity.description %></p>
      <% } %>
      <% if (activity.cover_image_url) { %>
        <img class="cover" src="<%= activity.cover_image_url %>" alt="" />
      <% } %>
    </header>

    <div class="stage-outer">
      <div class="stage">
        <div class="pointer"></div>
        <div class="canvas-wrap">
          <canvas id="wheel" width="720" height="720"></canvas>
        </div>
        <div class="center">
          <button type="button" id="spin-btn" class="spin-btn">SPIN</button>
        </div>
      </div>
    </div>

    <p class="status" id="status">準備中</p>

    <% if (prizes && prizes.length > 0) { %>
    <section class="prize-section">
      <div class="label">
        <span>獎項</span>
        <span><%= prizes.length %> 項</span>
      </div>
      <ul class="prize-list">
        <% prizes.forEach(function (p, i) { %>
          <li class="prize-row <%= p.is_grand_prize ? 'grand' : '' %>">
            <div class="prize-left">
              <span class="prize-num"><%= String(i + 1).padStart(2, '0') %></span>
              <div>
                <div class="prize-name"><%= p.name %></div>
                <% if (p.description) { %>
                  <div class="prize-tag"><%= p.description %></div>
                <% } %>
              </div>
            </div>
            <% if (p.is_grand_prize) { %>
              <span class="prize-mark">頭獎</span>
            <% } %>
          </li>
        <% }); %>
      </ul>
    </section>
    <% } %>

    <% if (activity.daily_plays_per_user != null) { %>
      <p class="foot">每人每天可抽 <%= activity.daily_plays_per_user %> 次</p>
    <% } %>

  </div>

  <!-- Result -->
  <div id="modal" class="modal" aria-hidden="true">
    <div class="sheet">
      <div class="handle"></div>
      <div class="modal-eyebrow">抽中</div>
      <div class="modal-img-wrap" id="modal-img-wrap">
        <img id="modal-img" alt="" hidden />
        <span class="glyph" id="modal-glyph">★</span>
      </div>
      <div class="modal-prize" id="modal-prize">—</div>
      <div class="modal-desc" id="modal-desc"></div>
      <button type="button" class="modal-btn" id="modal-close">完成</button>
    </div>
  </div>

  <script>
    (function () {
      var slug = <%- JSON.stringify(activity.slug) %>;
      var liffId = <%- JSON.stringify(liffId || '') %>;
      var prizes = <%- JSON.stringify(prizes || []) %>;

      var canvas = document.getElementById('wheel');
      var ctx = canvas.getContext('2d');
      var spinBtn = document.getElementById('spin-btn');
      var statusEl = document.getElementById('status');
      var modal = document.getElementById('modal');

      var spinning = false;
      var currentRotation = 0;
      var profile = null;
      var liffReady = false;

      // ===========================================================
      // 畫輪盤 — 純色 + 黑線、無漸層、無 shadow、無 LED 點點
      // ===========================================================
      function drawWheel() {
        var W = canvas.width;
        var H = canvas.height;
        var cx = W / 2, cy = H / 2;
        var R = W / 2 - 2;
        var n = prizes.length;
        var anglePer = (Math.PI * 2) / n;

        ctx.clearRect(0, 0, W, H);

        // 1) 扇形 — 純色：白 / 黃 / 紅(大獎)
        prizes.forEach(function (p, i) {
          var start = i * anglePer - Math.PI / 2;
          var end = start + anglePer;
          ctx.beginPath();
          ctx.moveTo(cx, cy);
          ctx.arc(cx, cy, R, start, end);
          ctx.closePath();

          if (p.is_grand_prize) ctx.fillStyle = '#E81E25';
          else ctx.fillStyle = (i % 2 === 0) ? '#FFFFFF' : '#FCC726';
          ctx.fill();
        });

        // 2) 扇形之間的黑線分隔（編輯設計感）
        prizes.forEach(function (p, i) {
          var angle = i * anglePer - Math.PI / 2;
          ctx.beginPath();
          ctx.moveTo(cx, cy);
          ctx.lineTo(cx + Math.cos(angle) * R, cy + Math.sin(angle) * R);
          ctx.lineWidth = 2;
          ctx.strokeStyle = '#0A0A0A';
          ctx.stroke();
        });

        // 3) 外圈黑線
        ctx.beginPath();
        ctx.arc(cx, cy, R, 0, Math.PI * 2);
        ctx.lineWidth = 3;
        ctx.strokeStyle = '#0A0A0A';
        ctx.stroke();

        // 4) 文字 — 粗黑體、水平擺放
        prizes.forEach(function (p, i) {
          var start = i * anglePer - Math.PI / 2;
          var midAngle = start + anglePer / 2;
          var textRadius = R * 0.65;

          ctx.save();
          ctx.translate(cx, cy);
          ctx.rotate(midAngle);
          ctx.translate(textRadius, 0);
          ctx.rotate(-midAngle);

          ctx.textAlign = 'center';
          ctx.textBaseline = 'middle';
          ctx.fillStyle = p.is_grand_prize ? '#FFFFFF' : '#0A0A0A';
          ctx.font = '800 22px -apple-system, "SF Pro Display", "PingFang TC", sans-serif';

          var label = String(p.name || '');
          if (label.length > 8) label = label.slice(0, 8) + '…';
          ctx.fillText(label, 0, 0);
          ctx.restore();
        });
      }

      // ----- LIFF init -----
      async function initLiff() {
        var qs = new URLSearchParams(location.search);
        var devUid = qs.get('uid');
        if (devUid) {
          profile = { userId: devUid, displayName: qs.get('name') || 'DEV' };
          return;
        }
        if (qs.get('preview') === '1') {
          profile = { userId: 'PREVIEW', displayName: '預覽' };
          spinBtn.disabled = true;
          spinBtn.textContent = '預覽';
          return;
        }
        if (!liffId) {
          throw new Error('LIFF ID 未設定');
        }
        try {
          await liff.init({ liffId: liffId });
        } catch (e) {
          throw new Error('LIFF 初始化失敗');
        }
        if (!liff.isInClient()) {
          throw new Error('請在 LINE App 內打開');
        }
        if (!liff.isLoggedIn()) {
          liff.login();
          return new Promise(function () {});
        }
        profile = await liff.getProfile();
      }

      // ----- 旋轉動畫 -----
      function animateToPrize(prize) {
        var n = prizes.length;
        if (n === 0) return Promise.resolve();
        var idx = prizes.findIndex(function (p) { return p.id === prize.id; });
        if (idx < 0) idx = 0;
        var anglePer = 360 / n;
        var targetCenter = (idx + 0.5) * anglePer;
        var jitter = (Math.random() - 0.5) * (anglePer * 0.5);
        var finalAngle = currentRotation + 360 * 6 + (360 - targetCenter) + jitter;
        currentRotation = finalAngle;
        canvas.style.transform = 'rotate(' + finalAngle + 'deg)';
        return new Promise(function (resolve) { setTimeout(resolve, 5700); });
      }

      // ----- spin -----
      async function spin() {
        if (spinning) return;
        if (!liffReady || !profile) {
          statusEl.textContent = '稍等';
          return;
        }
        spinning = true;
        spinBtn.disabled = true;
        statusEl.textContent = '抽選中';

        try {
          var resp = await fetch('/api/games/wheel/' + encodeURIComponent(slug) + '/spin', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              line_user_id: profile.userId,
              line_display_name: profile.displayName || null
            })
          }).then(function (r) { return r.json(); });

          if (!resp.ok) {
            statusEl.textContent = resp.detail || resp.error || '抽選失敗';
            spinning = false;
            spinBtn.disabled = false;
            return;
          }

          await animateToPrize(resp.prize);
          showResult(resp.prize);
        } catch (e) {
          statusEl.textContent = '錯誤';
        } finally {
          spinning = false;
          spinBtn.disabled = false;
        }
      }

      function showResult(prize) {
        statusEl.textContent = '';
        document.getElementById('modal-prize').textContent = prize.name || '—';
        var imgEl = document.getElementById('modal-img');
        var glyphEl = document.getElementById('modal-glyph');
        if (prize.image_url) {
          imgEl.src = prize.image_url;
          imgEl.hidden = false;
          glyphEl.style.display = 'none';
        } else {
          imgEl.hidden = true;
          glyphEl.style.display = 'block';
          glyphEl.textContent = prize.is_grand_prize ? '★' : '◆';
        }
        var descParts = [];
        if (prize.prize_value) {
          if (prize.prize_value.amount) descParts.push('NT$ ' + prize.prize_value.amount);
          if (prize.prize_value.code) descParts.push('優惠碼 ' + prize.prize_value.code);
          if (prize.prize_value.label) descParts.push(prize.prize_value.label);
          if (prize.prize_value.note) descParts.push(prize.prize_value.note);
        }
        document.getElementById('modal-desc').textContent = descParts.join('  ／  ');
        if (prize.is_grand_prize) modal.classList.add('grand');
        else modal.classList.remove('grand');
        requestAnimationFrame(function () { modal.classList.add('open'); });
      }

      document.getElementById('modal-close').addEventListener('click', function () {
        modal.classList.remove('open');
      });
      modal.addEventListener('click', function (e) {
        if (e.target === modal) modal.classList.remove('open');
      });

      spinBtn.addEventListener('click', spin);

      // ----- bootstrap -----
      if (prizes.length < 2) {
        statusEl.textContent = '獎品不足';
        spinBtn.disabled = true;
        spinBtn.textContent = '—';
      } else {
        drawWheel();
        spinBtn.disabled = true;
        statusEl.textContent = '驗證身分';
      }

      (async function () {
        if (prizes.length < 2) return;
        try {
          await initLiff();
          liffReady = true;
          spinBtn.disabled = false;
          statusEl.innerHTML = '哈囉 <strong>' + (profile.displayName || '') + '</strong>　|　按下中央按鈕';
        } catch (e) {
          statusEl.textContent = e.message || '初始化失敗';
        }
      })();
    })();
  </script>
</body>
</html>
