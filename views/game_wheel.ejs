<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#F5F2EC" />
  <title><%= title %></title>
  <script src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>
  <style>
    :root {
      /* OpenRice 品牌色系：黃主 / 紅副 / 白底 */
      --or-yellow:      #FCC726;
      --or-yellow-2:    #F5B800;
      --or-yellow-3:    #C68F00;
      --or-yellow-soft: #FFF4D1;
      --or-red:         #E81E25;
      --or-red-2:       #C0151B;
      --or-red-soft:    #FDECEC;
      --surface:        #FFFFFF;
      --bg-1:           #FFFFFF;
      --bg-2:           #FFF8E1;
      --ink:            #1D1D1F;
      --ink-2:          #6E6E73;
      --ink-3:          #B8B8BD;
      --shadow-1:       0 8px 24px rgba(232, 30, 37, 0.08);
      --shadow-2:       0 20px 50px rgba(232, 30, 37, 0.18);
    }
    * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
    html, body { margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "SF Pro Text",
        "PingFang TC", "Microsoft JhengHei", sans-serif;
      color: var(--ink);
      min-height: 100vh;
      background: var(--bg-1);
      letter-spacing: -0.01em;
      overflow-x: hidden;
    }
    /* 白底 + 上方黃色 spotlight + 底部紅色微光 */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background:
        radial-gradient(ellipse 90% 55% at 50% 0%, rgba(252, 199, 38, 0.32) 0%, transparent 60%),
        radial-gradient(ellipse 70% 45% at 50% 100%, rgba(232, 30, 37, 0.06) 0%, transparent 60%),
        var(--bg-1);
      z-index: -2;
    }
    /* 細微黃點 pattern */
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      background-image: radial-gradient(circle, rgba(252, 199, 38, 0.18) 1px, transparent 1.5px);
      background-size: 26px 26px;
      z-index: -1;
      pointer-events: none;
    }

    /* ---------- Page Layout ---------- */
    .w-app {
      max-width: 480px;
      margin: 0 auto;
      padding: 24px 20px 48px;
      position: relative;
    }

    /* ---------- Header ---------- */
    .w-header { text-align: center; padding: 8px 0 4px; }
    .w-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #FFFFFF;
      background: var(--or-red);
      padding: 5px 14px;
      border-radius: 999px;
      margin-bottom: 14px;
      box-shadow: 0 4px 12px rgba(232, 30, 37, 0.3);
    }
    .w-eyebrow::before {
      content: '';
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: #FFFFFF;
      box-shadow: 0 0 8px rgba(255, 255, 255, 0.9);
      animation: pulse-dot 1.6s ease-in-out infinite;
    }
    @keyframes pulse-dot {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.5; transform: scale(0.85); }
    }
    .w-cover {
      width: 100%;
      max-width: 320px;
      aspect-ratio: 16 / 9;
      object-fit: cover;
      display: block;
      margin: 0 auto 18px;
      border-radius: 20px;
      box-shadow: var(--shadow-1);
    }
    .w-header h1 {
      margin: 0 0 8px;
      font-size: 32px;
      font-weight: 800;
      letter-spacing: -0.03em;
      color: var(--ink);
      line-height: 1.1;
    }
    .w-header p {
      margin: 0 auto;
      max-width: 280px;
      color: var(--ink-2);
      font-size: 14px;
      line-height: 1.5;
      font-weight: 400;
    }

    /* ---------- Stage ---------- */
    .w-stage-outer {
      padding: 28px 0 12px;
      display: flex;
      justify-content: center;
      position: relative;
    }
    /* 輪盤旁的裝飾星 — 黃色 / 紅色交錯 */
    .w-stage-outer::before,
    .w-stage-outer::after {
      content: '✦';
      position: absolute;
      top: 50%;
      font-size: 20px;
      opacity: 0.7;
      animation: twinkle 3s ease-in-out infinite;
    }
    .w-stage-outer::before { left: 4%; transform: translateY(-60%); color: var(--or-yellow-2); }
    .w-stage-outer::after  { right: 4%; transform: translateY(40%); color: var(--or-red); animation-delay: 1.5s; }
    @keyframes twinkle {
      0%, 100% { opacity: 0.6; transform: translateY(-60%) scale(1); }
      50% { opacity: 1; transform: translateY(-60%) scale(1.3); }
    }
    .w-stage {
      position: relative;
      width: min(86vw, 340px);
      aspect-ratio: 1;
    }
    /* Pointer：細緻金屬箭頭 */
    .w-pointer {
      position: absolute;
      top: -4px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 5;
      width: 20px;
      height: 32px;
      filter: drop-shadow(0 4px 8px rgba(0,0,0,0.3));
    }
    .w-pointer svg { width: 100%; height: 100%; display: block; }

    /* 輪盤外框 — 白色 ring + 紅色細邊 */
    .w-canvas-wrap {
      position: relative;
      width: 100%;
      height: 100%;
      border-radius: 50%;
      background: radial-gradient(circle, var(--surface) 0%, #FFFCF2 90%);
      box-shadow:
        var(--shadow-2),
        inset 0 0 0 1px rgba(255,255,255,0.6),
        0 0 0 6px var(--surface),
        0 0 0 7px var(--or-red);
    }
    #wheel-canvas {
      width: 100%;
      height: 100%;
      display: block;
      transition: transform 5.5s cubic-bezier(0.16, 0.74, 0.24, 1);
    }
    /* 中心 SPIN 按鈕 + pulsing 光環 */
    .w-center {
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      width: 30%;
      height: 30%;
      border-radius: 50%;
      z-index: 4;
    }
    /* 三層 ring 製造立體基座 */
    .w-center::before {
      content: '';
      position: absolute;
      inset: -10px;
      border-radius: 50%;
      background: linear-gradient(180deg, #FFFFFF, #F0EBE0);
      box-shadow: 0 10px 24px rgba(120,80,20,0.18);
      z-index: -1;
    }
    /* pulsing glow ring — 紅色（OpenRice 紅，吸引點擊） */
    .w-center::after {
      content: '';
      position: absolute;
      inset: -4px;
      border-radius: 50%;
      border: 2.5px solid var(--or-red);
      opacity: 0;
      animation: pulse-ring 2.2s ease-out infinite;
      z-index: -1;
    }
    .w-center.spinning::after,
    .w-center.disabled::after { animation: none; }
    @keyframes pulse-ring {
      0%   { opacity: 0.6; transform: scale(1); }
      80%  { opacity: 0; transform: scale(1.45); }
      100% { opacity: 0; transform: scale(1.5); }
    }
    .w-spin-btn {
      width: 100%;
      height: 100%;
      border-radius: 50%;
      border: none;
      cursor: pointer;
      font-family: inherit;
      font-weight: 800;
      font-size: 17px;
      letter-spacing: 0.06em;
      color: var(--ink);
      background:
        radial-gradient(circle at 35% 28%, #FFE89A 0%, var(--or-yellow) 38%, var(--or-yellow-2) 100%);
      box-shadow:
        inset 0 -4px 8px rgba(140, 90, 0, 0.22),
        inset 0 3px 6px rgba(255,255,255,0.9),
        0 8px 20px rgba(252, 199, 38, 0.55);
      transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1), filter 0.2s;
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 1px;
      line-height: 1;
    }
    .w-spin-btn .tap {
      font-size: 9px;
      font-weight: 600;
      opacity: 0.6;
      letter-spacing: 0.15em;
      text-transform: uppercase;
    }
    .w-spin-btn:active:not(:disabled) {
      transform: scale(0.92);
    }
    .w-spin-btn:disabled {
      cursor: default;
      filter: saturate(0.4) brightness(0.96);
    }

    /* ---------- Status row（替換原本兩行文字） ---------- */
    .w-status-row {
      margin: 24px auto 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      font-size: 13px;
      color: var(--ink-2);
      min-height: 20px;
      padding: 0 20px;
    }
    .w-status-row .dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--or-red);
      box-shadow: 0 0 8px var(--or-red);
      flex-shrink: 0;
    }

    /* ---------- 獎品預覽 card ---------- */
    .w-prizes-card {
      background: var(--surface);
      border-radius: 20px;
      padding: 18px 18px 12px;
      box-shadow: var(--shadow-1);
      margin-top: 8px;
    }
    .w-prizes-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 12px;
    }
    .w-prizes-head h2 {
      margin: 0;
      font-size: 16px;
      font-weight: 700;
      letter-spacing: -0.01em;
    }
    .w-prizes-meta {
      font-size: 11px;
      color: var(--ink-2);
      font-weight: 500;
    }
    .w-prize-list {
      display: grid;
      grid-template-columns: 1fr;
      gap: 8px;
    }
    .w-prize-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 12px;
      background: var(--or-yellow-soft);
      border-radius: 12px;
      border: 1px solid rgba(252, 199, 38, 0.4);
    }
    .w-prize-item.grand {
      background: linear-gradient(135deg, var(--or-red-soft), #FFE5E5);
      border-color: var(--or-red);
    }
    .w-prize-thumb {
      width: 38px; height: 38px;
      border-radius: 10px;
      background: linear-gradient(135deg, var(--or-yellow), var(--or-yellow-2));
      color: var(--ink);
      display: flex; align-items: center; justify-content: center;
      font-size: 16px;
      font-weight: 700;
      flex-shrink: 0;
      overflow: hidden;
      box-shadow: 0 2px 6px rgba(252, 199, 38, 0.4);
    }
    .w-prize-item.grand .w-prize-thumb {
      background: linear-gradient(135deg, var(--or-red), var(--or-red-2));
      color: #FFFFFF;
      box-shadow: 0 2px 6px rgba(232, 30, 37, 0.4);
    }
    .w-prize-thumb img { width: 100%; height: 100%; object-fit: cover; }
    .w-prize-info { flex: 1; min-width: 0; }
    .w-prize-name {
      font-size: 13px;
      font-weight: 600;
      color: var(--ink);
      letter-spacing: -0.01em;
    }
    .w-prize-tag {
      font-size: 11px;
      color: var(--ink-2);
      margin-top: 1px;
    }
    .w-prize-item.grand .w-prize-tag { color: var(--or-red-2); font-weight: 600; }
    .w-prize-grand-badge {
      font-size: 10px;
      font-weight: 800;
      padding: 3px 8px;
      background: var(--or-red);
      color: white;
      border-radius: 4px;
      letter-spacing: 0.08em;
    }

    /* ---------- Footnote ---------- */
    .w-footnote {
      margin-top: 16px;
      text-align: center;
      font-size: 11px;
      color: var(--ink-3);
      letter-spacing: 0.02em;
    }

    /* ---------- Result Bottom Sheet ---------- */
    .w-modal {
      position: fixed;
      inset: 0;
      z-index: 100;
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.3s ease;
      background: rgba(20, 20, 22, 0.45);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      display: flex;
      align-items: flex-end;
      justify-content: center;
    }
    .w-modal.open { opacity: 1; pointer-events: auto; }
    .w-sheet {
      width: 100%;
      max-width: 480px;
      background: var(--surface);
      border-radius: 32px 32px 0 0;
      padding: 14px 24px 36px;
      padding-bottom: max(36px, env(safe-area-inset-bottom));
      transform: translateY(100%);
      transition: transform 0.5s cubic-bezier(0.32, 0.72, 0, 1);
      box-shadow: 0 -8px 32px rgba(0,0,0,0.2);
    }
    .w-modal.open .w-sheet { transform: translateY(0); }
    .w-handle {
      width: 38px; height: 5px;
      border-radius: 999px;
      background: var(--ink-3);
      margin: 0 auto 22px;
      opacity: 0.5;
    }
    .w-modal-title {
      text-align: center;
      font-size: 12px;
      font-weight: 700;
      color: var(--or-red);
      letter-spacing: 0.18em;
      text-transform: uppercase;
      margin-bottom: 12px;
    }
    .w-prize-img-wrap {
      width: 108px; height: 108px;
      margin: 0 auto 18px;
      border-radius: 28px;
      background: linear-gradient(135deg, var(--or-yellow-soft), var(--or-yellow));
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow:
        0 12px 28px rgba(252, 199, 38, 0.45),
        inset 0 -3px 8px rgba(140, 90, 0, 0.15),
        inset 0 3px 6px rgba(255,255,255,0.85);
      overflow: hidden;
      position: relative;
    }
    .w-modal.grand .w-prize-img-wrap {
      background: linear-gradient(135deg, var(--or-red), var(--or-red-2));
      box-shadow:
        0 12px 28px rgba(232, 30, 37, 0.45),
        inset 0 -3px 8px rgba(120, 10, 15, 0.2),
        inset 0 3px 6px rgba(255,255,255,0.4);
    }
    .w-modal.grand .w-prize-img-wrap .glyph { color: #FFFFFF; }
    .w-prize-img-wrap::after {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at 30% 20%, rgba(255,255,255,0.5), transparent 60%);
      pointer-events: none;
    }
    .w-prize-img-wrap img {
      width: 100%; height: 100%;
      object-fit: cover;
      border-radius: inherit;
      position: relative;
      z-index: 1;
    }
    .w-prize-img-wrap .glyph {
      font-size: 48px;
      filter: drop-shadow(0 3px 6px rgba(0,0,0,0.18));
      position: relative;
      z-index: 1;
    }
    .w-modal-prize {
      text-align: center;
      font-size: 30px;
      font-weight: 800;
      letter-spacing: -0.025em;
      color: var(--ink);
      margin-bottom: 8px;
      line-height: 1.15;
    }
    .w-modal.grand .w-modal-prize {
      background: linear-gradient(135deg, var(--or-red), var(--or-yellow-2));
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      animation: shimmer 1.4s ease infinite;
    }
    @keyframes shimmer {
      0%, 100% { filter: brightness(1) saturate(1); }
      50% { filter: brightness(1.2) saturate(1.2); }
    }
    .w-modal-desc {
      text-align: center;
      color: var(--ink-2);
      font-size: 14px;
      line-height: 1.55;
      margin-bottom: 28px;
    }
    .w-modal-btn {
      display: block;
      width: 100%;
      padding: 16px;
      background: var(--ink);
      color: #fff;
      border: none;
      border-radius: 16px;
      font-size: 17px;
      font-weight: 600;
      font-family: inherit;
      letter-spacing: -0.01em;
      cursor: pointer;
      transition: transform 0.15s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .w-modal-btn:active { transform: scale(0.97); }

    /* sparkles — 大獎觸發，黃 / 紅 / 白交錯 */
    .sparkle {
      position: fixed;
      pointer-events: none;
      top: 50%; left: 50%;
      width: 8px; height: 8px;
      background: radial-gradient(circle, #FFFFFF, var(--or-yellow) 50%, transparent 75%);
      border-radius: 50%;
      z-index: 99;
      opacity: 0;
      animation: spark 1.8s ease-out forwards;
    }
    .sparkle.red {
      background: radial-gradient(circle, #FFFFFF, var(--or-red) 50%, transparent 75%);
    }
    @keyframes spark {
      0%   { opacity: 0; transform: translate(-50%, -50%) scale(0); }
      15%  { opacity: 1; transform: translate(calc(-50% + var(--dx, 0px)), calc(-50% + var(--dy, 0px))) scale(1.2); }
      100% { opacity: 0; transform: translate(calc(-50% + var(--dx, 0px) * 1.4), calc(-50% + var(--dy, 0px) * 1.4 + 80px)) scale(0.3); }
    }
  </style>
</head>
<body>
  <div class="w-app">
    <header class="w-header">
      <div class="w-eyebrow">幸運抽獎</div>
      <% if (activity.cover_image_url) { %>
        <img class="w-cover" src="<%= activity.cover_image_url %>" alt="" />
      <% } %>
      <h1><%= activity.name %></h1>
      <% if (activity.description) { %>
        <p><%= activity.description %></p>
      <% } %>
    </header>

    <div class="w-stage-outer">
      <div class="w-stage">
        <div class="w-pointer">
          <svg viewBox="0 0 20 32" fill="none">
            <path d="M10 32 L0 8 Q0 0 10 0 Q20 0 20 8 Z" fill="url(#pg)"/>
            <circle cx="10" cy="9" r="4" fill="#FFFFFF" opacity="0.5"/>
            <defs>
              <linearGradient id="pg" x1="0" y1="0" x2="0" y2="32">
                <stop offset="0%" stop-color="#FF4A50"/>
                <stop offset="100%" stop-color="#C0151B"/>
              </linearGradient>
            </defs>
          </svg>
        </div>
        <div class="w-canvas-wrap">
          <canvas id="wheel-canvas" width="720" height="720"></canvas>
        </div>
        <div class="w-center" id="w-center">
          <button type="button" id="spin-btn" class="w-spin-btn">
            <span class="main">SPIN</span>
            <span class="tap">點擊開始</span>
          </button>
        </div>
      </div>
    </div>

    <div class="w-status-row" id="status-row">
      <div class="dot"></div>
      <span id="status">準備中…</span>
    </div>

    <% if (prizes && prizes.length > 0) { %>
    <section class="w-prizes-card">
      <div class="w-prizes-head">
        <h2>本次獎項</h2>
        <span class="w-prizes-meta"><%= prizes.length %> 種獎品</span>
      </div>
      <div class="w-prize-list">
        <% prizes.forEach(function (p) { %>
          <div class="w-prize-item <%= p.is_grand_prize ? 'grand' : '' %>">
            <div class="w-prize-thumb">
              <% if (p.image_url) { %>
                <img src="<%= p.image_url %>" alt="" />
              <% } else { %>
                <%= p.is_grand_prize ? '★' : '◆' %>
              <% } %>
            </div>
            <div class="w-prize-info">
              <div class="w-prize-name"><%= p.name %></div>
              <% if (p.description) { %>
                <div class="w-prize-tag"><%= p.description %></div>
              <% } %>
            </div>
            <% if (p.is_grand_prize) { %>
              <span class="w-prize-grand-badge">大獎</span>
            <% } %>
          </div>
        <% }); %>
      </div>
    </section>
    <% } %>

    <p class="w-footnote" id="info"></p>
  </div>

  <!-- Bottom sheet modal -->
  <div id="modal" class="w-modal" aria-hidden="true">
    <div class="w-sheet">
      <div class="w-handle"></div>
      <div class="w-modal-title">恭喜抽中</div>
      <div class="w-prize-img-wrap" id="modal-img-wrap">
        <img id="modal-img" alt="" hidden />
        <div class="glyph" id="modal-glyph">★</div>
      </div>
      <div class="w-modal-prize" id="modal-prize">—</div>
      <div class="w-modal-desc" id="modal-desc"></div>
      <button type="button" class="w-modal-btn" id="modal-close">完成</button>
    </div>
  </div>

  <script>
    (function () {
      var slug = <%- JSON.stringify(activity.slug) %>;
      var liffId = <%- JSON.stringify(liffId || '') %>;
      var dailyLimit = <%- JSON.stringify(activity.daily_plays_per_user) %>;
      var prizes = <%- JSON.stringify(prizes || []) %>;

      var canvas = document.getElementById('wheel-canvas');
      var ctx = canvas.getContext('2d');
      var spinBtn = document.getElementById('spin-btn');
      var centerEl = document.getElementById('w-center');
      var statusEl = document.getElementById('status');
      var infoEl = document.getElementById('info');
      var modal = document.getElementById('modal');

      var spinning = false;
      var currentRotation = 0;
      var profile = null;
      var liffReady = false;

      // ----- LIFF init -----
      async function initLiff() {
        var qs = new URLSearchParams(location.search);
        var devUid = qs.get('uid');
        if (devUid) {
          profile = { userId: devUid, displayName: qs.get('name') || 'DEV User' };
          return;
        }
        if (qs.get('preview') === '1') {
          profile = { userId: 'PREVIEW_MODE', displayName: '預覽模式' };
          spinBtn.disabled = true;
          spinBtn.querySelector('.main').textContent = '預覽';
          centerEl.classList.add('disabled');
          return;
        }
        if (!liffId) {
          throw new Error('LIFF ID 未設定（請聯絡管理員設定 GAMES_LIFF_ID 環境變數）');
        }
        try {
          await liff.init({ liffId: liffId });
        } catch (e) {
          throw new Error('LIFF 初始化失敗：' + (e.message || e));
        }
        if (!liff.isInClient()) {
          throw new Error('請在 LINE App 內打開（桌機預覽請在網址後加 ?preview=1）');
        }
        if (!liff.isLoggedIn()) {
          liff.login();
          return new Promise(function () {});
        }
        profile = await liff.getProfile();
      }

      function renderInfo() {
        if (dailyLimit != null) {
          infoEl.textContent = '每人每天可玩 ' + dailyLimit + ' 次';
        } else {
          infoEl.textContent = '';
        }
      }

      // ===========================================================
      // 畫輪盤 — 關鍵改進：文字水平擺放，不再倒置
      // ===========================================================
      function drawWheel() {
        var W = canvas.width;
        var H = canvas.height;
        var cx = W / 2, cy = H / 2;
        var ringWidth = 18;
        var R = W / 2 - ringWidth - 8;
        var n = prizes.length;
        var anglePer = (Math.PI * 2) / n;

        ctx.clearRect(0, 0, W, H);

        // 1) 外圈紅色 ring（OpenRice 紅漸層）
        var ringGrad = ctx.createLinearGradient(0, 0, 0, H);
        ringGrad.addColorStop(0, '#FF4A50');
        ringGrad.addColorStop(0.5, '#E81E25');
        ringGrad.addColorStop(1, '#A01016');
        ctx.beginPath();
        ctx.arc(cx, cy, R + ringWidth, 0, Math.PI * 2);
        ctx.fillStyle = ringGrad;
        ctx.fill();

        // 2) ring 上的 LED 風小白點（亮/暗交替）
        var dotCount = n * 3;
        for (var i = 0; i < dotCount; i++) {
          var a = (i / dotCount) * Math.PI * 2 - Math.PI / 2;
          var rx = cx + Math.cos(a) * (R + ringWidth / 2);
          var ry = cy + Math.sin(a) * (R + ringWidth / 2);
          ctx.beginPath();
          ctx.arc(rx, ry, 3.5, 0, Math.PI * 2);
          var bright = i % 2 === 0;
          ctx.fillStyle = bright ? '#FFFFFF' : 'rgba(255,255,255,0.4)';
          ctx.shadowColor = bright ? 'rgba(255,255,255,0.9)' : 'transparent';
          ctx.shadowBlur = bright ? 8 : 0;
          ctx.fill();
        }
        ctx.shadowBlur = 0;

        // 3) 扇形 — 白 / OpenRice 黃 交替，大獎用 OpenRice 紅
        prizes.forEach(function (p, i) {
          var start = i * anglePer - Math.PI / 2;
          var end = start + anglePer;
          ctx.beginPath();
          ctx.moveTo(cx, cy);
          ctx.arc(cx, cy, R, start, end);
          ctx.closePath();

          var baseColor;
          if (p.is_grand_prize) baseColor = '#E81E25';                      // OpenRice 紅
          else baseColor = (i % 2 === 0) ? '#FFFFFF' : '#FCC726';            // 白 / OpenRice 黃

          // 徑向漸層讓扇形有體積感
          var midAngle = start + anglePer / 2;
          var sectorGrad = ctx.createRadialGradient(
            cx + Math.cos(midAngle) * R * 0.35,
            cy + Math.sin(midAngle) * R * 0.35,
            0,
            cx, cy, R
          );
          sectorGrad.addColorStop(0, lightenColor(baseColor, 12));
          sectorGrad.addColorStop(1, baseColor);
          ctx.fillStyle = sectorGrad;
          ctx.fill();

          ctx.lineWidth = 2;
          ctx.strokeStyle = 'rgba(255, 255, 255, 0.85)';
          ctx.stroke();
        });

        // 4) 文字（水平擺放關鍵）— 用 transform sandwich 抵銷 sector rotation
        prizes.forEach(function (p, i) {
          var start = i * anglePer - Math.PI / 2;
          var midAngle = start + anglePer / 2;
          var textRadius = R * 0.62;

          ctx.save();
          ctx.translate(cx, cy);
          ctx.rotate(midAngle);
          ctx.translate(textRadius, 0);
          // 抵銷 sector rotation，讓文字保持水平
          ctx.rotate(-midAngle);
          // 但這樣會「永遠水平」— 對下半 sector，文字仍朝上方讀，等於要倒著看
          // 進一步：對下半 sector（midAngle > 90 度且 < 270 度），翻 180 度
          // canvas 座標 -PI/2 是上方，所以 midAngle 在 (PI/2, 3PI/2) 等於下半
          var normalizedAngle = ((midAngle + Math.PI * 2.5) % (Math.PI * 2)) - Math.PI / 2;
          // 上方 = -PI/2 到 PI/2；下方 = PI/2 到 3PI/2
          // 簡化判斷：cos(midAngle) > 0 = 右半；sin(midAngle) > 0 = 下半（canvas y 朝下）
          // 我們把「文字基線朝向圓心」設計：
          // - 右半 sector: 文字朝右、靠近外圈
          // - 左半 sector: 文字朝左
          ctx.textAlign = 'center';
          ctx.textBaseline = 'middle';
          ctx.fillStyle = p.is_grand_prize ? '#FFFFFF' : '#1D1D1F';
          ctx.font = '700 22px -apple-system, "SF Pro Display", "PingFang TC", sans-serif';

          var label = String(p.name || '');
          if (label.length > 8) label = label.slice(0, 8) + '…';
          ctx.fillText(label, 0, 0);

          if (p.is_grand_prize) {
            ctx.fillStyle = 'rgba(255,255,255,0.85)';
            ctx.font = '700 10px -apple-system, "SF Pro Display", sans-serif';
            ctx.fillText('GRAND PRIZE', 0, 18);
          }
          ctx.restore();
        });

        // 5) 中心圓底盤（讓中央按鈕浮起來）
        var centerR = R * 0.24;
        var coreGrad = ctx.createRadialGradient(cx, cy, 0, cx, cy, centerR);
        coreGrad.addColorStop(0, '#FFFFFF');
        coreGrad.addColorStop(1, '#F0EAD9');
        ctx.beginPath();
        ctx.arc(cx, cy, centerR, 0, Math.PI * 2);
        ctx.fillStyle = coreGrad;
        ctx.fill();
        // 中心圓邊框（細）
        ctx.lineWidth = 1.5;
        ctx.strokeStyle = 'rgba(217, 119, 6, 0.2)';
        ctx.stroke();
      }

      function lightenColor(hex, amount) {
        var c = hex.replace('#', '');
        var r = parseInt(c.substr(0, 2), 16);
        var g = parseInt(c.substr(2, 2), 16);
        var b = parseInt(c.substr(4, 2), 16);
        r = Math.min(255, r + amount);
        g = Math.min(255, g + amount);
        b = Math.min(255, b + amount);
        return '#' + [r, g, b].map(function (x) { return x.toString(16).padStart(2, '0'); }).join('');
      }

      // ----- 動畫旋轉 -----
      function animateToPrize(prize) {
        var n = prizes.length;
        if (n === 0) return Promise.resolve();
        var idx = prizes.findIndex(function (p) { return p.id === prize.id; });
        if (idx < 0) idx = 0;
        var anglePer = 360 / n;
        var targetCenter = (idx + 0.5) * anglePer;
        var jitter = (Math.random() - 0.5) * (anglePer * 0.5);
        var finalAngle = currentRotation + 360 * 6 + (360 - targetCenter) + jitter;
        currentRotation = finalAngle;
        canvas.style.transform = 'rotate(' + finalAngle + 'deg)';
        return new Promise(function (resolve) { setTimeout(resolve, 5600); });
      }

      // ----- spin -----
      async function spin() {
        if (spinning) return;
        if (!liffReady || !profile) {
          statusEl.textContent = 'LINE 身分準備中，稍等一下…';
          return;
        }
        spinning = true;
        spinBtn.disabled = true;
        centerEl.classList.add('spinning');
        statusEl.textContent = '抽選中…';

        try {
          var resp = await fetch('/api/games/wheel/' + encodeURIComponent(slug) + '/spin', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              line_user_id: profile.userId,
              line_display_name: profile.displayName || null
            })
          }).then(function (r) { return r.json(); });

          if (!resp.ok) {
            statusEl.textContent = resp.detail || resp.error || '抽選失敗';
            spinning = false;
            spinBtn.disabled = false;
            centerEl.classList.remove('spinning');
            return;
          }

          await animateToPrize(resp.prize);
          showResult(resp.prize);
        } catch (e) {
          statusEl.textContent = '錯誤：' + e.message;
        } finally {
          spinning = false;
          spinBtn.disabled = false;
          centerEl.classList.remove('spinning');
        }
      }

      // ----- result modal -----
      function showResult(prize) {
        statusEl.textContent = '';
        document.getElementById('modal-prize').textContent = prize.name || '—';
        var imgEl = document.getElementById('modal-img');
        var glyphEl = document.getElementById('modal-glyph');
        if (prize.image_url) {
          imgEl.src = prize.image_url;
          imgEl.hidden = false;
          glyphEl.style.display = 'none';
        } else {
          imgEl.hidden = true;
          glyphEl.style.display = 'block';
          glyphEl.textContent = prize.is_grand_prize ? '★' : '◆';
        }
        var descParts = [];
        if (prize.prize_value) {
          if (prize.prize_value.amount) descParts.push('NT$ ' + prize.prize_value.amount);
          if (prize.prize_value.code) descParts.push('優惠碼 ' + prize.prize_value.code);
          if (prize.prize_value.label) descParts.push(prize.prize_value.label);
          if (prize.prize_value.note) descParts.push(prize.prize_value.note);
        }
        document.getElementById('modal-desc').textContent = descParts.join('  ·  ');
        if (prize.is_grand_prize) {
          modal.classList.add('grand');
          sparkleBurst();
        } else {
          modal.classList.remove('grand');
        }
        requestAnimationFrame(function () { modal.classList.add('open'); });
      }

      document.getElementById('modal-close').addEventListener('click', function () {
        modal.classList.remove('open');
      });
      modal.addEventListener('click', function (e) {
        if (e.target === modal) modal.classList.remove('open');
      });

      function sparkleBurst() {
        for (var i = 0; i < 32; i++) {
          var el = document.createElement('div');
          el.className = 'sparkle' + (i % 3 === 0 ? ' red' : '');
          var angle = (i / 32) * Math.PI * 2 + Math.random() * 0.4;
          var distance = 80 + Math.random() * 120;
          el.style.setProperty('--dx', Math.cos(angle) * distance + 'px');
          el.style.setProperty('--dy', Math.sin(angle) * distance + 'px');
          el.style.animationDelay = (Math.random() * 0.2) + 's';
          var size = (4 + Math.random() * 6) + 'px';
          el.style.width = size;
          el.style.height = size;
          document.body.appendChild(el);
          setTimeout(function (e) { e.remove(); }.bind(null, el), 2200);
        }
      }

      spinBtn.addEventListener('click', spin);

      // ----- bootstrap -----
      if (prizes.length < 2) {
        statusEl.textContent = '獎品數量不足，無法開始遊戲（至少需 2 個）';
        spinBtn.disabled = true;
        spinBtn.querySelector('.main').textContent = '—';
        spinBtn.querySelector('.tap').textContent = '';
        centerEl.classList.add('disabled');
      } else {
        drawWheel();
        renderInfo();
        spinBtn.disabled = true;
        centerEl.classList.add('disabled');
        statusEl.textContent = '載入 LINE 身分…';
      }

      (async function () {
        if (prizes.length < 2) return;
        try {
          await initLiff();
          liffReady = true;
          spinBtn.disabled = false;
          centerEl.classList.remove('disabled');
          statusEl.textContent = '哈囉 ' + (profile.displayName || '') + '！輪到你了';
        } catch (e) {
          statusEl.textContent = e.message || '初始化失敗';
          console.error(e);
        }
      })();
    })();
  </script>
</body>
</html>
