<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#FAFAFA" />
  <title><%= title %></title>
  <script src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>
  <style>
    :root {
      --bg:         #FAFAFA;
      --surface:    #FFFFFF;
      --or-yellow:  #FCC726;
      --or-yellow-d: #E8B400;
      --or-red:     #E11D27;
      --ink:        #0F0F10;
      --ink-2:      #6B6B70;
      --ink-3:      #A0A0A6;
      --border:     #ECECEE;
      --border-2:   #E0E0E4;
    }
    * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
    html, body { margin: 0; padding: 0; }
    body {
      background:
        radial-gradient(640px 360px at 88% -80px, rgba(252, 199, 38, 0.20), transparent 70%),
        radial-gradient(520px 300px at -10% 240px, rgba(252, 199, 38, 0.08), transparent 70%),
        linear-gradient(180deg, #FFFBEB 0%, var(--bg) 360px);
      color: var(--ink);
      min-height: 100vh;
      font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "SF Pro Text",
        "Inter", "PingFang TC", "Microsoft JhengHei", sans-serif;
      letter-spacing: -0.011em;
      -webkit-font-smoothing: antialiased;
    }

    .page {
      max-width: 480px;
      margin: 0 auto;
      padding: 16px 16px 56px;
    }

    /* ========== 進場動畫（staggered fade + up）========== */
    @keyframes rise {
      from { opacity: 0; transform: translateY(14px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .brand-bar, .hero, .stats, .invite-card, .stage-card, .section, .foot {
      animation: rise 0.38s cubic-bezier(0.22, 0.9, 0.3, 1) both;
    }
    .hero       { animation-delay: 0.05s; }
    .stats      { animation-delay: 0.11s; }
    .invite-card{ animation-delay: 0.17s; }
    .stage-card { animation-delay: 0.23s; }
    .section    { animation-delay: 0.31s; }
    .foot       { animation-delay: 0.38s; }

    /* ========== Brand bar ========== */
    .brand-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 6px 0 16px;
    }
    .brand-bar .logo {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: -0.01em;
      color: var(--ink);
    }
    .brand-bar .logo .dot {
      width: 18px; height: 18px; border-radius: 6px;
      background: var(--or-yellow);
      display: inline-block;
      position: relative;
      flex-shrink: 0;
    }
    .brand-bar .logo .dot::after {
      content: '';
      position: absolute;
      inset: 4px;
      border-radius: 50%;
      background: var(--ink);
    }
    .brand-bar .chip {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      font-size: 11px;
      font-weight: 500;
      color: var(--ink-2);
      background: var(--surface);
      border: 1px solid var(--border);
      padding: 5px 10px;
      border-radius: 999px;
    }
    .brand-bar .chip::before {
      content: '';
      width: 5px; height: 5px;
      border-radius: 50%;
      background: #22C55E;
      box-shadow: 0 0 0 2px rgba(34, 197, 94, 0.15);
    }

    /* ========== Hero card ========== */
    .hero {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 22px 22px 24px;
      position: relative;
      overflow: hidden;
      box-shadow: 0 10px 28px -16px rgba(15, 15, 16, 0.12);
    }
    .hero::before {
      content: '';
      position: absolute;
      top: -40px;
      right: -40px;
      width: 180px;
      height: 180px;
      background: radial-gradient(circle, rgba(252, 199, 38, 0.18), transparent 70%);
      pointer-events: none;
    }
    .hero-tag {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.06em;
      color: var(--or-red);
      text-transform: uppercase;
      margin-bottom: 14px;
    }
    .hero-tag::before {
      content: '';
      width: 6px; height: 6px;
      background: var(--or-red);
      border-radius: 50%;
    }
    .hero h1 {
      margin: 0 0 8px;
      font-size: 26px;
      font-weight: 700;
      letter-spacing: -0.028em;
      line-height: 1.2;
    }
    .hero p {
      margin: 0;
      font-size: 14px;
      line-height: 1.55;
      color: var(--ink-2);
    }
    .hero-cover {
      width: calc(100% + 44px);
      margin: 18px -22px -24px;
      aspect-ratio: 16 / 9;
      object-fit: cover;
      display: block;
      border-top: 1px solid var(--border);
    }

    /* ========== Stats strip ========== */
    .stats {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 8px;
      margin-top: 12px;
    }
    .stat {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 12px 12px;
      box-shadow: 0 4px 14px -8px rgba(15, 15, 16, 0.08);
    }
    .stat .v {
      font-size: 20px;
      font-weight: 700;
      letter-spacing: -0.02em;
      line-height: 1;
      font-variant-numeric: tabular-nums;
      transform-origin: left center;
    }
    /* 次數變化時的 pop（scale 1.3 → 1） */
    @keyframes stat-pop {
      0%   { transform: scale(1.3); color: var(--or-yellow-d); }
      100% { transform: scale(1); }
    }
    .stat .v.pop {
      animation: stat-pop 0.45s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .stat .v .unit { font-size: 11px; font-weight: 500; color: var(--ink-2); margin-left: 2px; }
    .stat .k {
      font-size: 11px;
      color: var(--ink-2);
      margin-top: 5px;
      font-weight: 500;
    }

    /* ========== Invite card（MGM 主視覺：品牌黃）========== */
    .invite-card {
      margin-top: 8px;
      background: linear-gradient(135deg, #FFDC6B 0%, var(--or-yellow) 52%, #F3B913 100%);
      border-radius: 18px;
      padding: 16px 18px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      position: relative;
      overflow: hidden;
      color: var(--ink);
      box-shadow:
        0 1px 0 rgba(255, 255, 255, 0.5) inset,
        0 12px 26px -14px rgba(232, 180, 0, 0.65);
    }
    .invite-card::before {
      content: '';
      position: absolute;
      top: -48px;
      right: -28px;
      width: 144px; height: 144px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.30);
      pointer-events: none;
    }
    .invite-card::after {
      content: '';
      position: absolute;
      bottom: -62px;
      right: 42px;
      width: 112px; height: 112px;
      border-radius: 50%;
      background: rgba(31, 41, 55, 0.06);
      pointer-events: none;
    }
    .invite-left { flex: 1; min-width: 0; z-index: 1; }
    .invite-eyebrow {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: rgba(31, 41, 55, 0.62);
      margin-bottom: 4px;
    }
    .invite-title {
      font-size: 16px;
      font-weight: 800;
      letter-spacing: -0.015em;
      line-height: 1.3;
    }
    .invite-sub {
      font-size: 11.5px;
      font-weight: 500;
      color: rgba(31, 41, 55, 0.72);
      margin-top: 3px;
    }
    .invite-btn {
      flex-shrink: 0;
      background: var(--ink);
      color: #fff;
      border: none;
      border-radius: 999px;
      padding: 10px 18px;
      font-family: inherit;
      font-weight: 700;
      font-size: 13px;
      cursor: pointer;
      letter-spacing: -0.005em;
      z-index: 1;
      transition: background 0.15s ease, transform 0.15s cubic-bezier(0.34, 1.56, 0.64, 1);
      display: inline-flex;
      align-items: center;
      box-shadow: 0 6px 14px -6px rgba(15, 15, 16, 0.5);
    }
    .invite-btn:hover { background: #000; }
    .invite-btn:active { transform: scale(0.96); }
    .invite-card.maxed { opacity: 0.6; box-shadow: none; }
    .invite-card.maxed .invite-btn { background: var(--ink-3); cursor: default; pointer-events: none; box-shadow: none; }

    /* ========== Stage card ========== */
    .stage-card {
      margin-top: 12px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 24px 20px 20px;
      position: relative;
      overflow: hidden;
      box-shadow: 0 14px 32px -18px rgba(15, 15, 16, 0.14);
    }
    .stage-card::before {
      content: '';
      position: absolute;
      bottom: -80px;
      left: -60px;
      width: 240px; height: 240px;
      background: radial-gradient(circle, rgba(225, 29, 39, 0.05), transparent 70%);
      pointer-events: none;
    }
    .stage-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 12px;
      position: relative;
    }
    .stage-head .label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--ink-3);
    }
    .stage-head .count {
      font-size: 11px;
      color: var(--ink-2);
      font-weight: 500;
      font-variant-numeric: tabular-nums;
    }
    .stage-wrap {
      display: flex;
      justify-content: center;
      padding: 8px 0 4px;
      position: relative;
    }
    .stage {
      position: relative;
      width: min(76vw, 300px);
      aspect-ratio: 1;
    }
    .pointer {
      position: absolute;
      top: -6px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 5;
    }
    .pointer svg { display: block; transform-origin: 50% 20%; }
    /* 轉動中：指針細微 tick 抖動（模擬撞釘） */
    @keyframes ptr-tick {
      from { transform: rotate(2deg); }
      to   { transform: rotate(-8deg); }
    }
    .stage.spinning .pointer svg {
      animation: ptr-tick 0.12s linear infinite alternate;
    }
    /* 停止瞬間：指針 bounce */
    @keyframes ptr-bounce {
      0%   { transform: rotate(-11deg); }
      40%  { transform: rotate(7deg); }
      70%  { transform: rotate(-3deg); }
      100% { transform: rotate(0deg); }
    }
    .stage.landed .pointer svg {
      animation: ptr-bounce 0.55s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .canvas-wrap {
      position: relative;
      width: 100%;
      height: 100%;
      border-radius: 50%;
      overflow: hidden;
      box-shadow:
        0 0 0 1px rgba(15, 15, 16, 0.06),
        0 12px 36px -8px rgba(15, 15, 16, 0.18),
        0 4px 12px -2px rgba(15, 15, 16, 0.08);
    }
    #wheel {
      width: 100%;
      height: 100%;
      display: block;
      /* 期待感曲線：長尾 ease-out，最後一格慢慢滑過去 */
      transition: transform 5.2s cubic-bezier(0.12, 0.8, 0.2, 1);
    }
    /* 按下後先反向蓄力一小段 */
    #wheel.windup {
      transition: transform 0.3s cubic-bezier(0.45, 0, 0.55, 1);
    }

    /* 中央按鈕 — 黃色 + 微陰影，現代 web product 風 */
    .center {
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      width: 27%;
      height: 27%;
      z-index: 4;
    }
    .center::before {
      content: '';
      position: absolute;
      inset: -5px;
      border-radius: 50%;
      background: var(--surface);
      box-shadow:
        0 0 0 1px var(--border),
        0 6px 16px -4px rgba(15, 15, 16, 0.12);
      z-index: -1;
    }
    .spin-btn {
      width: 100%;
      height: 100%;
      border-radius: 50%;
      border: none;
      background: var(--or-yellow);
      color: var(--ink);
      font-family: inherit;
      font-weight: 700;
      font-size: 15px;
      letter-spacing: 0.08em;
      cursor: pointer;
      transition: transform 0.18s cubic-bezier(0.34, 1.56, 0.64, 1),
                  background 0.15s ease;
      position: relative;
    }
    .spin-btn:hover:not(:disabled) { background: var(--or-yellow-d); }
    .spin-btn:active:not(:disabled) { transform: scale(0.93); }
    .spin-btn:disabled {
      background: #F0F0F2;
      color: var(--ink-3);
      cursor: default;
    }
    /* 可以玩的時候：黃色呼吸光暈 */
    @keyframes breathe {
      0%, 100% { box-shadow: 0 0 0 0 rgba(252, 199, 38, 0.55); }
      55%      { box-shadow: 0 0 0 13px rgba(252, 199, 38, 0); }
      56%      { box-shadow: 0 0 0 0 rgba(252, 199, 38, 0); }
    }
    .spin-btn:not(:disabled) {
      animation: breathe 1.9s ease-out infinite;
    }

    /* ========== Status line ========== */
    .status-row {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      margin-top: 18px;
      font-size: 13px;
      color: var(--ink-2);
      min-height: 22px;
    }
    .status-row .arrow {
      color: var(--ink-3);
      font-size: 14px;
      animation: bounce 1.4s ease-in-out infinite;
    }
    @keyframes bounce {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-3px); }
    }
    .status-row.ready .arrow { display: inline-block; }
    .status-row:not(.ready) .arrow { display: none; }
    .status-row .name {
      color: var(--ink);
      font-weight: 600;
    }

    /* ========== Prize section ========== */
    .section {
      margin-top: 24px;
    }
    .section-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      padding: 0 4px;
      margin-bottom: 10px;
    }
    .section-head h2 {
      margin: 0;
      font-size: 17px;
      font-weight: 700;
      letter-spacing: -0.015em;
    }
    .section-head .meta {
      font-size: 11px;
      color: var(--ink-2);
      font-weight: 500;
      font-variant-numeric: tabular-nums;
    }

    .prize-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }
    .prize-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 14px;
      position: relative;
      transition: transform 0.15s ease, border-color 0.15s ease;
      box-shadow: 0 4px 14px -10px rgba(15, 15, 16, 0.10);
    }
    .prize-card:active { transform: scale(0.98); }
    .prize-card.grand {
      grid-column: span 2;
      border-color: var(--or-red);
      background: linear-gradient(180deg, rgba(225, 29, 39, 0.04), transparent);
    }
    .prize-card .top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 8px;
    }
    .prize-card .icon {
      width: 32px; height: 32px;
      border-radius: 10px;
      background: linear-gradient(135deg, #FFF7DA, var(--or-yellow));
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--ink);
      font-weight: 700;
      font-size: 14px;
      font-variant-numeric: tabular-nums;
      flex-shrink: 0;
    }
    .prize-card.grand .icon {
      background: var(--or-red);
      color: #fff;
    }
    .prize-card .badge {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.06em;
      padding: 3px 8px;
      border-radius: 999px;
      background: var(--or-red);
      color: #fff;
    }
    .prize-card .name {
      font-size: 14px;
      font-weight: 600;
      letter-spacing: -0.005em;
      line-height: 1.35;
      color: var(--ink);
    }
    .prize-card .desc {
      margin-top: 3px;
      font-size: 12px;
      color: var(--ink-2);
      line-height: 1.4;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    /* ========== Footer ========== */
    .foot {
      margin-top: 28px;
      padding: 14px 16px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-size: 12px;
      color: var(--ink-2);
    }
    .foot .l { display: flex; align-items: center; gap: 8px; }
    .foot .i {
      width: 20px; height: 20px;
      border-radius: 6px;
      background: var(--bg);
      border: 1px solid var(--border);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 11px;
      color: var(--ink-2);
    }
    .foot .r {
      font-weight: 600;
      color: var(--ink);
      font-variant-numeric: tabular-nums;
    }

    /* ========== Modal ========== */
    .modal {
      position: fixed;
      inset: 0;
      z-index: 100;
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.3s ease;
      background: rgba(15, 15, 16, 0.55);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      display: flex;
      align-items: flex-end;
      justify-content: center;
    }
    .modal.open { opacity: 1; pointer-events: auto; }
    .sheet {
      width: 100%;
      max-width: 480px;
      background: var(--surface);
      border-radius: 28px 28px 0 0;
      padding: 14px 24px 32px;
      padding-bottom: max(32px, env(safe-area-inset-bottom));
      transform: translateY(100%);
      transition: transform 0.5s cubic-bezier(0.32, 0.72, 0, 1);
    }
    .modal.open .sheet { transform: translateY(0); }
    .handle {
      width: 36px; height: 5px;
      border-radius: 999px;
      background: var(--border-2);
      margin: 0 auto 22px;
    }
    .modal-eyebrow {
      text-align: center;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--or-red);
      margin-bottom: 16px;
    }
    .modal-img-wrap {
      width: 88px; height: 88px;
      margin: 0 auto 16px;
      border-radius: 22px;
      background: linear-gradient(135deg, #FFF7DA, var(--or-yellow));
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    .modal.grand .modal-img-wrap {
      background: linear-gradient(135deg, var(--or-red), #B61118);
    }
    .modal-img-wrap img { width: 100%; height: 100%; object-fit: cover; }
    .modal-img-wrap .glyph {
      font-size: 36px;
      font-weight: 700;
      color: var(--ink);
    }
    .modal.grand .modal-img-wrap .glyph { color: #fff; }
    .modal-prize {
      text-align: center;
      font-size: 26px;
      font-weight: 700;
      letter-spacing: -0.025em;
      color: var(--ink);
      margin-bottom: 8px;
      line-height: 1.15;
    }
    .modal-desc {
      text-align: center;
      color: var(--ink-2);
      font-size: 14px;
      line-height: 1.55;
      margin-bottom: 24px;
    }
    .modal-btn {
      display: block;
      width: 100%;
      padding: 15px;
      background: var(--ink);
      color: #fff;
      border: none;
      border-radius: 14px;
      font-size: 15px;
      font-weight: 600;
      font-family: inherit;
      letter-spacing: -0.005em;
      cursor: pointer;
      transition: transform 0.15s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .modal-btn:active { transform: scale(0.98); }

    /* ========== 優惠序號區塊 ========== */
    .coupon-block {
      background: #FFFBEB;
      border: 1px solid var(--or-yellow);
      border-radius: 16px;
      padding: 16px 18px 18px;
      margin-bottom: 16px;
      text-align: center;
    }
    .coupon-label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.1em;
      color: var(--ink-2);
      text-transform: uppercase;
      margin-bottom: 8px;
    }
    .coupon-code {
      font-size: 26px;
      font-weight: 800;
      letter-spacing: 0.04em;
      color: var(--ink);
      line-height: 1.2;
      word-break: break-all;
      font-variant-numeric: tabular-nums;
      -webkit-user-select: all;
      user-select: all;
    }
    .coupon-hint {
      font-size: 12.5px;
      color: var(--ink-2);
      line-height: 1.5;
      margin-top: 10px;
    }
    .coupon-oos {
      background: var(--bg);
      border: 1px solid var(--border-2);
      border-radius: 14px;
      padding: 14px 16px;
      margin-bottom: 16px;
      text-align: center;
      font-size: 13px;
      color: var(--ink-2);
      line-height: 1.5;
    }
    .wallet-link {
      display: block;
      text-align: center;
      margin-top: 14px;
      font-size: 13px;
      font-weight: 600;
      color: var(--ink-2);
      text-decoration: none;
      letter-spacing: -0.005em;
    }
    .wallet-link:active { opacity: 0.6; }

    /* ========== 揭曉節奏：停頓 → 彈跳放大 → 慶祝 ========== */
    .modal .modal-img-wrap,
    .modal .modal-prize,
    .modal .modal-desc {
      opacity: 0;
    }
    @keyframes reveal-pop {
      0%   { transform: scale(0.35); opacity: 0; }
      62%  { transform: scale(1.1);  opacity: 1; }
      82%  { transform: scale(0.96); }
      100% { transform: scale(1);    opacity: 1; }
    }
    @keyframes reveal-rise {
      from { transform: translateY(10px) scale(0.94); opacity: 0; }
      to   { transform: translateY(0)    scale(1);    opacity: 1; }
    }
    .modal.open .modal-img-wrap {
      animation: reveal-pop 0.5s 0.16s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    }
    .modal.open .modal-prize {
      animation: reveal-pop 0.5s 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    }
    .modal.open .modal-desc {
      animation: reveal-rise 0.4s 0.46s ease-out forwards;
    }
    /* 銘謝惠顧類：溫和動效、不彈跳不慶祝 */
    @keyframes reveal-soft {
      from { transform: scale(0.94); opacity: 0; }
      to   { transform: scale(1);    opacity: 1; }
    }
    .modal.noprize .modal-img-wrap {
      background: linear-gradient(135deg, #F4F4F6, #E8E8EC);
    }
    .modal.noprize .modal-img-wrap .glyph { color: var(--ink-3); }
    .modal.noprize .modal-eyebrow { color: var(--ink-3); }
    .modal.noprize.open .modal-img-wrap,
    .modal.noprize.open .modal-prize {
      animation-name: reveal-soft;
      animation-timing-function: ease-out;
    }

    /* ========== Reduced motion：關閉大型動畫 ========== */
    @media (prefers-reduced-motion: reduce) {
      .brand-bar, .hero, .stats, .invite-card, .stage-card, .section, .foot {
        animation: none;
      }
      .spin-btn:not(:disabled) { animation: none; }
      .stage.spinning .pointer svg,
      .stage.landed .pointer svg { animation: none; }
      .status-row .arrow { animation: none; }
      .stat .v.pop { animation: none; }
      #wheel { transition-duration: 1.1s; }
      .modal.open .modal-img-wrap,
      .modal.open .modal-prize,
      .modal.open .modal-desc {
        animation: reveal-soft 0.25s ease-out forwards;
      }
    }
  </style>
</head>
<body>
  <div class="page">

    <header class="brand-bar">
      <div class="logo">
        <span class="dot"></span>
        OpenRice
      </div>
      <div class="chip">活動進行中</div>
    </header>

    <section class="hero">
      <div class="hero-tag">幸運抽獎</div>
      <h1><%= activity.name %></h1>
      <% if (activity.description) { %>
        <p><%= activity.description %></p>
      <% } %>
      <% if (activity.cover_image_url) { %>
        <img class="hero-cover" src="<%= activity.cover_image_url %>" alt="" />
      <% } %>
    </section>

    <section class="stats">
      <div class="stat">
        <div class="v" id="stat-remaining">—</div>
        <div class="k">剩餘次數</div>
      </div>
      <div class="stat">
        <div class="v" id="stat-referrals">—</div>
        <div class="k">已邀請</div>
      </div>
      <div class="stat">
        <div class="v"><%= prizes && prizes.length || 0 %><span class="unit">種</span></div>
        <div class="k">獎品</div>
      </div>
    </section>

    <section class="invite-card" id="invite-card">
      <div class="invite-left">
        <div class="invite-eyebrow">好友加碼</div>
        <% if (activity.referral_bonus_per && activity.referral_bonus_per > 0) { %>
          <div class="invite-title">邀 1 位朋友，立刻 +<%= activity.referral_bonus_per %> 次</div>
          <div class="invite-sub" id="invite-sub">最多可加 <%= activity.referral_bonus_max %> 次，分享就有</div>
        <% } else { %>
          <div class="invite-title">分享給朋友一起玩</div>
          <div class="invite-sub" id="invite-sub">把這個活動傳出去</div>
        <% } %>
      </div>
      <button type="button" class="invite-btn" id="invite-btn">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:5px;vertical-align:-2px;">
          <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/>
          <polyline points="16 6 12 2 8 6"/>
          <line x1="12" y1="2" x2="12" y2="15"/>
        </svg>分享
      </button>
    </section>

    <section class="stage-card">
      <div class="stage-head">
        <span class="label">轉盤</span>
        <span class="count">準備好按下中央按鈕</span>
      </div>
      <div class="stage-wrap">
        <div class="stage" id="stage">
          <div class="pointer">
            <svg width="22" height="26" viewBox="0 0 22 26" fill="none">
              <path d="M11 26 L1 8 Q1 1 11 1 Q21 1 21 8 Z" fill="#0F0F10"/>
              <circle cx="11" cy="9" r="3" fill="#FCC726"/>
            </svg>
          </div>
          <div class="canvas-wrap">
            <canvas id="wheel" width="720" height="720"></canvas>
          </div>
          <div class="center">
            <button type="button" id="spin-btn" class="spin-btn">SPIN</button>
          </div>
        </div>
      </div>
      <div class="status-row" id="status-row">
        <span id="status">準備中</span>
      </div>
    </section>

    <% if (prizes && prizes.length > 0) { %>
    <section class="section">
      <div class="section-head">
        <h2>本次獎項</h2>
        <span class="meta"><%= prizes.length %> 種</span>
      </div>
      <div class="prize-grid">
        <% prizes.forEach(function (p, i) { %>
          <div class="prize-card <%= p.is_grand_prize ? 'grand' : '' %>">
            <div class="top">
              <div class="icon"><%= String(i + 1).padStart(2, '0') %></div>
              <% if (p.is_grand_prize) { %>
                <span class="badge">頭獎</span>
              <% } %>
            </div>
            <div class="name"><%= p.name %></div>
            <% if (p.description) { %>
              <div class="desc"><%= p.description %></div>
            <% } %>
          </div>
        <% }); %>
      </div>
    </section>
    <% } %>

    <div class="foot">
      <div class="l">
        <span class="i">i</span>
        <span>遊戲規則</span>
      </div>
      <span class="r">公平隨機</span>
    </div>

  </div>

  <!-- Result -->
  <div id="modal" class="modal" aria-hidden="true">
    <div class="sheet">
      <div class="handle"></div>
      <div class="modal-eyebrow" id="modal-eyebrow">恭喜抽中</div>
      <div class="modal-img-wrap" id="modal-img-wrap">
        <img id="modal-img" alt="" hidden />
        <span class="glyph" id="modal-glyph">★</span>
      </div>
      <div class="modal-prize" id="modal-prize">—</div>
      <div class="modal-desc" id="modal-desc"></div>
      <div class="coupon-block" id="coupon-block" hidden>
        <div class="coupon-label">優惠序號</div>
        <div class="coupon-code" id="coupon-code">—</div>
        <div class="coupon-hint">請到店出示此畫面或序號給店員核銷</div>
      </div>
      <div class="coupon-oos" id="coupon-oos" hidden>此獎品序號暫時發完，請洽客服</div>
      <button type="button" class="modal-btn" id="modal-close">完成</button>
      <a class="wallet-link" id="wallet-link" href="#">我的優惠券</a>
    </div>
  </div>

  <script>
    (function () {
      var slug = <%- JSON.stringify(activity.slug) %>;
      var liffId = <%- JSON.stringify(liffId || '') %>;
      var prizes = <%- JSON.stringify(prizes || []) %>;
      var activityMeta = <%- JSON.stringify({
        name: activity.name,
        referral_bonus_per: activity.referral_bonus_per,
        referral_bonus_max: activity.referral_bonus_max
      }) %>;

      var canvas = document.getElementById('wheel');
      var ctx = canvas.getContext('2d');
      var spinBtn = document.getElementById('spin-btn');
      var statusEl = document.getElementById('status');
      var statusRow = document.getElementById('status-row');
      var modal = document.getElementById('modal');

      var spinning = false;
      var currentRotation = 0;
      var profile = null;
      var idToken = null;
      var liffReady = false;

      var REDUCED = !!(window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches);

      // ----- 觸覺回饋（guard）-----
      function buzz(pattern) {
        if (navigator.vibrate) {
          try { navigator.vibrate(pattern); } catch (e) {}
        }
      }

      // ----- 輕量 canvas 紙花（黃 / 墨 / 白，~80 顆，自動清理）-----
      function fireConfetti() {
        if (REDUCED) return;
        var c = document.createElement('canvas');
        c.style.cssText = 'position:fixed;inset:0;width:100%;height:100%;pointer-events:none;z-index:300;';
        var dpr = Math.min(window.devicePixelRatio || 1, 2);
        var vw = window.innerWidth, vh = window.innerHeight;
        c.width = vw * dpr;
        c.height = vh * dpr;
        document.body.appendChild(c);
        var cc = c.getContext('2d');
        cc.scale(dpr, dpr);
        var colors = ['#FCC726', '#1F2937', '#FFFFFF'];
        var parts = [];
        for (var i = 0; i < 80; i++) {
          parts.push({
            x: vw / 2 + (Math.random() - 0.5) * vw * 0.55,
            y: vh * 0.3 + (Math.random() - 0.5) * 50,
            vx: (Math.random() - 0.5) * 7,
            vy: -(Math.random() * 8 + 4),
            size: Math.random() * 6 + 4,
            color: colors[i % 3],
            round: Math.random() < 0.35,
            rot: Math.random() * Math.PI,
            vr: (Math.random() - 0.5) * 0.3
          });
        }
        var t0 = null;
        var LIFE = 1700;
        function tick(ts) {
          if (t0 === null) t0 = ts;
          var t = ts - t0;
          cc.clearRect(0, 0, vw, vh);
          cc.globalAlpha = t > LIFE - 400 ? Math.max(0, (LIFE - t) / 400) : 1;
          for (var j = 0; j < parts.length; j++) {
            var p = parts[j];
            p.vy += 0.28; p.x += p.vx; p.y += p.vy; p.rot += p.vr;
            cc.save();
            cc.translate(p.x, p.y);
            cc.rotate(p.rot);
            cc.fillStyle = p.color;
            if (p.round) {
              cc.beginPath();
              cc.arc(0, 0, p.size / 2, 0, Math.PI * 2);
              cc.fill();
            } else {
              cc.fillRect(-p.size / 2, -p.size / 2, p.size, p.size);
            }
            cc.restore();
          }
          if (t < LIFE) requestAnimationFrame(tick);
          else c.remove();
        }
        requestAnimationFrame(tick);
      }

      // ===========================================================
      // 畫輪盤 — 純色配色（黃白交替、紅大獎）+ 細邊分隔
      // ===========================================================
      function drawWheel(highlightIdx, pulse) {
        var W = canvas.width;
        var H = canvas.height;
        var cx = W / 2, cy = H / 2;
        var R = W / 2 - 3;
        var n = prizes.length;
        var anglePer = (Math.PI * 2) / n;

        ctx.clearRect(0, 0, W, H);

        // 扇形填色
        prizes.forEach(function (p, i) {
          var start = i * anglePer - Math.PI / 2;
          var end = start + anglePer;
          ctx.beginPath();
          ctx.moveTo(cx, cy);
          ctx.arc(cx, cy, R, start, end);
          ctx.closePath();
          if (p.is_grand_prize) ctx.fillStyle = '#E11D27';
          else ctx.fillStyle = (i % 2 === 0) ? '#FFFFFF' : '#FCC726';
          ctx.fill();
        });

        // 扇形分隔線（細）
        prizes.forEach(function (p, i) {
          var angle = i * anglePer - Math.PI / 2;
          ctx.beginPath();
          ctx.moveTo(cx, cy);
          ctx.lineTo(cx + Math.cos(angle) * R, cy + Math.sin(angle) * R);
          ctx.lineWidth = 1.5;
          ctx.strokeStyle = 'rgba(15, 15, 16, 0.1)';
          ctx.stroke();
        });

        // 外圈細線
        ctx.beginPath();
        ctx.arc(cx, cy, R, 0, Math.PI * 2);
        ctx.lineWidth = 2;
        ctx.strokeStyle = '#0F0F10';
        ctx.stroke();

        // 文字 — sans-serif 粗體，水平擺放
        prizes.forEach(function (p, i) {
          var start = i * anglePer - Math.PI / 2;
          var midAngle = start + anglePer / 2;
          var textRadius = R * 0.62;

          ctx.save();
          ctx.translate(cx, cy);
          ctx.rotate(midAngle);
          ctx.translate(textRadius, 0);
          ctx.rotate(-midAngle);

          ctx.textAlign = 'center';
          ctx.textBaseline = 'middle';
          ctx.fillStyle = p.is_grand_prize ? '#FFFFFF' : '#0F0F10';
          ctx.font = '700 19px -apple-system, "SF Pro Display", "Inter", "PingFang TC", sans-serif';

          var label = String(p.name || '');
          if (label.length > 8) label = label.slice(0, 8) + '…';
          ctx.fillText(label, 0, 0);
          ctx.restore();
        });

        // 停止瞬間的中獎高亮：其餘扇形微暗 + 中獎格亮黃描邊 pulse
        if (typeof highlightIdx === 'number' && highlightIdx >= 0 && highlightIdx < n) {
          prizes.forEach(function (p, i) {
            if (i === highlightIdx) return;
            var ds = i * anglePer - Math.PI / 2;
            var de = ds + anglePer;
            ctx.beginPath();
            ctx.moveTo(cx, cy);
            ctx.arc(cx, cy, R, ds, de);
            ctx.closePath();
            ctx.fillStyle = 'rgba(15, 15, 16, 0.30)';
            ctx.fill();
          });
          var hs = highlightIdx * anglePer - Math.PI / 2;
          var he = hs + anglePer;
          ctx.beginPath();
          ctx.moveTo(cx, cy);
          ctx.arc(cx, cy, R - 5, hs, he);
          ctx.closePath();
          ctx.lineWidth = 10;
          ctx.lineJoin = 'round';
          ctx.globalAlpha = (typeof pulse === 'number') ? (0.35 + 0.65 * pulse) : 1;
          ctx.strokeStyle = '#FCC726';
          ctx.stroke();
          ctx.globalAlpha = 1;
        }
      }

      // ----- 停止瞬間：中獎扇形高亮 pulse（~0.55s）再揭曉 -----
      function highlightWinner(prize) {
        var idx = prizes.findIndex(function (p) { return p.id === prize.id; });
        if (idx < 0) {
          return new Promise(function (resolve) { setTimeout(resolve, 250); });
        }
        buzz([12, 50, 20]);
        return new Promise(function (resolve) {
          if (REDUCED) {
            drawWheel(idx, 1);
            setTimeout(resolve, 250);
            return;
          }
          var startTs = null;
          var DUR = 550;
          function frame(ts) {
            if (startTs === null) startTs = ts;
            var t = Math.min((ts - startTs) / DUR, 1);
            var pulse = 0.5 - 0.5 * Math.cos(t * Math.PI * 4); // 兩次脈衝
            drawWheel(idx, t >= 1 ? 1 : pulse);
            if (t < 1) requestAnimationFrame(frame);
            else resolve();
          }
          requestAnimationFrame(frame);
        });
      }

      // ----- LIFF init -----
      async function initLiff() {
        var qs = new URLSearchParams(location.search);
        var devUid = qs.get('uid');
        if (devUid) {
          profile = { userId: devUid, displayName: qs.get('name') || 'DEV' };
          return;
        }
        if (qs.get('preview') === '1') {
          profile = { userId: 'PREVIEW', displayName: '預覽' };
          spinBtn.disabled = true;
          spinBtn.textContent = '預覽';
          return;
        }
        if (!liffId) throw new Error('LIFF ID 未設定');
        try { await liff.init({ liffId: liffId }); }
        catch (e) { throw new Error('LIFF 初始化失敗'); }
        if (!liff.isInClient()) throw new Error('請在 LINE App 內打開');
        if (!liff.isLoggedIn()) {
          liff.login();
          return new Promise(function () {});
        }
        profile = await liff.getProfile();
        try { idToken = liff.getIDToken(); } catch (e) {}
      }

      // ----- 旋轉動畫：反向蓄力 → 長尾 ease-out 正轉 → 指針 bounce -----
      function animateToPrize(prize) {
        var n = prizes.length;
        if (n === 0) return Promise.resolve();
        var idx = prizes.findIndex(function (p) { return p.id === prize.id; });
        if (idx < 0) idx = 0;
        var anglePer = 360 / n;
        var targetCenter = (idx + 0.5) * anglePer;
        var jitter = (Math.random() - 0.5) * (anglePer * 0.5);
        var finalAngle = currentRotation + 360 * 6 + (360 - targetCenter) + jitter;
        var windFrom = currentRotation;
        currentRotation = finalAngle;

        var stage = document.getElementById('stage');
        var spinMs = REDUCED ? 1200 : 5300; // 對應 CSS transition 時長

        return new Promise(function (resolve) {
          function mainSpin() {
            canvas.classList.remove('windup');
            void canvas.offsetWidth; // 強制 reflow，確保 transition 切換生效
            if (stage) stage.classList.add('spinning');
            canvas.style.transform = 'rotate(' + finalAngle + 'deg)';
            setTimeout(function () {
              if (stage) {
                stage.classList.remove('spinning');
                stage.classList.add('landed');
                setTimeout(function () { stage.classList.remove('landed'); }, 650);
              }
              resolve();
            }, spinMs);
          }
          if (REDUCED) {
            mainSpin();
            return;
          }
          // 蓄力：先反向 -15deg（0.3s），再正轉
          canvas.classList.add('windup');
          canvas.style.transform = 'rotate(' + (windFrom - 15) + 'deg)';
          setTimeout(mainSpin, 320);
        });
      }

      // ----- spin -----
      async function spin() {
        if (spinning) return;
        if (!liffReady || !profile) {
          statusEl.textContent = '請稍候';
          return;
        }
        spinning = true;
        spinBtn.disabled = true;
        statusRow.classList.remove('ready');
        statusEl.textContent = '抽選中⋯';
        buzz(12);

        try {
          var resp = await fetch('/api/games/wheel/' + encodeURIComponent(slug) + '/spin', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              line_user_id: profile.userId,
              line_display_name: profile.displayName || null,
              id_token: idToken
            })
          }).then(function (r) { return r.json(); });

          if (!resp.ok) {
            statusEl.textContent = resp.detail || resp.error || '抽選失敗';
            spinning = false;
            spinBtn.disabled = false;
            return;
          }

          await animateToPrize(resp.prize);
          await highlightWinner(resp.prize); // 停頓：高亮 pulse ~0.55s
          showResult(resp.prize, resp);
        } catch (e) {
          statusEl.textContent = '錯誤';
        } finally {
          spinning = false;
          spinBtn.disabled = false;
        }
      }

      // 「銘謝惠顧」類判斷（純演出用：決定要不要慶祝）
      function isNoPrize(prize) {
        if (!prize) return false;
        if (prize.prize_type === 'none') return true;
        return /銘謝|惠顧|再接再厲|未中|落空/.test(String(prize.name || ''));
      }

      // 優惠序號顯示：coupon_code 可能在 prize 物件上或 /play 回應頂層
      function renderCoupon(prize, resp) {
        var block = document.getElementById('coupon-block');
        var oos = document.getElementById('coupon-oos');
        if (!block || !oos) return;
        var code = (prize && prize.coupon_code) || (resp && resp.coupon_code) || '';
        var outOfStock = !!(resp && resp.coupon_out_of_stock) || !!(prize && prize.coupon_out_of_stock);
        if (code) {
          document.getElementById('coupon-code').textContent = code;
          block.hidden = false;
          oos.hidden = true;
        } else if (outOfStock) {
          block.hidden = true;
          oos.hidden = false;
        } else {
          block.hidden = true;
          oos.hidden = true;
        }
      }

      function showResult(prize, resp) {
        statusEl.textContent = '';
        renderCoupon(prize, resp);
        var noPrize = isNoPrize(prize);
        var eyebrowEl = document.getElementById('modal-eyebrow');
        if (eyebrowEl) eyebrowEl.textContent = noPrize ? '開獎結果' : '恭喜抽中';
        document.getElementById('modal-prize').textContent = prize.name || '—';
        var imgEl = document.getElementById('modal-img');
        var glyphEl = document.getElementById('modal-glyph');
        if (prize.image_url) {
          imgEl.src = prize.image_url;
          imgEl.hidden = false;
          glyphEl.style.display = 'none';
        } else {
          imgEl.hidden = true;
          glyphEl.style.display = 'block';
          glyphEl.textContent = prize.is_grand_prize ? '★' : '◆';
        }
        var descParts = [];
        if (prize.prize_value) {
          if (prize.prize_value.amount) descParts.push('NT$ ' + prize.prize_value.amount);
          if (prize.prize_value.code) descParts.push('優惠碼 ' + prize.prize_value.code);
          if (prize.prize_value.label) descParts.push(prize.prize_value.label);
          if (prize.prize_value.note) descParts.push(prize.prize_value.note);
        }
        document.getElementById('modal-desc').textContent = descParts.join(' · ');
        if (prize.is_grand_prize) modal.classList.add('grand');
        else modal.classList.remove('grand');
        if (noPrize) modal.classList.add('noprize');
        else modal.classList.remove('noprize');
        requestAnimationFrame(function () { modal.classList.add('open'); });
        // 揭曉節奏：modal 彈起 → 獎名彈跳放大 → 慶祝
        if (!noPrize) {
          setTimeout(function () {
            fireConfetti();
            buzz([18, 70, 32]);
          }, 380);
        } else {
          buzz(14);
        }
      }

      // 「我的優惠券」連結，導向錢包頁（LIFF 永久連結 /wallet）
      var walletLink = document.getElementById('wallet-link');
      if (walletLink) {
        walletLink.href = liffId ? ('https://liff.line.me/' + liffId + '/wallet') : '/games/wallet';
      }

      document.getElementById('modal-close').addEventListener('click', function () {
        modal.classList.remove('open');
        drawWheel(); // 還原高亮
      });
      modal.addEventListener('click', function (e) {
        if (e.target === modal) {
          modal.classList.remove('open');
          drawWheel(); // 還原高亮
        }
      });

      spinBtn.addEventListener('click', spin);

      // ----- bootstrap -----
      if (prizes.length < 2) {
        statusEl.textContent = '獎品不足';
        spinBtn.disabled = true;
        spinBtn.textContent = '—';
      } else {
        drawWheel();
        spinBtn.disabled = true;
        statusEl.textContent = '驗證身分中⋯';
      }

      (async function () {
        if (prizes.length < 2) return;
        try {
          await initLiff();
          liffReady = true;

          // 1) 先處理「我是被邀請來的」— 把 referral 寫進 DB
          await maybeRegisterReferral();

          // 2) 拉 quota
          await refreshQuota();

          // 3) ready
          statusRow.classList.add('ready');
          statusEl.innerHTML = '哈囉，<span class="name">' + (profile.displayName || '') + '</span>';
        } catch (e) {
          statusEl.textContent = e.message || '初始化失敗';
        }
      })();

      // ----- 邀請拉新：偵測 ?ref= 並寫 referral -----
      async function maybeRegisterReferral() {
        try {
          var qs = new URLSearchParams(location.search);
          var inviter = qs.get('ref');
          if (!inviter) return;
          if (!profile || !profile.userId) return;
          if (inviter === profile.userId) return; // 不能邀請自己
          await fetch('/api/games/wheel/' + encodeURIComponent(slug) + '/referral', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              line_user_id: profile.userId,
              inviter_line_user_id: inviter,
              id_token: idToken
            })
          });
          // 清掉 URL 上的 ref（避免重整時又 POST）
          var url = new URL(location.href);
          url.searchParams.delete('ref');
          history.replaceState({}, '', url.pathname + url.search);
        } catch (e) {
          console.warn('referral register failed:', e);
        }
      }

      // ----- 拉 quota 並更新 UI -----
      async function refreshQuota() {
        try {
          if (!profile || !profile.userId) return;
          var resp = await fetch('/api/games/wheel/' + encodeURIComponent(slug) +
            '/meta?line_user_id=' + encodeURIComponent(profile.userId) + '&id_token=' + encodeURIComponent(idToken || '')).then(function (r) { return r.json(); });
          if (!resp.ok || !resp.quota) return;
          renderQuota(resp.quota);
        } catch (e) { console.warn('quota fetch failed:', e); }
      }

      // 數字變化時 pop 一下（scale 1.3 → 1）
      var lastRemaining = null;
      var lastReferrals = null;
      function popStat(el) {
        if (!el || REDUCED) return;
        el.classList.remove('pop');
        void el.offsetWidth; // restart animation
        el.classList.add('pop');
      }

      function renderQuota(q) {
        var remEl = document.getElementById('stat-remaining');
        var refEl = document.getElementById('stat-referrals');
        if (remEl) remEl.innerHTML = q.remaining + '<span class="unit">/ ' + q.total + '</span>';
        if (refEl) refEl.innerHTML = q.referrals + '<span class="unit">人</span>';
        if (remEl && lastRemaining !== null && lastRemaining !== q.remaining) popStat(remEl);
        if (refEl && lastReferrals !== null && lastReferrals !== q.referrals) popStat(refEl);
        lastRemaining = q.remaining;
        lastReferrals = q.referrals;

        // 沒次數 → SPIN 鈕禁用 + 提示
        if (q.remaining <= 0) {
          spinBtn.disabled = true;
          var canMore = q.referral_bonus_per > 0 && q.referral_bonus < q.referral_bonus_max;
          if (canMore) {
            statusRow.classList.remove('ready');
            statusEl.textContent = '次數用完，邀請朋友 +' + q.referral_bonus_per + ' 次';
          } else {
            statusEl.textContent = '次數已用完';
          }
        } else {
          spinBtn.disabled = false;
        }

        // invite card 顯示剩餘可加額度
        var inviteCard = document.getElementById('invite-card');
        var inviteSub = document.getElementById('invite-sub');
        // 只在有邀請機制時更新文案；否則保留 server render 的「把這個活動傳出去」
        if (inviteCard && q.referral_bonus_per > 0) {
          var bonusLeft = q.referral_bonus_max - q.referral_bonus;
          if (bonusLeft <= 0) {
            inviteCard.classList.add('maxed');
            if (inviteSub) inviteSub.textContent = '邀請次數已用滿';
          } else {
            inviteCard.classList.remove('maxed');
            if (inviteSub) inviteSub.textContent = '還可再邀請 ' + Math.ceil(bonusLeft / q.referral_bonus_per) + ' 位拿 +' + bonusLeft + ' 次';
          }
        }
      }

      // ----- 分享按鈕（LIFF Share Target Picker）-----
      var inviteBtn = document.getElementById('invite-btn');
      if (inviteBtn) {
        inviteBtn.addEventListener('click', shareWithFriend);
      }
      async function shareWithFriend() {
        if (!profile || !profile.userId) {
          alert('身分驗證中，稍等一下再試');
          return;
        }
        // 邀請連結：LIFF 短網址帶 ref query 跟 sub-path
        // 注意：LIFF 短網址子路徑會被 append 到 endpoint URL
        // /wheel/<slug>?ref=<my_id> 會解析到 /games/wheel/<slug>?ref=<my_id>
        var inviteUrl = 'https://liff.line.me/' + liffId +
          '/wheel/' + encodeURIComponent(slug) + '?ref=' + encodeURIComponent(profile.userId);
        var msg = '快來抽「' + activityMeta.name + '」！我已經抽過了，你也來試試';

        try {
          if (liff.isApiAvailable && liff.isApiAvailable('shareTargetPicker')) {
            var res = await liff.shareTargetPicker([{
              type: 'text',
              text: msg + '\n' + inviteUrl
            }]);
            if (res) {
              // 分享成功（不一定代表對方點開，只代表用戶選擇了對象）
              flashStatus('已分享！朋友打開後就加 ' + activityMeta.referral_bonus_per + ' 次');
            }
            return;
          }
        } catch (e) {
          console.warn('shareTargetPicker failed:', e);
        }
        // fallback: 複製連結
        try {
          await navigator.clipboard.writeText(inviteUrl);
          flashStatus('連結已複製，傳給朋友吧');
        } catch (e) {
          prompt('複製這個連結傳給朋友：', inviteUrl);
        }
      }
      function flashStatus(msg) {
        var orig = statusEl.textContent;
        statusEl.textContent = msg;
        setTimeout(function () {
          // 重新拉 quota 確保 UI sync
          refreshQuota();
          if (statusEl.textContent === msg && profile) {
            statusEl.innerHTML = '哈囉，<span class="name">' + (profile.displayName || '') + '</span>';
          }
        }, 2400);
      }

      // spin 成功後也要 refresh quota
      var origAnimate = animateToPrize;
      animateToPrize = function (prize) {
        return origAnimate(prize).then(function () {
          // 不要 await（讓 modal 先彈），但稍後 refresh
          setTimeout(refreshQuota, 600);
        });
      };
    })();
  </script>
</body>
</html>
