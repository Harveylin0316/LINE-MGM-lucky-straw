<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#FAFAFA" />
  <title><%= title %></title>
  <script src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>
  <style>
    :root {
      --bg:         #FAFAFA;
      --surface:    #FFFFFF;
      --or-yellow:  #FCC726;
      --or-yellow-d: #E8B400;
      --or-red:     #E11D27;
      --ink:        #0F0F10;
      --ink-2:      #6B6B70;
      --ink-3:      #A0A0A6;
      --border:     #ECECEE;
      --border-2:   #E0E0E4;
    }
    * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
    html, body { margin: 0; padding: 0; }
    body {
      background: var(--bg);
      color: var(--ink);
      min-height: 100vh;
      font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "SF Pro Text",
        "Inter", "PingFang TC", "Microsoft JhengHei", sans-serif;
      letter-spacing: -0.011em;
      -webkit-font-smoothing: antialiased;
    }

    .page {
      max-width: 480px;
      margin: 0 auto;
      padding: 16px 16px 56px;
    }

    /* ========== Brand bar ========== */
    .brand-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 6px 0 16px;
    }
    .brand-bar .logo {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: -0.01em;
      color: var(--ink);
    }
    .brand-bar .logo .dot {
      width: 18px; height: 18px; border-radius: 6px;
      background: var(--or-yellow);
      display: inline-block;
      position: relative;
      flex-shrink: 0;
    }
    .brand-bar .logo .dot::after {
      content: '';
      position: absolute;
      inset: 4px;
      border-radius: 50%;
      background: var(--ink);
    }
    .brand-bar .chip {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      font-size: 11px;
      font-weight: 500;
      color: var(--ink-2);
      background: var(--surface);
      border: 1px solid var(--border);
      padding: 5px 10px;
      border-radius: 999px;
    }
    .brand-bar .chip::before {
      content: '';
      width: 5px; height: 5px;
      border-radius: 50%;
      background: #22C55E;
      box-shadow: 0 0 0 2px rgba(34, 197, 94, 0.15);
    }

    /* ========== Hero card ========== */
    .hero {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 22px 22px 24px;
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute;
      top: -40px;
      right: -40px;
      width: 180px;
      height: 180px;
      background: radial-gradient(circle, rgba(252, 199, 38, 0.18), transparent 70%);
      pointer-events: none;
    }
    .hero-tag {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.06em;
      color: var(--or-red);
      text-transform: uppercase;
      margin-bottom: 14px;
    }
    .hero-tag::before {
      content: '';
      width: 6px; height: 6px;
      background: var(--or-red);
      border-radius: 50%;
    }
    .hero h1 {
      margin: 0 0 8px;
      font-size: 26px;
      font-weight: 700;
      letter-spacing: -0.028em;
      line-height: 1.2;
    }
    .hero p {
      margin: 0;
      font-size: 14px;
      line-height: 1.55;
      color: var(--ink-2);
    }
    .hero-cover {
      width: calc(100% + 44px);
      margin: 18px -22px -24px;
      aspect-ratio: 16 / 9;
      object-fit: cover;
      display: block;
      border-top: 1px solid var(--border);
    }

    /* ========== Stats strip ========== */
    .stats {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 8px;
      margin-top: 12px;
    }
    .stat {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 12px 12px;
    }
    .stat .v {
      font-size: 20px;
      font-weight: 700;
      letter-spacing: -0.02em;
      line-height: 1;
      font-variant-numeric: tabular-nums;
    }
    .stat .v .unit { font-size: 11px; font-weight: 500; color: var(--ink-2); margin-left: 2px; }
    .stat .k {
      font-size: 11px;
      color: var(--ink-2);
      margin-top: 5px;
      font-weight: 500;
    }

    /* ========== Invite card（MGM）========== */
    .invite-card {
      margin-top: 8px;
      background: var(--ink);
      border-radius: 16px;
      padding: 14px 16px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      position: relative;
      overflow: hidden;
      color: #fff;
    }
    .invite-card::before {
      content: '';
      position: absolute;
      top: -40px;
      right: -30px;
      width: 140px; height: 140px;
      background: radial-gradient(circle, rgba(252, 199, 38, 0.32), transparent 70%);
      pointer-events: none;
    }
    .invite-left { flex: 1; min-width: 0; z-index: 1; }
    .invite-title {
      font-size: 14px;
      font-weight: 700;
      letter-spacing: -0.012em;
      line-height: 1.3;
    }
    .invite-sub {
      font-size: 11px;
      color: rgba(255, 255, 255, 0.62);
      margin-top: 3px;
    }
    .invite-btn {
      flex-shrink: 0;
      background: var(--or-yellow);
      color: var(--ink);
      border: none;
      border-radius: 999px;
      padding: 8px 16px;
      font-family: inherit;
      font-weight: 700;
      font-size: 13px;
      cursor: pointer;
      letter-spacing: -0.005em;
      z-index: 1;
      transition: background 0.15s ease, transform 0.15s cubic-bezier(0.34, 1.56, 0.64, 1);
      display: inline-flex;
      align-items: center;
    }
    .invite-btn:hover { background: var(--or-yellow-d); }
    .invite-btn:active { transform: scale(0.96); }
    .invite-card.maxed { opacity: 0.6; }
    .invite-card.maxed .invite-btn { background: var(--ink-3); cursor: default; pointer-events: none; }

    /* ========== Stage card ========== */
    .stage-card {
      margin-top: 12px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 24px;
      padding: 24px 20px 20px;
      position: relative;
      overflow: hidden;
    }
    .stage-card::before {
      content: '';
      position: absolute;
      bottom: -80px;
      left: -60px;
      width: 240px; height: 240px;
      background: radial-gradient(circle, rgba(225, 29, 39, 0.05), transparent 70%);
      pointer-events: none;
    }
    .stage-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 12px;
      position: relative;
    }
    .stage-head .label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--ink-3);
    }
    .stage-head .count {
      font-size: 11px;
      color: var(--ink-2);
      font-weight: 500;
      font-variant-numeric: tabular-nums;
    }
    .stage-wrap {
      display: flex;
      justify-content: center;
      padding: 8px 0 4px;
      position: relative;
    }
    .stage {
      position: relative;
      width: min(76vw, 300px);
      aspect-ratio: 1;
    }
    .pointer {
      position: absolute;
      top: -6px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 5;
    }
    .pointer svg { display: block; }
    .canvas-wrap {
      position: relative;
      width: 100%;
      height: 100%;
      border-radius: 50%;
      overflow: hidden;
      box-shadow:
        0 0 0 1px rgba(15, 15, 16, 0.06),
        0 12px 36px -8px rgba(15, 15, 16, 0.18),
        0 4px 12px -2px rgba(15, 15, 16, 0.08);
    }
    #wheel {
      width: 100%;
      height: 100%;
      display: block;
      transition: transform 5.6s cubic-bezier(0.16, 0.74, 0.24, 1);
    }

    /* 中央按鈕 — 黃色 + 微陰影，現代 web product 風 */
    .center {
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      width: 27%;
      height: 27%;
      z-index: 4;
    }
    .center::before {
      content: '';
      position: absolute;
      inset: -5px;
      border-radius: 50%;
      background: var(--surface);
      box-shadow:
        0 0 0 1px var(--border),
        0 6px 16px -4px rgba(15, 15, 16, 0.12);
      z-index: -1;
    }
    .spin-btn {
      width: 100%;
      height: 100%;
      border-radius: 50%;
      border: none;
      background: var(--or-yellow);
      color: var(--ink);
      font-family: inherit;
      font-weight: 700;
      font-size: 15px;
      letter-spacing: 0.08em;
      cursor: pointer;
      transition: transform 0.18s cubic-bezier(0.34, 1.56, 0.64, 1),
                  background 0.15s ease;
      position: relative;
    }
    .spin-btn:hover:not(:disabled) { background: var(--or-yellow-d); }
    .spin-btn:active:not(:disabled) { transform: scale(0.93); }
    .spin-btn:disabled {
      background: #F0F0F2;
      color: var(--ink-3);
      cursor: default;
    }

    /* ========== Status line ========== */
    .status-row {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      margin-top: 18px;
      font-size: 13px;
      color: var(--ink-2);
      min-height: 22px;
    }
    .status-row .arrow {
      color: var(--ink-3);
      font-size: 14px;
      animation: bounce 1.4s ease-in-out infinite;
    }
    @keyframes bounce {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-3px); }
    }
    .status-row.ready .arrow { display: inline-block; }
    .status-row:not(.ready) .arrow { display: none; }
    .status-row .name {
      color: var(--ink);
      font-weight: 600;
    }

    /* ========== Prize section ========== */
    .section {
      margin-top: 24px;
    }
    .section-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      padding: 0 4px;
      margin-bottom: 10px;
    }
    .section-head h2 {
      margin: 0;
      font-size: 17px;
      font-weight: 700;
      letter-spacing: -0.015em;
    }
    .section-head .meta {
      font-size: 11px;
      color: var(--ink-2);
      font-weight: 500;
      font-variant-numeric: tabular-nums;
    }

    .prize-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }
    .prize-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 14px;
      position: relative;
      transition: transform 0.15s ease, border-color 0.15s ease;
    }
    .prize-card.grand {
      grid-column: span 2;
      border-color: var(--or-red);
      background: linear-gradient(180deg, rgba(225, 29, 39, 0.04), transparent);
    }
    .prize-card .top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 8px;
    }
    .prize-card .icon {
      width: 32px; height: 32px;
      border-radius: 10px;
      background: linear-gradient(135deg, #FFF7DA, var(--or-yellow));
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--ink);
      font-weight: 700;
      font-size: 14px;
      font-variant-numeric: tabular-nums;
      flex-shrink: 0;
    }
    .prize-card.grand .icon {
      background: var(--or-red);
      color: #fff;
    }
    .prize-card .badge {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.06em;
      padding: 3px 8px;
      border-radius: 999px;
      background: var(--or-red);
      color: #fff;
    }
    .prize-card .name {
      font-size: 14px;
      font-weight: 600;
      letter-spacing: -0.005em;
      line-height: 1.35;
      color: var(--ink);
    }
    .prize-card .desc {
      margin-top: 3px;
      font-size: 12px;
      color: var(--ink-2);
      line-height: 1.4;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    /* ========== Footer ========== */
    .foot {
      margin-top: 28px;
      padding: 14px 16px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-size: 12px;
      color: var(--ink-2);
    }
    .foot .l { display: flex; align-items: center; gap: 8px; }
    .foot .i {
      width: 20px; height: 20px;
      border-radius: 6px;
      background: var(--bg);
      border: 1px solid var(--border);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 11px;
      color: var(--ink-2);
    }
    .foot .r {
      font-weight: 600;
      color: var(--ink);
      font-variant-numeric: tabular-nums;
    }

    /* ========== Modal ========== */
    .modal {
      position: fixed;
      inset: 0;
      z-index: 100;
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.3s ease;
      background: rgba(15, 15, 16, 0.55);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      display: flex;
      align-items: flex-end;
      justify-content: center;
    }
    .modal.open { opacity: 1; pointer-events: auto; }
    .sheet {
      width: 100%;
      max-width: 480px;
      background: var(--surface);
      border-radius: 28px 28px 0 0;
      padding: 14px 24px 32px;
      padding-bottom: max(32px, env(safe-area-inset-bottom));
      transform: translateY(100%);
      transition: transform 0.5s cubic-bezier(0.32, 0.72, 0, 1);
    }
    .modal.open .sheet { transform: translateY(0); }
    .handle {
      width: 36px; height: 5px;
      border-radius: 999px;
      background: var(--border-2);
      margin: 0 auto 22px;
    }
    .modal-eyebrow {
      text-align: center;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--or-red);
      margin-bottom: 16px;
    }
    .modal-img-wrap {
      width: 88px; height: 88px;
      margin: 0 auto 16px;
      border-radius: 22px;
      background: linear-gradient(135deg, #FFF7DA, var(--or-yellow));
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    .modal.grand .modal-img-wrap {
      background: linear-gradient(135deg, var(--or-red), #B61118);
    }
    .modal-img-wrap img { width: 100%; height: 100%; object-fit: cover; }
    .modal-img-wrap .glyph {
      font-size: 36px;
      font-weight: 700;
      color: var(--ink);
    }
    .modal.grand .modal-img-wrap .glyph { color: #fff; }
    .modal-prize {
      text-align: center;
      font-size: 26px;
      font-weight: 700;
      letter-spacing: -0.025em;
      color: var(--ink);
      margin-bottom: 8px;
      line-height: 1.15;
    }
    .modal-desc {
      text-align: center;
      color: var(--ink-2);
      font-size: 14px;
      line-height: 1.55;
      margin-bottom: 24px;
    }
    .modal-btn {
      display: block;
      width: 100%;
      padding: 15px;
      background: var(--ink);
      color: #fff;
      border: none;
      border-radius: 14px;
      font-size: 15px;
      font-weight: 600;
      font-family: inherit;
      letter-spacing: -0.005em;
      cursor: pointer;
      transition: transform 0.15s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .modal-btn:active { transform: scale(0.98); }
  </style>
</head>
<body>
  <div class="page">

    <header class="brand-bar">
      <div class="logo">
        <span class="dot"></span>
        OpenRice
      </div>
      <div class="chip">活動進行中</div>
    </header>

    <section class="hero">
      <div class="hero-tag">幸運抽獎</div>
      <h1><%= activity.name %></h1>
      <% if (activity.description) { %>
        <p><%= activity.description %></p>
      <% } %>
      <% if (activity.cover_image_url) { %>
        <img class="hero-cover" src="<%= activity.cover_image_url %>" alt="" />
      <% } %>
    </section>

    <section class="stats">
      <div class="stat">
        <div class="v" id="stat-remaining">—</div>
        <div class="k">剩餘次數</div>
      </div>
      <div class="stat">
        <div class="v" id="stat-referrals">—</div>
        <div class="k">已邀請</div>
      </div>
      <div class="stat">
        <div class="v"><%= prizes && prizes.length || 0 %><span class="unit">種</span></div>
        <div class="k">獎品</div>
      </div>
    </section>

    <% if (activity.referral_bonus_per && activity.referral_bonus_per > 0) { %>
    <section class="invite-card" id="invite-card">
      <div class="invite-left">
        <div class="invite-title">邀請朋友 +<%= activity.referral_bonus_per %> 次抽獎</div>
        <div class="invite-sub" id="invite-sub">最多再加 <%= activity.referral_bonus_max %> 次</div>
      </div>
      <button type="button" class="invite-btn" id="invite-btn">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:5px;vertical-align:-2px;">
          <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/>
          <polyline points="16 6 12 2 8 6"/>
          <line x1="12" y1="2" x2="12" y2="15"/>
        </svg>分享
      </button>
    </section>
    <% } %>

    <section class="stage-card">
      <div class="stage-head">
        <span class="label">轉盤</span>
        <span class="count">準備好按下中央按鈕</span>
      </div>
      <div class="stage-wrap">
        <div class="stage">
          <div class="pointer">
            <svg width="22" height="26" viewBox="0 0 22 26" fill="none">
              <path d="M11 26 L1 8 Q1 1 11 1 Q21 1 21 8 Z" fill="#0F0F10"/>
              <circle cx="11" cy="9" r="3" fill="#FCC726"/>
            </svg>
          </div>
          <div class="canvas-wrap">
            <canvas id="wheel" width="720" height="720"></canvas>
          </div>
          <div class="center">
            <button type="button" id="spin-btn" class="spin-btn">SPIN</button>
          </div>
        </div>
      </div>
      <div class="status-row" id="status-row">
        <span id="status">準備中</span>
      </div>
    </section>

    <% if (prizes && prizes.length > 0) { %>
    <section class="section">
      <div class="section-head">
        <h2>本次獎項</h2>
        <span class="meta"><%= prizes.length %> 種</span>
      </div>
      <div class="prize-grid">
        <% prizes.forEach(function (p, i) { %>
          <div class="prize-card <%= p.is_grand_prize ? 'grand' : '' %>">
            <div class="top">
              <div class="icon"><%= String(i + 1).padStart(2, '0') %></div>
              <% if (p.is_grand_prize) { %>
                <span class="badge">頭獎</span>
              <% } %>
            </div>
            <div class="name"><%= p.name %></div>
            <% if (p.description) { %>
              <div class="desc"><%= p.description %></div>
            <% } %>
          </div>
        <% }); %>
      </div>
    </section>
    <% } %>

    <div class="foot">
      <div class="l">
        <span class="i">i</span>
        <span>遊戲規則</span>
      </div>
      <span class="r">公平隨機</span>
    </div>

  </div>

  <!-- Result -->
  <div id="modal" class="modal" aria-hidden="true">
    <div class="sheet">
      <div class="handle"></div>
      <div class="modal-eyebrow">恭喜抽中</div>
      <div class="modal-img-wrap" id="modal-img-wrap">
        <img id="modal-img" alt="" hidden />
        <span class="glyph" id="modal-glyph">★</span>
      </div>
      <div class="modal-prize" id="modal-prize">—</div>
      <div class="modal-desc" id="modal-desc"></div>
      <button type="button" class="modal-btn" id="modal-close">完成</button>
    </div>
  </div>

  <script>
    (function () {
      var slug = <%- JSON.stringify(activity.slug) %>;
      var liffId = <%- JSON.stringify(liffId || '') %>;
      var prizes = <%- JSON.stringify(prizes || []) %>;
      var activityMeta = <%- JSON.stringify({
        name: activity.name,
        referral_bonus_per: activity.referral_bonus_per,
        referral_bonus_max: activity.referral_bonus_max
      }) %>;

      var canvas = document.getElementById('wheel');
      var ctx = canvas.getContext('2d');
      var spinBtn = document.getElementById('spin-btn');
      var statusEl = document.getElementById('status');
      var statusRow = document.getElementById('status-row');
      var modal = document.getElementById('modal');

      var spinning = false;
      var currentRotation = 0;
      var profile = null;
      var liffReady = false;

      // ===========================================================
      // 畫輪盤 — 純色配色（黃白交替、紅大獎）+ 細邊分隔
      // ===========================================================
      function drawWheel() {
        var W = canvas.width;
        var H = canvas.height;
        var cx = W / 2, cy = H / 2;
        var R = W / 2 - 3;
        var n = prizes.length;
        var anglePer = (Math.PI * 2) / n;

        ctx.clearRect(0, 0, W, H);

        // 扇形填色
        prizes.forEach(function (p, i) {
          var start = i * anglePer - Math.PI / 2;
          var end = start + anglePer;
          ctx.beginPath();
          ctx.moveTo(cx, cy);
          ctx.arc(cx, cy, R, start, end);
          ctx.closePath();
          if (p.is_grand_prize) ctx.fillStyle = '#E11D27';
          else ctx.fillStyle = (i % 2 === 0) ? '#FFFFFF' : '#FCC726';
          ctx.fill();
        });

        // 扇形分隔線（細）
        prizes.forEach(function (p, i) {
          var angle = i * anglePer - Math.PI / 2;
          ctx.beginPath();
          ctx.moveTo(cx, cy);
          ctx.lineTo(cx + Math.cos(angle) * R, cy + Math.sin(angle) * R);
          ctx.lineWidth = 1.5;
          ctx.strokeStyle = 'rgba(15, 15, 16, 0.1)';
          ctx.stroke();
        });

        // 外圈細線
        ctx.beginPath();
        ctx.arc(cx, cy, R, 0, Math.PI * 2);
        ctx.lineWidth = 2;
        ctx.strokeStyle = '#0F0F10';
        ctx.stroke();

        // 文字 — sans-serif 粗體，水平擺放
        prizes.forEach(function (p, i) {
          var start = i * anglePer - Math.PI / 2;
          var midAngle = start + anglePer / 2;
          var textRadius = R * 0.62;

          ctx.save();
          ctx.translate(cx, cy);
          ctx.rotate(midAngle);
          ctx.translate(textRadius, 0);
          ctx.rotate(-midAngle);

          ctx.textAlign = 'center';
          ctx.textBaseline = 'middle';
          ctx.fillStyle = p.is_grand_prize ? '#FFFFFF' : '#0F0F10';
          ctx.font = '700 19px -apple-system, "SF Pro Display", "Inter", "PingFang TC", sans-serif';

          var label = String(p.name || '');
          if (label.length > 8) label = label.slice(0, 8) + '…';
          ctx.fillText(label, 0, 0);
          ctx.restore();
        });
      }

      // ----- LIFF init -----
      async function initLiff() {
        var qs = new URLSearchParams(location.search);
        var devUid = qs.get('uid');
        if (devUid) {
          profile = { userId: devUid, displayName: qs.get('name') || 'DEV' };
          return;
        }
        if (qs.get('preview') === '1') {
          profile = { userId: 'PREVIEW', displayName: '預覽' };
          spinBtn.disabled = true;
          spinBtn.textContent = '預覽';
          return;
        }
        if (!liffId) throw new Error('LIFF ID 未設定');
        try { await liff.init({ liffId: liffId }); }
        catch (e) { throw new Error('LIFF 初始化失敗'); }
        if (!liff.isInClient()) throw new Error('請在 LINE App 內打開');
        if (!liff.isLoggedIn()) {
          liff.login();
          return new Promise(function () {});
        }
        profile = await liff.getProfile();
      }

      // ----- 旋轉動畫 -----
      function animateToPrize(prize) {
        var n = prizes.length;
        if (n === 0) return Promise.resolve();
        var idx = prizes.findIndex(function (p) { return p.id === prize.id; });
        if (idx < 0) idx = 0;
        var anglePer = 360 / n;
        var targetCenter = (idx + 0.5) * anglePer;
        var jitter = (Math.random() - 0.5) * (anglePer * 0.5);
        var finalAngle = currentRotation + 360 * 6 + (360 - targetCenter) + jitter;
        currentRotation = finalAngle;
        canvas.style.transform = 'rotate(' + finalAngle + 'deg)';
        return new Promise(function (resolve) { setTimeout(resolve, 5700); });
      }

      // ----- spin -----
      async function spin() {
        if (spinning) return;
        if (!liffReady || !profile) {
          statusEl.textContent = '請稍候';
          return;
        }
        spinning = true;
        spinBtn.disabled = true;
        statusRow.classList.remove('ready');
        statusEl.textContent = '抽選中⋯';

        try {
          var resp = await fetch('/api/games/wheel/' + encodeURIComponent(slug) + '/spin', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              line_user_id: profile.userId,
              line_display_name: profile.displayName || null
            })
          }).then(function (r) { return r.json(); });

          if (!resp.ok) {
            statusEl.textContent = resp.detail || resp.error || '抽選失敗';
            spinning = false;
            spinBtn.disabled = false;
            return;
          }

          await animateToPrize(resp.prize);
          showResult(resp.prize);
        } catch (e) {
          statusEl.textContent = '錯誤';
        } finally {
          spinning = false;
          spinBtn.disabled = false;
        }
      }

      function showResult(prize) {
        statusEl.textContent = '';
        document.getElementById('modal-prize').textContent = prize.name || '—';
        var imgEl = document.getElementById('modal-img');
        var glyphEl = document.getElementById('modal-glyph');
        if (prize.image_url) {
          imgEl.src = prize.image_url;
          imgEl.hidden = false;
          glyphEl.style.display = 'none';
        } else {
          imgEl.hidden = true;
          glyphEl.style.display = 'block';
          glyphEl.textContent = prize.is_grand_prize ? '★' : '◆';
        }
        var descParts = [];
        if (prize.prize_value) {
          if (prize.prize_value.amount) descParts.push('NT$ ' + prize.prize_value.amount);
          if (prize.prize_value.code) descParts.push('優惠碼 ' + prize.prize_value.code);
          if (prize.prize_value.label) descParts.push(prize.prize_value.label);
          if (prize.prize_value.note) descParts.push(prize.prize_value.note);
        }
        document.getElementById('modal-desc').textContent = descParts.join(' · ');
        if (prize.is_grand_prize) modal.classList.add('grand');
        else modal.classList.remove('grand');
        requestAnimationFrame(function () { modal.classList.add('open'); });
      }

      document.getElementById('modal-close').addEventListener('click', function () {
        modal.classList.remove('open');
      });
      modal.addEventListener('click', function (e) {
        if (e.target === modal) modal.classList.remove('open');
      });

      spinBtn.addEventListener('click', spin);

      // ----- bootstrap -----
      if (prizes.length < 2) {
        statusEl.textContent = '獎品不足';
        spinBtn.disabled = true;
        spinBtn.textContent = '—';
      } else {
        drawWheel();
        spinBtn.disabled = true;
        statusEl.textContent = '驗證身分中⋯';
      }

      (async function () {
        if (prizes.length < 2) return;
        try {
          await initLiff();
          liffReady = true;

          // 1) 先處理「我是被邀請來的」— 把 referral 寫進 DB
          await maybeRegisterReferral();

          // 2) 拉 quota
          await refreshQuota();

          // 3) ready
          statusRow.classList.add('ready');
          statusEl.innerHTML = '哈囉，<span class="name">' + (profile.displayName || '') + '</span>';
        } catch (e) {
          statusEl.textContent = e.message || '初始化失敗';
        }
      })();

      // ----- 邀請拉新：偵測 ?ref= 並寫 referral -----
      async function maybeRegisterReferral() {
        try {
          var qs = new URLSearchParams(location.search);
          var inviter = qs.get('ref');
          if (!inviter) return;
          if (!profile || !profile.userId) return;
          if (inviter === profile.userId) return; // 不能邀請自己
          await fetch('/api/games/wheel/' + encodeURIComponent(slug) + '/referral', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              line_user_id: profile.userId,
              inviter_line_user_id: inviter
            })
          });
          // 清掉 URL 上的 ref（避免重整時又 POST）
          var url = new URL(location.href);
          url.searchParams.delete('ref');
          history.replaceState({}, '', url.pathname + url.search);
        } catch (e) {
          console.warn('referral register failed:', e);
        }
      }

      // ----- 拉 quota 並更新 UI -----
      async function refreshQuota() {
        try {
          if (!profile || !profile.userId) return;
          var resp = await fetch('/api/games/wheel/' + encodeURIComponent(slug) +
            '/meta?line_user_id=' + encodeURIComponent(profile.userId)).then(function (r) { return r.json(); });
          if (!resp.ok || !resp.quota) return;
          renderQuota(resp.quota);
        } catch (e) { console.warn('quota fetch failed:', e); }
      }

      function renderQuota(q) {
        var remEl = document.getElementById('stat-remaining');
        var refEl = document.getElementById('stat-referrals');
        if (remEl) remEl.innerHTML = q.remaining + '<span class="unit">/ ' + q.total + '</span>';
        if (refEl) refEl.innerHTML = q.referrals + '<span class="unit">人</span>';

        // 沒次數 → SPIN 鈕禁用 + 提示
        if (q.remaining <= 0) {
          spinBtn.disabled = true;
          var canMore = q.referral_bonus_per > 0 && q.referral_bonus < q.referral_bonus_max;
          if (canMore) {
            statusRow.classList.remove('ready');
            statusEl.textContent = '次數用完，邀請朋友 +' + q.referral_bonus_per + ' 次';
          } else {
            statusEl.textContent = '次數已用完';
          }
        } else {
          spinBtn.disabled = false;
        }

        // invite card 顯示剩餘可加額度
        var inviteCard = document.getElementById('invite-card');
        var inviteSub = document.getElementById('invite-sub');
        if (inviteCard) {
          var bonusLeft = q.referral_bonus_max - q.referral_bonus;
          if (bonusLeft <= 0) {
            inviteCard.classList.add('maxed');
            if (inviteSub) inviteSub.textContent = '邀請次數已用滿';
          } else {
            inviteCard.classList.remove('maxed');
            if (inviteSub) inviteSub.textContent = '還可再邀請 ' + Math.ceil(bonusLeft / q.referral_bonus_per) + ' 位拿 +' + bonusLeft + ' 次';
          }
        }
      }

      // ----- 分享按鈕（LIFF Share Target Picker）-----
      var inviteBtn = document.getElementById('invite-btn');
      if (inviteBtn) {
        inviteBtn.addEventListener('click', shareWithFriend);
      }
      async function shareWithFriend() {
        if (!profile || !profile.userId) {
          alert('身分驗證中，稍等一下再試');
          return;
        }
        // 邀請連結：LIFF 短網址帶 ref query 跟 sub-path
        // 注意：LIFF 短網址子路徑會被 append 到 endpoint URL
        // /wheel/<slug>?ref=<my_id> 會解析到 /games/wheel/<slug>?ref=<my_id>
        var inviteUrl = 'https://liff.line.me/' + liffId +
          '/wheel/' + encodeURIComponent(slug) + '?ref=' + encodeURIComponent(profile.userId);
        var msg = '快來抽「' + activityMeta.name + '」！我已經抽過了，你也來試試 🎁';

        try {
          if (liff.isApiAvailable && liff.isApiAvailable('shareTargetPicker')) {
            var res = await liff.shareTargetPicker([{
              type: 'text',
              text: msg + '\n' + inviteUrl
            }]);
            if (res) {
              // 分享成功（不一定代表對方點開，只代表用戶選擇了對象）
              flashStatus('已分享！朋友打開後就加 ' + activityMeta.referral_bonus_per + ' 次');
            }
            return;
          }
        } catch (e) {
          console.warn('shareTargetPicker failed:', e);
        }
        // fallback: 複製連結
        try {
          await navigator.clipboard.writeText(inviteUrl);
          flashStatus('連結已複製，傳給朋友吧');
        } catch (e) {
          prompt('複製這個連結傳給朋友：', inviteUrl);
        }
      }
      function flashStatus(msg) {
        var orig = statusEl.textContent;
        statusEl.textContent = msg;
        setTimeout(function () {
          // 重新拉 quota 確保 UI sync
          refreshQuota();
          if (statusEl.textContent === msg && profile) {
            statusEl.innerHTML = '哈囉，<span class="name">' + (profile.displayName || '') + '</span>';
          }
        }, 2400);
      }

      // spin 成功後也要 refresh quota
      var origAnimate = animateToPrize;
      animateToPrize = function (prize) {
        return origAnimate(prize).then(function () {
          // 不要 await（讓 modal 先彈），但稍後 refresh
          setTimeout(refreshQuota, 600);
        });
      };
    })();
  </script>
</body>
</html>
