# 複製為 .env.migrate 並填入（勿提交、勿貼到聊天）
# URI 請到 Supabase → Settings → Database → Connection string → URI（Direct, port 5432）
# 密碼含特殊字元請做 URL 編碼；建議 URI 結尾加 ?sslmode=require

OLD_DATABASE_URL=postgresql://postgres:舊專案密碼@db.舊專案REF.supabase.co:5432/postgres?sslmode=require
NEW_DATABASE_URL=postgresql://postgres:新專案密碼@db.新專案REF.supabase.co:5432/postgres?sslmode=require
